---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import "../styles/global.css";
import "@fontsource/permanent-marker";
import "@fontsource/bebas-neue";
import "@fontsource/archivo-black";
import "@fontsource/poppins";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Noticias, actualidad y estadísticas del Real Madrid femenino | Madrid Femenino Xtra",
	description = "Tu fuente 100% dedicada al Real Madrid Femenino. Consulta todas las noticias, resultados, clasificación, calendario y estadísticas en un solo lugar. ¡Entra y no te pierdas nada de la actualidad del equipo!",
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>

		<link rel="icon" type="image/png" href="/favicon.png" />

		<meta name="description" content={description} />

		<meta property="og:url" content="https://www.madridfemeninoxtra.com" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta
			property="og:image"
			content="https://www.madridfemeninoxtra.com/og.png"
		/>
		<meta property="og:locale" content="es_ES" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@madridfemxtra" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
	</head>
	<body>
		<Header />
		<div class="page-wrapper">
			<slot />
		</div>
		<Footer />
		<ScrollToTop />
	</body>
</html>
