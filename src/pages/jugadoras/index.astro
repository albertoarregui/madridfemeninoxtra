---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import { fetchPlayersDirectly } from "../../utils/players";
import PlayersGrid from "../../components/PlayersGrid";
import PlayerMapWrapper from "../../components/PlayerMapWrapper";
import PlayerStatsDashboard from "../../components/PlayerStatsDashboard";

import { getFlagSrc } from "../../utils/flags";

let playersRaw = await fetchPlayersDirectly();

if (!playersRaw) {
    playersRaw = [];
}

const playersData = playersRaw.map((player) => {
    const { iso, pais_origin } = player;
    return {
        ...player,
        countryName: pais_origin || iso || "",
        flagUrl: getFlagSrc(iso || pais_origin),
    };
});
---

<Layout
    title="Jugadoras del Real Madrid Femenino | Madrid Femenino Xtra"
    description="Todas las jugadoras del Real Madrid Femenino a lo largo de su historia: ficha técnica, posiciones, dorsales, estadísticas y trayectoria."
>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <section class="content-container">
            <h1 class="page-title">JUGADORAS</h1>

            <p class="content-h2">
                Todas las jugadoras del Real Madrid Femenino a lo largo de su
                historia
            </p>
        </section>

        <PlayerStatsDashboard players={playersData} client:load />

        <PlayerMapWrapper players={playersData} client:only="react" />

        <PlayersGrid players={playersData} client:load />
    </main>
</Layout>


