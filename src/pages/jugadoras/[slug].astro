                                                    </strong>
                                                </td>
                                                <td>
                                                    <strong>
                                                        {
                                                            season.total
                                                                .cambio_entrada
                                                        }
                                                    </strong>
                                                </td>
                                                <td>
                                                    <strong>
                                                        {
