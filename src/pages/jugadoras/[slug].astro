---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import {
    fetchPlayersDirectly,
    fetchPlayerStats,
    fetchPlayerDebut,
    fetchPlayerTrajectory,
} from "../../utils/players";

import { getAssetUrl } from "../../utils/assets";
import { getFlagSrc } from "../../utils/flags";
import { fetchAllGoals } from "../../utils/partidos";
import { fetchAllClubShields } from "../../utils/rivales";
import PlayerEvolutionCharts from "../../components/PlayerEvolutionCharts";
const { slug } = Astro.params;
const allPlayers = await fetchPlayersDirectly();
const player = allPlayers.find((p) => p.slug === slug);
if (!player) {
    return Astro.redirect("/404");
}
const resolvedImage = getAssetUrl("jugadoras", player.imageUrl);
const seasonPhotosData = Object.entries(player.season_photos || {})
    .sort((a, b) => b[0].localeCompare(a[0])) // Latest first, Oldest last
    .map(([season, url]) => ({ season, url }));

const initialSeasonIndex = 0;
const currentImageUrl = (seasonPhotosData.length > 0
        ? seasonPhotosData[initialSeasonIndex].url
        : resolvedImage) as string;
const currentSeasonName =
    seasonPhotosData.length > 0
        ? seasonPhotosData[initialSeasonIndex].season
        : player.temporada || "Actualidad";
const isGoalkeeper = player.posicion === "Portera";
const playerStats = await fetchPlayerStats(player.id_jugadora, isGoalkeeper);
if (playerStats) {
    playerStats.jugadora = { id: player.id_jugadora, nombre: player.nombre };
}

const formatDate = (dateString: string | null | undefined): string => {
    if (!dateString) return "-";
    try {
        const date = new Date(dateString.split("T")[0]);
        if (isNaN(date.getTime())) return "-";
        return date.toLocaleDateString("es-ES", {
            day: "2-digit",
            month: "long",
            year: "numeric",
        });
    } catch {
        return "-";
    }
};

const formatShortDate = (dateString: string | null | undefined): string => {
    if (!dateString) return "-";
    try {
        const date = new Date(dateString.split("T")[0]);
        if (isNaN(date.getTime())) return "-";
        return date.toLocaleDateString("es-ES", {
            day: "2-digit",
            month: "2-digit",
            year: "numeric",
        });
    } catch {
        return "-";
    }
};

const calculateAge = (dateString: string | null | undefined): number | null => {
    if (!dateString) return null;
    try {
        const birthDate = new Date(dateString.split("T")[0]);
        if (isNaN(birthDate.getTime())) return null;
        const today = new Date();
        let age = today.getFullYear() - birthDate.getFullYear();
        const monthDiff = today.getMonth() - birthDate.getMonth();
        if (
            monthDiff < 0 ||
            (monthDiff === 0 && today.getDate() < birthDate.getDate())
        ) {
            age--;
        }
        return age;
    } catch {
        return null;
    }
};
const fechaNacimiento = formatShortDate(player.fecha_nacimiento);
const edad = calculateAge(player.fecha_nacimiento);
const alturaDisplay = player.altura ? `${player.altura} m.` : "-";
const pesoDisplay = player.peso ? `${player.peso} kg` : "-";
const debutInfo = await fetchPlayerDebut(player.id_jugadora);
const debutDisplay =
    debutInfo && debutInfo.fecha_debut
        ? `${formatShortDate(debutInfo.fecha_debut)}${
              debutInfo.rival ? ` (${debutInfo.rival})` : ""
          }`
        : "-";
const trajectory = await fetchPlayerTrajectory(player.id_jugadora);

// Goal Milestones Logic
const allGoals = await fetchAllGoals();
const officialComps = [
    "Liga F",
    "UWCL",
    "Copa de la Reina",
    "Supercopa de España",
];
const clubShields = await fetchAllClubShields();

const milestones = allGoals
    .filter((g) => {
        const isCurrentPlayer =
            g.goleadora === player.id_jugadora ||
            g.nombre_goleadora === player.nombre;
        const isOfficial = officialComps.includes(g.competicion);
        return isCurrentPlayer && isOfficial;
    })
    .sort((a, b) => {
        const dateA = new Date(a.fecha).getTime();
        const dateB = new Date(b.fecha).getTime();
        if (dateA !== dateB) return dateA - dateB;
        // If same day, sort by minute (ignoring + extra time for simplicity in sorting)
        return parseInt(a.minuto) - parseInt(b.minuto);
    })
    .map((g, index) => ({
        ...g,
        goalNumber: index + 1,
        rival: g.club_local === "Real Madrid" ? g.club_visitante : g.club_local,
    }))
    .filter((g) => g.goalNumber % 10 === 0);

const getPlayerCoordinates = (pos: string) => {
    const p = pos.toLowerCase();
    let left = "50%";
    let top = "50%";

    if (p.includes("portera")) {
        left = "10%";
    } else if (p.includes("defensa") || p.includes("central")) {
        left = "30%";
    } else if (p.includes("lateral")) {
        left = "30%";

        if (p.includes("izquierd")) {
            top = "20%";
        } else if (p.includes("derech")) {
            top = "80%";
        } else {
            top = "20%";
        }
    } else if (
        p.includes("centrocampista") ||
        p.includes("pivote") ||
        p.includes("interior") ||
        p.includes("mediapunta")
    ) {
        left = "55%";
    } else if (p.includes("delantera") || p.includes("ariete")) {
        left = "80%";
    } else if (p.includes("extremo")) {
        left = "80%";
        if (p.includes("izquierd")) {
            top = "20%";
        } else if (p.includes("derech")) {
            top = "80%";
        } else {
            top = "20%";
        }
    }
    return { left, top };
};
const playerPosition = getPlayerCoordinates(player.posicion || "");

const schema = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: player.nombre,
    jobTitle: "Jugadora de Fútbol",
    affiliation: {
        "@type": "SportsTeam",
        name: "Real Madrid Femenino",
    },
    image: resolvedImage || player.imageUrl,
    birthDate: player.fecha_nacimiento,
    birthPlace: {
        "@type": "Place",
        name: player.lugar_nacimiento,
    },
    height: player.altura ? `${player.altura} m` : undefined,
    weight: player.peso ? `${player.peso} kg` : undefined,
    nationality: player.pais_origin,
};
---

<Layout
    title={`${player.nombre} | Madrid Femenino Xtra`}
    description={`Ficha completa de ${player.nombre}, jugadora del Real Madrid Femenino. Consulta sus estadísticas, posición, biografía y récords.`}
>
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <main class="player-profile-page">
        <a href="/jugadoras" class="back-link">
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Volver al resto de jugadoras
        </a>
        <div class="profile-grid">
            <section class="ficha-section">
                <h1 class="section-header">Ficha de {player.nombre}</h1>
                <div class="ficha-content">
                    <div class="player-photo-container">
                        <div class="photo-carousel-wrapper">
                            <div class="current-photo-box">
                                <button
                                    id="prev-photo"
                                    class="carousel-nav-btn prev"
                                    aria-label="Ver fotos anteriores"
                                    disabled={seasonPhotosData.length <= 1}
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="40"
                                        height="40"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="white"
                                        stroke-width="2.5"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="icon icon-tabler icons-tabler-outline icon-tabler-chevron-left"
                                        ><path
                                            stroke="none"
                                            d="M0 0h24v24H0z"
                                            fill="none"></path><path
                                            d="M15 6l-6 6l6 6"></path></svg
                                    >
                                </button>

                                <img
                                    id="main-player-photo"
                                    src={currentImageUrl}
                                    alt={`Foto de ${player.nombre}`}
                                    class="player-photo"
                                    loading="lazy"
                                />
                                <div
                                    id="photo-season-badge"
                                    class="photo-season-badge"
                                >
                                    {currentSeasonName}
                                </div>

                                <button
                                    id="next-photo"
                                    class="carousel-nav-btn next"
                                    aria-label="Ver fotos más recientes"
                                    disabled={seasonPhotosData.length <= 1}
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="40"
                                        height="40"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="white"
                                        stroke-width="2.5"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="icon icon-tabler icons-tabler-outline icon-tabler-chevron-right"
                                        ><path
                                            stroke="none"
                                            d="M0 0h24v24H0z"
                                            fill="none"></path><path
                                            d="M9 6l6 6l-6 6"></path></svg
