                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="player-info">
                        <div class="info-row">
                            <span class="info-label">Nombre completo:</span>
                            <span class="info-value">{player.nombre}</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Fecha de nacimiento:</span>
                            <span class="info-value">{fechaNacimiento}</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Lugar de nacimiento:</span>
                            <span class="info-value"
                                >{player.lugar_nacimiento || "-"}</span
