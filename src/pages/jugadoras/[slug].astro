import {
    fetchPlayersDirectly,
    fetchPlayerStats,
    fetchPlayerDebut,
    fetchPlayerTrajectory,
} from "../../utils/players";
import ligaFLogo from "../../assets/competiciones/liga_f.png";
import uwclLogo from "../../assets/competiciones/uwcl.png";
import copaLogo from "../../assets/competiciones/copa_de_la_reina.png";
import supercopaLogo from "../../assets/competiciones/supercopa_de_espana.png";
const competitionLogos: Record<string, any> = {
    "Liga F": ligaFLogo,
    UWCL: uwclLogo,
    "Copa de la Reina": copaLogo,
    "Supercopa de España": supercopaLogo,
};
import alemaniaFlag from "../../assets/banderas/alemania.svg";
import australiaFlag from "../../assets/banderas/australia.svg";
import austriaFlag from "../../assets/banderas/austria.svg";
import azerbaiyanFlag from "../../assets/banderas/azerbaiyan.svg";
import brasilFlag from "../../assets/banderas/brasil.svg";
import colombiaFlag from "../../assets/banderas/colombia.svg";
import dinamarcaFlag from "../../assets/banderas/dinamarca.svg";
import escociaFlag from "../../assets/banderas/escocia.svg";
import espanaFlag from "../../assets/banderas/espana.svg";
import franciaFlag from "../../assets/banderas/francia.svg";
import inglaterraFlag from "../../assets/banderas/inglaterra.svg";
import islandiaFlag from "../../assets/banderas/islandia.svg";
import italiaFlag from "../../assets/banderas/italia.svg";
import mexicoFlag from "../../assets/banderas/mexico.svg";
import noruegaFlag from "../../assets/banderas/noruega.svg";
import paisesBajosFlag from "../../assets/banderas/paises_bajos.svg";
import paraguayFlag from "../../assets/banderas/paraguay.svg";
import portugalFlag from "../../assets/banderas/portugal.svg";
import republicaChecaFlag from "../../assets/banderas/republica_checa.svg";
import sueciaFlag from "../../assets/banderas/suecia.svg";
import ucraniaFlag from "../../assets/banderas/ucrania.svg";
const countryFlags: Record<string, any> = {
    Alemania: alemaniaFlag,
    Australia: australiaFlag,
    Austria: austriaFlag,
    Azerbaiyán: azerbaiyanFlag,
    Brasil: brasilFlag,
    Colombia: colombiaFlag,
    Dinamarca: dinamarcaFlag,
    Escocia: escociaFlag,
    España: espanaFlag,
    Francia: franciaFlag,
    Inglaterra: inglaterraFlag,
    Islandia: islandiaFlag,
    Italia: italiaFlag,
    México: mexicoFlag,
    Noruega: noruegaFlag,
    "Países Bajos": paisesBajosFlag,
    Paraguay: paraguayFlag,
    Portugal: portugalFlag,
    "República Checa": republicaChecaFlag,
    Suecia: sueciaFlag,
    Ucrania: ucraniaFlag,
};
const { slug } = Astro.params;
const allPlayers = await fetchPlayersDirectly();
const player = allPlayers.find((p) => p.slug === slug);
if (!player) {
    return Astro.redirect("/404");
}
const playerImages = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/jugadoras/*.{png,jpg,jpeg,webp}",
    { eager: true },
);
function getPlayerImageSrc(slug: string) {
    const lookupSlug = slug.replace(/-/g, "_"); // Try finding exact match or match with underscore
    const matchingPath = Object.keys(playerImages).find(
        (path) =>
            path.includes(`/${lookupSlug}.`) || path.includes(`/${slug}.`),
    );
    return matchingPath
        ? playerImages[matchingPath].default.src
        : player.imageUrl;
}
const resolvedImage = getPlayerImageSrc(player.slug);
const isGoalkeeper = player.posicion === "Portera";
const playerStats = await fetchPlayerStats(player.id_jugadora, isGoalkeeper);
if (playerStats) {
    playerStats.jugadora = { id: player.id_jugadora, nombre: player.nombre };
}

const formatDate = (dateString: string | null | undefined): string => {
    if (!dateString) return "-";
    try {
        const date = new Date(dateString.split("T")[0]);
        if (isNaN(date.getTime())) return "-";
        return date.toLocaleDateString("es-ES", {
            day: "2-digit",
            month: "long",
            year: "numeric",
        });
    } catch {
        return "-";
    }
};

const formatShortDate = (dateString: string | null | undefined): string => {
    if (!dateString) return "-";
    try {
        const date = new Date(dateString.split("T")[0]);
        if (isNaN(date.getTime())) return "-";
        return date.toLocaleDateString("es-ES", {
            day: "2-digit",
            month: "2-digit",
            year: "numeric",
        });
    } catch {
        return "-";
    }
};

const calculateAge = (dateString: string | null | undefined): number | null => {
    if (!dateString) return null;
    try {
        const birthDate = new Date(dateString.split("T")[0]);
        if (isNaN(birthDate.getTime())) return null;
        const today = new Date();
        let age = today.getFullYear() - birthDate.getFullYear();
        const monthDiff = today.getMonth() - birthDate.getMonth();
        if (
            monthDiff < 0 ||
            (monthDiff === 0 && today.getDate() < birthDate.getDate())
        ) {
            age--;
        }
        return age;
    } catch {
        return null;
    }
};
const fechaNacimiento = formatShortDate(player.fecha_nacimiento);
const edad = calculateAge(player.fecha_nacimiento);
const alturaDisplay = player.altura ? `${player.altura} m.` : "-";
const pesoDisplay = player.peso ? `${player.peso} kg` : "-";
const debutInfo = await fetchPlayerDebut(player.id_jugadora);
const debutDisplay =
    debutInfo && debutInfo.fecha_debut
        ? `${formatShortDate(debutInfo.fecha_debut)}${
              debutInfo.rival ? ` (${debutInfo.rival})` : ""
          }`
        : "-";
const trajectory = await fetchPlayerTrajectory(player.id_jugadora);
const getPlayerCoordinates = (pos: string) => {
    const p = pos.toLowerCase();
    let left = "50%";
    let top = "50%";

    // Determinar eje X (Línea de juego)
    if (p.includes("portera")) {
        left = "10%";
    } else if (p.includes("defensa") || p.includes("central")) {
        left = "30%";
    } else if (p.includes("lateral")) {
        left = "30%";
        // Laterales por defecto
        if (p.includes("izquierd")) {
            top = "20%"; // Arriba
        } else if (p.includes("derech")) {
            top = "80%"; // Abajo
        } else {
            top = "20%"; // Default
        }
    } else if (
        p.includes("centrocampista") ||
        p.includes("pivote") ||
        p.includes("interior") ||
        p.includes("mediapunta")
    ) {
        left = "55%";
    } else if (p.includes("delantera") || p.includes("ariete")) {
        left = "80%";
    } else if (p.includes("extremo")) {
        left = "80%";
        if (p.includes("izquierd")) {
            top = "20%";
        } else if (p.includes("derech")) {
            top = "80%";
        } else {
            top = "20%";
        }
    }
    return { left, top };
};
const playerPosition = getPlayerCoordinates(player.posicion || "");
