                        </div>
                        <div class="info-row">
                            <span class="info-label">Nacionalidad:</span>
                            <span class="info-value">
                                {player.pais_origin}
                                {
                                    getFlagSrc(
                                        player.iso ||
                                            player.pais_origin ||
                                            player.pais_origen,
                                    ) && (
                                        <img
                                            class="flag-icon"
