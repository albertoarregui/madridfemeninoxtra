                                                            {
                                                                comp.tarjetas_amarillas
                                                            }
                                                        </td>
                                                        <td>
                                                            {
                                                                comp.tarjetas_rojas
                                                            }
                                                        </td>
                                                        <td>
                                                            {comp.capitanias}
                                                        </td>
                                                    </tr>
                                                ),
                                            )}
                                        </>
                                    ))}
                                <tr class="career-total-row">
                                    <td>
                                        <strong>TOTAL</strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {
                                                playerStats
                                                    .total_carrera_oficial
                                                    .convocatorias
                                            }
                                        </strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {
                                                playerStats
                                                    .total_carrera_oficial
