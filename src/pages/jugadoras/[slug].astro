        }

        /* FICHA SECTION */
        .ficha-section {
            grid-column: 1;
            grid-row: 1 / 3;
            background: white;
            border: 1px solid #ddd;
            border-radius: 8px;
            overflow: hidden;
        }

        .ficha-content {
            padding: 1.5rem;
            display: flex;
            gap: 1.5rem;
            align-items: flex-start;
        }

        .player-photo-container {
            margin-bottom: 0;
            text-align: center;
            flex-shrink: 0;
        }

        .player-photo {
            max-width: 250px;
            height: auto;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .player-info {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            flex: 1;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 0.5rem 0;
            border-bottom: 1px solid #eee;
        }

        .info-label {
            font-weight: 600;
            color: #333;
        }

        .info-value {
            color: #666;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .flag-icon {
            width: 20px;
            height: auto;
        }

        /* POSITION SECTION */
        .position-section {
            grid-column: 2;
            grid-row: 1;
            background: white;
            border: 1px solid #ddd;
            border-radius: 8px;
            overflow: hidden;
        }

        .field-diagram {
            position: relative;
            padding: 1.5rem;
            min-height: 300px;
        }

        .field-svg {
            width: 100%;
            height: auto;
            border-radius: 4px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
        }

        .player-marker {
            position: absolute;
            transform: translate(-50%, -50%);
        }

        .marker-icon {
            width: 30px;
            height: 30px;
            background: white;
            border: 3px solid #ff6b00;
            border-radius: 50%;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
        }

        /* TEAMS SECTION */
        .teams-section {
            grid-column: 2;
            grid-row: 2;
            background: white;
            border: 1px solid #ddd;
            border-radius: 8px;
            overflow: hidden;
        }

        .teams-content {
            padding: 1.5rem;
        }

        /* BIOGRAPHY SECTION */
        .biography-section {
            grid-column: 1 / -1;
            grid-row: 3;
            background: white;
            border: 1px solid #ddd;
            border-radius: 8px;
            overflow: hidden;
        }

        .biography-content {
            padding: 1.5rem;
            line-height: 1.8;
            color: #444;
        }

        /* RECORDS SECTION */
        .records-section {
            grid-column: 1 / -1;
            grid-row: 4;
            background: white;
            border: 1px solid #ddd;
            border-radius: 8px;
            overflow: hidden;
        }

        .records-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            padding: 1.5rem;
        }

        .record-item {
            display: flex;
            justify-content: space-between;
            padding: 0.75rem;
            background: #f9f9f9;
            border-radius: 4px;
        }

        .record-label {
            font-weight: 600;
            color: #333;
        }

        .record-value {
            color: #ffde59;
            font-weight: bold;
        }

