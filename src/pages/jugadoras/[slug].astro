                                        </div>
                                    </div>
                                ))}
                            </div>
                        ) : (
                            <p class="no-data">Sin datos disponibles</p>
                        )
                    }
                </div>
            </section>

            <div class="charts-section">
                <PlayerEvolutionCharts
                    stats={playerStats.estadisticas}
                    isGoalkeeper={isGoalkeeper}
                    client:load
                />
            </div>

            <section class="stats-section">
                <h2 class="section-header">ESTADÍSTICAS</h2>
                {
                    playerStats ? (
                <div class="stats-table-wrapper">
                    <table class="stats-table">
                            <thead>
                                <tr>
                                    <th>Temporada</th>
                                    <th title="Convocatorias">Conv.</th>
                                    <th title="Partidos">Part.</th>
                                    <th title="Titularidades">Tit.</th>
                                    <th title="Minutos">Min.</th>
                                    <th title="Cambio Entrada">Ent.</th>
                                    <th title="Cambio Salida">Sal.</th>
                                    <th title="Goles">Goles</th>
                                    <th title="Asistencias">Asist.</th>
                                    <th title="Goles + Asistencias">G+A</th>
                                    <th title="Victorias">Vict.</th>
                                    {playerStats.jugadora.es_portera && (
                                        <th title="Porterías a cero">P.0</th>
                                    )}
