                                                                        src={getAssetUrl("competiciones", comp.competicion.toLowerCase().includes("amistoso") ? "amistoso" : comp.competicion)}
                                                                        alt={
                                                                            comp.competicion
                                                                        }
                                                                        class="competition-logo"
                                                                    />
                                                                )}
                                                                {comp.competicion}
                                                            </div>
                                                        </td>
                                                        <td>
                                                            {comp.convocatorias}
                                                        </td>
                                                        <td>{comp.partidos}</td>
                                                        <td>
                                                            {comp.titularidades}
                                                        </td>
                                                        <td>{comp.minutos}</td>
                                                        <td>
                                                            {
                                                                comp.cambio_entrada
                                                            }
                                                        </td>
                                                        <td>
                                                            {comp.cambio_salida}
                                                        </td>
                                                        <td>{comp.goles}</td>
                                                        <td>
                                                            {comp.asistencias}
                                                        </td>
                                                        <td>
                                                            {
                                                                comp.goles_asistencias
                                                            }
                                                        </td>
                                                        <td>
                                                            {comp.victorias}
                                                        </td>
                                                        {playerStats.jugadora
                                                            .es_portera && (
                                                            <td>
                                                                {
