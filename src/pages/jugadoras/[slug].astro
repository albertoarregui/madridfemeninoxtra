                                    <td>
                                        <strong>
                                            {
                                                playerStats
                                                    .total_carrera_oficial
                                                    .cambio_salida
                                            }
                                        </strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {
                                                playerStats
                                                    .total_carrera_oficial.goles
                                            }
                                        </strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {
                                                playerStats
                                                    .total_carrera_oficial
                                                    .asistencias
                                            }
                                        </strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {
                                                playerStats
                                                    .total_carrera_oficial
                                                    .goles_asistencias
                                            }
                                        </strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {
                                                playerStats
                                                    .total_carrera_oficial
                                                    .victorias
                                            }
                                        </strong>
                                    </td>
                                    {playerStats.jugadora.es_portera && (
                                        <td>
                                            <strong>
                                                {
                                                    playerStats
                                                        .total_carrera_oficial
                                                        .porterias_cero
                                                }
                                            </strong>
                                        </td>
                                    )}
                                    <td>
                                        <strong>
                                            {
                                                playerStats
                                                    .total_carrera_oficial
                                                    .tarjetas_amarillas
                                            }
                                        </strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {
                                                playerStats
