---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import {
    fetchPlayersDirectly,
    fetchPlayerStats,
    fetchPlayerDebut,
    fetchPlayerTrajectory,
} from "../../utils/players";

import { getAssetUrl } from "../../utils/assets";
import { getFlagSrc } from "../../utils/flags";
const { slug } = Astro.params;
const allPlayers = await fetchPlayersDirectly();
const player = allPlayers.find((p) => p.slug === slug);
if (!player) {
    return Astro.redirect("/404");
}
const resolvedImage = getAssetUrl("jugadoras", player.slug);
const isGoalkeeper = player.posicion === "Portera";
const playerStats = await fetchPlayerStats(player.id_jugadora, isGoalkeeper);
if (playerStats) {
    playerStats.jugadora = { id: player.id_jugadora, nombre: player.nombre };
}

const formatDate = (dateString: string | null | undefined): string => {
    if (!dateString) return "-";
    try {
        const date = new Date(dateString.split("T")[0]);
        if (isNaN(date.getTime())) return "-";
        return date.toLocaleDateString("es-ES", {
            day: "2-digit",
            month: "long",
            year: "numeric",
        });
    } catch {
        return "-";
    }
};

const formatShortDate = (dateString: string | null | undefined): string => {
    if (!dateString) return "-";
    try {
        const date = new Date(dateString.split("T")[0]);
        if (isNaN(date.getTime())) return "-";
        return date.toLocaleDateString("es-ES", {
            day: "2-digit",
            month: "2-digit",
            year: "numeric",
        });
    } catch {
        return "-";
    }
};

const calculateAge = (dateString: string | null | undefined): number | null => {
    if (!dateString) return null;
    try {
        const birthDate = new Date(dateString.split("T")[0]);
        if (isNaN(birthDate.getTime())) return null;
        const today = new Date();
        let age = today.getFullYear() - birthDate.getFullYear();
        const monthDiff = today.getMonth() - birthDate.getMonth();
        if (
            monthDiff < 0 ||
            (monthDiff === 0 && today.getDate() < birthDate.getDate())
        ) {
            age--;
        }
        return age;
    } catch {
        return null;
    }
};
const fechaNacimiento = formatShortDate(player.fecha_nacimiento);
const edad = calculateAge(player.fecha_nacimiento);
const alturaDisplay = player.altura ? `${player.altura} m.` : "-";
const pesoDisplay = player.peso ? `${player.peso} kg` : "-";
const debutInfo = await fetchPlayerDebut(player.id_jugadora);
const debutDisplay =
    debutInfo && debutInfo.fecha_debut
        ? `${formatShortDate(debutInfo.fecha_debut)}${
              debutInfo.rival ? ` (${debutInfo.rival})` : ""
          }`
        : "-";
const trajectory = await fetchPlayerTrajectory(player.id_jugadora);

const getPlayerCoordinates = (pos: string) => {
    const p = pos.toLowerCase();
    let left = "50%";
    let top = "50%";

    if (p.includes("portera")) {
        left = "10%";
    } else if (p.includes("defensa") || p.includes("central")) {
        left = "30%";
    } else if (p.includes("lateral")) {
        left = "30%";

        if (p.includes("izquierd")) {
            top = "20%";
        } else if (p.includes("derech")) {
            top = "80%";
        } else {
            top = "20%";
        }
    } else if (
        p.includes("centrocampista") ||
        p.includes("pivote") ||
        p.includes("interior") ||
        p.includes("mediapunta")
    ) {
        left = "55%";
    } else if (p.includes("delantera") || p.includes("ariete")) {
        left = "80%";
    } else if (p.includes("extremo")) {
        left = "80%";
        if (p.includes("izquierd")) {
            top = "20%";
        } else if (p.includes("derech")) {
            top = "80%";
        } else {
            top = "20%";
        }
    }
    return { left, top };
};
const playerPosition = getPlayerCoordinates(player.posicion || "");

const schema = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: player.nombre,
    jobTitle: "Jugadora de Fútbol",
    affiliation: {
        "@type": "SportsTeam",
        name: "Real Madrid Femenino",
    },
    image: resolvedImage || player.imageUrl,
    birthDate: player.fecha_nacimiento,
    birthPlace: {
        "@type": "Place",
        name: player.lugar_nacimiento,
    },
    height: player.altura ? `${player.altura} m` : undefined,
    weight: player.peso ? `${player.peso} kg` : undefined,
    nationality: player.pais_origin,
};
---

<Layout
    title={`${player.nombre} | Madrid Femenino Xtra`}
    description={`Ficha completa de ${player.nombre}, jugadora del Real Madrid Femenino. Consulta sus estadísticas, posición, biografía y récords.`}
>
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <main class="player-profile-page">
        <a href="/jugadoras" class="back-link">
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Volver al resto de jugadoras
        </a>
        <div class="profile-grid">
            <section class="ficha-section">
                <h1 class="section-header">Ficha de {player.nombre}</h1>
                <div class="ficha-content">
                    <div class="player-photo-container">
                        <Image
                            src={resolvedImage || player.imageUrl}
                            alt={`Foto de ${player.nombre}`}
                            class="player-photo"
                            width={400}
                            height={500}
                            format="webp"
                            loading="eager"
                        />
                    </div>
                    <div class="player-info">
                        <div class="info-row">
                            <span class="info-label">Nombre completo:</span>
                            <span class="info-value">{player.nombre}</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Fecha de nacimiento:</span>
                            <span class="info-value">{fechaNacimiento}</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Lugar de nacimiento:</span>
                            <span class="info-value"
                                >{player.lugar_nacimiento || "-"}</span
                            >
                        </div>
                        <div class="info-row">
                            <span class="info-label">Nacionalidad:</span>
                            <span class="info-value">
                                {player.pais_origin}
                                {
                                    getFlagSrc(player.pais_origin) && (
                                        <Image
                                            class="flag-icon"
                                            src={getFlagSrc(player.pais_origin)}
                                            alt={`Bandera de ${player.pais_origin}`}
                                            width={24}
                                            height={24}
                                        />
                                    )
                                }
                            </span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Altura / Peso:</span>
                            <span class="info-value"
                                >{alturaDisplay} / {pesoDisplay}</span
                            >
                        </div>
                        <div class="info-row">
                            <span class="info-label">Debut:</span>
                            <span class="info-value">{debutDisplay}</span>
                        </div>
                    </div>
                </div>
            </section>
            <section class="position-section">
                <h2 class="section-header">Posición</h2>
                <div class="field-diagram">
                    <svg viewBox="0 0 100 65" class="field-svg">
                        <rect x="0" y="0" width="100" height="65" fill="#4a7c35"
                        ></rect>
                        <rect
                            x="0"
                            y="0"
                            width="10"
                            height="65"
                            fill="#3d6b2e"
                            opacity="0.3"></rect>
                        <rect
                            x="20"
                            y="0"
                            width="10"
                            height="65"
                            fill="#3d6b2e"
                            opacity="0.3"></rect>
                        <rect
                            x="40"
                            y="0"
                            width="10"
                            height="65"
                            fill="#3d6b2e"
                            opacity="0.3"></rect>
                        <rect
                            x="60"
                            y="0"
                            width="10"
                            height="65"
                            fill="#3d6b2e"
                            opacity="0.3"></rect>
                        <rect
                            x="80"
                            y="0"
                            width="10"
                            height="65"
                            fill="#3d6b2e"
                            opacity="0.3"></rect>
                        <rect
                            x="0"
                            y="0"
                            width="100"
                            height="65"
                            fill="none"
                            stroke="white"
                            stroke-width="0.3"></rect>
                        <line
                            x1="50"
                            y1="0"
                            x2="50"
                            y2="65"
                            stroke="white"
                            stroke-width="0.3"></line>
                        <circle
                            cx="50"
                            cy="32.5"
                            r="8"
                            fill="none"
                            stroke="white"
                            stroke-width="0.3"></circle>
                        <rect
                            x="0"
                            y="20"
                            width="15"
                            height="25"
                            fill="none"
                            stroke="white"
                            stroke-width="0.3"></rect>
                        <rect
                            x="0"
                            y="26"
                            width="5"
                            height="13"
                            fill="none"
                            stroke="white"
                            stroke-width="0.3"></rect>
                        <rect
                            x="85"
                            y="20"
                            width="15"
                            height="25"
                            fill="none"
                            stroke="white"
                            stroke-width="0.3"></rect>
                        <rect
                            x="95"
                            y="26"
                            width="5"
                            height="13"
                            fill="none"
                            stroke="white"
                            stroke-width="0.3"></rect>
                    </svg>
                    <div
                        class="player-marker"
                        style={`left: ${playerPosition.left}; top: ${playerPosition.top};`}
                    >
                        <div class="marker-icon"></div>
                    </div>
                </div>
            </section>

            <section class="teams-section">
                <h2 class="section-header">TRAYECTORIA</h2>
                <div class="teams-content">
                    {
                        trajectory && trajectory.length > 0 ? (
                            <div class="trajectory-timeline">
                                <div class="trajectory-vertical-line" />
                                {trajectory.map((item) => (
                                    <div class="timeline-item">
                                        <div class="timeline-marker" />
                                        <div class="timeline-content">
                                            <div class="timeline-years">
                                                {item.anio_inicio} -
                                                {item.anio_fin || "Act."}
                                            </div>
                                            <div class="timeline-club">
                                                {item.club}
                                            </div>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        ) : (
                            <p class="no-data">Sin datos disponibles</p>
                        )
                    }
                </div>
            </section>

            <section class="stats-section">
                <h2 class="section-header">ESTADÍSTICAS</h2>
                {
                    playerStats ? (
                        <table class="stats-table">
                            <thead>
                                <tr>
                                    <th>Temporada</th>
                                    <th title="Convocatorias">Conv.</th>
                                    <th title="Partidos">Part.</th>
                                    <th title="Titularidades">Tit.</th>
                                    <th title="Minutos">Min.</th>
                                    <th title="Cambio Entrada">Ent.</th>
                                    <th title="Cambio Salida">Sal.</th>
                                    <th title="Goles">Goles</th>
                                    <th title="Asistencias">Asist.</th>
                                    <th title="Goles + Asistencias">G+A</th>
                                    <th title="Victorias">Vict.</th>
                                    {playerStats.jugadora.es_portera && (
                                        <th title="Porterías a cero">P.0</th>
                                    )}
                                    <th title="Tarjetas Amarillas">TA</th>
                                    <th title="Tarjetas Rojas">TR</th>
                                    <th title="Capitanías">Cap.</th>
                                </tr>
                            </thead>
                            <tbody>
                                {playerStats.estadisticas.map((season: any) => (
                                    <>
                                        <tr
                                            class="season-total-row"
                                            onclick={`toggleSeason('${season.temporada.replace(/\//g, "-")}')`}
                                            style="cursor: pointer;"
                                        >
                                            <td>
                                                <strong>
                                                    {season.temporada}
                                                </strong>
                                                <span class="toggle-icon">
                                                    ▼
                                                </span>
                                            </td>
                                            <td>
                                                <strong>
                                                    {season.total.convocatorias}
                                                </strong>
                                            </td>
                                            <td>
                                                <strong>
                                                    {season.total.partidos}
                                                </strong>
                                            </td>
                                            <td>
                                                <strong>
                                                    {season.total.titularidades}
                                                </strong>
                                            </td>
                                            <td>
                                                <strong>
                                                    {season.total.minutos}
                                                </strong>
                                            </td>
                                            <td>
                                                <strong>
                                                    {
                                                        season.total
                                                            .cambio_entrada
                                                    }
                                                </strong>
                                            </td>
                                            <td>
                                                <strong>
                                                    {season.total.cambio_salida}
                                                </strong>
                                            </td>
                                            <td>
                                                <strong>
                                                    {season.total.goles}
                                                </strong>
                                            </td>
                                            <td>
                                                <strong>
                                                    {season.total.asistencias}
                                                </strong>
                                            </td>
                                            <td>
                                                <strong>
                                                    {
                                                        season.total
                                                            .goles_asistencias
                                                    }
                                                </strong>
                                            </td>
                                            <td>
                                                <strong>
                                                    {season.total.victorias}
                                                </strong>
                                            </td>
                                            {playerStats.jugadora
                                                .es_portera && (
                                                <td>
                                                    <strong>
                                                        {
                                                            season.total
                                                                .porterias_cero
                                                        }
                                                    </strong>
                                                </td>
                                            )}
                                            <td>
                                                <strong>
                                                    {
                                                        season.total
                                                            .tarjetas_amarillas
                                                    }
                                                </strong>
                                            </td>
                                            <td>
                                                <strong>
                                                    {
                                                        season.total
                                                            .tarjetas_rojas
                                                    }
                                                </strong>
                                            </td>
                                            <td>
                                                <strong>
                                                    {season.total.capitanias}
                                                </strong>
                                            </td>
                                        </tr>
                                        {season.competiciones.map(
                                            (comp: any) => (
                                                <tr
                                                    class={`competition-row season-${season.temporada.replace(
                                                        /\//g,
                                                        "-",
                                                    )}`}
                                                    style="display: none;"
                                                >
                                                    <td class="competition-name">
                                                        {getAssetUrl(
                                                            "competiciones",
                                                            comp.competicion,
                                                        ) && (
                                                            <Image
                                                                src={getAssetUrl(
                                                                    "competiciones",
                                                                    comp.competicion,
                                                                )}
                                                                alt={
                                                                    comp.competicion
                                                                }
                                                                class="competition-logo"
                                                                width={20}
                                                                height={20}
                                                            />
                                                        )}
                                                        {comp.competicion}
                                                    </td>
                                                    <td>
                                                        {comp.convocatorias}
                                                    </td>
                                                    <td>{comp.partidos}</td>
                                                    <td>
                                                        {comp.titularidades}
                                                    </td>
                                                    <td>{comp.minutos}</td>
                                                    <td>
                                                        {comp.cambio_entrada}
                                                    </td>
                                                    <td>
                                                        {comp.cambio_salida}
                                                    </td>
                                                    <td>{comp.goles}</td>
                                                    <td>{comp.asistencias}</td>
                                                    <td>
                                                        {comp.goles_asistencias}
                                                    </td>
                                                    <td>{comp.victorias}</td>
                                                    {playerStats.jugadora
                                                        .es_portera && (
                                                        <td>
                                                            {
                                                                comp.porterias_cero
                                                            }
                                                        </td>
                                                    )}
                                                    <td>
                                                        {
                                                            comp.tarjetas_amarillas
                                                        }
                                                    </td>
                                                    <td>
                                                        {comp.tarjetas_rojas}
                                                    </td>
                                                    <td>{comp.capitanias}</td>
                                                </tr>
                                            ),
                                        )}
                                    </>
                                ))}
                                <tr class="career-total-row">
                                    <td>
                                        <strong>TOTAL</strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {
                                                playerStats.total_carrera
                                                    .convocatorias
                                            }
                                        </strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {playerStats.total_carrera.partidos}
                                        </strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {
                                                playerStats.total_carrera
                                                    .titularidades
                                            }
                                        </strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {playerStats.total_carrera.minutos}
                                        </strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {
                                                playerStats.total_carrera
                                                    .cambio_entrada
                                            }
                                        </strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {
                                                playerStats.total_carrera
                                                    .cambio_salida
                                            }
                                        </strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {playerStats.total_carrera.goles}
                                        </strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {
                                                playerStats.total_carrera
                                                    .asistencias
                                            }
                                        </strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {
                                                playerStats.total_carrera
                                                    .goles_asistencias
                                            }
                                        </strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {
                                                playerStats.total_carrera
                                                    .victorias
                                            }
                                        </strong>
                                    </td>
                                    {playerStats.jugadora.es_portera && (
                                        <td>
                                            <strong>
                                                {
                                                    playerStats.total_carrera
                                                        .porterias_cero
                                                }
                                            </strong>
                                        </td>
                                    )}
                                    <td>
                                        <strong>
                                            {
                                                playerStats.total_carrera
                                                    .tarjetas_amarillas
                                            }
                                        </strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {
                                                playerStats.total_carrera
                                                    .tarjetas_rojas
                                            }
                                        </strong>
                                    </td>
                                    <td>
                                        <strong>
                                            {
                                                playerStats.total_carrera
                                                    .capitanias
                                            }
                                        </strong>
                                    </td>
                                </tr>
                            </tbody>{" "}
                        </table>
                    ) : (
                        <p class="no-data">
                            No hay estadísticas disponibles para esta
                            jugadora.{" "}
                        </p>
                    )
                }
            </section>
        </div>

        <script is:inline>
            function toggleSeason(season) {
                const rows = document.querySelectorAll(
                    `.competition-row.season-${season}`,
                );
                const icon = document.querySelector(
                    `.season-total-row[onclick*="${season}"] .toggle-icon`,
                );
                rows.forEach((row) => {
                    if (row.style.display === "none") {
                        row.style.display = "table-row";
                        if (icon) icon.textContent = "▲";
                    } else {
                        row.style.display = "none";
                        if (icon) icon.textContent = "▼";
                    }
                });
            }
        </script>
        <style>
            .player-profile-page {
                max-width: 1200px;
                margin: 0 auto;
                padding: 2rem 1rem;
            }
            .back-link {
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
                color: #666;
                text-decoration: none;
                font-weight: 600;
                margin-bottom: 1.5rem;
                transition: color 0.3s;
            }
            .back-link:hover {
                color: #ffde59;
            }
            .profile-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 1.5rem;
            }
            .section-header {
                background: #ffde59;
                color: #2b2b2b;
                padding: 0.75rem 1rem;
                margin: 0;
                font-size: 1rem;
                font-weight: bold;
                text-transform: uppercase;
            }
            .ficha-section {
                grid-column: 1 / -1;
                grid-row: 1;
                background: white;
                border: 1px solid #ddd;
                border-radius: 8px;
                overflow: hidden;
            }
            .ficha-content {
                padding: 1.5rem;
                display: flex;
                gap: 1.5rem;
                align-items: stretch;
            }
            .player-photo-container {
                margin-bottom: 0;
                text-align: center;
                flex-shrink: 0;
                display: flex;
            }
            .player-photo {
                max-width: 280px;
                height: 100%;
                width: auto;
                object-fit: cover;
                border-radius: 8px;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            }
            .player-info {
                display: flex;
                flex-direction: column;
                gap: 0.75rem;
                flex: 1;
            }
            .info-row {
                display: flex;
                justify-content: space-between;
                padding: 0.5rem 0;
                border-bottom: 1px solid #eee;
            }
            .info-label {
                font-weight: 600;
                color: #333;
            }
            .info-value {
                color: #666;
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }
            .flag-icon {
                width: 20px;
                height: auto;
            }
            .position-section {
                grid-column: 1;
                grid-row: 2;
                background: white;
                border: 1px solid #ddd;
                border-radius: 8px;
                overflow: hidden;
            }
            .field-diagram {
                position: relative;
                padding: 1.5rem;
                min-height: 300px;
            }
            .field-svg {
                width: 100%;
                height: auto;
                border-radius: 4px;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
            }
            .player-marker {
                position: absolute;
                transform: translate(-50%, -50%);
            }
            .marker-icon {
                width: 30px;
                height: 30px;
                background: white;
                border: 3px solid #ffde59;
                border-radius: 50%;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
            }
            .teams-section {
                grid-column: 2;
                grid-row: 2;
                background: white;
                border: 1px solid #ddd;
                border-radius: 8px;
                overflow: hidden;
            }
            .teams-content {
                padding: 1.5rem;
            }
            .records-section {
                grid-column: 1 / -1;
                grid-row: 4;
                background: white;
                border: 1px solid #ddd;
                border-radius: 8px;
                overflow: hidden;
            }
            .records-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
                gap: 1rem;
                padding: 1.5rem;
            }
            .record-item {
                display: flex;
                justify-content: space-between;
                padding: 0.75rem;
                background: #f9f9f9;
                border-radius: 4px;
            }
            .record-label {
                font-weight: 600;
                color: #333;
