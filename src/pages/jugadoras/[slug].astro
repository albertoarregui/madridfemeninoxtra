                                    <th title="Tarjetas Rojas">TR</th>
                                    <th title="Capitanías">Cap.</th>
                                </tr>
                            </thead>
                            <tbody>
                                {playerStats.estadisticas
                                    .filter((s: any) => s.total.partidos > 0)
                                    .map((season: any) => (
                                        <>
                                            <tr
                                                class="season-total-row"
                                                onclick={`toggleSeason('${season.temporada.replace(/\//g, "-")}')`}
                                                style="cursor: pointer;"
                                            >
                                                <td>
                                                    <strong>
                                                        {season.temporada}
                                                    </strong>
                                                    <span class="toggle-icon">
                                                        ▼
                                                    </span>
                                                </td>
