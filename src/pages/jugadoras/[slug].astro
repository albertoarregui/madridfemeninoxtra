        <script define:vars={{ seasonPhotos: seasonPhotosData }}>
            let currentIdx = 0;
            const photoEl = document.getElementById("main-player-photo");
            const badgeEl = document.getElementById("photo-season-badge");
            const prevBtn = document.getElementById("prev-photo");
            const nextBtn = document.getElementById("next-photo");

            function updateCarousel() {
                if (!photoEl || !badgeEl || seasonPhotos.length === 0) return;

                const current = seasonPhotos[currentIdx];
                photoEl.src = current.url;
                badgeEl.textContent = current.season;

                // Left button (Next in array = Older)
                if (prevBtn)
                    prevBtn.disabled = currentIdx === seasonPhotos.length - 1;
                // Right button (Prev in array = Newer)
                if (nextBtn) nextBtn.disabled = currentIdx === 0;
            }

            if (prevBtn) {
                prevBtn.addEventListener("click", () => {
                    // Clicking Left advances to the "next" in our reversed list (Older)
                    if (currentIdx < seasonPhotos.length - 1) {
                        currentIdx++;
                        updateCarousel();
                    }
                });
            }

            if (nextBtn) {
                nextBtn.addEventListener("click", () => {
                    // Clicking Right goes back to "previous" in our reversed list (Newer)
                    if (currentIdx > 0) {
                        currentIdx--;
                        updateCarousel();
                    }
                });
            }

            // Initial state
            updateCarousel();
        </script>
        <script is:inline>
            function toggleSeason(season) {
                const rows = document.querySelectorAll(
                    `.competition-row.season-${season}`,
                );
                const icon = document.querySelector(
                    `.season-total-row[onclick*="${season}"] .toggle-icon`,
                );
                rows.forEach((row) => {
                    if (row.style.display === "none") {
                        row.style.display = "table-row";
                        if (icon) icon.textContent = "▲";
                    } else {
                        row.style.display = "none";
                        if (icon) icon.textContent = "▼";
                    }
                });
            }
        </script>
