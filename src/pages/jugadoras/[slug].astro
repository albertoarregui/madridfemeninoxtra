                            height="25"
                            fill="none"
                            stroke="white"
                            stroke-width="0.3"></rect>
                        <rect
                            x="0"
                            y="26"
                            width="5"
                            height="13"
                            fill="none"
                            stroke="white"
                            stroke-width="0.3"></rect>
                        <rect
                            x="85"
                            y="20"
                            width="15"
                            height="25"
                            fill="none"
                            stroke="white"
                            stroke-width="0.3"></rect>
                        <rect
                            x="95"
                            y="26"
                            width="5"
                            height="13"
                            fill="none"
                            stroke="white"
                            stroke-width="0.3"></rect>
                    </svg>
                    <div
                        class="player-marker"
                        style={`left: ${playerPosition.left}; top: ${playerPosition.top};`}
                    >
                        <div class="marker-icon"></div>
                    </div>
                </div>
            </section>

            <section class="teams-section">
                <h2 class="section-header">TRAYECTORIA</h2>
                <div class="teams-content">
                    {
                        trajectory && trajectory.length > 0 ? (
                            <div class="trajectory-timeline">
                                <div class="trajectory-vertical-line" />
                                {trajectory.map((item) => (
                                    <div class="timeline-item">
                                        <div class="timeline-marker" />
                                        <div class="timeline-content">
                                            <div class="timeline-years">
                                                {item.anio_inicio} -
                                                {item.anio_fin || "Act."}
                                            </div>
                                            <div class="timeline-club">
