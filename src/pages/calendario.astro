---
import Layout from "../layouts/Layout.astro";
import { fetchGamesDirectly } from "../utils/partidos";
import CalendarArchive from "../components/CalendarArchive";
import "../styles/global.css";

export const prerender = false;

let matches: any[] = [];
let error = null;

try {
    const allMatches = await fetchGamesDirectly();
    matches = allMatches.filter(m => !m.isPlayed);
} catch (e: any) {
    console.error("Error fetching matches for calendar:", e);
    error = e.message;
}

const title = "Calendario Real Madrid Femenino | Madrid Femenino Xtra";
const description = "Explora el próximo calendario del Real Madrid Femenino: partidos confirmados, horarios y competiciones.";
---

<Layout title={title} description={description}>
    <main class="calendar-page">
        <header class="page-header-container">
            <h1 class="landing-title">CALENDARIO</h1>
            <p class="landing-subtitle">Consulta los próximos encuentros en los que aún no se han jugado</p>
        </header>

        <section class="calendar-content-section max-w-7xl mx-auto">
            {error && <div class="p-10 bg-red-50 text-red-600 rounded-3xl border border-red-100 font-bold">Error cargando el calendario: {error}</div>}
            
            <CalendarArchive matches={matches} client:load />
        </section>
    </main>
</Layout>

<style>
    .calendar-page {
        background-color: #fcfcfc;
        min-height: 100vh;
    }
</style>
