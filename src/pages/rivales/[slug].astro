---
import Layout from "../../layouts/Layout.astro";
import { fetchRivalsDirectly } from "../../utils/rivales";
import { fetchRivalRecords } from "../../utils/rival-records";
import type { ImageMetadata } from "astro";

export async function getStaticPaths() {
    const allRivals = await fetchRivalsDirectly();

    return allRivals.map((rival) => ({
        params: { slug: rival.slug },
        props: { rival },
    }));
}

const { rival } = Astro.props;

// Fetch rival records from database
const rivalRecords = await fetchRivalRecords(rival.id_club);

const mockPlayers: string[] = [];
const mockTopScorers: any[] = [];
const mockTopAssisters: any[] = [];
const mockTopContributors: any[] = [];
const mockMatches: any[] = [];
---

<Layout
    title={`${rival.nombre} - Rival | Madrid Femenino Xtra`}
    description={`Historial completo del Real Madrid Femenino contra ${rival.nombre}. Estadísticas, goleadoras, asistentes y todos los partidos disputados.`}
>
    <main class="rival-details-page">
        <a href="/rivales" class="back-link">
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Volver al resto de rivales
        </a>

        <div class="rival-grid">
            <div class="left-column">
                <section class="rival-card">
                    <h2 class="section-header">
                        Ficha de rival: {rival.nombre}
                    </h2>
                    <div class="rival-info">
                        <div class="rival-shield">
                            <img
                                src={rival.shieldUrl}
                                alt={`Escudo de ${rival.nombre}`}
                                onerror="this.onerror=null; this.src='/assets/escudos/placeholder.png';"
                            />
                        </div>
                        <div class="rival-details">
                            <div class="info-row">
                                <span class="label">Nombre:</span>
                                <span class="value">{rival.nombre}</span>
                            </div>
                            <div class="info-row">
                                <span class="label">Ciudad:</span>
                                <span class="value">{rival.ciudad}</span>
                            </div>
                            <div class="info-row">
                                <span class="label">País:</span>
                                <span class="value">{rival.pais}</span>
                            </div>
                            <div class="info-row">
                                <span class="label">Estadio:</span>
                                <span class="value">{rival.estadio}</span>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="players-card">
                    <h2 class="section-header">
                        Jugadoras del Real Madrid que jugaron en el {
                            rival.nombre
                        }
                    </h2>
                    <div class="players-list">
                        <p>{mockPlayers.join(", ")}</p>
                    </div>
                </section>

                <section class="charts-card">
                    <h2 class="section-header">Gráficas</h2>
                    <div class="charts-content">
                        <div class="chart-controls">
                            <div class="control">
                                <label>Competición:</label>
                                <select>
                                    <option>25 seleccionadas</option>
                                </select>
                            </div>
                            <button class="btn-ok">OK</button>
                            <div class="control">
                                <label>Cambiar rival:</label>
                                <select>
                                    <option>{rival.nombre}</option>
                                </select>
                            </div>
                        </div>
                        <div class="charts-row">
                            <div class="chart-item">
                                <svg viewBox="0 0 100 100" class="pie-chart">
                                    <circle
                                        cx="50"
                                        cy="50"
                                        r="35"
                                        fill="none"
                                        stroke="#4CAF50"
                                        stroke-width="20"
                                        stroke-dasharray="69 132"
                                        transform="rotate(-90 50 50)"></circle>
                                    <circle
                                        cx="50"
                                        cy="50"
                                        r="35"
                                        fill="none"
                                        stroke="#ff9800"
                                        stroke-width="20"
                                        stroke-dasharray="33 165"
                                        stroke-dashoffset="-69"
                                        transform="rotate(-90 50 50)"></circle>
                                    <circle
                                        cx="50"
                                        cy="50"
                                        r="35"
                                        fill="none"
                                        stroke="#f44336"
                                        stroke-width="20"
                                        stroke-dasharray="30 168"
                                        stroke-dashoffset="-102"
                                        transform="rotate(-90 50 50)"></circle>
                                </svg>
                                <div class="chart-legend">
                                    <div>
                                        <span class="dot green"></span> Ganados ()
                                    </div>
                                    <div>
                                        <span class="dot orange"></span> Empatados
                                        ()
                                    </div>
                                    <div>
                                        <span class="dot red"></span> Perdidos ())
                                    </div>
                                </div>
                            </div>
                            <div class="chart-item">
                                <svg viewBox="0 0 100 100" class="pie-chart">
                                    <circle
                                        cx="50"
                                        cy="50"
                                        r="35"
                                        fill="none"
                                        stroke="#4CAF50"
                                        stroke-width="20"
                                        stroke-dasharray="126 72"
                                        transform="rotate(-90 50 50)"></circle>
                                    <circle
                                        cx="50"
                                        cy="50"
                                        r="35"
                                        fill="none"
                                        stroke="#f44336"
                                        stroke-width="20"
                                        stroke-dasharray="72 126"
                                        stroke-dashoffset="-126"
                                        transform="rotate(-90 50 50)"></circle>
                                </svg>
                                <div class="chart-legend">
                                    <div>
                                        <span class="dot green"></span> Goles a favor
                                        ()
                                    </div>
                                    <div>
                                        <span class="dot red"></span> Goles en contra
                                        ()
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="stats-table-card">
                    <h3 class="section-subheader">
                        Estadísticas contra el {rival.nombre}
                    </h3>
                    <div class="table-wrapper">
                        <table class="stats-table">
                            <thead>
                                <tr>
                                    <th>Jugados como</th>
                                    <th>PJ</th>
                                    <th>PG</th>
                                    <th>%PG</th>
                                    <th>PE</th>
                                    <th>%PE</th>
                                    <th>PP</th>
                                    <th>%PP</th>
                                    <th class="highlight-yellow">⚽</th>
                                    <th class="highlight-red">⚽</th>
                                    <th class="highlight-blue">📊</th>
                                    <th>Avg.</th>
                                    <th>Dif.</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Local</td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td>Visitante</td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td>Neutral</td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                                <tr class="total-row">
                                    <td><strong>Total</strong></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </section>

                <section class="matches-card">
                    <h3 class="section-subheader">
                        Todos los partidos disputados contra el {rival.nombre}
                    </h3>
                    <div class="table-wrapper">
                        <div class="matches-controls">
                            <button class="filter-btn">Filtrar:</button>
                        </div>
                        <table class="matches-table">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Competición</th>
                                    <th>En</th>
                                    <th>Res.</th>
                                    <th>Árbitro</th>
                                    <th>Estadio</th>
                                    <th>Asist.</th>
                                </tr>
                            </thead>
                            <tbody>
                                {
                                    mockMatches.map((match) => (
                                        <tr>
                                            <td>{match.date}</td>
                                            <td>{match.competition}</td>
                                            <td>{match.location}</td>
                                            <td>{match.result}</td>
                                            <td>{match.referee}</td>
                                            <td>{match.stadium}</td>
                                            <td>{match.attendance}</td>
                                        </tr>
                                    ))
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
            </div>

            <div class="right-column">
                <section class="stadium-card">
                    <h2 class="section-header">Estadio</h2>
                    <div class="stadium-content">
                        <div class="stadium-photo">
                            <div class="photo-placeholder"></div>
                        </div>
                    </div>
                </section>

                <section class="records-card">
                    <h2 class="section-header">Records</h2>
                    <div class="records-list">
                        {
                            rivalRecords?.maximo_goleador && (
                                <div class="record-row">
                                    <span class="record-label">
                                        Máximo goleador:
                                    </span>
                                    <span class="record-value">
                                        {rivalRecords.maximo_goleador.nombre} -{" "}
                                        {rivalRecords.maximo_goleador.goles}
                                    </span>
                                </div>
                            )
                        }
                        {
                            rivalRecords?.goleador_rival && (
                                <div class="record-row">
                                    <span class="record-label">
                                        Goleador rival:
                                    </span>
                                    <span class="record-value">
                                        {rivalRecords.goleador_rival.nombre} -{" "}
                                        {rivalRecords.goleador_rival.goles}
                                    </span>
                                </div>
                            )
                        }
                        {
                            rivalRecords?.mas_partidos && (
                                <div class="record-row">
                                    <span class="record-label">
                                        Más partidos:
                                    </span>
                                    <span class="record-value">
                                        {rivalRecords.mas_partidos.nombre} -{" "}
                                        {rivalRecords.mas_partidos.partidos}
                                    </span>
                                </div>
                            )
                        }
                        {
                            rivalRecords?.mayor_victoria && (
                                <div class="record-row">
                                    <span class="record-label">
                                        Mayor victoria:
                                    </span>
                                    <span class="record-value">
                                        {rivalRecords.mayor_victoria.resultado}
                                    </span>
                                </div>
                            )
                        }
                        {
                            rivalRecords?.mayor_derrota && (
                                <div class="record-row">
                                    <span class="record-label">
                                        Mayor derrota:
                                    </span>
                                    <span class="record-value">
                                        {rivalRecords.mayor_derrota.resultado}
                                    </span>
                                </div>
                            )
                        }
                        {
                            rivalRecords?.mas_repetido && (
                                <div class="record-row">
                                    <span class="record-label">
                                        Más repetido:
                                    </span>
                                    <span class="record-value">
                                        {rivalRecords.mas_repetido.resultado} -{" "}
                                        {rivalRecords.mas_repetido.veces} veces
                                    </span>
                                </div>
                            )
                        }
                    </div>
                </section>

                <section class="top-scorers-card">
                    <h2 class="section-header">Máximas Goleadoras</h2>
                    <div class="top-list">
                        {
                            mockTopScorers.map((player, index) => (
                                <div class="top-item">
                                    <span class="position">{index + 1}.</span>
                                    <span class="player-name">
                                        {player.name}
                                    </span>
                                    <span class="stat-value">
                                        {player.goals} goles
                                    </span>
                                </div>
                            ))
                        }
                    </div>
                </section>

                <section class="top-assisters-card">
                    <h2 class="section-header">Máximas Asistentes</h2>
                    <div class="top-list">
                        {
                            mockTopAssisters.map((player, index) => (
                                <div class="top-item">
                                    <span class="position">{index + 1}.</span>
                                    <span class="player-name">
                                        {player.name}
                                    </span>
                                    <span class="stat-value">
                                        {player.assists} asistencias
                                    </span>
                                </div>
                            ))
                        }
                    </div>
                </section>

                <section class="top-contributors-card">
                    <h2 class="section-header">Más Goles Generados (G+A)</h2>
                    <div class="top-list">
                        {
                            mockTopContributors.map((player, index) => (
                                <div class="top-item">
                                    <span class="position">{index + 1}.</span>
                                    <span class="player-name">
                                        {player.name}
                                    </span>
                                    <span class="stat-value">
                                        {player.total} ({player.goals}G +{" "}
                                        {player.assists}A)
                                    </span>
                                </div>
                            ))
                        }
                    </div>
                </section>
            </div>
        </div>
    </main>

    <style>
        .rival-details-page {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: #666;
            text-decoration: none;
            font-weight: 600;
            margin-bottom: 1.5rem;
            transition: color 0.3s;
        }

        .back-link:hover {
            color: #ffde59;
        }

        .rival-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 1.5rem;
        }

        .left-column,
        .right-column {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .section-header {
            background: #ffde59;
            color: #2b2b2b;
            padding: 0.75rem 1rem;
            margin: 0;
            font-size: 1rem;
            font-weight: bold;
        }

        .section-subheader {
            background: #333;
            color: white;
            padding: 0.75rem 1rem;
            margin: 0;
            font-size: 0.95rem;
            font-weight: bold;
        }

        .rival-card,
        .players-card,
        .charts-card,
        .stats-table-card,
        .matches-card,
        .stadium-card,
        .kit-card,
        .records-card,
        .top-scorers-card,
        .top-assisters-card,
        .top-contributors-card {
            background: white;
            border: 1px solid #ddd;
            border-radius: 8px;
            overflow: hidden;
        }

        .rival-info {
            padding: 1.5rem;
            display: flex;
            gap: 1.5rem;
        }

        .rival-shield {
            flex-shrink: 0;
        }

        .rival-shield img {
            width: 150px;
            height: 150px;
            object-fit: contain;
        }

        .rival-details {
            flex: 1;
        }

        .info-row {
            display: flex;
            padding: 0.5rem 0;
            border-bottom: 1px solid #eee;
        }

        .info-row .label {
            font-weight: 600;
            width: 150px;
        }

        .info-row .value {
            flex: 1;
        }

        .info-row .link {
            color: #0066cc;
        }

        .players-list {
            padding: 1.5rem;
            font-size: 0.9rem;
            line-height: 1.8;
        }

        .charts-content {
            padding: 1.5rem;
        }

        .chart-controls {
            display: flex;
            gap: 1rem;
            margin-bottom: 1.5rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .control {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .control label {
            font-weight: 600;
            font-size: 0.85rem;
        }

        .control select {
            padding: 0.5rem;
            border: 1px solid #ddd;
            border-radius: 4px;
        }

        .btn-ok {
            padding: 0.5rem 1rem;
            background: #4caf50;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }

        .charts-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
        }

        .chart-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
        }

        .pie-chart {
            width: 200px;
            height: 200px;
        }

        .chart-legend {
            font-size: 0.85rem;
        }

        .chart-legend .dot {
            display: inline-block;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin-right: 0.5rem;
        }

        .dot.green {
            background: #4caf50;
        }
        .dot.orange {
            background: #ff9800;
        }
        .dot.red {
            background: #f44336;
        }

        .table-wrapper {
            overflow-x: auto;
        }

        .stats-table,
        .matches-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }

        .stats-table th,
        .stats-table td,
        .matches-table th,
        .matches-table td {
            padding: 0.75rem 0.5rem;
            text-align: center;
            border: 1px solid #ddd;
        }

        .stats-table th,
        .matches-table th {
            background: #333;
            color: white;
            font-weight: 600;
        }

        .stats-table th.highlight-yellow {
            background: #ffcc00;
            color: #333;
        }

        .stats-table th.highlight-red {
            background: #dc3545;
        }

        .stats-table th.highlight-blue {
            background: #007bff;
        }

        .stats-table tbody tr:nth-child(even) {
            background: #fff5e6;
        }

        .total-row {
            background: #f0f0f0 !important;
            font-weight: bold;
        }

        .matches-controls {
            padding: 1rem;
            background: #f9f9f9;
        }

        .filter-btn {
            padding: 0.5rem 1rem;
            background: #ffde59;
            color: #2b2b2b;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }

        .stadium-photo,
        .kit-row {
            padding: 1.5rem;
        }

        .photo-placeholder {
            width: 100%;
            height: 200px;
            background: #f0f0f0;
            border-radius: 8px;
        }

        .kit-row {
            display: flex;
            gap: 1rem;
            justify-content: center;
        }

        .kit-placeholder {
            width: 120px;
            height: 150px;
            border-radius: 8px;
        }

        .kit-placeholder.home {
            background: linear-gradient(to bottom, #ff0000, #cc0000);
        }

        .kit-placeholder.away {
            background: linear-gradient(to bottom, #006600, #004400);
        }

        .records-list,
        .top-list {
            padding: 1.5rem;
        }

        .record-row,
        .top-item {
            display: flex;
            justify-content: space-between;
            padding: 0.75rem 0;
            border-bottom: 1px solid #eee;
        }

        .record-label,
        .player-name {
            font-weight: 600;
        }

        .record-value,
        .stat-value {
            color: #ffde59;
            font-weight: bold;
        }

        .top-item {
            align-items: center;
            gap: 0.5rem;
        }

        .position {
            width: 30px;
            font-weight: bold;
            color: #ffde59;
        }

        .player-name {
            flex: 1;
        }

        @media (max-width: 1024px) {
            .rival-grid {
                grid-template-columns: 1fr;
            }

            .charts-row {
                grid-template-columns: 1fr;
            }
        }
    </style>
</Layout>
