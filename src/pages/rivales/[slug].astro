                        }
                        {
                            rivalRecords?.mas_repetido && (
                                <div class="record-row">
                                    <span class="record-label">
                                        Más repetido:
                                    </span>
                                    <span class="record-value">
                                        {rivalRecords.mas_repetido.resultado} -{" "}
                                        {rivalRecords.mas_repetido.veces} veces
                                    </span>
                                </div>
                            )
                        }
                        {
                            rivalRecords?.maximo_goleador && (
                                <div class="record-row">
                                    <span class="record-label">
                                        Máxima goleadora:
                                    </span>
                                    <span class="record-value">
                                        {rivalRecords.maximo_goleador.nombre} -{" "}
                                        {rivalRecords.maximo_goleador.goles}
                                    </span>
                                </div>
                            )
                        }
                        {
                            rivalRecords?.goleador_rival && (
                                <div class="record-row">
                                    <span class="record-label">
                                        Goleador rival:
                                    </span>
                                    <span class="record-value">
                                        {rivalRecords.goleador_rival.nombre} -{" "}
                                        {rivalRecords.goleador_rival.goles}
                                    </span>
                                </div>
