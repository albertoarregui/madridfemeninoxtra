---
import Layout from "../../layouts/Layout.astro";
import { fetchRivalsDirectly } from "../../utils/rivales";
import {
    fetchRivalRecords,
    fetchRivalTopPlayers,
    fetchRivalMatches,
    calculateRivalStats,
} from "../../utils/rival-records";
import type { ImageMetadata } from "astro";

export async function getStaticPaths() {
    const allRivals = await fetchRivalsDirectly();

    return allRivals.map((rival) => ({
        params: { slug: rival.slug },
        props: { rival },
    }));
}

const { rival } = Astro.props;

// Import shield dynamically from src/assets
let shieldImage: ImageMetadata | undefined;
try {
    const images = import.meta.glob<{ default: ImageMetadata }>(
        "/src/assets/escudos/*.png",
    );
    // Convert slug from guiones to guiones bajos to match filename format
    const fileSlug = rival.slug.replace(/-/g, "_");
    const imagePath = `/src/assets/escudos/${fileSlug}.png`;

    console.log("Trying to load shield:", imagePath);
    console.log("Available images:", Object.keys(images));

    if (images[imagePath]) {
        shieldImage = (await images[imagePath]()).default;
        console.log("Shield loaded successfully for", rival.nombre);
    } else {
        console.log(
            "Shield not found for",
            rival.nombre,
            "at path:",
            imagePath,
        );
    }
} catch (error) {
    console.error(`Error loading shield for ${rival.nombre}:`, error);
}

// Import country flag dynamically from src/assets/banderas
let flagImage: ImageMetadata | undefined;
try {
    const flags = import.meta.glob<{ default: ImageMetadata }>(
        "/src/assets/banderas/*.svg",
    );
    // Normalize country name to match filename format
    const flagSlug = rival.pais
        ?.toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/\s+/g, "_");
    const flagPath = `/src/assets/banderas/${flagSlug}.svg`;

    console.log("Trying to load flag:", flagPath);

    if (flags[flagPath]) {
        flagImage = (await flags[flagPath]()).default;
        console.log("Flag loaded successfully for", rival.pais);
    } else {
        console.log("Flag not found for", rival.pais, "at path:", flagPath);
    }
} catch (error) {
    console.error(`Error loading flag for ${rival.pais}:`, error);
}

// Fetch rival records from database
const rivalRecords = await fetchRivalRecords(rival.id_club);

// Fetch top players statistics
const topPlayersData = await fetchRivalTopPlayers(rival.id_club);

// Fetch all matches against this rival
const rivalMatches = await fetchRivalMatches(rival.id_club);

// Calculate statistics from matches
const rivalStats = calculateRivalStats(rivalMatches);

// Extract unique competitions and sort in specific order
const competitionOrder = [
    "Liga F",
    "UWCL",
    "Copa de la Reina",
    "Supercopa de España",
    "Amistosos",
];
const uniqueCompetitions = [
    ...new Set(rivalMatches.map((m) => m.competicion)),
].filter((c) => c && c !== "-");
const competitions = uniqueCompetitions.sort((a, b) => {
    const indexA = competitionOrder.indexOf(a);
    const indexB = competitionOrder.indexOf(b);
    if (indexA === -1 && indexB === -1) return a.localeCompare(b);
    if (indexA === -1) return 1;
    if (indexB === -1) return -1;
    return indexA - indexB;
});

// Calculate pie chart values (circumference = 2 * PI * r = 2 * 3.14159 * 35 ≈ 220)
const circumference = 220;
const totalMatches = rivalStats.total.pj;

// Wins/Draws/Losses percentages
const winsArc =
    totalMatches > 0
        ? Math.round((rivalStats.total.pg / totalMatches) * circumference)
        : 0;
const drawsArc =
    totalMatches > 0
        ? Math.round((rivalStats.total.pe / totalMatches) * circumference)
        : 0;
const lossesArc =
    totalMatches > 0
        ? Math.round((rivalStats.total.pp / totalMatches) * circumference)
        : 0;

// Goals for/against percentages
const totalGoals = rivalStats.total.gf + rivalStats.total.gc;
const goalsForArc =
    totalGoals > 0
        ? Math.round((rivalStats.total.gf / totalGoals) * circumference)
        : 0;
const goalsAgainstArc =
    totalGoals > 0
        ? Math.round((rivalStats.total.gc / totalGoals) * circumference)
        : 0;

const mockPlayers: string[] = [];
---

<Layout
    title={`${rival.nombre} - Rival | Madrid Femenino Xtra`}
    description={`Historial completo del Real Madrid Femenino contra ${rival.nombre}. Estadísticas, goleadoras, asistentes y todos los partidos disputados.`}
>
    <main class="rival-details-page">
        <a href="/rivales" class="back-link">
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Volver al resto de rivales
        </a>

        <div class="rival-grid">
            <div class="left-column">
                <section class="rival-card">
                    <h2 class="section-header">
                        FICHA DE RIVAL: {rival.nombre}
                    </h2>
                    <div class="rival-info">
                        <div class="rival-shield">
                            {
                                shieldImage ? (
                                    <img
                                        src={shieldImage.src}
                                        alt={`Escudo de ${rival.nombre}`}
                                    />
                                ) : (
                                    <img
                                        src={rival.shieldUrl}
                                        alt={`Escudo de ${rival.nombre}`}
                                        onerror="this.onerror=null; this.src='/assets/escudos/placeholder.png';"
                                    />
                                )
                            }
                        </div>
                        <div class="rival-details">
                            <div class="info-row">
                                <span class="label">Nombre:</span>
                                <span class="value">{rival.nombre}</span>
                            </div>
                            <div class="info-row">
                                <span class="label">Ciudad:</span>
                                <span class="value">{rival.ciudad}</span>
                            </div>
                            <div class="info-row">
                                <span class="label">País:</span>
                                <span class="value">
                                    {rival.pais}
                                    {
                                        flagImage && (
                                            <img
                                                src={flagImage.src}
                                                alt={`Bandera de ${rival.pais}`}
                                                class="country-flag"
                                            />
                                        )
                                    }
                                </span>
                            </div>
                            <div class="info-row">
                                <span class="label">Estadio:</span>
                                <span class="value">{rival.estadio}</span>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="players-card">
                    <h2 class="section-header">
                        JUGADORAS DEL REAL MADRID QUE JUGARON EN EL {
                            rival.nombre
                        }
                    </h2>
                    <div class="players-list">
                        <p>{mockPlayers.join(", ")}</p>
                    </div>
                </section>

                <section class="charts-card">
                    <h2 class="section-header">GRÁFICAS</h2>
                    <div class="charts-content">
                        <div
                            class="chart-controls"
                            style="justify-content: center;"
                        >
                            <div class="control">
                                <label>COMPETICIÓN:</label>
                                <select id="competition-filter">
                                    <option value="all">Todas</option>
                                    {
                                        competitions.map((comp) => (
                                            <option value={comp}>{comp}</option>
                                        ))
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="charts-row">
                            <div class="chart-item">
                                <svg
                                    viewBox="0 0 100 100"
                                    class="pie-chart"
                                    id="results-chart"
                                >
                                    <circle
                                        cx="50"
                                        cy="50"
                                        r="35"
                                        fill="none"
                                        stroke="#c8e6c9"
                                        stroke-width="20"
                                        stroke-dasharray={`${winsArc} ${circumference - winsArc}`}
                                        transform="rotate(-90 50 50)"></circle>
                                    <circle
                                        cx="50"
                                        cy="50"
                                        r="35"
                                        fill="none"
                                        stroke="#fff9c4"
                                        stroke-width="20"
                                        stroke-dasharray={`${drawsArc} ${circumference - drawsArc}`}
                                        stroke-dashoffset={-winsArc}
                                        transform="rotate(-90 50 50)"></circle>
                                    <circle
                                        cx="50"
                                        cy="50"
                                        r="35"
                                        fill="none"
                                        stroke="#ffcdd2"
                                        stroke-width="20"
                                        stroke-dasharray={`${lossesArc} ${circumference - lossesArc}`}
                                        stroke-dashoffset={-(
                                            winsArc + drawsArc
                                        )}
                                        transform="rotate(-90 50 50)"></circle>
                                </svg>
                                <div class="chart-legend" id="results-legend">
                                    <div>
                                        <span class="dot green"></span> Ganados ({
                                            rivalStats.total.pg
                                        })
                                    </div>
                                    <div>
                                        <span class="dot orange"></span> Empatados
                                        ({rivalStats.total.pe})
                                    </div>
                                    <div>
                                        <span class="dot red"></span> Perdidos ({
                                            rivalStats.total.pp
                                        })
                                    </div>
                                </div>
                            </div>
                            <div class="chart-item">
                                <svg
                                    viewBox="0 0 100 100"
                                    class="pie-chart"
                                    id="goals-chart"
                                >
                                    <circle
                                        cx="50"
                                        cy="50"
                                        r="35"
                                        fill="none"
                                        stroke="#c8e6c9"
                                        stroke-width="20"
                                        stroke-dasharray={`${goalsForArc} ${circumference - goalsForArc}`}
                                        transform="rotate(-90 50 50)"></circle>
                                    <circle
                                        cx="50"
                                        cy="50"
                                        r="35"
                                        fill="none"
                                        stroke="#ffcdd2"
                                        stroke-width="20"
                                        stroke-dasharray={`${goalsAgainstArc} ${circumference - goalsAgainstArc}`}
                                        stroke-dashoffset={-goalsForArc}
                                        transform="rotate(-90 50 50)"></circle>
                                </svg>
                                <div class="chart-legend" id="goals-legend">
                                    <div>
                                        <span class="dot green"></span> A favor ({
                                            rivalStats.total.gf
                                        })
                                    </div>
                                    <div>
                                        <span class="dot red"></span> En contra ({
                                            rivalStats.total.gc
                                        })
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="stats-table-card">
                    <h3 class="section-subheader">
                        ESTADÍSTICAS CONTRA EL {rival.nombre}
                    </h3>
                    <div class="table-wrapper">
                        <table class="stats-table">
                            <thead>
                                <tr>
                                    <th>JUGADOS COMO</th>
                                    <th>PJ</th>
                                    <th>PG</th>
                                    <th>%PG</th>
                                    <th>PE</th>
                                    <th>%PE</th>
                                    <th>PP</th>
                                    <th>%PP</th>
                                    <th class="highlight-yellow">⚽</th>
                                    <th class="highlight-red">⚽</th>
                                    <th class="highlight-blue">📊</th>
                                    <th>Avg.</th>
                                    <th>Dif.</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>LOCAL</td>
                                    <td>{rivalStats.home.pj}</td>
                                    <td>{rivalStats.home.pg}</td>
                                    <td>{rivalStats.home.percPG}%</td>
                                    <td>{rivalStats.home.pe}</td>
                                    <td>{rivalStats.home.percPE}%</td>
                                    <td>{rivalStats.home.pp}</td>
                                    <td>{rivalStats.home.percPP}%</td>
                                    <td class="highlight-yellow"
                                        >{rivalStats.home.gf}</td
                                    >
                                    <td class="highlight-red"
                                        >{rivalStats.home.gc}</td
                                    >
                                    <td class="highlight-blue"
                                        >{rivalStats.home.dif > 0 ? "+" : ""}{
                                            rivalStats.home.dif
                                        }</td
                                    >
                                    <td>{rivalStats.home.avg}</td>
                                    <td>{rivalStats.home.dif}</td>
                                </tr>
                                <tr>
                                    <td>VISITANTE</td>
                                    <td>{rivalStats.away.pj}</td>
                                    <td>{rivalStats.away.pg}</td>
                                    <td>{rivalStats.away.percPG}%</td>
                                    <td>{rivalStats.away.pe}</td>
                                    <td>{rivalStats.away.percPE}%</td>
                                    <td>{rivalStats.away.pp}</td>
                                    <td>{rivalStats.away.percPP}%</td>
                                    <td class="highlight-yellow"
                                        >{rivalStats.away.gf}</td
                                    >
                                    <td class="highlight-red"
                                        >{rivalStats.away.gc}</td
                                    >
                                    <td class="highlight-blue"
                                        >{rivalStats.away.dif > 0 ? "+" : ""}{
                                            rivalStats.away.dif
                                        }</td
                                    >
                                    <td>{rivalStats.away.avg}</td>
                                    <td>{rivalStats.away.dif}</td>
                                </tr>

                                <tr class="total-row">
                                    <td><strong>TOTAL</strong></td>
                                    <td>{rivalStats.total.pj}</td>
                                    <td>{rivalStats.total.pg}</td>
                                    <td>{rivalStats.total.percPG}%</td>
                                    <td>{rivalStats.total.pe}</td>
                                    <td>{rivalStats.total.percPE}%</td>
                                    <td>{rivalStats.total.pp}</td>
                                    <td>{rivalStats.total.percPP}%</td>
                                    <td class="highlight-yellow"
                                        >{rivalStats.total.gf}</td
                                    >
                                    <td class="highlight-red"
                                        >{rivalStats.total.gc}</td
                                    >
                                    <td class="highlight-blue"
                                        >{rivalStats.total.dif > 0 ? "+" : ""}{
                                            rivalStats.total.dif
                                        }</td
                                    >
                                    <td>{rivalStats.total.avg}</td>
                                    <td>{rivalStats.total.dif}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </section>

                <section class="matches-card">
                    <h3 class="section-subheader">
                        TODOS LOS PARTIDOS DISPUTADOS CONTRA EL {rival.nombre}
                    </h3>
                    <div class="table-wrapper">
                        <table class="matches-table">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Competición</th>
                                    <th>En</th>
                                    <th>Res.</th>
                                    <th>Árbitro</th>
                                    <th>Estadio</th>
                                    <th>Asist.</th>
                                </tr>
                            </thead>
                            <tbody>
                                {
                                    rivalMatches.length > 0 ? (
                                        rivalMatches.map((match: any) => {
                                            // Determinar tipo de resultado
                                            const golesRM =
                                                parseInt(match.golesRM) || 0;
                                            const golesRival =
                                                parseInt(match.golesRival) || 0;
                                            let resultClass = "";
                                            if (golesRM > golesRival) {
                                                resultClass =
                                                    "resultado-victoria";
                                            } else if (golesRM === golesRival) {
                                                resultClass =
                                                    "resultado-empate";
                                            } else {
                                                resultClass =
                                                    "resultado-derrota";
                                            }

                                            return (
                                                <tr>
                                                    <td>
                                                        {new Date(
                                                            match.fecha,
                                                        ).toLocaleDateString(
                                                            "es-ES",
                                                        )}
                                                    </td>
                                                    <td>{match.competicion}</td>
                                                    <td>{match.ubicacion}</td>
                                                    <td class={resultClass}>
                                                        {match.resultado}
                                                    </td>
                                                    <td>{match.arbitra}</td>
                                                    <td>{match.estadio}</td>
                                                    <td>
                                                        {match.asistencia ||
                                                            "-"}
                                                    </td>
                                                </tr>
                                            );
                                        })
                                    ) : (
                                        <tr>
                                            <td
                                                colspan="7"
                                                style="text-align: center; padding: 2rem;"
                                            >
                                                No hay partidos registrados
                                            </td>
                                        </tr>
                                    )
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
            </div>

            <div class="right-column">
                <section class="stadium-card">
                    <h2 class="section-header">ESTADIO</h2>
                    <div class="stadium-content">
                        <div class="stadium-photo">
                            <div class="photo-placeholder"></div>
                        </div>
                    </div>
                </section>

                <section class="records-card">
                    <h2 class="section-header">RÉCORDS</h2>
                    <div class="records-list">
                        {
                            rivalRecords?.maximo_goleador && (
                                <div class="record-row">
                                    <span class="record-label">
                                        Máxima goleadora:
                                    </span>
                                    <span class="record-value">
                                        {rivalRecords.maximo_goleador.nombre} -{" "}
                                        {rivalRecords.maximo_goleador.goles}
                                    </span>
                                </div>
                            )
                        }
                        {
                            rivalRecords?.goleador_rival && (
                                <div class="record-row">
                                    <span class="record-label">
                                        Goleador rival:
                                    </span>
                                    <span class="record-value">
                                        {rivalRecords.goleador_rival.nombre} -{" "}
                                        {rivalRecords.goleador_rival.goles}
                                    </span>
                                </div>
                            )
                        }
                        {
                            rivalRecords?.mas_partidos && (
                                <div class="record-row">
                                    <span class="record-label">
                                        Jugadora con más partidos:
                                    </span>
                                    <span class="record-value">
                                        {rivalRecords.mas_partidos.nombre} -{" "}
                                        {rivalRecords.mas_partidos.partidos}
                                    </span>
                                </div>
                            )
                        }
                        {
                            rivalRecords?.mayor_victoria && (
                                <div class="record-row">
                                    <span class="record-label">
                                        Mayor victoria:
                                    </span>
                                    <span class="record-value">
                                        {rivalRecords.mayor_victoria.resultado}
                                    </span>
                                </div>
                            )
                        }
                        {
                            rivalRecords?.mayor_derrota && (
                                <div class="record-row">
                                    <span class="record-label">
                                        Mayor derrota:
                                    </span>
                                    <span class="record-value">
                                        {rivalRecords.mayor_derrota.resultado}
                                    </span>
                                </div>
                            )
                        }
                        {
                            rivalRecords?.mas_repetido && (
                                <div class="record-row">
                                    <span class="record-label">
                                        Más repetido:
                                    </span>
                                    <span class="record-value">
                                        {rivalRecords.mas_repetido.resultado} -{" "}
                                        {rivalRecords.mas_repetido.veces} veces
                                    </span>
                                </div>
                            )
                        }
                    </div>
                </section>

                <section class="top-scorers-card">
                    <h2 class="section-header">MÁXIMAS GOLEADORAS</h2>
                    <div class="top-list">
                        {
                            topPlayersData.topScorers.length > 0 ? (
                                topPlayersData.topScorers.map(
                                    (player: any, index: number) => (
                                        <div class="top-item">
                                            <span class="position">
                                                {index + 1}.
                                            </span>
                                            <span class="player-name">
                                                {player.nombre}
                                            </span>
                                            <span class="stat-value">
                                                {player.goles}{" "}
                                                {player.goles === 1
                                                    ? "gol"
                                                    : "goles"}
                                            </span>
                                        </div>
                                    ),
                                )
                            ) : (
                                <p class="no-data">Sin datos disponibles</p>
                            )
                        }
                    </div>
                </section>

                <section class="top-assisters-card">
                    <h2 class="section-header">MÁS ASISTENTES</h2>
                    <div class="top-list">
                        {
                            topPlayersData.topAssisters.length > 0 ? (
                                topPlayersData.topAssisters.map(
                                    (player: any, index: number) => (
                                        <div class="top-item">
                                            <span class="position">
                                                {index + 1}.
                                            </span>
                                            <span class="player-name">
                                                {player.nombre}
                                            </span>
                                            <span class="stat-value">
                                                {player.asistencias}{" "}
                                                {player.asistencias === 1
                                                    ? "asistencia"
                                                    : "asistencias"}
                                            </span>
                                        </div>
                                    ),
                                )
                            ) : (
                                <p class="no-data">Sin datos disponibles</p>
                            )
                        }
                    </div>
                </section>

                <section class="top-contributors-card">
                    <h2 class="section-header">MÁS GOLES GENERADOS (G+A)</h2>
                    <div class="top-list">
                        {
                            topPlayersData.topContributors.length > 0 ? (
                                topPlayersData.topContributors.map(
                                    (player: any, index: number) => (
                                        <div class="top-item">
                                            <span class="position">
                                                {index + 1}.
                                            </span>
                                            <span class="player-name">
                                                {player.nombre}
                                            </span>
                                            <span class="stat-value">
                                                {player.total} ({player.goles}G
                                                + {player.asistencias}A)
                                            </span>
                                        </div>
                                    ),
                                )
                            ) : (
                                <p class="no-data">Sin datos disponibles</p>
                            )
                        }
                    </div>
                </section>
            </div>
        </div>
    </main>

    <style>
        .rival-details-page {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: #666;
            text-decoration: none;
            font-weight: 600;
            margin-bottom: 1.5rem;
            transition: color 0.3s;
        }

        .back-link:hover {
            color: #ffde59;
        }

        .rival-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 1.5rem;
        }

        .left-column,
        .right-column {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .section-header {
            background: #ffde59;
            color: #2b2b2b;
            padding: 0.75rem 1rem;
            margin: 0;
            font-size: 1rem;
            font-weight: bold;
        }

        .section-subheader {
            background: #ffde59;
            color: #000;
            padding: 0.75rem 1rem;
            margin: 0;
            font-size: 0.95rem;
            font-weight: bold;
        }

        .rival-card,
        .players-card,
        .charts-card,
        .stats-table-card,
        .matches-card,
        .stadium-card,
        .kit-card,
        .records-card,
        .top-scorers-card,
        .top-assisters-card,
        .top-contributors-card {
            background: white;
            border: 1px solid #ddd;
            border-radius: 8px;
            overflow: hidden;
        }

        .rival-info {
            padding: 1.5rem;
            display: flex;
            gap: 1.5rem;
        }

        .rival-shield {
            flex-shrink: 0;
        }

        .rival-shield img {
            width: 300px;
            height: 300px;
            object-fit: contain;
        }

        .rival-details {
            flex: 1;
        }

        .info-row {
            display: flex;
            padding: 0.5rem 0;
            border-bottom: 1px solid #eee;
        }

        .info-row .label {
            font-weight: 600;
            width: 150px;
        }

        .info-row .value {
            flex: 1;
            text-align: right;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 0.5rem;
        }

        .country-flag {
            width: 24px;
            height: 16px;
            object-fit: cover;
            border: 1px solid #ddd;
        }

        .info-row .link {
            color: #0066cc;
        }

        .players-list {
            padding: 1.5rem;
            font-size: 0.9rem;
            line-height: 1.8;
