                        </div>
                        <div class="record-row">
                            <span class="record-label">Sin perder:</span>
                            <span class="record-value"
                                >{streaksTotal.undefeated}</span
                            >
                            <span class="record-value"
                                >{streaksHome.undefeated}</span
                            >
                            <span class="record-value"
                                >{streaksAway.undefeated}</span
