                    </div>
                </section>

                <section class="top-scorers-card">
                    <h2 class="section-header">MÁXIMAS GOLEADORAS</h2>
                    <div class="top-list">
                        {
                            topPlayersData.topScorers.length > 0 ? (
                                topPlayersData.topScorers.map(
                                    (player: any, index: number) => (
