                        <div class="record-row">
                            <span class="record-label">Porterías a cero:</span>
                            <span class="record-value"
                                >{streaksTotal.cleanSheets}</span
                            >
                            <span class="record-value"
                                >{streaksHome.cleanSheets}</span
                            >
