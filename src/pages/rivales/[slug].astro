                <section class="top-assisters-card">
                    <h2 class="section-header">MÁS ASISTENTES</h2>
                    <div class="top-list">
                        {
                            topPlayersData.topAssisters.length > 0 ? (
                                topPlayersData.topAssisters.map(
                                    (player: any, index: number) => (
                                        <div class="top-item">
                                            <span class="position">
                                                {index + 1}.
                                            </span>
                                            <span class="player-name">
                                                {player.nombre}
                                            </span>
                                            <span class="stat-value">
                                                {player.asistencias}{" "}
                                                {player.asistencias === 1
                                                    ? "asistencia"
                                                    : "asistencias"}
                                            </span>
                                        </div>
                                    ),
                                )
                            ) : (
                                <p class="no-data">Sin datos disponibles</p>
                            )
                        }
                    </div>
                </section>

                <section class="top-contributors-card">
                    <h2 class="section-header">MÁS GOLES GENERADOS (G+A)</h2>
                    <div class="top-list">
                        {
                            topPlayersData.topContributors.length > 0 ? (
                                topPlayersData.topContributors.map(
                                    (player: any, index: number) => (
                                        <div class="top-item">
                                            <span class="position">
                                                {index + 1}.
                                            </span>
                                            <span class="player-name">
                                                {player.nombre}
                                            </span>
                                            <span class="stat-value">
                                                {player.total} ({player.goles}G
                                                + {player.asistencias}A)
                                            </span>
                                        </div>
                                    ),
                                )
                            ) : (
                                <p class="no-data">Sin datos disponibles</p>
                            )
                        }
                    </div>
                </section>
            </div>
        </div>
    </main>
</Layout>

<script define:vars={{ initialMatches: rivalMatches }}>
    // Helper to determine season from date
    function getSeason(dateStr) {
        const d = new Date(dateStr);
        const year = d.getFullYear();
        const month = d.getMonth() + 1;
        const startYear = month >= 8 ? year : year - 1;
        const endYear = startYear + 1;
        return `${startYear}/${endYear.toString().slice(-2)}`;
    }

    // Add season to matches
    const allMatches = initialMatches.map((m) => ({
        ...m,
        season: getSeason(m.fecha),
    }));

    const compFilter = document.getElementById("competition-filter");
    const seasonFilter = document.getElementById("season-filter");
    const locationFilter = document.getElementById("location-filter");

    function calculateStats(matches) {
        const stats = {
            home: {
                pj: 0,
                pg: 0,
                pe: 0,
                pp: 0,
                gf: 0,
                gc: 0,
                cleanSheets: 0,
                conceded: 0,
                yellowCards: 0,
                redCards: 0,
            },
            away: {
                pj: 0,
                pg: 0,
                pe: 0,
                pp: 0,
                gf: 0,
                gc: 0,
                cleanSheets: 0,
                conceded: 0,
                yellowCards: 0,
                redCards: 0,
            },
            total: {
                pj: 0,
                pg: 0,
                pe: 0,
                pp: 0,
                gf: 0,
                gc: 0,
                cleanSheets: 0,
                conceded: 0,
                yellowCards: 0,
                redCards: 0,
            },
        };

        matches.forEach((match) => {
            const golesRM = parseInt(match.golesRM) || 0;
            const golesRival = parseInt(match.golesRival) || 0;
            const isHome = match.esLocal;
            const location = isHome ? stats.home : stats.away;

            location.pj++;
            location.gf += golesRM;
            location.gc += golesRival;

            if (golesRival === 0) {
                location.cleanSheets++;
            } else {
                location.conceded++;
            }

            location.yellowCards += match.amarillas || 0;
            location.redCards += match.rojas || 0;

            if (golesRM > golesRival) location.pg++;
            else if (golesRM === golesRival) location.pe++;
            else location.pp++;
        });

        // Aggregate totals
        stats.total.pj = stats.home.pj + stats.away.pj;
        stats.total.pg = stats.home.pg + stats.away.pg;
        stats.total.pe = stats.home.pe + stats.away.pe;
        stats.total.pp = stats.home.pp + stats.away.pp;
        stats.total.gf = stats.home.gf + stats.away.gf;
        stats.total.gc = stats.home.gc + stats.away.gc;
        stats.total.gc = stats.home.gc + stats.away.gc;
        stats.total.cleanSheets =
            stats.home.cleanSheets + stats.away.cleanSheets;
        stats.total.conceded = stats.home.conceded + stats.away.conceded;
        stats.total.yellowCards =
            stats.home.yellowCards + stats.away.yellowCards;
        stats.total.redCards = stats.home.redCards + stats.away.redCards;

        const addFields = (obj) => ({
            ...obj,
            percPG: obj.pj > 0 ? ((obj.pg / obj.pj) * 100).toFixed(1) : "0.0",
            percPE: obj.pj > 0 ? ((obj.pe / obj.pj) * 100).toFixed(1) : "0.0",
            percPP: obj.pj > 0 ? ((obj.pp / obj.pj) * 100).toFixed(1) : "0.0",
            avg: obj.pj > 0 ? (obj.gf / obj.pj).toFixed(2) : "0.00",
            dif: obj.gf - obj.gc,
        });

        return {
            home: addFields(stats.home),
            away: addFields(stats.away),
            total: addFields(stats.total),
        };
    }

    function updateCharts(stats) {
        const circumference = 220;
        const totalMatches = stats.total.pj;
        const totalGoals = stats.total.gf + stats.total.gc;

        // Updated Arcs
        const winsArc =
            totalMatches > 0
                ? Math.round((stats.total.pg / totalMatches) * circumference)
                : 0;
        const drawsArc =
            totalMatches > 0
                ? Math.round((stats.total.pe / totalMatches) * circumference)
                : 0;
        const lossesArc =
            totalMatches > 0
                ? Math.round((stats.total.pp / totalMatches) * circumference)
                : 0;

        const goalsForArc =
            totalGoals > 0
                ? Math.round((stats.total.gf / totalGoals) * circumference)
                : 0;
        const goalsAgainstArc =
            totalGoals > 0
                ? Math.round((stats.total.gc / totalGoals) * circumference)
                : 0;

        const cleanSheetsArc =
            totalMatches > 0
                ? Math.round(
                      (stats.total.cleanSheets / totalMatches) * circumference,
                  )
                : 0;
        const concededArc =
            totalMatches > 0
                ? Math.round(
                      (stats.total.conceded / totalMatches) * circumference,
                  )
                : 0;

        // Update DOM - Circles
        // Results Chart
        const resultsChart = document.getElementById("results-chart");
        if (resultsChart) {
            const circles = resultsChart.querySelectorAll("circle");
            // 0: wins, 1: draws, 2: losses
            if (circles[0])
                circles[0].setAttribute(
                    "stroke-dasharray",
                    `${winsArc} ${circumference - winsArc}`,
                );
            if (circles[1]) {
                circles[1].setAttribute(
                    "stroke-dasharray",
                    `${drawsArc} ${circumference - drawsArc}`,
                );
                circles[1].setAttribute("stroke-dashoffset", -winsArc);
            }
            if (circles[2]) {
                circles[2].setAttribute(
                    "stroke-dasharray",
                    `${lossesArc} ${circumference - lossesArc}`,
                );
                circles[2].setAttribute(
                    "stroke-dashoffset",
                    -(winsArc + drawsArc),
                );
            }
        }

        // Goals Chart
        const goalsChart = document.getElementById("goals-chart");
        if (goalsChart) {
            const circles = goalsChart.querySelectorAll("circle");
            // 0: for, 1: against
            if (circles[0])
                circles[0].setAttribute(
                    "stroke-dasharray",
                    `${goalsForArc} ${circumference - goalsForArc}`,
                );
            if (circles[1]) {
                circles[1].setAttribute(
                    "stroke-dasharray",
                    `${goalsAgainstArc} ${circumference - goalsAgainstArc}`,
                );
                circles[1].setAttribute("stroke-dashoffset", -goalsForArc);
            }
        }

        // Clean Sheets Chart
        const cleanSheetsChart = document.getElementById("clean-sheets-chart");
        if (cleanSheetsChart) {
            const circles = cleanSheetsChart.querySelectorAll("circle");
            // 0: clean sheets, 1: conceded
            if (circles[0])
                circles[0].setAttribute(
                    "stroke-dasharray",
                    `${cleanSheetsArc} ${circumference - cleanSheetsArc}`,
                );
            if (circles[1]) {
                circles[1].setAttribute(
                    "stroke-dasharray",
                    `${concededArc} ${circumference - concededArc}`,
                );
                circles[1].setAttribute("stroke-dashoffset", -cleanSheetsArc);
            }
        }

        // Update Legends
        const resultsLegend = document.getElementById("results-legend");
        if (resultsLegend) {
            const divs = resultsLegend.querySelectorAll("div");
            if (divs[0])
                divs[0].innerHTML = `<span class="dot green"></span> Ganados (${stats.total.pg})`;
            if (divs[1])
                divs[1].innerHTML = `<span class="dot orange"></span> Empatados (${stats.total.pe})`;
            if (divs[2])
                divs[2].innerHTML = `<span class="dot red"></span> Perdidos (${stats.total.pp})`;
        }

        const goalsLegend = document.getElementById("goals-legend");
        if (goalsLegend) {
            const divs = goalsLegend.querySelectorAll("div");
            if (divs[0])
                divs[0].innerHTML = `<span class="dot green"></span> A favor (${stats.total.gf})`;
            if (divs[1])
                divs[1].innerHTML = `<span class="dot red"></span> En contra (${stats.total.gc})`;
        }

        const cleanSheetsLegend = document.getElementById(
            "clean-sheets-legend",
        );
        if (cleanSheetsLegend) {
            const divs = cleanSheetsLegend.querySelectorAll("div");
            if (divs[0])
                divs[0].innerHTML = `<span class="dot green"></span> P. a cero (${stats.total.cleanSheets})`;
            if (divs[1])
                divs[1].innerHTML = `<span class="dot red"></span> Con gol (${stats.total.conceded})`;
        }

        // Cards Chart Logic
        const totalCards =
            (stats.total.yellowCards || 0) + (stats.total.redCards || 0);
        const yellowCardsArc =
            totalCards > 0
                ? Math.round(
                      (stats.total.yellowCards / totalCards) * circumference,
                  )
                : 0;
        const redCardsArc =
            totalCards > 0
                ? Math.round(
                      (stats.total.redCards / totalCards) * circumference,
                  )
                : 0;

        const cardsChart = document.getElementById("cards-chart");
        if (cardsChart) {
            const circles = cardsChart.querySelectorAll("circle");
            // 0: yellow, 1: red
            if (circles[0])
                circles[0].setAttribute(
                    "stroke-dasharray",
                    `${yellowCardsArc} ${circumference - yellowCardsArc}`,
                );
            if (circles[1]) {
                circles[1].setAttribute(
                    "stroke-dasharray",
                    `${redCardsArc} ${circumference - redCardsArc}`,
                );
                circles[1].setAttribute("stroke-dashoffset", -yellowCardsArc);
            }
        }

        const cardsLegend = document.getElementById("cards-legend");
        if (cardsLegend) {
            const divs = cardsLegend.querySelectorAll("div");
            if (divs[0])
                divs[0].innerHTML = `<span class="dot yellow"></span> Amarillas (${stats.total.yellowCards})`;
            if (divs[1])
                divs[1].innerHTML = `<span class="dot red"></span> Rojas (${stats.total.redCards})`;
        }
    }

    function updateTable(stats) {
        const table = document.querySelector(".stats-table tbody");
        if (!table) return;

        // Helper to generate row HTML
        const getRowHtml = (label, data) => `
                <td>${label}</td>
                <td>${data.pj}</td>
                <td>${data.pg}</td>
                <td>${data.percPG}%</td>
                <td>${data.pe}</td>
                <td>${data.percPE}%</td>
                <td>${data.pp}</td>
                <td>${data.percPP}%</td>
                <td class="highlight-yellow">${data.gf}</td>
                <td class="highlight-red">${data.gc}</td>
                <td class="highlight-blue">${data.dif > 0 ? "+" : ""}${data.dif}</td>
                <td>${data.avg}</td>
                <td>${data.dif}</td>
            `;

        table.innerHTML = `
                <tr>${getRowHtml("LOCAL", stats.home)}</tr>
                <tr>${getRowHtml("VISITANTE", stats.away)}</tr>
                <tr class="total-row">${getRowHtml("<strong>TOTAL</strong>", stats.total)}</tr>
            `;
    }

    function updateUI() {
        const selectedComp = compFilter.value;
        const selectedSeason = seasonFilter.value;
        const selectedLocation = locationFilter.value;

        const filteredMatches = allMatches.filter((m) => {
            let compMatch = false;
            if (selectedComp === "all") {
                compMatch = true;
            } else if (selectedComp === "oficiales") {
                const officialComps = [
                    "Liga F",
                    "UWCL",
                    "Copa de la Reina",
                    "Supercopa",
                    "Supercopa de España",
                ];
                compMatch = officialComps.some((c) =>
                    m.competicion.includes(c),
                );
            } else {
                compMatch = m.competicion === selectedComp;
            }

            const seasonMatch =
                selectedSeason === "all" || m.season === selectedSeason;

            let locationMatch = true;
            if (selectedLocation === "local") {
                locationMatch = m.esLocal === true;
            } else if (selectedLocation === "visitor") {
                locationMatch = m.esLocal === false;
            }

            return compMatch && seasonMatch && locationMatch;
        });

        const newStats = calculateStats(filteredMatches);
        updateCharts(newStats);
        updateTable(newStats);
    }

    if (compFilter) compFilter.addEventListener("change", updateUI);
    if (seasonFilter) seasonFilter.addEventListener("change", updateUI);
    if (locationFilter) locationFilter.addEventListener("change", updateUI);

    const showMoreBtn = document.getElementById("show-more-matches");
    if (showMoreBtn) {
        showMoreBtn.addEventListener("click", () => {
            const hiddenMatches = document.querySelectorAll(".hidden-match");
            hiddenMatches.forEach((row) => {
                row.classList.remove("hidden-match");
                // Animate entry if desired, or just show
                row.style.display = "table-row";
            });
            showMoreBtn.parentElement.style.display = "none";
        });
    }
</script>

