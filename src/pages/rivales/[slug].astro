---
import Layout from "../../layouts/Layout.astro";
import { fetchRivalsDirectly, slugify } from "../../utils/rivales";
import {
    fetchRivalRecords,
    fetchRivalTopPlayers,
    fetchRivalMatches,
    calculateRivalStats,
    calculateStreaks,
} from "../../utils/rival-records";
import type { ImageMetadata } from "astro";

const { slug } = Astro.params;

const allRivals = await fetchRivalsDirectly();
let rival = allRivals.find((r) => r.slug === slug);

if (!rival) {
    if (slug === "cacereno") {
        rival = allRivals.find(
            (r) =>
                r.slug.includes("cacereno") ||
                r.nombre.toLowerCase().includes("cacereño"),
        );
    } else if (slug === "ffc-turbine-potsdam") {
        rival = allRivals.find(
            (r) =>
                r.nombre.toLowerCase().includes("turbine") &&
                r.nombre.toLowerCase().includes("potsdam"),
        );
    } else {
        rival = allRivals.find(
            (r) => r.slug.includes(slug!) || (slug && slug.includes(r.slug)),
        );
    }
}

if (!rival) {
    return Astro.redirect("/404");
}

let shieldImage: ImageMetadata | undefined;
try {
    const images = import.meta.glob<{ default: ImageMetadata }>(
        "../../assets/escudos/*.png",
    );
    let fileSlug = rival.slug.replace(/-/g, "_");

    const normalizeName = (name: string) =>
        name
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "");
    const nameNorm = normalizeName(rival.nombre);

    if (nameNorm.includes("cacereno")) {
        fileSlug = "cacereno";
    } else if (nameNorm.includes("turbine") && nameNorm.includes("potsdam")) {
        fileSlug = "ffc_turbine_potsdam";
    } else if (
        nameNorm.includes("wolfsburgo") ||
        nameNorm.includes("wolfsburg")
    ) {
        fileSlug = "wolfsburgo";
    }

    const imagePath = `../../assets/escudos/${fileSlug}.png`;

    if (images[imagePath]) {
        shieldImage = (await images[imagePath]()).default;
    } else {
        // console.log("Shield not found");
    }
} catch (error) {
    // console.error(`Error loading shield for ${rival.nombre}:`, error);
}

let flagImage: ImageMetadata | undefined;
try {
    const flags = import.meta.glob<{ default: ImageMetadata }>(
        "/src/assets/banderas/*.svg",
    );
    const flagSlug = rival.pais
        ?.toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/\s+/g, "_");
    const flagPath = `/src/assets/banderas/${flagSlug}.svg`;

    if (flags[flagPath]) {
        flagImage = (await flags[flagPath]()).default;
    } else {
        // console.log("Flag not found");
    }
} catch (error) {
    // console.error(`Error loading flag for ${rival.pais}:`, error);
}

// Stadium Images Logic
let stadiumImage: ImageMetadata | undefined;
try {
    const stadiumImages = import.meta.glob<{ default: ImageMetadata }>(
        "/src/assets/estadios/*.{png,jpg,jpeg,webp}",
    );
    // Try to find image by stadium name slug
    if (rival.estadio) {
        const stadiumSlug = slugify(rival.estadio).replace(/-/g, "_");
        const stadiumPath = `/src/assets/estadios/${stadiumSlug}.png`;

        // Find the matching key in glob result
        const matchingKey = Object.keys(stadiumImages).find((key) => {
            return key.includes(stadiumSlug);
        });

        if (matchingKey && stadiumImages[matchingKey]) {
            stadiumImage = (await stadiumImages[matchingKey]()).default;
        }
    }
} catch (error) {
    console.error(`Error loading stadium image for ${rival.estadio}:`, error);
}

const rivalRecords = await fetchRivalRecords(rival.id_club);

const topPlayersData = await fetchRivalTopPlayers(rival.id_club);

const rivalMatches = await fetchRivalMatches(rival.id_club);

const rivalStats = calculateRivalStats(rivalMatches);

const competitionOrder = [
    "Liga F",
    "UWCL",
    "Copa de la Reina",
    "Supercopa de España",
    "Amistosos",
];
const uniqueCompetitions = [
    ...new Set(rivalMatches.map((m) => m.competicion)),
].filter((c) => c && c !== "-");
const competitions = uniqueCompetitions.sort((a, b) => {
    const indexA = competitionOrder.indexOf(a);
    const indexB = competitionOrder.indexOf(b);
    if (indexA === -1 && indexB === -1) return a.localeCompare(b);
    if (indexA === -1) return 1;
    if (indexB === -1) return -1;
    return indexA - indexB;
});

const getSeason = (dateStr: string) => {
    const d = new Date(dateStr);
    const year = d.getFullYear();
    const month = d.getMonth() + 1;
    const startYear = month >= 8 ? year : year - 1;
    const endYear = startYear + 1;
    return `${startYear}/${endYear.toString().slice(-2)}`;
};

const officialMatches = rivalMatches.filter(
    (m) => m.competicion !== "Amistoso",
);
const homeMatches = officialMatches.filter((m) => m.esLocal);
const awayMatches = officialMatches.filter((m) => !m.esLocal);

const streaksTotal = calculateStreaks(officialMatches);
const streaksHome = calculateStreaks(homeMatches);
const streaksAway = calculateStreaks(awayMatches);

const uniqueSeasons = [
    ...new Set(rivalMatches.map((m) => getSeason(m.fecha))),
].sort((a, b) => b.localeCompare(a));

const circumference = 220;
const totalMatches = rivalStats.total.pj;

const winsArc =
    totalMatches > 0
        ? Math.round((rivalStats.total.pg / totalMatches) * circumference)
        : 0;
const drawsArc =
    totalMatches > 0
        ? Math.round((rivalStats.total.pe / totalMatches) * circumference)
        : 0;
const lossesArc =
    totalMatches > 0
        ? Math.round((rivalStats.total.pp / totalMatches) * circumference)
        : 0;

const totalGoals = rivalStats.total.gf + rivalStats.total.gc;
const goalsForArc =
    totalGoals > 0
        ? Math.round((rivalStats.total.gf / totalGoals) * circumference)
        : 0;
const goalsAgainstArc =
    totalGoals > 0
        ? Math.round((rivalStats.total.gc / totalGoals) * circumference)
        : 0;

const cleanSheetsArc =
    totalMatches > 0
        ? Math.round(
              (rivalStats.total.cleanSheets / totalMatches) * circumference,
          )
        : 0;
const concededArc =
    totalMatches > 0
        ? Math.round((rivalStats.total.conceded / totalMatches) * circumference)
        : 0;

const totalCards =
    (rivalStats.total.yellowCards || 0) + (rivalStats.total.redCards || 0);
const yellowCardsArc =
    totalCards > 0
        ? Math.round(
              (rivalStats.total.yellowCards / totalCards) * circumference,
          )
        : 0;
const redCardsArc =
    totalCards > 0
        ? Math.round((rivalStats.total.redCards / totalCards) * circumference)
        : 0;

const mockPlayers: string[] = [];

const isRealMadrid =
    rival.nombre.toLowerCase().trim().includes("real madrid") ||
    slug === "real-madrid";
---

<Layout
    title={`${rival.nombre} | Madrid Femenino Xtra`}
    description={`Historial completo del Real Madrid Femenino contra ${rival.nombre}. Estadísticas, goleadoras, asistentes y todos los partidos disputados.`}
>
    <main class="rival-details-page">
        <a href={isRealMadrid ? "/" : "/rivales"} class="back-link">
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            {
                isRealMadrid
                    ? "Volver a la página de inicio"
                    : "Volver al resto de rivales"
            }
        </a>

        <div class="rival-grid">
            <div class="left-column">
                <section class="rival-card">
                    <h2 class="section-header">
                        {
                            isRealMadrid
                                ? "FICHA DEL REAL MADRID"
                                : `FICHA DE RIVAL: ${rival.nombre}`
                        }
                    </h2>
                    <div class="rival-info">
                        <div class="rival-shield">
                            {
                                shieldImage ? (
                                    <img
                                        src={shieldImage.src}
                                        alt={`Escudo de ${rival.nombre}`}
                                    />
                                ) : (
                                    <img
                                        src={rival.shieldUrl}
                                        alt={`Escudo de ${rival.nombre}`}
                                        onerror="this.onerror=null; this.src='/assets/escudos/placeholder.png';"
                                    />
                                )
                            }
                        </div>
                        <div class="rival-details">
                            <div class="info-row">
                                <span class="label">Nombre:</span>
                                <span class="value">{rival.nombre}</span>
                            </div>
                            <div class="info-row">
                                <span class="label">Ciudad:</span>
                                <span class="value">{rival.ciudad}</span>
                            </div>
                            <div class="info-row">
                                <span class="label">País:</span>
                                <span class="value">
                                    {rival.pais}
                                    {
                                        flagImage && (
                                            <img
                                                src={flagImage.src}
                                                alt={`Bandera de ${rival.pais}`}
                                                class="country-flag"
                                            />
                                        )
                                    }
                                </span>
                            </div>
                            <div class="info-row">
                                <span class="label">Estadio:</span>
                                <span class="value">{rival.estadio}</span>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="stats-table-card">
                    <h3 class="section-subheader">
                        {
                            isRealMadrid
                                ? "ESTADÍSTICAS DEL REAL MADRID"
                                : `ESTADÍSTICAS CONTRA ${rival.nombre}`
                        }
                    </h3>
                    <div class="table-wrapper">
                        <table class="stats-table">
                            <thead>
                                <tr>
                                    <th>JUGADOS COMO</th>
                                    <th>PJ</th>
                                    <th>PG</th>
                                    <th>%PG</th>
                                    <th>PE</th>
                                    <th>%PE</th>
                                    <th>PP</th>
                                    <th>%PP</th>
                                    <th class="highlight-yellow">⚽</th>
                                    <th class="highlight-red">⚽</th>
                                    <th class="highlight-blue">📊</th>
                                    <th>Avg.</th>
                                    <th>Dif.</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>LOCAL</td>
                                    <td>{rivalStats.home.pj}</td>
                                    <td>{rivalStats.home.pg}</td>
                                    <td>{rivalStats.home.percPG}%</td>
                                    <td>{rivalStats.home.pe}</td>
                                    <td>{rivalStats.home.percPE}%</td>
                                    <td>{rivalStats.home.pp}</td>
                                    <td>{rivalStats.home.percPP}%</td>
                                    <td class="highlight-yellow"
                                        >{rivalStats.home.gf}</td
                                    >
                                    <td class="highlight-red"
                                        >{rivalStats.home.gc}</td
                                    >
                                    <td class="highlight-blue"
                                        >{rivalStats.home.dif > 0 ? "+" : ""}{
                                            rivalStats.home.dif
                                        }</td
                                    >
                                    <td>{rivalStats.home.avg}</td>
                                    <td>{rivalStats.home.dif}</td>
                                </tr>
                                <tr>
                                    <td>VISITANTE</td>
                                    <td>{rivalStats.away.pj}</td>
                                    <td>{rivalStats.away.pg}</td>
                                    <td>{rivalStats.away.percPG}%</td>
                                    <td>{rivalStats.away.pe}</td>
                                    <td>{rivalStats.away.percPE}%</td>
                                    <td>{rivalStats.away.pp}</td>
                                    <td>{rivalStats.away.percPP}%</td>
                                    <td class="highlight-yellow"
                                        >{rivalStats.away.gf}</td
                                    >
                                    <td class="highlight-red"
                                        >{rivalStats.away.gc}</td
                                    >
                                    <td class="highlight-blue"
                                        >{rivalStats.away.dif > 0 ? "+" : ""}{
                                            rivalStats.away.dif
                                        }</td
                                    >
                                    <td>{rivalStats.away.avg}</td>
                                    <td>{rivalStats.away.dif}</td>
                                </tr>

                                <tr class="total-row">
                                    <td><strong>TOTAL</strong></td>
                                    <td>{rivalStats.total.pj}</td>
                                    <td>{rivalStats.total.pg}</td>
                                    <td>{rivalStats.total.percPG}%</td>
                                    <td>{rivalStats.total.pe}</td>
                                    <td>{rivalStats.total.percPE}%</td>
                                    <td>{rivalStats.total.pp}</td>
                                    <td>{rivalStats.total.percPP}%</td>
                                    <td class="highlight-yellow"
                                        >{rivalStats.total.gf}</td
                                    >
                                    <td class="highlight-red"
                                        >{rivalStats.total.gc}</td
                                    >
                                    <td class="highlight-blue"
                                        >{rivalStats.total.dif > 0 ? "+" : ""}{
                                            rivalStats.total.dif
                                        }</td
                                    >
                                    <td>{rivalStats.total.avg}</td>
                                    <td>{rivalStats.total.dif}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </section>

                <section class="charts-card">
                    <h2 class="section-header">GRÁFICAS</h2>
                    <div class="filters-container">
                        <div class="filter-wrapper">
                            <select id="location-filter">
                                <option value="all">Local/Visitante</option>
                                <option value="local">Como Local</option>
                                <option value="visitor">Como Visitante</option>
                            </select>
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="filter-icon"
                                ><path
                                    stroke="none"
                                    d="M0 0h24v24H0z"
                                    fill="none"></path><path d="M6 9l6 6l6 -6"
                                ></path></svg
                            >
                        </div>
                        <div class="filter-wrapper">
                            <select id="competition-filter">
                                <option value="all"
                                    >Todas las Competiciones</option
                                >
                                <option value="oficiales"
                                    >Partidos oficiales</option
                                >
                                {
                                    competitions.map((comp) => (
                                        <option value={comp}>{comp}</option>
                                    ))
                                }
                            </select>
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="filter-icon"
                                ><path
                                    stroke="none"
                                    d="M0 0h24v24H0z"
                                    fill="none"></path><path d="M6 9l6 6l6 -6"
                                ></path></svg
                            >
                        </div>
                        <div class="filter-wrapper">
                            <select id="season-filter">
                                <option value="all">Todas las Temporadas</option
                                >
                                {
                                    uniqueSeasons.map((season) => (
                                        <option value={season}>{season}</option>
                                    ))
                                }
                            </select>
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="filter-icon"
                                ><path
                                    stroke="none"
                                    d="M0 0h24v24H0z"
                                    fill="none"></path><path d="M6 9l6 6l6 -6"
                                ></path></svg
                            >
                        </div>
                    </div>
                    <div class="charts-row">
                        <div class="chart-item">
                            <svg
                                viewBox="0 0 100 100"
                                class="pie-chart"
                                id="results-chart"
                            >
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#c8e6c9"
                                    stroke-width="20"
                                    stroke-dasharray={`${winsArc} ${circumference - winsArc}`}
                                    transform="rotate(-90 50 50)"></circle>
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#fff9c4"
                                    stroke-width="20"
                                    stroke-dasharray={`${drawsArc} ${circumference - drawsArc}`}
                                    stroke-dashoffset={-winsArc}
                                    transform="rotate(-90 50 50)"></circle>
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#ffcdd2"
                                    stroke-width="20"
                                    stroke-dasharray={`${lossesArc} ${circumference - lossesArc}`}
                                    stroke-dashoffset={-(winsArc + drawsArc)}
                                    transform="rotate(-90 50 50)"></circle>
                            </svg>
                            <div class="chart-legend" id="results-legend">
                                <div>
                                    <span class="dot green"></span> Ganados ({
                                        rivalStats.total.pg
                                    })
                                </div>
                                <div>
                                    <span class="dot orange"></span> Empatados ({
                                        rivalStats.total.pe
                                    })
                                </div>
                                <div>
                                    <span class="dot red"></span> Perdidos ({
                                        rivalStats.total.pp
                                    })
                                </div>
                            </div>
                        </div>
                        <div class="chart-item">
                            <svg
                                viewBox="0 0 100 100"
                                class="pie-chart"
                                id="goals-chart"
                            >
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#c8e6c9"
                                    stroke-width="20"
                                    stroke-dasharray={`${goalsForArc} ${circumference - goalsForArc}`}
                                    transform="rotate(-90 50 50)"></circle>
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#ffcdd2"
                                    stroke-width="20"
                                    stroke-dasharray={`${goalsAgainstArc} ${circumference - goalsAgainstArc}`}
                                    stroke-dashoffset={-goalsForArc}
                                    transform="rotate(-90 50 50)"></circle>
                            </svg>
                            <div class="chart-legend" id="goals-legend">
                                <div>
                                    <span class="dot green"></span> A favor ({
                                        rivalStats.total.gf
                                    })
                                </div>
                                <div>
                                    <span class="dot red"></span> En contra ({
                                        rivalStats.total.gc
                                    })
                                </div>
                            </div>
                        </div>

                        <div class="chart-item">
                            <svg
                                viewBox="0 0 100 100"
                                class="pie-chart"
                                id="clean-sheets-chart"
                            >
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#c8e6c9"
                                    stroke-width="20"
                                    stroke-dasharray={`${cleanSheetsArc} ${circumference - cleanSheetsArc}`}
                                    transform="rotate(-90 50 50)"></circle>
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#ffcdd2"
                                    stroke-width="20"
                                    stroke-dasharray={`${concededArc} ${circumference - concededArc}`}
                                    stroke-dashoffset={-cleanSheetsArc}
                                    transform="rotate(-90 50 50)"></circle>
                            </svg>
                            <div class="chart-legend" id="clean-sheets-legend">
                                <div>
                                    <span class="dot green"></span> P. a cero ({
                                        rivalStats.total.cleanSheets
                                    })
                                </div>
                                <div>
                                    <span class="dot red"></span> Con gol ({
                                        rivalStats.total.conceded
                                    })
                                </div>
                            </div>
                        </div>

                        <div class="chart-item">
                            <svg
                                viewBox="0 0 100 100"
                                class="pie-chart"
                                id="cards-chart"
                            >
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#fff9c4"
                                    stroke-width="20"
                                    stroke-dasharray={`${yellowCardsArc} ${circumference - yellowCardsArc}`}
                                    transform="rotate(-90 50 50)"></circle>
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#ffcdd2"
                                    stroke-width="20"
                                    stroke-dasharray={`${redCardsArc} ${circumference - redCardsArc}`}
                                    stroke-dashoffset={-yellowCardsArc}
                                    transform="rotate(-90 50 50)"></circle>
                            </svg>
                            <div class="chart-legend" id="cards-legend">
                                <div>
                                    <span class="dot yellow"></span> Amarillas ({
                                        rivalStats.total.yellowCards
                                    })
                                </div>
                                <div>
                                    <span class="dot red"></span> Rojas ({
                                        rivalStats.total.redCards
                                    })
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="matches-card">
                    <h3 class="section-subheader">
                        {
                            isRealMadrid
                                ? "TODOS LOS PARTIDOS DISPUTADOS POR EL REAL MADRID"
                                : `TODOS LOS PARTIDOS DISPUTADOS CONTRA ${rival.nombre}`
                        }
                    </h3>
                    <div class="table-wrapper">
                        <table class="matches-table">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Competición</th>
                                    <th>En</th>
                                    <th>Res.</th>
                                    <th>Árbitra</th>
                                    <th>Estadio</th>
                                    <th>Asist.</th>
                                </tr>
                            </thead>
                            <tbody>
                                {
                                    rivalMatches.length > 0 ? (
                                        rivalMatches.map(
                                            (match: any, index: number) => {
                                                const golesRM =
                                                    parseInt(match.golesRM) ||
                                                    0;
                                                const golesRival =
                                                    parseInt(
                                                        match.golesRival,
                                                    ) || 0;
                                                let resultClass = "";
                                                if (golesRM > golesRival) {
                                                    resultClass =
                                                        "resultado-victoria";
                                                } else if (
                                                    golesRM === golesRival
                                                ) {
                                                    resultClass =
                                                        "resultado-empate";
                                                } else {
                                                    resultClass =
                                                        "resultado-derrota";
                                                }

                                                return (
                                                    <tr
                                                        class={`match-row ${index >= 5 ? "hidden-match" : ""}`}
                                                    >
                                                        <td>
                                                            {new Date(
                                                                match.fecha,
                                                            ).toLocaleDateString(
                                                                "es-ES",
                                                            )}
                                                        </td>
                                                        <td>
                                                            {match.competicion}
                                                        </td>
                                                        <td>
                                                            {match.ubicacion}
                                                        </td>
                                                        <td class={resultClass}>
                                                            {match.resultado}
                                                        </td>
                                                        <td>{match.arbitra}</td>
                                                        <td>{match.estadio}</td>
                                                        <td>
                                                            {match.asistencia ||
                                                                "-"}
                                                        </td>
                                                    </tr>
                                                );
                                            },
                                        )
                                    ) : (
                                        <tr>
                                            <td
                                                colspan="7"
                                                style="text-align: center; padding: 2rem;"
                                            >
                                                No hay partidos registrados
                                            </td>
                                        </tr>
                                    )
                                }
                            </tbody>
                        </table>
                    </div>
                    {
                        rivalMatches.length > 5 && (
                            <div class="matches-footer">
                                <button id="show-more-matches" class="btn-more">
                                    Ver todos los partidos (
                                    {rivalMatches.length})
                                </button>
                            </div>
                        )
                    }
                </section>
            </div>

