                                                {player.goles}{" "}
                                                {player.goles === 1
                                                    ? "gol"
                                                    : "goles"}
                                            </span>
                                        </div>
                                    ),
                                )
                            ) : (
                                <p class="no-data">Sin datos disponibles</p>
                            )
                        }
