---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import { fetchAllStadiumsWithStats } from "../../utils/estadios";
import StadiumsTable from "../../components/StadiumsTable";

const stadiums = await fetchAllStadiumsWithStats();
---

<Layout
    title="Estadios | Madrid Femenino Xtra"
    description="Descubre todos los estadios donde ha jugado el Real Madrid Femenino: datos históricos, ubicación y estadísticas en cada campo."
>
    <main class="max-w-[1700px] mx-auto px-6 md:px-0 py-10">
        <header class="page-header-container">
            <h1 class="landing-title">ESTADIOS</h1>
            <p class="landing-subtitle">Estadísticas detalladas de los campos de fútbol donde ha jugado el Real Madrid Femenino</p>
        </header>

        <StadiumsTable client:load stadiums={stadiums} />
    </main>
</Layout>


