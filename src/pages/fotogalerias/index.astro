---
import Layout from "../../layouts/Layout.astro";
import GalleryArchive from "../../components/GalleryArchive";
import { contentfulClient } from "../../lib/contentful";
import "../../styles/global.css";

export const prerender = false;

let albums: any[] = [];
try {
    const entries = await contentfulClient.getEntries({
        content_type: "gallery",
        order: ["-sys.createdAt"],
    });

    albums = entries.items.map((item: any) => {
        const f = item.fields as any;

        const getV = (label: string) => {
            const search = label.toLowerCase().replace(/\s/g, "");
            const key = Object.keys(f).find((k) => k.toLowerCase() === search);
            return key ? f[key] : null;
        };

        const title = getV("title") || getV("titulo") || "Sin Título";
        const subtitle = getV("competition") || getV("competicion") || "";
        const slug = getV("slug") || "";
        const dateRaw = getV("date") || getV("fecha");
        const total = getV("totalphotos") || getV("totalFotos") || 0;
        const cover =
            getV("portrait") || getV("imagenDePortada") || getV("cover");
        const folder = getV("route") || getV("rutaDeCarpetas") || "";

        return {
            id: item.sys.id,
            slug: slug,
            title: title,
            subtitle: subtitle,
            date: dateRaw
                ? new Date(dateRaw)
                      .toLocaleDateString("es-ES", {
                          day: "2-digit",
                          month: "long",
                          year: "numeric",
                      })
                      .toUpperCase()
                : "SIN FECHA",
            cover: cover?.fields?.file?.url
                ? `https:${cover.fields.file.url}`
                : folder
                  ? `https://media.madridfemeninoxtra.com/galerias/${folder}/${folder}1.webp`
                  : "/assets/background/stadium.webp",
            count: Number(total),
        };
    });
} catch (e) {
    console.error("Error fetching galleries:", e);
}

const title = "Galería | Madrid Femenino Xtra";
const description =
    "Explora las mejores imágenes del Real Madrid Femenino: partidos, entrenamientos y momentos exclusivos.";
---

<Layout title={title} description={description}>
    <main class="gallery-archive-page">
        <header class="page-header-container">
            <h1 class="landing-title">FOTOGALERÍAS</h1>
            <p class="landing-subtitle">
                Los mejores momentos del Real Madrid Femenino capturados desde
                el césped
            </p>
        </header>

        <section class="gallery-grid-section">
            <div class="container">
                <GalleryArchive initialAlbums={albums} client:load />
            </div>
        </section>
    </main>
</Layout>

<style>
    .gallery-archive-page {
        background-color: #fdfdfd;
        min-height: 100vh;
        padding-bottom: 5rem;
    }

    .container {
        max-width: 1240px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    .gallery-grid-section {
        margin-top: 2rem;
    }

    @media (max-width: 768px) {
        .gallery-archive-page {
            padding-top: 1rem;
        }
        .container {
            padding: 0 1.5rem;
        }
    }
</style>
