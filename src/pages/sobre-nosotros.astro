---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import "../styles/global.css";
import "../styles/sobre-nosotros.css";
import { getAssetMetadata, getAssetUrl } from "../utils/assets";

const fotoPerfil = getAssetMetadata("galeria", "foto-perfil");
const albertoProject = getAssetMetadata("galeria", "foto-presentacion");

const gallery = [
  { src: getAssetMetadata("galeria", "foto-1"), alt: "Estadio San Mamés" },
  { src: getAssetMetadata("galeria", "foto-2"), alt: "Final de la Copa" },
  { src: getAssetMetadata("galeria", "foto-3"), alt: "En el Bernabéu" },
  { src: getAssetMetadata("galeria", "foto-4"), alt: "Foto con jugadora" },
  { src: getAssetMetadata("galeria", "foto-5"), alt: "Otra foto con jugadora" },
  { src: getAssetMetadata("galeria", "foto-6"), alt: "Celebración título" },
  { src: getAssetMetadata("galeria", "foto-7"), alt: "Camp Nou" },
  { src: getAssetMetadata("galeria", "foto-8"), alt: "Galería 8" },
  { src: getAssetMetadata("galeria", "foto-9"), alt: "Galería 9" },
  { src: getAssetMetadata("galeria", "foto-10"), alt: "Galería 10" },
  { src: getAssetMetadata("galeria", "foto-11"), alt: "Galería 11" },
  { src: getAssetMetadata("galeria", "foto-12"), alt: "Galería 12" },
  { src: getAssetMetadata("galeria", "foto-13"), alt: "Galería 13" },
  { src: getAssetMetadata("galeria", "foto-14"), alt: "Galería 14" },
  { src: getAssetMetadata("galeria", "foto-15"), alt: "Galería 15" },
  { src: getAssetMetadata("galeria", "foto-16"), alt: "Galería 16" },
  { src: getAssetMetadata("galeria", "foto-17"), alt: "Galería 17" },
  { src: getAssetMetadata("galeria", "foto-18"), alt: "Galería 18" },
  {
    src: getAssetMetadata("galeria", "foto-19"),
    alt: "Galería 19",
    class: "vertical",
  },
  {
    src: getAssetMetadata("galeria", "foto-20"),
    alt: "Galería 20",
    class: "vertical",
  },
];
---

<Layout
  title="Sobre Nosotros | Madrid Femenino Xtra"
  description="Conoce al equipo de redacción de Madrid Femenino Xtra. La mejor cobertura sobre la actualidad del Real Madrid Femenino. ¡Síguenos y no te pierdas nada!"
>
  <div class="page">
    <div class="sobre-nosotros-container">
      <section class="proyecto-section">
        <h2 class="page-title">EL PROYECTO</h2>
        <div class="proyecto-content-wrapper">
          <div class="content p project-text">
            <p>
              Madrid Femenino Xtra nace en septiembre de 2023 ante la necesidad
              de ofrecer una cobertura exclusiva y profesional del día a día del
              Real Madrid. Nuestro objetivo es ser la referencia para todos los
              aficionados que busca seguir de cerca la actualidad, noticias y
              estadísticas de la sección femenina del club.
            </p>
            <p>
              El proyecto comenzó en redes sociales, concretamente en X, y a lo
              largo de su corta pero intensa existencia se expandió a Instagram,
              TikTok y YouTube. En diciembre de 2025 dio el siguiente paso
              lanzando su propia página web: un proyecto sin ánimo de luccro con
              el objetivo de construir la mayor base de datos histórica del Real
              Madrid Femenino, con datos y estadísticas de todas las jugadoras,
              entrenadores, partidos, rivales, estadios, árbitras y rankings,
              con gráficos interactivos, desde su fundación.
            </p>
            <p>
              Actualmente, cuenta con más de 11.000 seguidores entre todas las
              redes sociales. En X es donde más volumen tiene con más de 7.500
              seguidores, seguido por YouTube con más de 2.800 suscriptores,
              manteniendo un gran ritmo de crecimiento desde septiembre de 2025.
              Todo esto no sería posible sin la comunidad, que a lo largo de los
              meses es cada vez más grande y activa, empujándonos a mejorar cada
              día.
            </p>
            <p>
              La estructura, organización y compilación de la presente base de
              datos están inscritas en el
              <a
                href="https://www.comunidad.madrid/inversion/inicia-desarrolla-tu-empresa/registro-territorial-propiedad-intelectual"
                target="_blank"
                rel="noopener noreferrer"
              >
                Registro Territorial de la Propiedad Intelectual
              </a>
              con el número de solicitud <strong>09/448957.9/26</strong>. De
              acuerdo con el <strong>Derecho Sui Generis</strong>
              reconocido por la Ley de Propiedad Intelectual, Madrid Femenino Xtra
              prohíbe la extracción o reutilización de una parte sustancial de su
              contenido. El autor declara haber realizado una inversión sustancial
              de <strong>500 horas</strong> de investigación y verificación manual
              para la creación de esta arquitectura. Cualquier uso de estos datos
              debe ser autorizado previamente por escrito por el titular: <strong
                >Alberto Arregui Jiménez</strong
              >.
            </p>
          </div>
          <div class="project-image">
            <Image
              src={albertoProject as any}
              alt="Alberto en Venecia"
              width={600}
              height={400}
              format="webp"
            />
          </div>
        </div>
      </section>

      <hr class="section-separator" />

      <section class="equipo-section">
        <h2 class="page-title">EQUIPO</h2>
        <div class="equipo-grid">
          <div class="team-card">
            <Image
              src={fotoPerfil as any}
              alt="Alberto Arregui"
              class="team-avatar"
              width={200}
              height={200}
              format="webp"
            />
            <h3 class="team-name">Alberto Arregui</h3>
            <p class="team-role">Founder</p>
            <div class="team-social">
              <a
                href="https://x.com/madridfemxtra"
                target="_blank"
                rel="noopener noreferrer"
              >
                <img
                  src={getAssetUrl("redes", "x")}
                  alt="X"
                  width="24"
                  height="24"
                />
              </a>
              <a
                href="https://instagram.com/madridfemxtra"
                target="_blank"
                rel="noopener noreferrer"
              >
                <img
                  src={getAssetUrl("redes", "instagram")}
                  alt="Instagram"
                  width="24"
                  height="24"
                />
              </a>
              <a
                href="https://tiktok.com/@madridfemeninoxtra"
                target="_blank"
                rel="noopener noreferrer"
              >
                <img
                  src={getAssetUrl("redes", "tiktok")}
                  alt="TikTok"
                  width="24"
                  height="24"
                />
              </a>
              <a
                href="https://www.youtube.com/@albertxx98rmcf"
                target="_blank"
                rel="noopener noreferrer"
              >
                <img
                  src={getAssetUrl("redes", "youtube")}
                  alt="YouTube"
                  width="24"
                  height="24"
                />
              </a>
              <a
                href="https://www.linkedin.com/in/alberto-arregui/"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="icon icon-tabler icons-tabler-outline icon-tabler-brand-linkedin"
                >
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                  <path d="M8 11v5"></path>
                  <path d="M8 8v.01"></path>
                  <path d="M12 16v-5"></path>
                  <path d="M16 16v-3a2 2 0 1 0 -4 0"></path>
                  <path
                    d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4l0 -10"
                  ></path>
                </svg>
              </a>
            </div>
            <p class="team-bio">
              Creador y director de Madrid Femenino Xtra. Siguiendo al Real
              Madrid femenino desde 2019.
            </p>
          </div>
        </div>
      </section>

      <section class="galeria-section">
        <div class="galeria-grid" id="gallery-grid">
          {
            gallery.map((img, index) => (
              <div class={`galeria-item ${img.class || ""}`} data-index={index}>
                <Image
                  src={img.src as any}
                  alt={img.alt}
                  width={img.class === "vertical" ? 400 : 600}
                  height={img.class === "vertical" ? 600 : 400}
                  format="webp"
                  loading="lazy"
                />
              </div>
            ))
          }
        </div>
      </section>
    </div>
  </div>

  <div id="lightbox" class="lightbox">
    <button class="lightbox-close">&times;</button>
    <button class="lightbox-prev">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="icon icon-tabler icons-tabler-outline icon-tabler-chevron-left"
        ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
          d="M15 6l-6 6l6 6"></path></svg
      >
    </button>
    <div class="lightbox-content">
      <img src="" alt="" class="lightbox-image" />
    </div>
    <button class="lightbox-next">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="icon icon-tabler icons-tabler-outline icon-tabler-chevron-right"
        ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
          d="M9 6l6 6l-6 6"></path></svg
      >
    </button>
  </div>

  <script
    define:vars={{
      galleryImages: gallery.map((img) => img.src?.src),
    }}
  >
    const lightbox = document.getElementById("lightbox");
    const lightboxImg = lightbox.querySelector(".lightbox-image");
    const closeBtn = lightbox.querySelector(".lightbox-close");
    const prevBtn = lightbox.querySelector(".lightbox-prev");
    const nextBtn = lightbox.querySelector(".lightbox-next");
    const items = document.querySelectorAll(".galeria-item");

    let currentIndex = 0;

    function openLightbox(index) {
      currentIndex = index;
      lightboxImg.src = galleryImages[currentIndex];
      lightbox.classList.add("active");
      document.body.style.overflow = "hidden";
    }

    function closeLightbox() {
      lightbox.classList.remove("active");
      document.body.style.overflow = "";
    }

    function showNext() {
      currentIndex = (currentIndex + 1) % galleryImages.length;
      lightboxImg.src = galleryImages[currentIndex];
    }

    function showPrev() {
      currentIndex =
        (currentIndex - 1 + galleryImages.length) % galleryImages.length;
      lightboxImg.src = galleryImages[currentIndex];
    }

    items.forEach((item, index) => {
      item.addEventListener("click", () => openLightbox(index));
    });

    closeBtn.addEventListener("click", closeLightbox);
    nextBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      showNext();
    });
    prevBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      showPrev();
    });

    lightbox.addEventListener("click", (e) => {
      if (
        e.target === lightbox ||
        e.target.classList.contains("lightbox-content")
      ) {
        closeLightbox();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (!lightbox.classList.contains("active")) return;
      if (e.key === "Escape") closeLightbox();
      if (e.key === "ArrowRight") showNext();
      if (e.key === "ArrowLeft") showPrev();
    });

    const observerOptions = {
      root: null,
      rootMargin: "0px",
      threshold: 0.1,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    items.forEach((item) => {
      observer.observe(item);
    });
  </script>
</Layout>


