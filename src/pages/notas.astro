import Layout from "../layouts/Layout.astro";
import { turso } from "../lib/turso";
import { CALENDAR } from "../consts/calendar";
import { SQUAD } from "../../public/consts/squad";
import { SignInButton, SignedIn, SignedOut, UserButton } from "@clerk/astro/components";
import type { ImageMetadata } from 'astro';

// Import assets
const playerImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/jugadoras/*.{png,jpg,jpeg,webp}');
const teamShields = import.meta.glob<{ default: ImageMetadata }>('/src/assets/escudos/*.{png,jpg,jpeg,webp}');
const competitionLogos = import.meta.glob<{ default: ImageMetadata }>('/src/assets/competiciones/*.{png,jpg,jpeg,webp}');

// Helpers
async function getPlayerImage(id: string) {
    const path = `/src/assets/jugadoras/${id}.png`;
    const imageLoader = playerImages[path];
    if (imageLoader) {
        const mod = await imageLoader();
        return mod.default.src;
    }
    return '/assets/img/default-player.png';
}

const getShield = async (teamName: string) => {
    const slug = teamName.toLowerCase().replace(/ /g, '_').normalize("NFD").replace(/[\u0300-\u036f]/g, "");
    
    let path = `/src/assets/escudos/${slug}.png`;
    let loader = teamShields[path];
    if (loader) return (await loader()).default.src;
    
    path = `/src/assets/escudos/${slug.replace(/_/g, '-')}.png`;
    loader = teamShields[path];
    if (loader) return (await loader()).default.src;
    
    if (slug.includes('madrid')) return '/assets/escudos/real_madrid.png'; 
    return '';
};

const getCompetitionLogo = async (compName: string) => {
    const slug = compName.toLowerCase().replace(/ /g, '_').normalize("NFD").replace(/[\u0300-\u036f]/g, "");
    let path = `/src/assets/competiciones/${slug}.png`;
    if (slug.includes('liga')) path = '/src/assets/competiciones/liga_f.png';
    else if (slug.includes('uwcl') || slug.includes('champions')) path = '/src/assets/competiciones/uwcl.png';
    else if (slug.includes('copa')) path = '/src/assets/competiciones/copa_de_la_reina.png';
    else if (slug.includes('supercopa')) path = '/src/assets/competiciones/supercopa_de_espana.png';

    const loader = competitionLogos[path];
    if (loader) return (await loader()).default.src;
    return '';
};

// 1. Find Last Played Match
const now = new Date();
const pastMatches = CALENDAR.filter((m) => new Date(m.date) < now);
const lastMatch = pastMatches.length > 0 ? pastMatches[pastMatches.length - 1] : null;

// Prepare match assets
const homeShield = lastMatch ? await getShield(lastMatch.team1) : '';
const awayShield = lastMatch ? await getShield(lastMatch.team2) : '';
const compLogo = lastMatch ? await getCompetitionLogo(lastMatch.competition) : '';

// 2. Fetch User's Previous Votes (if any)
const { userId } = Astro.locals.auth();
let existingRatings: Record<string, number> = {};
let existingMVP: string | null = null;
const squad: any[] = SQUAD;

if (userId && lastMatch) {
    try {
        // Fetch Ratings
        const ratingsResult = await turso.execute({
            sql: "SELECT player_id, rating FROM ratings WHERE user_id = ? AND match_id = ?",
            args: [userId, lastMatch.id],
        });
        ratingsResult.rows.forEach((row: any) => {
            existingRatings[row.player_id] = row.rating;
        });

        // Fetch MVP
        const mvpResult = await turso.execute({
            sql: "SELECT player_id FROM mvp_votes WHERE user_id = ? AND match_id = ?",
            args: [userId, lastMatch.id],
        });
        if (mvpResult.rows.length > 0) {
            existingMVP = mvpResult.rows[0].player_id;
        }

    } catch (e) {
        console.error("Error fetching ratings", e);
    }
}

// Prepare squad details with images
const squadWithImages = await Promise.all(squad.map(async (p) => ({
    ...p,
    image: await getPlayerImage(p.id)
})));
---

<Layout title="Notas y MVP | Madrid Femenino Xtra">
    <div class="notas-page max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <header class="text-center mb-12 max-w-4xl mx-auto">
            <h1 class="page-title" style="color: var(--text-primary);">NOTAS DEL PARTIDO</h1>
            <p class="content-h2 mx-auto" style="text-align: center;">
                Valora el rendimiento de las jugadoras y elige a la MVP del último partido.
            </p>
             <div class="auth-controls mt-6 flex justify-center">
                <SignedOut>
                    <SignInButton mode="modal" as="button" class="header-login-btn">
                        INICIAR SESIÓN
                    </SignInButton>
                </SignedOut>
                <SignedIn>
                    <UserButton />
                </SignedIn>
            </div>
        </header>

        {lastMatch ? (
            <div class="content-container" data-match-id={lastMatch.id}>
                
                <!-- MATCH CARD -->
                <section class="match-card mb-12">
                    <div class="card-title-overlay">ÚLTIMO PARTIDO</div>
                    
                    <div class="match-header">
                        {compLogo ? (
                            <img src={compLogo} alt={lastMatch.competition} class="comp-logo" />
                        ) : (
                            <span class="competition-text">{lastMatch.competition}</span>
                        )}
                        <span class="match-date">{new Date(lastMatch.date).toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' })}</span>
                    </div>

                    <div class="teams-container">
                        <div class="team home">
                            {homeShield && <img src={homeShield} alt={lastMatch.team1} class="team-shield" />}
                            <span class="team-name">{lastMatch.team1}</span>
                        </div>
                        <div class="vs-text">VS</div>
                        <div class="team away">
                            {awayShield && <img src={awayShield} alt={lastMatch.team2} class="team-shield" />}
                            <span class="team-name">{lastMatch.team2}</span>
                        </div>
                    </div>
                </section>

                <form id="ratings-form">
                    
                    <!-- MVP Selection -->
                    <section class="mvp-section mb-12">
                        <div class="section-header-cnt">
                            <h3 class="subsection-title">ELIGE TU MVP</h3>
                        </div>
                        
                        <div class="mvp-grid">
                            {squadWithImages.map(player => (
                                <div 
                                    class={`mvp-chip ${existingMVP === player.id ? 'selected' : ''}`}
                                    data-player-id={player.id}
                                    onclick="selectMvp(this)"
                                    title={player.name}
                                >
                                    <div class="chip-image-container">
                                            <img src={player.image} alt={player.name} class="chip-img" loading="lazy" />
                                    </div>
                                    <div class="chip-info">
                                        <span class="player-num">#{player.number}</span>
                                        <span class="player-name-chip">{player.name}</span>
                                    </div>
                                    <div class="mvp-badge">MVP</div>
                                </div>
                            ))}
                        </div>
                        <input type="hidden" id="mvp-input" value={existingMVP || ''} />
                    </section>
                    
                    <hr class="section-divider" />

                    <!-- Player Ratings -->
                    <section class="ratings-section mt-12">
                         <div class="section-header-cnt">
                            <h3 class="subsection-title">PON NOTA (1-10)</h3>
                        </div>

                        <div class="players-ratings-grid">
                            {squadWithImages.map((player) => (
                                <div class="rating-card">
                                    <div class="rating-player-info">
                                        <div class="rating-img-wrapper">
                                            <img src={player.image} alt={player.name} />
                                        </div>
                                        <div class="rating-text">
                                            <span class="r-number">#{player.number}</span>
                                            <span class="r-name">{player.name}</span>
                                        </div>
                                    </div>
                                    
                                    <div class="rating-control-wrapper">
                                        <button type="button" class="rate-btn minus" onclick={`adjustRating('${player.id}', -1)`}>-</button>
                                        <input 
                                            type="number" 
                                            id={`rating-${player.id}`}
                                            class="rating-input"
                                            value={existingRatings[player.id] || ''} 
                                            placeholder="-"
                                            readonly
                                            data-player-id={player.id}
                                        />
                                        <button type="button" class="rate-btn plus" onclick={`adjustRating('${player.id}', 1)`}>+</button>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </section>

                    <div class="actions mt-12">
                        {!userId ? (
                            <p class="login-prompt">Inicia sesión para enviar tus notas</p>
                        ) : (
                            <button type="submit" id="submit-ratings" class="submit-btn" disabled={!userId}>
                                ENVIAR VALORACIONES
                            </button>
                        )}
                         <p id="form-feedback" class="feedback-msg hidden"></p>
                    </div>
                </form>

            </div>
        ) : (
            <div class="no-match-card">
                <p>No hay partidos recientes para valorar.</p>
            </div>
        )}
    </div>
</Layout>

<script is:inline>
    // Global functions for inline handlers
    function selectMvp(element) {
        // Deselect all others
        document.querySelectorAll('.mvp-chip').forEach(el => el.classList.remove('selected'));
        // Select clicked
        element.classList.add('selected');
        // Update hidden input
        const pid = element.dataset.playerId;
        const input = document.getElementById('mvp-input');
        if(input) input.value = pid;
    }

    function adjustRating(playerId, delta) {
        console.log('Adjusting', playerId, delta);
        const input = document.getElementById(`rating-${playerId}`);
        if (!input) return;

        let val = parseInt(input.value);
        if (isNaN(val)) val = 5; // Default start at 5 if empty? Or maybe 0? Let's say if empty start at 5 for ease
        else val += delta;

        // Bounds 1-10
        if (val < 1) val = 1;
        if (val > 10) val = 10;

        input.value = val;
    }
</script>

<script lang="ts">
    const form = document.getElementById('ratings-form');
    const submitBtn = document.getElementById('submit-ratings');
    const feedbackMsg = document.getElementById('form-feedback');
    const container = document.querySelector('.content-container') as HTMLElement;

    interface RatingSubmission {
        player_id: string | undefined;
        rating: number;
    }

    if (form && submitBtn && container) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const matchId = container.dataset.matchId;
            const mvpInput = document.getElementById('mvp-input') as HTMLInputElement;
            const mvpId = mvpInput ? mvpInput.value : null;
            
            const ratings: RatingSubmission[] = [];
            document.querySelectorAll('.rating-input').forEach((input) => {
                const i = input as HTMLInputElement;
                const val = parseInt(i.value);
                if (!isNaN(val)) {
                    ratings.push({
                        player_id: i.dataset.playerId,
                        rating: val
                    });
                }
            });

            if (ratings.length === 0 && !mvpId) {
                 if(feedbackMsg) {
                    feedbackMsg.textContent = "Por favor, selecciona al menos una nota o MVP.";
                    feedbackMsg.className = "feedback-msg error";
                    feedbackMsg.classList.remove('hidden');
                }
                return;
            }

            submitBtn.textContent = "ENVIANDO...";
            (submitBtn as HTMLButtonElement).disabled = true;

            try {
                const response = await fetch('/api/ratings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        match_id: matchId, 
                        ratings: ratings,
                        mvp_player_id: mvpId || null
                    })
                });

                if (response.ok) {
                    submitBtn.textContent = "¡ENVIADO!";
                    if(feedbackMsg) {
                        feedbackMsg.textContent = "Tus notas han sido registradas.";
                        feedbackMsg.className = "feedback-msg success";
                        feedbackMsg.classList.remove('hidden');
                    }
                    setTimeout(() => {
                        submitBtn.textContent = "ACTUALIZAR NOTAS";
                       (submitBtn as HTMLButtonElement).disabled = false;
                    }, 2000);
                } else {
                    throw new Error("Error en el envío");
                }
            } catch (error) {
                console.error(error);
                submitBtn.textContent = "ERROR";
                (submitBtn as HTMLButtonElement).disabled = false;
                 if(feedbackMsg) {
                    feedbackMsg.textContent = "Error al conectar con el servidor.";
                    feedbackMsg.className = "feedback-msg error";
                    feedbackMsg.classList.remove('hidden');
                }
            }
        });
    }
</script>

