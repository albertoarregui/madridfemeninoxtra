---
import Layout from "../layouts/Layout.astro";
import { turso } from "../lib/turso";
import { CALENDAR } from "../consts/calendar";
import { SQUAD } from "../../public/consts/squad"; // Keep consistency with existing imports
import { SignInButton, SignedIn, SignedOut, UserButton } from "@clerk/astro/components";

// 1. Find Last Played Match
const now = new Date();
const pastMatches = CALENDAR.filter((m) => new Date(m.date) < now);
const lastMatch = pastMatches.length > 0 ? pastMatches[pastMatches.length - 1] : null;

// 2. Fetch User's Previous Votes (if any)
const { userId } = Astro.locals.auth();
let existingRatings: Record<string, number> = {};
let existingMVP = null;

if (userId && lastMatch) {
    try {
        // Fetch Ratings
        const ratingsResult = await turso.execute({
            sql: "SELECT player_id, rating FROM ratings WHERE user_id = ? AND match_id = ?",
            args: [userId, lastMatch.id],
        });
        ratingsResult.rows.forEach((row: any) => {
            existingRatings[row.player_id] = row.rating;
        });

        // Fetch MVP
        const mvpResult = await turso.execute({
            sql: "SELECT player_id FROM mvp_votes WHERE user_id = ? AND match_id = ?",
            args: [userId, lastMatch.id],
        });
        if (mvpResult.rows.length > 0) {
            existingMVP = mvpResult.rows[0].player_id;
        }

    } catch (e) {
        console.error("Error fetching ratings", e);
    }
}
---

<Layout title="Notas y MVP | Madrid Femenino Xtra">
    <div class="notas-page">
        <header class="page-header">
            <h1 class="page-title">NOTAS DEL PARTIDO</h1>
            <p class="page-subtitle">VALORA A LAS JUGADORAS Y ELIGE TU MVP</p>
             <div class="auth-controls">
                <SignedOut>
                    <SignInButton mode="modal" as="button" class="login-btn">
                        INICIAR SESIÓN PARA VOTAR
                    </SignInButton>
                </SignedOut>
                <SignedIn>
                    <UserButton />
                </SignedIn>
            </div>
        </header>

        {lastMatch ? (
            <div class="content-container" data-match-id={lastMatch.id}>
                
                <section class="match-context">
                    <h2 class="section-title">PARTIDO DE LA JORNADA</h2>
                    <div class="match-info">
                        <span class="teams">{lastMatch.team1} vs {lastMatch.team2}</span>
                        <span class="details">{lastMatch.competition} - {lastMatch.date}</span>
                    </div>
                </section>

                <form id="ratings-form">
                    <!-- MVP Selection -->
                    <section class="mvp-section">
                        <h3 class="subsection-title">👑 ELIGE TU MVP</h3>
                        <div class="select-wrapper">
                             <select id="mvp-select" class="mvp-select" disabled={!userId}>
                                <option value="">Selecciona la mejor jugadora...</option>
                                {SQUAD.map((player) => (
                                    <option value={player.id} selected={existingMVP === player.id}>
                                        #{player.number} - {player.name}
                                    </option>
                                ))}
                            </select>
                        </div>
                    </section>

                    <!-- Player Ratings -->
                    <section class="ratings-section">
                        <h3 class="subsection-title">📊 NOTAS (1-10)</h3>
                        <div class="players-grid">
                            {SQUAD.map((player) => (
                                <div class="player-card">
                                    <div class="player-info">
                                        <span class="player-number">#{player.number}</span>
                                        <span class="player-name">{player.name}</span>
                                    </div>
                                    <div class="rating-control">
                                        <input 
                                            type="range" 
                                            min="1" 
                                            max="10" 
                                            value={existingRatings[player.id] || 5} 
                                            class="rating-slider"
                                            id={`rating-${player.id}`}
                                            data-player-id={player.id}
                                            disabled={!userId}
                                            oninput={`document.getElementById('display-${player.id}').textContent = this.value`}
                                        />
                                        <span id={`display-${player.id}`} class="rating-value">
                                            {existingRatings[player.id] || 5}
                                        </span>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </section>

                    <div class="actions">
                        {!userId ? (
                            <p class="login-prompt">Inicia sesión para enviar tus notas</p>
                        ) : (
                            <button type="submit" id="submit-ratings" class="submit-btn" disabled={!userId}>
                                ENVIAR VALORACIONES
                            </button>
                        )}
                         <p id="form-feedback" class="feedback-msg hidden"></p>
                    </div>
                </form>

            </div>
        ) : (
            <div class="no-match">
                <p>No hay partidos recientes para valorar.</p>
            </div>
        )}
    </div>
</Layout>

<script>
    const form = document.getElementById('ratings-form');
    const submitBtn = document.getElementById('submit-ratings');
    const feedbackMsg = document.getElementById('form-feedback');
    const container = document.querySelector('.content-container') as HTMLElement;

    if (form && submitBtn && container) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const matchId = container.dataset.matchId;
            const mvpSelect = document.getElementById('mvp-select') as HTMLSelectElement;
            const mvpId = mvpSelect.value;

            // Collect ratings distinct from default only if acted upon? 
            // Or just submit all. Submitting all is safer to represent user state.
            // But we should filter for sliders that might be untouched if we wanted 'did not play' logic.
            // For simplicity, we submit all 20+ players with default 5? That's bad data.
            // Better: Implicitly, we probably only want to rate players who played.
            // But we don't know who played easily without match stats API.
            // Let's submit ALL for now, or add a checkbox "No jugó".
            // Alternative: Slider 0 = "N/A" or "No jugó". 
            // Simplification for user request "intuitivas y faciles":
            // Let's assume user only moves sliders for players they want to rate.
            // But HTML range input always has a value.
            // Let's send everything for now.
            
            const ratings = [];
            document.querySelectorAll('.rating-slider').forEach((slider) => {
                const input = slider as HTMLInputElement;
                ratings.push({
                    player_id: input.dataset.playerId,
                    rating: parseInt(input.value)
                });
            });

            submitBtn.textContent = "ENVIANDO...";
            (submitBtn as HTMLButtonElement).disabled = true;

            try {
                const response = await fetch('/api/ratings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        match_id: matchId, 
                        ratings: ratings,
                        mvp_player_id: mvpId || null
                    })
                });

                if (response.ok) {
                    submitBtn.textContent = "¡ENVIADO!";
                    submitBtn.style.background = "#2ecc71";
                     if(feedbackMsg) {
                        feedbackMsg.textContent = "Tus notas han sido registradas.";
                        feedbackMsg.classList.remove('hidden', 'error');
                        feedbackMsg.classList.add('success');
                    }
                    setTimeout(() => {
                        submitBtn.textContent = "ACTUALIZAR NOTAS";
                       (submitBtn as HTMLButtonElement).disabled = false;
                       submitBtn.style.background = "";
                    }, 2000);
                } else {
                    throw new Error("Error en el envío");
                }
            } catch (error) {
                console.error(error);
                submitBtn.textContent = "ERROR";
                (submitBtn as HTMLButtonElement).disabled = false;
                 if(feedbackMsg) {
                    feedbackMsg.textContent = "Error al conectar con el servidor.";
                    feedbackMsg.classList.remove('hidden', 'success');
                    feedbackMsg.classList.add('error');
                }
            }
        });
    }
</script>

<style>
    :root {
        --primary: #0a0e27;
        --accent: #ffde59;
        --text: #ffffff;
        --success: #2ecc71;
    }

    .notas-page {
        padding: 2rem 1rem;
        color: var(--text);
        font-family: 'Poppins', sans-serif;
        max-width: 800px;
        margin: 0 auto;
    }

    .page-header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .page-title {
        font-family: 'Archivo Black', sans-serif;
        font-size: 2.5rem;
        color: var(--accent);
        margin: 0;
    }
    
    .page-subtitle {
        color: #a0a0a0;
        font-size: 1rem;
        margin-top: 0.5rem;
        letter-spacing: 1px;
    }

    .login-btn {
        margin-top: 1rem;
        background: var(--accent);
        color: var(--primary);
        border: none;
        padding: 0.5rem 1.5rem;
        font-weight: 700;
        border-radius: 4px;
        cursor: pointer;
    }

    .match-context {
        text-align: center;
        margin-bottom: 2rem;
        padding: 1.5rem;
        background: rgba(255,255,255,0.05);
        border-radius: 8px;
        border: 1px solid rgba(255,222,89,0.2);
    }

    .section-title, .subsection-title {
        color: var(--accent);
        font-weight: 700;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
    }
    
    .match-info {
        font-size: 1.2rem;
        font-weight: 600;
        display: flex;
        flex-direction: column;
    }
    
    .match-info .details {
        font-size: 0.9rem;
        color: #888;
        font-weight: 400;
    }

    .mvp-section {
        margin-bottom: 3rem;
        text-align: center;
    }

    .mvp-select {
        width: 100%;
        max-width: 400px;
        padding: 1rem;
        background: #1a1f3c;
        border: 2px solid #333;
        color: white;
        border-radius: 8px;
        font-size: 1rem;
        cursor: pointer;
    }

    .mvp-select:focus {
        border-color: var(--accent);
        outline: none;
    }

    .ratings-section {
        margin-bottom: 2rem;
    }

    .players-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    }

    .player-card {
        background: #1a1f3c;
        padding: 1rem;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .player-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .player-number {
        color: var(--accent);
        font-weight: 700;
        font-family: 'Archivo Black', sans-serif;
    }

    .rating-control {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex: 1;
        justify-content: flex-end;
    }

    .rating-slider {
        flex: 1;
        max-width: 150px;
        accent-color: var(--accent);
        cursor: pointer;
    }

    .rating-value {
        font-size: 1.2rem;
        font-weight: 700;
        width: 30px;
        text-align: center;
        color: var(--accent);
    }

    .submit-btn {
        width: 100%;
        padding: 1.2rem;
        background: var(--accent);
        color: #000;
        border: none;
        border-radius: 8px;
        font-size: 1.2rem;
        font-weight: 800;
        cursor: pointer;
        text-transform: uppercase;
        transition: transform 0.2s;
        box-shadow: 0 4px 15px rgba(255,222,89,0.3);
    }

    .submit-btn:hover:not(:disabled) {
        transform: translateY(-2px);
    }
    
    .submit-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        box-shadow: none;
        background: #555;
    }
    
    .feedback-msg {
        text-align: center;
        margin-top: 1rem;
    }
    .feedback-msg.success { color: var(--success); }
    .feedback-msg.error { color: #e74c3c; }
    .feedback-msg.hidden { display: none; }
</style>
