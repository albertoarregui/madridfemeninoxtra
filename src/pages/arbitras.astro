---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import { fetchRefereesDirectly } from "../utils/arbitras";
import RefereesTable from "../components/RefereesTable";

const referees = await fetchRefereesDirectly();
---

<Layout
    title="Árbitras del Real Madrid Femenino | Madrid Femenino Xtra"
    description="Estadísticas de todas las árbitras que han dirigido partidos del Real Madrid Femenino: balance de resultados y tarjetas mostradas."
>
    <main class="max-w-[1700px] mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <h1 class="page-title">ÁRBITRAS</h1>

        <h2 class="content-h2 mb-12">
            Estadísticas completas de todas las árbitras que han dirigido
            partidos del Real Madrid Femenino a lo largo de su historia: balance
            de victorias, empates, derrotas y tarjetas mostradas.
        </h2>

        <RefereesTable client:load referees={referees} />
    </main>
</Layout>
