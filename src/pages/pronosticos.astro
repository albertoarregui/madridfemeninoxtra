---
import Layout from "../layouts/Layout.astro";
import { turso } from "../lib/turso";
import { CALENDAR } from "../consts/calendar";
import { SQUAD } from "../../public/consts/squad";
import { SignInButton, SignedIn, SignedOut, UserButton } from "@clerk/astro/components";
import type { ImageMetadata } from 'astro';

// Import all assets
const playerImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/jugadoras/*.{png,jpg,jpeg,webp}');
const teamShields = import.meta.glob<{ default: ImageMetadata }>('/src/assets/escudos/*.{png,jpg,jpeg,webp}');
const competitionLogos = import.meta.glob<{ default: ImageMetadata }>('/src/assets/competiciones/*.{png,jpg,jpeg,webp}');

// 1. Find Next Match
const now = new Date();
const nextMatchIndex = CALENDAR.find((m) => new Date(m.date) >= now); 
const nextMatch = nextMatchIndex || null;

// Helpers
async function getPlayerImage(id: string) {
    const path = `/src/assets/jugadoras/${id}.png`;
    if (playerImages[path]) {
        const mod = await playerImages[path]();
        return mod.default.src;
    }
    return '/assets/img/default-player.png';
}

const getShield = async (teamName) => {
    const slug = teamName.toLowerCase().replace(/ /g, '_').normalize("NFD").replace(/[\u0300-\u036f]/g, "");
    let path = `/src/assets/escudos/${slug}.png`;
    if (teamShields[path]) return (await teamShields[path]()).default.src;
    path = `/src/assets/escudos/${slug.replace(/_/g, '-')}.png`;
    if (teamShields[path]) return (await teamShields[path]()).default.src;
    if (slug.includes('madrid')) return '/assets/escudos/real_madrid.png'; 
    return '';
};

const getCompetitionLogo = async (compName) => {
    const slug = compName.toLowerCase().replace(/ /g, '_').normalize("NFD").replace(/[\u0300-\u036f]/g, "");
    let path = `/src/assets/competiciones/${slug}.png`;
    // Map specific names if needed or fuzzy match
    // Check known files: liga_f.png, uwcl.png, copa_de_la_reina.png, supercopa_de_espana.png
    if (slug.includes('liga')) path = '/src/assets/competiciones/liga_f.png';
    else if (slug.includes('uwcl') || slug.includes('champions')) path = '/src/assets/competiciones/uwcl.png';
    else if (slug.includes('copa')) path = '/src/assets/competiciones/copa_de_la_reina.png';
    else if (slug.includes('supercopa')) path = '/src/assets/competiciones/supercopa_de_espana.png';

    if (competitionLogos[path]) return (await competitionLogos[path]()).default.src;
    return '';
};

// 2. Fetch Data
const { userId } = Astro.locals.auth();
let userPrediction = null;
let leaderboard = [];

if (userId && nextMatch) {
    try {
        const result = await turso.execute({
            sql: "SELECT home_score, away_score, scorers FROM predictions WHERE user_id = ? AND match_id = ?",
            args: [userId, nextMatch.id],
        });
        if (result.rows.length > 0) {
            userPrediction = result.rows[0];
            if (typeof userPrediction.scorers === 'string') {
                try {
                    userPrediction.scorers = JSON.parse(userPrediction.scorers);
                } catch (e) {
                    userPrediction.scorers = [];
                }
            }
        }
    } catch (e) {
        console.error("Error fetching user prediction", e);
    }
}

try {
    const result = await turso.execute({
        sql: "SELECT user_id, SUM(points_earned) as total_points FROM predictions GROUP BY user_id ORDER BY total_points DESC LIMIT 20",
        args: [],
    });
    leaderboard = result.rows;
} catch(e) {
    console.error("Error fetching leaderboard", e);
}

const isMatchOpen = nextMatch ? true : false; 
const matchDate = nextMatch ? new Date(nextMatch.date) : new Date();
const formattedDate = matchDate.toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' });

// Prepare assets
const playersWithImages = await Promise.all(SQUAD.sort((a, b) => a.number - b.number).map(async (p) => ({
    ...p,
    image: await getPlayerImage(p.id)
})));

const homeShield = nextMatch ? await getShield(nextMatch.team1) : '';
const awayShield = nextMatch ? await getShield(nextMatch.team2) : '';
const compLogo = nextMatch ? await getCompetitionLogo(nextMatch.competition) : '';

---

<Layout title="La Porra | Madrid Femenino Xtra">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 pronosticos-page">
        <header class="page-header text-center mb-12">
            <h1 class="page-title">LA PORRA</h1>
             <p class="content-h2">
                Adivina el resultado del próximo partido y gana puntos para subir en la clasificación.
            </p>
             <div class="auth-controls mt-6">
                <SignedOut>
                    <SignInButton mode="modal" as="button" class="login-btn">
                        INICIAR SESIÓN
                    </SignInButton>
                </SignedOut>
                <SignedIn>
                    <UserButton />
                </SignedIn>
            </div>
        </header>

        <div class="grid-layout">
            <!-- LEFT COLUMN: PREDICTION CARD -->
            <section class="prediction-column">
                {nextMatch ? (
                    <div class="match-card">
                        <div class="card-title-overlay">PRÓXIMO PARTIDO</div>
                        
                         <div class="match-header">
                            {compLogo ? (
                                <img src={compLogo} alt={nextMatch.competition} class="comp-logo" />
                            ) : (
                                <span class="competition-text">{nextMatch.competition}</span>
                            )}
                            <div class="date-container">
                                <span class="match-date-day">{formattedDate}</span>
                                <span class="match-date-time">{nextMatch.time}</span>
                            </div>
                        </div>
                        
                        <div class="teams-container" data-match-id={nextMatch.id}>
                            <div class="team home">
                                {homeShield && <img src={homeShield} alt={nextMatch.team1} class="team-shield" />}
                                <span class="team-name">{nextMatch.team1}</span>
                            </div>
                            
                            <div class="score-board">
                                <input 
                                    type="number" 
                                    id="home-score" 
                                    min="0" 
                                    max="20" 
                                    value={userPrediction ? userPrediction.home_score : ''}
                                    placeholder="" 
                                    disabled={!userId || !isMatchOpen}
                                />
                                <span class="score-separator">:</span>
                                <input 
                                    type="number" 
                                    id="away-score" 
                                    min="0" 
                                    max="20" 
                                    value={userPrediction ? userPrediction.away_score : ''}
                                    placeholder=""
                                     disabled={!userId || !isMatchOpen}
                                />
                            </div>

                            <div class="team away">
                                {awayShield && <img src={awayShield} alt={nextMatch.team2} class="team-shield" />}
                                <span class="team-name">{nextMatch.team2}</span>
                            </div>
                        </div>

                        <!-- GOALSCORERS SECTION -->
                        <div class="scorers-section">
                            <h3 class="scorers-title">¿QUIÉN MARCARÁ?</h3>
                            
                            <div class="scorers-select-container">
                                {playersWithImages.map(player => (
                                    <div 
                                        class={`scorer-chip ${userPrediction && userPrediction.scorers && userPrediction.scorers.includes(player.id) ? 'selected' : ''}`}
                                        data-player-id={player.id}
                                        onclick="toggleScorer(this)"
                                        title={player.name}
                                    >
                                        <div class="chip-image-container">
                                             <img src={player.image} alt={player.name} class="chip-img" loading="lazy" />
                                        </div>
                                        <div class="chip-info">
                                            <span class="player-num">#{player.number}</span>
                                            <span class="player-name-chip">{player.name.split(' ')[0]}</span>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>

                        <div class="action-area">
                             {!userId ? (
                                <p class="login-prompt">Debes iniciar sesión para participar</p>
                            ) : (
                                <button id="submit-prediction" class="submit-btn" disabled={!isMatchOpen}>
                                    {userPrediction ? "ACTUALIZAR PRONÓSTICO" : "ENVIAR PRONÓSTICO"}
                                </button>
                            )}
                             <p id="feedback-msg" class="feedback-msg hidden"></p>
                        </div>
                    </div>
                ) : (
                    <div class="no-match-card">
                        <p>No hay partidos próximos programados.</p>
                    </div>
                )}
            </section>

            <!-- RIGHT COLUMN: LEADERBOARD -->
            <section class="leaderboard-column">
                <div class="leaderboard-container">
                    <div class="card-title-overlay">CLASIFICACIÓN</div>
                    
                    <div class="leaderboard-header">
                        <span class="th-pos">#</span>
                        <span class="th-user">USUARIO</span>
                        <span class="th-pts">PTS</span>
                    </div>
                    <div class="leaderboard-list">
                        {leaderboard.length > 0 ? leaderboard.map((user, index) => (
                            <div class={`leaderboard-row ${index < 3 ? 'top-3' : ''}`}>
                                <span class="td-pos">{index + 1}</span>
                                <span class="td-user">
                                    <div class="user-avatar-placeholder">{user.user_id.slice(0, 1).toUpperCase()}</div>
                                    Madridista #{user.user_id.toString().slice(-4)}
                                </span>
                                <span class="td-pts">{user.total_points || 0}</span>
                            </div>
                        )) : (
                            <div class="empty-state">
                                ¡Aún no hay puntuaciones! Sé el primero.
                            </div>
                        )}
                    </div>
                </div>
            </section>
        </div>
    </main>
</Layout>

<script is:inline>
    // Global function
    function toggleScorer(element) {
        const submitBtn = document.getElementById('submit-prediction');
        if (!submitBtn) return; // Not auth
        
        element.classList.toggle('selected');
    }
</script>

<script>
    const submitBtn = document.getElementById('submit-prediction');
    const homeInput = document.getElementById('home-score') as HTMLInputElement;
    const awayInput = document.getElementById('away-score') as HTMLInputElement;
    const feedbackMsg = document.getElementById('feedback-msg');
    const container = document.querySelector('.teams-container') as HTMLElement;

    if (submitBtn && container) {
        submitBtn.addEventListener('click', async () => {
            const matchId = container.dataset.matchId;
            const homeScore = parseInt(homeInput.value); // If empty, NaN
            const awayScore = parseInt(awayInput.value);

            // Collect selected scorers
            const selectedScorers = [];
            document.querySelectorAll('.scorer-chip.selected').forEach(chip => {
                const pid = (chip as HTMLElement).dataset.playerId;
                if(pid) selectedScorers.push(pid);
            });

            if (isNaN(homeScore) || isNaN(awayScore)) {
                if(feedbackMsg) {
                    feedbackMsg.textContent = "Por favor, introduce un marcador válido.";
                    feedbackMsg.className = 'feedback-msg error';
                    feedbackMsg.classList.remove('hidden');
                }
                return;
            }

            submitBtn.textContent = "ENVIANDO...";
            (submitBtn as HTMLButtonElement).disabled = true;

            try {
                const response = await fetch('/api/predictions', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        match_id: matchId, 
                        home_score: homeScore, 
                        away_score: awayScore,
                        scorers: selectedScorers
                    })
                });

                if (response.ok) {
                    submitBtn.textContent = "¡GUARDADO!";
                    submitBtn.style.background = "#2ecc71";
                    submitBtn.style.color = "#fff";
                    
                    if(feedbackMsg) {
                        feedbackMsg.textContent = "Pronóstico guardado correctamente.";
                        feedbackMsg.className = 'feedback-msg success';
                        feedbackMsg.classList.remove('hidden');
                    }
                    setTimeout(() => {
                        submitBtn.textContent = "ACTUALIZAR PRONÓSTICO";
                        (submitBtn as HTMLButtonElement).disabled = false;
                        submitBtn.removeAttribute('style'); // Reset styles
                    }, 2000);
                } else {
                    throw new Error("Error en la petición");
                }
            } catch (error) {
                console.error(error);
                submitBtn.textContent = "ERROR";
                 (submitBtn as HTMLButtonElement).disabled = false;
                 if(feedbackMsg) {
                    feedbackMsg.textContent = "Ha ocurrido un error. Inténtalo de nuevo.";
                    feedbackMsg.className = 'feedback-msg error';
                    feedbackMsg.classList.remove('hidden');
                }
            }
        });
    }
</script>

<style>
    :root {
        --primary: #2b2b2b;
        --accent: #ffde59;
        --text: #ffffff;
        --card-bg: #ffffff;
        --text-dark: #2b2b2b;
    }

    .pronosticos-page {
        font-family: 'Poppins', sans-serif;
    }
    
    .page-title {
        color: var(--text);
        font-family: "Archivo Black", sans-serif;
        font-size: 3.5rem;
        line-height: 1;
        text-transform: uppercase;
        margin-bottom: 1rem;
        text-align: center;
    }
    
    .content-h2 {
        color: #b0b0b0;
        font-size: 1.1rem;
        max-width: 800px;
        margin: 0 auto;
        line-height: 1.6;
    }

    /* GRID LAYOUT FOR DESKTOP */
    .grid-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        margin-top: 3rem;
    }

    @media (min-width: 1024px) {
        .grid-layout {
            grid-template-columns: 3fr 2fr;
            align-items: start;
        }
    }

    /* CARD STYLING */
    .match-card, .leaderboard-container {
        position: relative;
        background: white;
        border-radius: 12px;
        padding: 3.5rem 2rem 2.5rem 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        color: var(--text-dark);
        border: 1px solid rgba(255,255,255,0.05); /* Subtle border */
    }

    /* Uniform look for both cards */
    .leaderboard-container {
        background: white; /* Changed to white as requested */
        color: var(--text-dark); /* Dark text for white bg */
    }

    .card-title-overlay {
        position: absolute;
        top: -18px;
        left: 30px;
        background: var(--accent);
        color: #000;
        padding: 0.5rem 1.5rem;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 1.6rem;
        font-weight: 700;
        letter-spacing: 1px;
        transform: skew(-10deg);
        box-shadow: 4px 4px 0px rgba(0,0,0,0.3);
        z-index: 10;
        line-height: 1;
    }
    
    .card-title-overlay::after {
        content: ''; 
        display: block;
        transform: skew(10deg);
    }

    .no-match-card {
        background: rgba(255,255,255,0.1);
        padding: 3rem;
        text-align: center;
        border-radius: 8px;
        color: #aaa;
    }

    /* HEADER */
    .match-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 2.5rem;
        border-bottom: 1px solid #f0f0f0;
        padding-bottom: 1.5rem;
        gap: 1rem;
    }

    .comp-logo {
        height: 60px;
        width: auto;
        display: block;
        object-fit: contain;
    }
    
    .competition-text {
        font-weight: 700;
        font-size: 1.2rem;
        text-transform: uppercase;
        color: var(--primary);
    }

    .date-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .match-date-day {
        color: var(--primary);
        font-size: 1.1rem;
        text-transform: capitalize;
        font-weight: 600;
    }
    
    .match-date-time {
        color: #666;
        font-size: 1rem;
        font-weight: 500;
    }

    /* TEAMS & SCORE */
    .teams-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2.5rem;
        gap: 1rem;
        padding: 0 1rem;
    }

    .team {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        text-align: center;
    }
    
    .team-shield {
        width: 120px; /* Larger shields */
        height: 120px;
        object-fit: contain;
        filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));
        transition: transform 0.3s;
    }
    
    .team-shield:hover {
        transform: scale(1.05);
    }
    
    .team-name {
        font-weight: 900;
        font-size: 1.1rem;
        text-transform: uppercase;
        color: var(--primary);
        line-height: 1.2;
        max-width: 150px;
    }

    .score-board {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        /* Clean style, no background */
        padding: 0 1rem;
    }

    .score-board input {
        width: 60px;
        height: 70px;
        text-align: center;
        background: transparent;
        border: none;
        border-bottom: 4px solid #eee; /* Underline only */
        color: var(--primary);
        font-size: 3rem;
        font-weight: 800;
        border-radius: 0;
        transition: border-color 0.2s;
        padding: 0;
        font-family: 'Archivo Black', sans-serif;
    }
    
    .score-board input:focus {
        border-color: var(--accent);
        outline: none;
    }
    
    .score-board input::placeholder {
        color: transparent;
    }

    .score-separator {
        font-size: 3rem;
        font-weight: 700;
        color: var(--primary);
        margin-top: -10px;
    }

    /* GOALSCORERS */
    .scorers-section {
        margin-top: 2rem;
        border-top: 1px solid #f0f0f0;
        padding-top: 1.5rem;
        background: #fafafa; /* Subtle bg area for scorers */
        border-radius: 8px;
        padding: 1.5rem;
    }

    .scorers-title {
        font-size: 1rem;
        font-weight: 800;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        color: var(--primary);
        text-align: center;
        letter-spacing: 1px;
    }

    .scorers-select-container {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
        gap: 1rem;
        max-height: 400px;
        overflow-y: auto;
    }

    .scorer-chip {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        padding: 0.8rem;
        background: white;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s;
        border: 2px solid transparent;
        text-align: center;
        user-select: none;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }

    .scorer-chip:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .scorer-chip.selected {
        background: var(--primary);
        border-color: var(--primary);
    }
    
    .chip-image-container {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        overflow: hidden;
        background: #f0f0f0;
        border: 2px solid #fff;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        position: relative;
    }
    
    .chip-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        /* Ensure no cut off by scaling slightly down or fitting properly */
        object-position: top center; 
    }
    
    /* When selected, highlight image border */
    .scorer-chip.selected .chip-image-container {
        border-color: var(--accent);
    }

    .chip-info {
        display: flex;
        flex-direction: column;
        line-height: 1;
        gap: 0.2rem;
    }

    .player-num {
        font-size: 0.75rem;
        font-weight: 700;
        color: #999;
    }
    
    .scorer-chip.selected .player-num {
        color: rgba(255,255,255,0.7);
    }

    .player-name-chip {
        font-size: 0.9rem;
        font-weight: 700;
        color: #333;
    }
    
    .scorer-chip.selected .player-name-chip {
        color: var(--accent);
    }

    /* ACTIONS */
    .action-area {
        margin-top: 2rem;
        text-align: center;
    }

    .submit-btn {
        background: var(--primary);
        color: white;
        border: none;
        width: 100%;
        padding: 1.2rem;
        font-weight: 800;
        text-transform: uppercase;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 5px 0px #000;
        font-family: 'Archivo Black', sans-serif;
        font-size: 1.2rem;
        letter-spacing: 1px;
    }

    .submit-btn:hover:not(:disabled) {
        transform: translateY(-2px);
        background: #3a3a3a;
        box-shadow: 0 7px 0px #000;
    }
    
    .submit-btn:active:not(:disabled) {
        transform: translateY(2px);
        box-shadow: 0 0px 0px #000;
    }
    
    .submit-btn:disabled {
        background: #e0e0e0;
        color: #a0a0a0;
        cursor: not-allowed;
        box-shadow: none;
    }


    /* LEADERBOARD LIST - WHITE THEME */
    .leaderboard-header {
        display: grid;
        grid-template-columns: 50px 1fr 60px;
        padding: 0.8rem 1rem;
        font-weight: 800;
        font-size: 0.8rem;
        color: #999;
        border-bottom: 2px solid #f0f0f0;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .leaderboard-list {
        max-height: 700px;
        overflow-y: auto;
    }

    .leaderboard-row {
        display: grid;
        grid-template-columns: 50px 1fr 60px;
        padding: 1rem 1rem;
        align-items: center;
        border-bottom: 1px solid #f5f5f5;
        font-size: 0.95rem;
        color: var(--primary);
        transition: background 0.2s;
    }
    
    .leaderboard-row:hover {
        background: #fafafa;
    }
    
    .leaderboard-row:last-child {
        border-bottom: none;
    }

    .top-3 {
        background: #fffbf0; /* Light yellow tint */
    }
    
    .top-3 .td-pos {
        color: #d4af37; /* Gold-ish */
        font-size: 1.2rem;
        font-weight: 900;
    }

    .td-user {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        font-weight: 600;
    }

    .user-avatar-placeholder {
        width: 32px;
        height: 32px;
        background: #eee;
        color: #555;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        font-weight: 800;
    }
    
    .top-3 .user-avatar-placeholder {
        background: var(--accent);
        color: var(--primary);
    }

    .td-pts {
        font-weight: 800;
        text-align: center;
        color: var(--primary);
        background: #f0f0f0;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        font-size: 0.9rem;
    }
    
    /* Login prompt styling */
    .login-prompt {
        color: #888;
        font-weight: 500;
        margin-bottom: 1rem;
    }

    @media (max-width: 600px) {
        .page-title { font-size: 2.5rem; }
        .score-board input { width: 50px; font-size: 2.5rem; height: 60px; }
        .scorers-select-container { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); }
        .card-title-overlay { font-size: 1.2rem; padding: 0.4rem 1rem; top: -15px; left: 15px; }
        .team-shield { width: 90px; height: 90px; }
    }
</style>
