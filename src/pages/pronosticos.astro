---
import Layout from "../layouts/Layout.astro";
import { turso } from "../lib/turso";
import { CALENDAR } from "../consts/calendar";
import { SQUAD } from "../../public/consts/squad";
import { SignInButton, SignedIn, SignedOut, UserButton } from "@clerk/astro/components";
import type { ImageMetadata } from 'astro';

// Import all player images and shields directly using import.meta.glob
const playerImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/jugadoras/*.{png,jpg,jpeg,webp}');
const teamShields = import.meta.glob<{ default: ImageMetadata }>('/src/assets/escudos/*.{png,jpg,jpeg,webp}');

// 1. Find Next Match
const now = new Date();
const nextMatchIndex = CALENDAR.find((m) => new Date(m.date) >= now); 
const nextMatch = nextMatchIndex || null;

// Helper to get image URL safely
async function getPlayerImage(id: string) {
    const path = `/src/assets/jugadoras/${id}.png`;
    if (playerImages[path]) {
        const mod = await playerImages[path]();
        return mod.default.src;
    }
    return '/assets/img/default-player.png'; // Fallback
}

// 2. Fetch Data (Server Side)
const { userId } = Astro.locals.auth();
let userPrediction = null;
let leaderboard = [];

if (userId && nextMatch) {
    try {
        const result = await turso.execute({
            sql: "SELECT home_score, away_score, scorers FROM predictions WHERE user_id = ? AND match_id = ?",
            args: [userId, nextMatch.id],
        });
        if (result.rows.length > 0) {
            userPrediction = result.rows[0];
            if (typeof userPrediction.scorers === 'string') {
                try {
                    userPrediction.scorers = JSON.parse(userPrediction.scorers);
                } catch (e) {
                    userPrediction.scorers = [];
                }
            }
        }
    } catch (e) {
        console.error("Error fetching user prediction", e);
    }
}

try {
    const result = await turso.execute({
        sql: "SELECT user_id, SUM(points_earned) as total_points FROM predictions GROUP BY user_id ORDER BY total_points DESC LIMIT 20",
        args: [],
    });
    leaderboard = result.rows;
} catch(e) {
    console.error("Error fetching leaderboard", e);
}

const isMatchOpen = nextMatch ? true : false; 
const matchDate = nextMatch ? new Date(nextMatch.date) : new Date();
const formattedDate = matchDate.toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' });

// Prepare squad with images
const playersWithImages = await Promise.all(SQUAD.sort((a, b) => a.number - b.number).map(async (p) => ({
    ...p,
    image: await getPlayerImage(p.id)
})));

// Helper for team shields - matching naming convention from previous tasks might be complex. 
// Assuming team names in CALENDAR match file names or we try to slugify.
// Using a simple slugify for shield checking: "Real Madrid" -> "real_madrid.png"
const getShield = async (teamName) => {
    // Basic slugify: remove accents, lowercase, replace spaces with underscores/hyphens
    const slug = teamName.toLowerCase().replace(/ /g, '_').normalize("NFD").replace(/[\u0300-\u036f]/g, "");
    
    // Try underscore first, then hyphen, then maybe specific mappings
    let path = `/src/assets/escudos/${slug}.png`;
    if (teamShields[path]) return (await teamShields[path]()).default.src;
    
    path = `/src/assets/escudos/${slug.replace(/_/g, '-')}.png`;
    if (teamShields[path]) return (await teamShields[path]()).default.src;

    // Hardcoded check for Real Madrid if needed, as it might be named differently
    if (slug.includes('madrid')) return '/assets/escudos/real_madrid.png'; 

    return ''; // Return empty if not found, or default
};

const homeShield = nextMatch ? await getShield(nextMatch.team1) : '';
const awayShield = nextMatch ? await getShield(nextMatch.team2) : '';

---

<Layout title="La Porra | Madrid Femenino Xtra">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 pronosticos-page">
        <header class="page-header text-center mb-10">
            <h1 class="page-title">LA PORRA</h1>
             <p class="content-h2">
                Adivina el resultado del próximo partido y gana puntos para subir en la clasificación.
            </p>
             <div class="auth-controls mt-4">
                <SignedOut>
                    <SignInButton mode="modal" as="button" class="login-btn">
                        INICIAR SESIÓN
                    </SignInButton>
                </SignedOut>
                <SignedIn>
                    <UserButton />
                </SignedIn>
            </div>
        </header>

        <div class="grid-layout">
            <!-- LEFT COLUMN: PREDICTION CARD -->
            <section class="prediction-column">
                <!-- Title removed from here as requested -->
                
                {nextMatch ? (
                    <div class="match-card">
                        <div class="card-title-overlay">PRÓXIMO PARTIDO</div>
                        
                         <div class="match-header">
                            <span class="competition-badge">{nextMatch.competition}</span>
                            <span class="match-date">{formattedDate} - {nextMatch.time}</span>
                        </div>
                        
                        <div class="teams-container" data-match-id={nextMatch.id}>
                            <div class="team home">
                                {homeShield && <img src={homeShield} alt={nextMatch.team1} class="team-shield" />}
                                <span class="team-name">{nextMatch.team1}</span>
                            </div>
                            
                            <div class="score-board">
                                <input 
                                    type="number" 
                                    id="home-score" 
                                    min="0" 
                                    max="20" 
                                    value={userPrediction ? userPrediction.home_score : ''}
                                    placeholder="-"
                                    disabled={!userId || !isMatchOpen}
                                />
                                <span class="score-separator">:</span>
                                <input 
                                    type="number" 
                                    id="away-score" 
                                    min="0" 
                                    max="20" 
                                    value={userPrediction ? userPrediction.away_score : ''}
                                    placeholder="-"
                                     disabled={!userId || !isMatchOpen}
                                />
                            </div>

                            <div class="team away">
                                {awayShield && <img src={awayShield} alt={nextMatch.team2} class="team-shield" />}
                                <span class="team-name">{nextMatch.team2}</span>
                            </div>
                        </div>

                        <!-- GOALSCORERS SECTION -->
                        <div class="scorers-section">
                            <h3 class="scorers-title">¿QUIÉN MARCARÁ?</h3>
                            
                            <div class="scorers-select-container">
                                {playersWithImages.map(player => (
                                    <div 
                                        class={`scorer-chip ${userPrediction && userPrediction.scorers && userPrediction.scorers.includes(player.id) ? 'selected' : ''}`}
                                        data-player-id={player.id}
                                        onclick="toggleScorer(this)"
                                        title={player.name}
                                    >
                                        <div class="chip-image">
                                             <img src={player.image} alt={player.name} loading="lazy" />
                                        </div>
                                        <div class="chip-info">
                                            <span class="player-num">#{player.number}</span>
                                            <span class="player-name-chip">{player.name.split(' ')[0]}</span>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>

                        <div class="action-area">
                             {!userId ? (
                                <p class="login-prompt">Debes iniciar sesión para participar</p>
                            ) : (
                                <button id="submit-prediction" class="submit-btn" disabled={!isMatchOpen}>
                                    {userPrediction ? "ACTUALIZAR PRONÓSTICO" : "ENVIAR PRONÓSTICO"}
                                </button>
                            )}
                             <p id="feedback-msg" class="feedback-msg hidden"></p>
                        </div>
                    </div>
                ) : (
                    <div class="no-match-card">
                        <p>No hay partidos próximos programados.</p>
                    </div>
                )}
            </section>

            <!-- RIGHT COLUMN: LEADERBOARD -->
            <section class="leaderboard-column">
                <div class="leaderboard-container">
                    <div class="card-title-overlay">CLASIFICACIÓN</div>
                    
                    <div class="leaderboard-header">
                        <span class="th-pos">#</span>
                        <span class="th-user">USUARIO</span>
                        <span class="th-pts">PTS</span>
                    </div>
                    <div class="leaderboard-list">
                        {leaderboard.length > 0 ? leaderboard.map((user, index) => (
                            <div class={`leaderboard-row ${index < 3 ? 'top-3' : ''}`}>
                                <span class="td-pos">{index + 1}</span>
                                <span class="td-user">
                                    <div class="user-avatar-placeholder">{user.user_id.slice(0, 1).toUpperCase()}</div>
                                    Madridista #{user.user_id.toString().slice(-4)}
                                </span>
                                <span class="td-pts">{user.total_points || 0}</span>
                            </div>
                        )) : (
                            <div class="empty-state">
                                ¡Aún no hay puntuaciones! Sé el primero.
                            </div>
                        )}
                    </div>
                </div>
            </section>
        </div>
    </main>
</Layout>

<script is:inline>
    // Global function for onclick handler
    function toggleScorer(element) {
        const submitBtn = document.getElementById('submit-prediction');
        if (!submitBtn) return; // Not auth
        
        element.classList.toggle('selected');
    }
</script>

<script>
    const submitBtn = document.getElementById('submit-prediction');
    const homeInput = document.getElementById('home-score') as HTMLInputElement;
    const awayInput = document.getElementById('away-score') as HTMLInputElement;
    const feedbackMsg = document.getElementById('feedback-msg');
    const container = document.querySelector('.teams-container') as HTMLElement;

    if (submitBtn && container) {
        submitBtn.addEventListener('click', async () => {
            const matchId = container.dataset.matchId;
            const homeScore = parseInt(homeInput.value);
            const awayScore = parseInt(awayInput.value);

            // Collect selected scorers
            const selectedScorers = [];
            document.querySelectorAll('.scorer-chip.selected').forEach(chip => {
                const pid = (chip as HTMLElement).dataset.playerId;
                if(pid) selectedScorers.push(pid);
            });

            if (isNaN(homeScore) || isNaN(awayScore)) {
                if(feedbackMsg) {
                    feedbackMsg.textContent = "Por favor, introduce un marcador válido.";
                    feedbackMsg.className = 'feedback-msg error';
                }
                return;
            }

            submitBtn.textContent = "ENVIANDO...";
            (submitBtn as HTMLButtonElement).disabled = true;

            try {
                const response = await fetch('/api/predictions', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        match_id: matchId, 
                        home_score: homeScore, 
                        away_score: awayScore,
                        scorers: selectedScorers
                    })
                });

                if (response.ok) {
                    submitBtn.textContent = "¡GUARDADO!";
                    submitBtn.style.background = "#2ecc71";
                    submitBtn.style.color = "#fff";
                    
                    if(feedbackMsg) {
                        feedbackMsg.textContent = "Pronóstico guardado correctamente.";
                        feedbackMsg.className = 'feedback-msg success';
                    }
                    setTimeout(() => {
                        submitBtn.textContent = "ACTUALIZAR PRONÓSTICO";
                        (submitBtn as HTMLButtonElement).disabled = false;
                        submitBtn.removeAttribute('style'); // Reset styles
                    }, 2000);
                } else {
                    throw new Error("Error en la petición");
                }
            } catch (error) {
                console.error(error);
                submitBtn.textContent = "ERROR";
                 (submitBtn as HTMLButtonElement).disabled = false;
                 if(feedbackMsg) {
                    feedbackMsg.textContent = "Ha ocurrido un error. Inténtalo de nuevo.";
                    feedbackMsg.className = 'feedback-msg error';
                }
            }
        });
    }
</script>

<style>
    :root {
        --primary: #2b2b2b;
        --accent: #ffde59;
        --text: #ffffff;
        --card-bg: #ffffff;
        --text-dark: #2b2b2b;
    }

    .pronosticos-page {
        font-family: 'Poppins', sans-serif;
    }
    
    /* Reusing styles from Plantilla */
    .page-title {
        color: var(--text);
        font-family: "Archivo Black", sans-serif;
        font-size: 3.5rem;
        line-height: normal;
        text-transform: uppercase;
        margin-bottom: 0px;
        text-align: center;
    }
    
    .content-h2 {
        color: #b0b0b0;
        font-size: 1.1rem;
        max-width: 800px;
        margin: 0 auto;
        line-height: 1.6;
    }

    /* GRID LAYOUT FOR DESKTOP */
    .grid-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        margin-top: 3rem;
    }

    @media (min-width: 1024px) {
        .grid-layout {
            grid-template-columns: 1.5fr 1fr; /* Match card slightly wider */
            align-items: start;
        }
    }

    /* CARD STYLING */
    .match-card, .leaderboard-container {
        position: relative;
        background: white;
        border-radius: 12px;
        padding: 3rem 2rem 2rem 2rem; /* Top padding for title overlay */
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        color: var(--text-dark);
        border: 1px solid #eee;
        overflow: visible; /* For title overlay */
    }

    .leaderboard-container {
        background: #1a1f3c; /* Dark theme for leaderboard */
        color: white;
        border: 1px solid rgba(255,255,255,0.1);
        padding: 3rem 0 0 0;
    }

    .card-title-overlay {
        position: absolute;
        top: -15px;
        left: 20px;
        background: var(--accent);
        color: #000;
        padding: 0.3rem 1.2rem;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: 1px;
        transform: skew(-10deg);
        box-shadow: 2px 2px 0px rgba(0,0,0,0.2);
    }
    
    .card-title-overlay::after {
        content: ''; /* Fix skew for text */
        display: block;
        transform: skew(10deg);
    }

    .no-match-card {
        background: rgba(255,255,255,0.1);
        padding: 3rem;
        text-align: center;
        border-radius: 8px;
        color: #aaa;
    }

    .match-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        border-bottom: 1px solid #eee;
        padding-bottom: 1rem;
    }

    .competition-badge {
        background: var(--primary);
        color: var(--accent);
        padding: 0.3rem 0.8rem;
        border-radius: 4px;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
    }

    .match-date {
        color: #666;
        font-size: 0.9rem;
        text-transform: capitalize;
    }

    .teams-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        gap: 1rem;
    }

    .team {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        text-align: center;
    }
    
    .team-shield {
        width: 80px;
        height: 80px;
        object-fit: contain;
        filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
    }
    
    .team-name {
        font-weight: 800;
        font-size: 1rem;
        text-transform: uppercase;
        color: var(--primary);
        line-height: 1.2;
    }

    .score-board {
        background: #f8f9fa;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 0.3rem;
        border: 1px solid #eee;
    }

    .score-board input {
        width: 50px;
        height: 60px;
        text-align: center;
        background: white;
        border: 2px solid #ddd;
        color: var(--primary);
        font-size: 2rem;
        font-weight: 700;
        border-radius: 4px;
        transition: all 0.2s;
        -moz-appearance: textfield;
        padding: 0;
    }
    
    .score-board input:focus {
        border-color: var(--accent);
        outline: none;
    }

    .score-separator {
        font-size: 2rem;
        font-weight: 700;
        color: #ddd;
    }

    /* GOALSCORERS */
    .scorers-section {
        margin-top: 2rem;
        border-top: 1px solid #eee;
        padding-top: 1.5rem;
    }

    .scorers-title {
        font-size: 1.1rem;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 1rem;
        color: var(--primary);
        border-left: 3px solid var(--accent);
        padding-left: 0.5rem;
    }

    .scorers-select-container {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
        gap: 0.8rem;
        max-height: 400px; /* Taller area */
        overflow-y: auto;
        padding-right: 0.5rem;
    }

    .scorer-chip {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem;
        background: #f8f9fa;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.2s;
        border: 2px solid transparent;
        user-select: none;
    }

    .scorer-chip:hover {
        background: #e9ecef;
        transform: translateY(-2px);
    }

    .scorer-chip.selected {
        background: #fff;
        border-color: var(--accent);
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    
    .chip-image {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        overflow: hidden;
        background: #ccc;
        flex-shrink: 0;
    }
    
    .chip-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .chip-info {
        display: flex;
        flex-direction: column;
        line-height: 1;
    }

    .player-num {
        font-size: 0.7rem;
        font-weight: 700;
        color: #999;
    }
    
    .scorer-chip.selected .player-num {
        color: var(--primary);
    }

    .player-name-chip {
        font-size: 0.85rem;
        font-weight: 600;
        color: #333;
    }

    /* ACTIONS */
    .action-area {
        margin-top: 2rem;
        text-align: center;
    }

    .submit-btn {
        background: var(--accent);
        color: var(--primary);
        border: none;
        width: 100%;
        padding: 1rem;
        font-weight: 800;
        text-transform: uppercase;
        border-radius: 8px;
        cursor: pointer;
        transition: transform 0.2s, background 0.2s;
        box-shadow: 0 4px 0px #e6c84c; /* Retro button style */
        font-family: 'Archivo Black', sans-serif;
    }

    .submit-btn:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 6px 0px #e6c84c;
    }
    
    .submit-btn:active:not(:disabled) {
        transform: translateY(2px);
        box-shadow: 0 0px 0px #e6c84c;
    }
    
    .submit-btn:disabled {
        background: #ccc;
        color: #888;
        cursor: not-allowed;
        box-shadow: none;
    }

    .feedback-msg {
        margin-top: 1rem;
        font-weight: 600;
        font-size: 0.9rem;
    }
    .feedback-msg.success { color: #2ecc71; }
    .feedback-msg.error { color: #e74c3c; }


    /* LEADERBOARD LIST */
    .leaderboard-header {
        display: grid;
        grid-template-columns: 50px 1fr 60px;
        padding: 0.8rem 1rem;
        font-weight: 700;
        font-size: 0.85rem;
        color: rgba(255,255,255,0.5);
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .leaderboard-list {
        max-height: 600px;
        overflow-y: auto;
    }

    .leaderboard-row {
        display: grid;
        grid-template-columns: 50px 1fr 60px;
        padding: 0.8rem 1rem;
        align-items: center;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        font-size: 0.9rem;
        color: #eee;
    }
    
    .leaderboard-row:last-child {
        border-bottom: none;
    }

    .top-3 {
        background: rgba(255, 222, 89, 0.05);
    }
    
    .top-3 .td-pos {
        color: var(--accent);
        font-size: 1.1rem;
        font-weight: 900;
    }

    .td-user {
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

    .user-avatar-placeholder {
        width: 25px;
        height: 25px;
        background: rgba(255,255,255,0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: 700;
    }
    
    .top-3 .user-avatar-placeholder {
        background: var(--accent);
        color: var(--primary);
    }

    .td-pts {
        font-weight: 700;
        text-align: center;
        color: var(--accent);
    }
    
    .empty-state {
        padding: 2rem;
        text-align: center;
        color: rgba(255,255,255,0.4);
        font-style: italic;
    }

    .login-btn {
        background: var(--accent);
        color: var(--primary);
        border: none;
        padding: 0.6rem 2rem;
        font-weight: 800;
        border-radius: 4px;
        cursor: pointer;
        text-transform: uppercase;
        font-size: 1rem;
        transition: all 0.2s;
    }
    .login-btn:hover {
        transform: scale(1.05);
    }

    @media (max-width: 600px) {
        .page-title { font-size: 2.2rem; }
        .score-board input { width: 40px; font-size: 1.5rem; height: 50px; }
        .scorers-select-container { grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); }
        .card-title-overlay { font-size: 1.1rem; padding: 0.3rem 0.8rem; top: -12px; left: 10px; }
    }
</style>
