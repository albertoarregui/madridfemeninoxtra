---
import Layout from "../layouts/Layout.astro";
import { turso } from "../lib/turso";
import { CALENDAR } from "../consts/calendar";
import { SQUAD } from "../../public/consts/squad";
import { SignInButton, SignedIn, SignedOut, UserButton } from "@clerk/astro/components";
import type { ImageMetadata } from 'astro';

// Import all assets
const playerImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/jugadoras/*.{png,jpg,jpeg,webp}');
const teamShields = import.meta.glob<{ default: ImageMetadata }>('/src/assets/escudos/*.{png,jpg,jpeg,webp}');
const competitionLogos = import.meta.glob<{ default: ImageMetadata }>('/src/assets/competiciones/*.{png,jpg,jpeg,webp}');

// 1. Find Next Match
const now = new Date();
const nextMatchIndex = CALENDAR.find((m) => new Date(m.date) >= now); 
const nextMatch = nextMatchIndex || null;

// Helpers
async function getPlayerImage(id: string) {
    const path = `/src/assets/jugadoras/${id}.png`;
    if (playerImages[path]) {
        const mod = await playerImages[path]();
        return mod.default.src;
    }
    return '/assets/img/default-player.png';
}

const getShield = async (teamName) => {
    const slug = teamName.toLowerCase().replace(/ /g, '_').normalize("NFD").replace(/[\u0300-\u036f]/g, "");
    let path = `/src/assets/escudos/${slug}.png`;
    if (teamShields[path]) return (await teamShields[path]()).default.src;
    path = `/src/assets/escudos/${slug.replace(/_/g, '-')}.png`;
    if (teamShields[path]) return (await teamShields[path]()).default.src;
    if (slug.includes('madrid')) return '/assets/escudos/real_madrid.png'; 
    return '';
};

const getCompetitionLogo = async (compName) => {
    const slug = compName.toLowerCase().replace(/ /g, '_').normalize("NFD").replace(/[\u0300-\u036f]/g, "");
    let path = `/src/assets/competiciones/${slug}.png`;
    if (slug.includes('liga')) path = '/src/assets/competiciones/liga_f.png';
    else if (slug.includes('uwcl') || slug.includes('champions')) path = '/src/assets/competiciones/uwcl.png';
    else if (slug.includes('copa')) path = '/src/assets/competiciones/copa_de_la_reina.png';
    else if (slug.includes('supercopa')) path = '/src/assets/competiciones/supercopa_de_espana.png';

    if (competitionLogos[path]) return (await competitionLogos[path]()).default.src;
    return '';
};

// 2. Fetch Data
const { userId } = Astro.locals.auth();
let userPrediction = null;
let leaderboard = [];

if (userId && nextMatch) {
    try {
        const result = await turso.execute({
            sql: "SELECT home_score, away_score, scorers FROM predictions WHERE user_id = ? AND match_id = ?",
            args: [userId, nextMatch.id],
        });
        if (result.rows.length > 0) {
            userPrediction = result.rows[0];
            if (typeof userPrediction.scorers === 'string') {
                try {
                    userPrediction.scorers = JSON.parse(userPrediction.scorers);
                } catch (e) {
                    userPrediction.scorers = [];
                }
            }
        }
    } catch (e) {
        console.error("Error fetching user prediction", e);
    }
}

try {
    const result = await turso.execute({
        sql: "SELECT user_id, SUM(points_earned) as total_points FROM predictions GROUP BY user_id ORDER BY total_points DESC LIMIT 20",
        args: [],
    });
    leaderboard = result.rows;
} catch(e) {
    console.error("Error fetching leaderboard", e);
}

const isMatchOpen = nextMatch ? true : false; 
const matchDate = nextMatch ? new Date(nextMatch.date) : new Date();
const formattedDate = matchDate.toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' });

// Prepare assets
const YOUTH_PLAYERS = [
    { id: "irune_dorado", name: "Irune Dorado", number: 28, image: "" },
    { id: "silvia_cristobal", name: "Silvia Cristóbal", number: 29, image: "" },
    { id: "iris_ashley_santiago", name: "Iris Ashley", number: 43, image: "" }
];

const fullSquad = [...SQUAD, ...YOUTH_PLAYERS];

const playersWithImages = await Promise.all(fullSquad.sort((a, b) => a.number - b.number).map(async (p) => ({
    ...p,
    image: await getPlayerImage(p.id)
})));

const homeShield = nextMatch ? await getShield(nextMatch.team1) : '';
const awayShield = nextMatch ? await getShield(nextMatch.team2) : '';
const compLogo = nextMatch ? await getCompetitionLogo(nextMatch.competition) : '';

---

<Layout title="La Porra | Madrid Femenino Xtra">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 pronosticos-page">
        <header class="text-center mb-12">
            <!-- Using global page-title style, forcing visible color -->
            <h1 class="page-title" style="color: var(--text-primary);">LA PORRA</h1>
             <p class="content-h2-center mx-auto max-w-2xl">
                Adivina el resultado del próximo partido y gana puntos para subir en la clasificación.
            </p>
             <div class="auth-controls mt-6 flex justify-center">
                <SignedOut>
                    <SignInButton mode="modal" as="button" class="header-login-btn">
                        INICIAR SESIÓN
                    </SignInButton>
                </SignedOut>
                <SignedIn>
                    <UserButton />
                </SignedIn>
            </div>
        </header>

        <div class="grid-layout">
            <!-- LEFT COLUMN: PREDICTION CARD -->
            <section class="prediction-column">
                {nextMatch ? (
                    <div class="match-card">
                        <div class="card-title-overlay">PRÓXIMO PARTIDO</div>
                        
                         <div class="match-header">
                            {compLogo ? (
                                <img src={compLogo} alt={nextMatch.competition} class="comp-logo" />
                            ) : (
                                <span class="competition-text">{nextMatch.competition}</span>
                            )}
                            <div class="date-container">
                                <span class="match-date-day">{formattedDate}</span>
                                <span class="match-date-time">{nextMatch.time}</span>
                            </div>
                        </div>
                        
                        <div class="teams-container" data-match-id={nextMatch.id}>
                            <div class="team home">
                                {homeShield && <img src={homeShield} alt={nextMatch.team1} class="team-shield" />}
                                <span class="team-name">{nextMatch.team1}</span>
                            </div>
                            
                            <!-- Score inputs with hover container ref -->
                            <div class="score-board-container">
                                <div class="score-input-wrapper">
                                    <input 
                                        type="number" 
                                        id="home-score" 
                                        min="0" 
                                        max="20" 
                                        value={userPrediction ? userPrediction.home_score : ''}
                                        placeholder="" 
                                        disabled={!userId || !isMatchOpen}
                                    />
                                </div>
                                <span class="score-separator">:</span>
                                <div class="score-input-wrapper">
                                    <input 
                                        type="number" 
                                        id="away-score" 
                                        min="0" 
                                        max="20" 
                                        value={userPrediction ? userPrediction.away_score : ''}
                                        placeholder=""
                                        disabled={!userId || !isMatchOpen}
                                    />
                                </div>
                            </div>

                            <div class="team away">
                                {awayShield && <img src={awayShield} alt={nextMatch.team2} class="team-shield" />}
                                <span class="team-name">{nextMatch.team2}</span>
                            </div>
                        </div>

                        <!-- GOALSCORERS SECTION -->
                        <div class="scorers-section">
                            <h3 class="scorers-title">¿QUIÉN MARCARÁ?</h3>
                            
                            <div class="scorers-select-container">
                                {playersWithImages.map(player => (
                                    <div 
                                        class={`scorer-chip ${userPrediction && userPrediction.scorers && userPrediction.scorers.includes(player.id) ? 'selected' : ''}`}
                                        data-player-id={player.id}
                                        onclick="toggleScorer(this)"
                                        title={player.name}
                                    >
                                        <div class="chip-image-container">
                                             <img src={player.image} alt={player.name} class="chip-img" loading="lazy" />
                                        </div>
                                        <div class="chip-info">
                                            <span class="player-num">#{player.number}</span>
                                            <span class="player-name-chip">{player.name}</span>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>

                        <div class="action-area">
                             {!userId ? (
                                <p class="login-prompt">Debes iniciar sesión para participar</p>
                            ) : (
                                <button id="submit-prediction" class="submit-btn" disabled={!isMatchOpen}>
                                    {userPrediction ? "ACTUALIZAR PRONÓSTICO" : "ENVIAR PRONÓSTICO"}
                                </button>
                            )}
                             <p id="feedback-msg" class="feedback-msg hidden"></p>
                        </div>
                    </div>
                ) : (
                    <div class="no-match-card">
                        <p>No hay partidos próximos programados.</p>
                    </div>
                )}
            </section>

            <!-- RIGHT COLUMN: LEADERBOARD -->
            <section class="leaderboard-column">
                <div class="leaderboard-container">
                    <div class="card-title-overlay">CLASIFICACIÓN</div>
                    
                    <div class="leaderboard-table-wrapper">
                        <table class="leaderboard-table">
                            <thead>
                                <tr>
                                    <th class="th-pos">#</th>
                                    <th class="th-user">USUARIO</th>
                                    <th class="th-pts">PTS</th>
                                </tr>
                            </thead>
                            <tbody>
                                {leaderboard.length > 0 ? leaderboard.map((user, index) => (
                                    <tr class={`leaderboard-row ${index < 3 ? 'top-3' : ''}`}>
                                        <td class="td-pos">{index + 1}</td>
                                        <td class="td-user">
                                            <div class="user-cell">
                                                <div class="user-avatar-placeholder">{user.user_id.slice(0, 1).toUpperCase()}</div>
                                                <span class="user-id">#{user.user_id.toString().slice(-4)}</span>
                                            </div>
                                        </td>
                                        <td class="td-pts">
                                            <span class="pts-badge">{user.total_points || 0}</span>
                                        </td>
                                    </tr>
                                )) : (
                                    <tr>
                                        <td colspan="3" class="empty-state">
                                            ¡Aún no hay puntuaciones! Sé el primero.
                                        </td>
                                    </tr>
                                )}
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </div>
    </main>
</Layout>

<script is:inline>
    // Global function
    function toggleScorer(element) {
        const submitBtn = document.getElementById('submit-prediction');
        if (!submitBtn) return; // Not auth
        element.classList.toggle('selected');
    }
</script>

<script>
    const submitBtn = document.getElementById('submit-prediction');
    const homeInput = document.getElementById('home-score') as HTMLInputElement;
    const awayInput = document.getElementById('away-score') as HTMLInputElement;
    const feedbackMsg = document.getElementById('feedback-msg');
    const container = document.querySelector('.teams-container') as HTMLElement;

    if (submitBtn && container) {
        submitBtn.addEventListener('click', async () => {
            const matchId = container.dataset.matchId;
            const homeScore = parseInt(homeInput.value); 
            const awayScore = parseInt(awayInput.value);

            // Collect selected scorers
            const selectedScorers = [];
            document.querySelectorAll('.scorer-chip.selected').forEach(chip => {
                const pid = (chip as HTMLElement).dataset.playerId;
                if(pid) selectedScorers.push(pid);
            });

            if (isNaN(homeScore) || isNaN(awayScore)) {
                if(feedbackMsg) {
                    feedbackMsg.textContent = "Por favor, introduce un marcador válido.";
                    feedbackMsg.className = 'feedback-msg error';
                    feedbackMsg.classList.remove('hidden');
                }
                return;
            }

            submitBtn.textContent = "ENVIANDO...";
            (submitBtn as HTMLButtonElement).disabled = true;

            try {
                const response = await fetch('/api/predictions', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        match_id: matchId, 
                        home_score: homeScore, 
                        away_score: awayScore,
                        scorers: selectedScorers
                    })
                });

                if (response.ok) {
                    submitBtn.textContent = "¡GUARDADO!";
                    if(feedbackMsg) {
                        feedbackMsg.textContent = "Pronóstico guardado correctamente.";
                        feedbackMsg.className = 'feedback-msg success';
                        feedbackMsg.classList.remove('hidden');
                    }
                    setTimeout(() => {
                        submitBtn.textContent = "ACTUALIZAR PRONÓSTICO";
                        (submitBtn as HTMLButtonElement).disabled = false;
                    }, 2000);
                } else {
                    throw new Error("Error en la petición");
                }
            } catch (error) {
                console.error(error);
                submitBtn.textContent = "ERROR";
                 (submitBtn as HTMLButtonElement).disabled = false;
                 if(feedbackMsg) {
                    feedbackMsg.textContent = "Ha ocurrido un error. Inténtalo de nuevo.";
                    feedbackMsg.className = 'feedback-msg error';
                    feedbackMsg.classList.remove('hidden');
                }
            }
        });
    }
</script>

<style>
    :root {
        --primary: #2b2b2b;
        --accent: #ffde59;
        --text-primary: #2b2b2b;
    }

    .pronosticos-page {
        font-family: 'Poppins', sans-serif;
    }

    /* GRID LAYOUT FOR DESKTOP */
    .grid-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        margin-top: 3rem;
    }

    @media (min-width: 1024px) {
        .grid-layout {
            grid-template-columns: 3fr 2fr;
            align-items: start;
        }
    }

    /* CARD STYLING */
    .match-card, .leaderboard-container {
        position: relative;
        background: white;
        border-radius: 12px;
        padding: 3.5rem 2rem 2.5rem 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        color: var(--text-primary);
        border: 1px solid rgba(0,0,0,0.05);
    }
    
    .card-title-overlay {
        position: absolute;
        top: -18px;
        left: 30px;
        background: var(--accent);
        color: #2b2b2b;
        padding: 0.5rem 1.5rem;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 1.6rem;
        font-weight: 700;
        letter-spacing: 1px;
        transform: skew(-10deg);
        box-shadow: 4px 4px 0px rgba(0,0,0,0.1);
        z-index: 10;
        line-height: 1;
    }
    .card-title-overlay::after {
        content: ''; 
        display: block;
        transform: skew(10deg);
    }

    /* COMPONENT STYLES */
    .match-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 2.5rem;
        border-bottom: 1px solid #f0f0f0;
        padding-bottom: 1.5rem;
        gap: 1rem;
    }

    .comp-logo { height: 60px; width: auto; object-fit: contain; }
    .competition-text { font-weight: 700; font-size: 1.2rem; text-transform: uppercase; color: var(--primary); }

    .date-container { display: flex; flex-direction: column; align-items: center; text-align: center; }
    .match-date-day { color: var(--primary); font-size: 1.1rem; text-transform: capitalize; font-weight: 600; }
    .match-date-time { color: #888; font-size: 1rem; font-weight: 500; }

    /* TEAMS & SCORE */
    .teams-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2.5rem;
        gap: 1rem;
    }

    .team {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        text-align: center;
    }
    
    .team-shield {
        width: 120px;
        height: 120px;
        object-fit: contain;
        filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));
        transition: transform 0.3s;
    }
    
    .team-name {
        font-weight: 900;
        font-size: 1.1rem;
        text-transform: uppercase;
        color: var(--primary);
        line-height: 1.2;
        max-width: 150px;
    }

    /* SCORE INPUTS STYLE */
    .score-board-container {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .score-input-wrapper {
        border: 2px solid transparent;
        border-radius: 8px;
        padding: 5px;
        transition: all 0.2s;
        /* Hover effect container */
    }
    
    .score-input-wrapper:hover {
        background-color: rgba(255, 222, 89, 0.1); /* Subtle yellow background */
        border-color: var(--accent);
    }
    
    .score-input-wrapper:focus-within {
        background-color: rgba(255, 222, 89, 0.2);
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(255, 222, 89, 0.3);
    }

    .score-board-container input {
        width: 70px;
        height: 80px;
        text-align: center;
        background: transparent;
        border: none;
        color: var(--primary);
        font-size: 3.5rem;
        font-weight: 800;
        padding: 0;
        font-family: 'Archivo Black', sans-serif;
        line-height: 1;
    }
    
    .score-board-container input:focus {
        outline: none;
    }
    .score-board-container input::placeholder { color: transparent; }
    
    .score-separator {
        font-size: 3rem;
        font-weight: 700;
        color: #ddd;
        margin-top: -10px;
    }

    /* BUTTON STYLE MATCHING PREMIOS */
    .submit-btn {
        background: linear-gradient(135deg, #ffd700 0%, #ffed4e 50%, #ffd700 100%);
        color: #2b2b2b;
        border: none;
        padding: 1rem 2rem;
        border-radius: 50px;
        font-family: "Archivo Black", sans-serif;
        font-size: 1.1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        text-transform: uppercase;
        box-shadow: 0 4px 15px rgba(255, 222, 89, 0.4);
        width: 100%;
        margin-top: 1rem;
    }

    .submit-btn:hover:not(:disabled) {
        transform: scale(1.02) translateY(-2px);
        box-shadow: 0 6px 20px rgba(255, 222, 89, 0.6);
        color: #000;
    }
    
    .submit-btn:disabled {
        background: #e0e0e0;
        color: #a0a0a0;
        cursor: not-allowed;
        box-shadow: none;
    }
    
    .header-login-btn {
        /* Matching style for login in header */
        background: linear-gradient(135deg, #ffd700 0%, #ffed4e 50%, #ffd700 100%);
        color: #2b2b2b;
        border: none;
        padding: 0.8rem 2rem;
        border-radius: 50px;
        font-family: "Archivo Black", sans-serif;
        font-size: 1rem;
        font-weight: 800;
        text-transform: uppercase;
        cursor: pointer;
        box-shadow: 0 4px 10px rgba(255, 222, 89, 0.3);
        transition: all 0.3s;
    }
    .header-login-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 15px rgba(255, 222, 89, 0.5);
    }

    /* SCORERS */
    .scorers-section {
        margin-top: 2rem;
        border-top: 1px solid #f0f0f0;
        padding-top: 1.5rem;
    }
    .scorers-title {
        font-size: 1rem; font-weight: 800; text-transform: uppercase; margin-bottom: 1.5rem;
        color: var(--primary); text-align: center; letter-spacing: 1px;
    }
    .scorers-select-container {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 1rem;
        max-height: 400px; overflow-y: auto; padding: 0.5rem;
    }
    .scorer-chip {
        display: flex; flex-direction: column; align-items: center; gap: 0.5rem; padding: 0.8rem;
        background: white; border-radius: 8px; cursor: pointer; transition: all 0.2s;
        border: 2px solid transparent; text-align: center; user-select: none;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }
    .scorer-chip:hover { transform: translateY(-3px); box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
    .scorer-chip.selected { background: #fafafa; border-color: var(--accent); }
    .scorer-chip.selected .chip-image-container { border-color: var(--accent); }
    .chip-image-container {
        width: 60px; height: 60px; border-radius: 50%; overflow: hidden; background: #f0f0f0;
        border: 2px solid #fff; box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
    .chip-img { width: 100%; height: 100%; object-fit: cover; object-position: top center; }
    .chip-info { display: flex; flex-direction: column; line-height: 1; gap: 0.2rem; }
    .player-num { font-size: 0.75rem; font-weight: 700; color: #999; }
    .player-name-chip { font-size: 0.9rem; font-weight: 700; color: #333; }
    .scorer-chip.selected .player-name-chip { color: var(--accent); }

    /* LEADERBOARD TABLE */
    .leaderboard-table-wrapper {
        overflow-x: auto;
    }
    .leaderboard-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }
    .leaderboard-table th {
        padding: 1rem;
        font-weight: 800;
        font-size: 0.85rem;
        color: #888;
        border-bottom: 2px solid #f0f0f0;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .leaderboard-table td {
        padding: 1rem;
        border-bottom: 1px solid #f5f5f5;
        vertical-align: middle;
    }
    .leaderboard-table tr:last-child td { border-bottom: none; }
    
    .leaderboard-table tr:hover {
        background-color: #fafafa;
    }

    .th-pos, .td-pos { width: 50px; text-align: center; }
    .th-pts, .td-pts { width: 80px; text-align: center; }
    
    .td-pos {
        font-weight: 700; color: #ccc;
    }
    .top-3 .td-pos { color: #d4af37; font-size: 1.2rem; font-weight: 900; }
    .top-3 { background-color: #fffdf5; }

    .user-cell { display: flex; align-items: center; gap: 0.8rem; }
    .user-avatar-placeholder {
        width: 32px; height: 32px; background: #eee; color: #555;
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        font-size: 0.8rem; font-weight: 800; flex-shrink: 0;
    }
    .top-3 .user-avatar-placeholder { background: var(--accent); color: var(--primary); }
    .user-id { font-weight: 600; font-size: 0.95rem; color: var(--primary); }
    
    .pts-badge {
        background: #f0f0f0; color: #333; padding: 0.3rem 0.6rem;
        border-radius: 6px; font-weight: 800; font-size: 0.9rem;
    }
    .top-3 .pts-badge { background: var(--accent); color: var(--primary); }

    .empty-state { text-align: center; padding: 2rem; color: #999; font-style: italic; }
    .feedback-msg { margin-top: 1rem; font-weight: 600; text-align: center; }
    .feedback-msg.success { color: #2ecc71; }
    .feedback-msg.error { color: #e74c3c; }

    @media (max-width: 600px) {
        .score-board-container input { width: 50px; font-size: 2.8rem; }
    }
</style>
