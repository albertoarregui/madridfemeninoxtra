---
import Layout from "../layouts/Layout.astro";
import { createClient } from "@libsql/client";

const url = import.meta.env.TURSO_DATABASE_URL;
const authToken = import.meta.env.TURSO_AUTH_TOKEN;

const client = createClient({ url, authToken });

const { rows: stats } = await client.execute(
    "SELECT * FROM goles_y_asistencias LIMIT 50",
);
const { rows: matches } = await client.execute(
    "SELECT id_partido, club_local, club_visitante, fecha FROM partidos ORDER BY fecha DESC LIMIT 10",
);
---

<Layout title="Debug DB">
    <main style="padding: 2rem;">
        <h1>Debug DB Data</h1>

        <h2>Goles y Asistencias (First 50)</h2>
        <div style="overflow: auto; max-height: 400px; border: 1px solid #ccc;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #eee;">
                        {
                            stats.length > 0 &&
                                Object.keys(stats[0]).map((k) => (
                                    <th style="padding: 5px; border: 1px solid #ddd;">
                                        {k}
                                    </th>
                                ))
                        }
                    </tr>
                </thead>
                <tbody>
                    {
                        stats.map((row) => (
                            <tr>
                                {Object.values(row).map((v: any) => (
                                    <td style="padding: 5px; border: 1px solid #ddd;">
                                        {String(v)}
                                    </td>
                                ))}
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>

        <h2>Recent Matches</h2>
        <div style="overflow: auto; max-height: 400px; border: 1px solid #ccc;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #eee;">
                        {
                            matches.length > 0 &&
                                Object.keys(matches[0]).map((k) => (
                                    <th style="padding: 5px; border: 1px solid #ddd;">
                                        {k}
                                    </th>
                                ))
                        }
                    </tr>
                </thead>
                <tbody>
                    {
                        matches.map((row) => (
                            <tr>
                                {Object.values(row).map((v: any) => (
                                    <td style="padding: 5px; border: 1px solid #ddd;">
                                        {String(v)}
                                    </td>
                                ))}
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>
    </main>
</Layout>
