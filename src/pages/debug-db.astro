---
import Layout from "../layouts/Layout.astro";
import { getDbClient, getPlayersDbClient } from "../db/client";

async function testDb(name: string, clientFunc: any) {
    const startTime = Date.now();
    try {
        const client = await clientFunc();
        if (!client) {
            return {
                name,
                status: "ERROR",
                message: "Client creation failed (check logs)",
                time: Date.now() - startTime,
            };
        }
        const result = await client.execute("SELECT 1 as test");
        return {
            name,
            status: "SUCCESS",
            message: "Connected and queried SELECT 1 successfully",
            rows: result.rows.length,
            time: Date.now() - startTime,
        };
    } catch (e: any) {
        return {
            name,
            status: "FAILED",
            message: e.message || "Unknown error",
            code: e.code || "No code",
            time: Date.now() - startTime,
        };
    }
}

const awardsTest = await testDb("AWARDS", getDbClient);
const statsTest = await testDb("STATS", getPlayersDbClient);

// Test a real query on stats
let statsQueryTest = {
    name: "STATS (Real Query)",
    status: "PENDING",
    message: "",
};
try {
    const client = await getPlayersDbClient();
    if (client) {
        const res = await client.execute(
            "SELECT COUNT(*) as count FROM partidos",
        );
        statsQueryTest = {
            name: "STATS (Real Query)",
            status: "SUCCESS",
            message: `Counted ${res.rows[0].count} matches in 'partidos' table`,
        };
    }
} catch (e: any) {
    statsQueryTest = {
        name: "STATS (Real Query)",
        status: "FAILED",
        message:
            e.message || "Table 'partidos' might not exist or quota exceeded",
    };
}
---

<Layout title="Database Debug">
    <main
        style="padding: 2rem; max-width: 800px; margin: 0 auto; font-family: sans-serif;"
    >
        <h1
            style="color: #1a202c; border-bottom: 2px solid #e2e8f0; padding-bottom: 1rem;"
        >
            DB Diagnostic Tool
        </h1>

        <p style="margin-bottom: 2rem; color: #4a5568;">
            Use this page to verify Turso database connections and quotas.
        </p>

        <section style="margin-bottom: 2rem;">
            <h2 style="font-size: 1.25rem; margin-bottom: 1rem;">Results:</h2>

            {
                [awardsTest, statsTest, statsQueryTest].map((test) => (
                    <div
                        style={`
                    padding: 1.5rem; 
                    border-radius: 8px; 
                    margin-bottom: 1rem; 
                    border-left: 5px solid ${test.status === "SUCCESS" ? "#48bb78" : "#f56565"};
                    background: ${test.status === "SUCCESS" ? "#f0fff4" : "#fff5f5"};
                `}
                    >
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <strong style="font-size: 1.1rem;">
                                {test.name}
                            </strong>
                            <span
                                style={`
                            padding: 0.25rem 0.75rem; 
                            border-radius: 999px; 
                            font-size: 0.8rem; 
                            font-weight: bold;
                            background: ${test.status === "SUCCESS" ? "#c6f6d5" : "#fed7d7"};
                            color: ${test.status === "SUCCESS" ? "#22543d" : "#822727"};
                        `}
                            >
                                {test.status}
                            </span>
                        </div>
                        <p style="margin: 0.5rem 0; color: #2d3748;">
                            {test.message}
                        </p>
                        {test.time && (
                            <small style="color: #718096;">
                                Response time: {test.time}ms
                            </small>
                        )}
                    </div>
                ))
            }
        </section>

        <div
            style="background: #edf2f7; padding: 1rem; border-radius: 8px; font-size: 0.9rem;"
        >
            <p>
                <strong>Note:</strong> If you see "quota exceeded" or "usage limit",
                you need to upgrade your Turso plan or wait until the next billing
                cycle.
            </p>
        </div>

        <div style="margin-top: 2rem;">
            <a href="/" style="color: #3182ce; text-decoration: none;"
                >&larr; Return to Home</a
            >
        </div>
    </main>
</Layout>
