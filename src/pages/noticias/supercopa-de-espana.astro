---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import "../../styles/noticias.css";

const PAGE_TITLE = "SUPERCOPA DE ESPAÑA";
const CATEGORY_FILTER = "supercopa";
---

<Layout
    title={`${PAGE_TITLE} | Madrid Femenino Xtra`}
    description={`Últimas noticias de la ${PAGE_TITLE} relacionadas con el Real Madrid Femenino.`}
>
    <main class="noticias-page">
        <div class="container">
            <header>
                <h1 class="page-title">{PAGE_TITLE}</h1>
                <h2 class="content-h2">
                    Última hora del Real Madrid femenino en directo: actualidad,
                    próximos partidos y fichajes en Liga F, UWCL, Copa de la
                    Reina y Supercopa de España.
                </h2>
            </header>

            <div class="noticias-grid"></div>
            <p class="no-category-news" style="display: none;">
                No hay noticias disponibles en esta categoría.
            </p>
        </div>
    </main>

    <script is:inline define:vars={{ CATEGORY_FILTER }}>
        const WP_URL =
            "https://cms.madridfemeninoxtra.com/wp-json/wp/v2/posts?per_page=30&_embed=true";

        function formatDate(dateString) {
            const date = new Date(dateString);
            return new Intl.DateTimeFormat("es-ES", {
                year: "numeric",
                month: "long",
                day: "numeric",
            }).format(date);
        }

        function createNewsCard(noticia) {
            const featuredImage =
                noticia._embedded?.["wp:featuredmedia"]?.[0]?.source_url;
            const featuredImageAlt =
                noticia._embedded?.["wp:featuredmedia"]?.[0]?.alt_text ||
                noticia.title.rendered;

            const link = `/noticias/${noticia.slug}`;

            return `
                <article class="noticia-card" onclick="window.location.href='${link}'" style="cursor: pointer;">
                    ${
                        featuredImage
                            ? `
                        <div class="noticia-image">
                            <img src="${featuredImage}" alt="${featuredImageAlt}" loading="lazy" />
                        </div>
                    `
                            : ""
                    }
                    <div class="noticia-content">
                        <div class="noticia-meta">
                            <time datetime="${noticia.date}">${formatDate(noticia.date)}</time>
                        </div>
                        <h2 class="noticia-title">${noticia.title.rendered}</h2>
                        <div class="noticia-excerpt">${noticia.excerpt.rendered}</div>
                        <a href="${link}" class="read-more">
                            Leer más
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M5 12h14M12 5l7 7-7 7" />
                            </svg>
                        </a>
                    </div>
                </article>
            `;
        }

        async function loadNews() {
            const grid = document.querySelector(".noticias-grid");
            const noNews = document.querySelector(".no-category-news");

            try {
                const response = await fetch(WP_URL);
                if (!response.ok) throw new Error("Failed to fetch");

                const posts = await response.json();

                const filtered = posts.filter((p) =>
                    p._embedded?.["wp:term"]?.[0]?.some((cat) =>
                        cat.name.toLowerCase().includes(CATEGORY_FILTER),
                    ),
                );

                if (filtered.length > 0) {
                    grid.innerHTML = filtered.map(createNewsCard).join("");
                    if (noNews) noNews.style.display = "none";
                } else {
                    grid.style.display = "none";
                    if (noNews) noNews.style.display = "block";
                }
            } catch (error) {
                console.error("Error loading news:", error);
                if (noNews) {
                    noNews.textContent = "Error al cargar las noticias.";
                    noNews.style.display = "block";
                }
            }
        }

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", loadNews);
        } else {
            loadNews();
        }
    </script>
</Layout>
