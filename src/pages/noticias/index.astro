---
import Layout from "../../layouts/Layout.astro";
import { contentfulClient } from "../../lib/contentful";
import NewsArchive from "../../components/NewsArchive";

export const prerender = false;

let noticias: any[] = [];
let error = null;

try {
    const entries = await contentfulClient.getEntries({
        content_type: "noticia",
        order: ["-sys.createdAt"],
    });
    noticias = entries.items.map((item: any) => ({
        ...item.fields,
        id: item.sys.id,
        createdAt: item.sys.createdAt,
        updatedAt: item.sys.updatedAt,
    }));
} catch (e: any) {
    console.error("Error fetching news:", e);
    error = e.message;
}

const title = "Noticias | Madrid Femenino Xtra";
const description = "Todas las noticias, actualidad y última hora del Real Madrid Femenino.";
---

<Layout title={title} description={description}>
    <main class="news-archive-page">
        <header class="page-header-container">
            <h1 class="landing-title">NOTICIAS</h1>
            <p class="landing-subtitle">Toda la actualidad del Real Madrid Femenino</p>
        </header>

        <section class="news-grid-section">
            <div class="container">
                {error && <p class="error-message">Error cargando las noticias: {error}</p>}
                
                <NewsArchive noticias={noticias} client:load />
            </div>
        </section>
    </main>
</Layout>

<style>
    .news-archive-page {
        background-color: #fdfdfd;
        min-height: 100vh;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    @media (max-width: 768px) {
        .news-archive-page {
            padding-top: 1rem;
        }
    }
</style>
