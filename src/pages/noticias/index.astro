---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import "../../styles/noticias.css";

interface Noticia {
    id: number;
    title: string;
    excerpt: string;
    content: string;
    slug: string;
    date: string;
    link: string;
    featuredImage?: string;
    featuredImageAlt?: string;
    categories: string[];
}

interface Pagination {
    currentPage: number;
    perPage: number;
    totalPosts: number;
    totalPages: number;
}

// Las noticias se cargarán en el cliente
let noticias: Noticia[] = [];
let error: string | null = null;
let pagination: Pagination | null = null;

function formatDate(dateString: string) {
    const date = new Date(dateString);
    return new Intl.DateTimeFormat("es-ES", {
        year: "numeric",
        month: "long",
        day: "numeric",
    }).format(date);
}
---

<Layout
    title="Noticias del Real Madrid Femenino | Madrid Femenino Xtra"
    description="Última hora del Real Madrid femenino en directo: actualidad, próximos partidos y fichajes en Liga F, UWCL, Copa de la Reina y Supercopa de España."
>
    <main class="noticias-page">
        <div class="container">
            <header>
                <h1 class="page-title">NOTICIAS</h1>
                <h2 class="content-h2">
                    Última hora del Real Madrid femenino en directo: actualidad,
                    próximos partidos y fichajes en Liga F, UWCL, Copa de la
                    Reina y Supercopa de España.
                </h2>
            </header>

            {/* PREVIAS */}
            <>
                <h2 class="section-title">PREVIAS</h2>
                {
                    error ? (
                        <p class="no-category-news">
                            Error al conectar con el servidor.
                        </p>
                    ) : noticias.filter((n) =>
                          n.categories.some((cat) =>
                              cat.toLowerCase().includes("previas"),
                          ),
                      ).length > 0 ? (
                        <div class="noticias-grid">
                            {noticias
                                .filter((n) =>
                                    n.categories.some((cat) =>
                                        cat.toLowerCase().includes("previas"),
                                    ),
                                )
                                .map((noticia) => (
                                    <article class="noticia-card">
                                        {noticia.featuredImage && (
                                            <div class="noticia-image">
                                                <img
                                                    src={noticia.featuredImage}
                                                    alt={
                                                        noticia.featuredImageAlt ||
                                                        noticia.title
                                                    }
                                                    loading="lazy"
                                                />
                                            </div>
                                        )}
                                        <div class="noticia-content">
                                            <div class="noticia-meta">
                                                <time datetime={noticia.date}>
                                                    {formatDate(noticia.date)}
                                                </time>
                                                {noticia.categories.length >
                                                    0 && (
                                                    <span class="category">
                                                        {noticia.categories[0]}
                                                    </span>
                                                )}
                                            </div>
                                            <h2 class="noticia-title">
                                                {noticia.title}
                                            </h2>
                                            <div
                                                class="noticia-excerpt"
                                                set:html={noticia.excerpt}
                                            />
                                            <a
                                                href={noticia.link}
                                                class="read-more"
                                            >
                                                Leer más
                                                <svg
                                                    xmlns="http://www.w3.org/2000/svg"
                                                    width="16"
                                                    height="16"
                                                    viewBox="0 0 24 24"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    stroke-width="2"
                                                >
                                                    <path d="M5 12h14M12 5l7 7-7 7" />
                                                </svg>
                                            </a>
                                        </div>
                                    </article>
                                ))}
                        </div>
                    ) : (
                        <p class="no-category-news">
                            No hay previas disponibles.
                        </p>
                    )
                }
            </>

            {/* LIGA F */}
            <>
                <h2 class="section-title">LIGA F</h2>
                {
                    error ? (
                        <p class="no-category-news">
                            Error al conectar con el servidor.
                        </p>
                    ) : noticias.filter((n) =>
                          n.categories.some(
                              (cat) => cat.toLowerCase() === "liga f",
                          ),
                      ).length > 0 ? (
                        <div class="noticias-grid">
                            {noticias
                                .filter((n) =>
                                    n.categories.some(
                                        (cat) => cat.toLowerCase() === "liga f",
                                    ),
                                )
                                .map((noticia) => (
                                    <article class="noticia-card">
                                        {noticia.featuredImage && (
                                            <div class="noticia-image">
                                                <img
                                                    src={noticia.featuredImage}
                                                    alt={
                                                        noticia.featuredImageAlt ||
                                                        noticia.title
                                                    }
                                                    loading="lazy"
                                                />
                                            </div>
                                        )}
                                        <div class="noticia-content">
                                            <div class="noticia-meta">
                                                <time datetime={noticia.date}>
                                                    {formatDate(noticia.date)}
                                                </time>
                                                {noticia.categories.length >
                                                    0 && (
                                                    <span class="category">
                                                        {noticia.categories[0]}
                                                    </span>
                                                )}
                                            </div>
                                            <h2 class="noticia-title">
                                                {noticia.title}
                                            </h2>
                                            <div
                                                class="noticia-excerpt"
                                                set:html={noticia.excerpt}
                                            />
                                            <a
                                                href={noticia.link}
                                                class="read-more"
                                            >
                                                Leer más
                                                <svg
                                                    xmlns="http://www.w3.org/2000/svg"
                                                    width="16"
                                                    height="16"
                                                    viewBox="0 0 24 24"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    stroke-width="2"
                                                >
                                                    <path d="M5 12h14M12 5l7 7-7 7" />
                                                </svg>
                                            </a>
                                        </div>
                                    </article>
                                ))}
                        </div>
                    ) : (
                        <p class="no-category-news">
                            No hay noticias de Liga F disponibles.
                        </p>
                    )
                }
            </>

            {/* UWCL */}
            <>
                <h2 class="section-title">UWCL</h2>
                {
                    error ? (
                        <p class="no-category-news">
                            Error al conectar con el servidor.
                        </p>
                    ) : noticias.filter((n) =>
                          n.categories.some(
                              (cat) => cat.toLowerCase() === "uwcl",
                          ),
                      ).length > 0 ? (
                        <div class="noticias-grid">
                            {noticias
                                .filter((n) =>
                                    n.categories.some(
                                        (cat) => cat.toLowerCase() === "uwcl",
                                    ),
                                )
                                .map((noticia) => (
                                    <article class="noticia-card">
                                        {noticia.featuredImage && (
                                            <div class="noticia-image">
                                                <img
                                                    src={noticia.featuredImage}
                                                    alt={
                                                        noticia.featuredImageAlt ||
                                                        noticia.title
                                                    }
                                                    loading="lazy"
                                                />
                                            </div>
                                        )}
                                        <div class="noticia-content">
                                            <div class="noticia-meta">
                                                <time datetime={noticia.date}>
                                                    {formatDate(noticia.date)}
                                                </time>
                                                {noticia.categories.length >
                                                    0 && (
                                                    <span class="category">
                                                        {noticia.categories[0]}
                                                    </span>
                                                )}
                                            </div>
                                            <h2 class="noticia-title">
                                                {noticia.title}
                                            </h2>
                                            <div
                                                class="noticia-excerpt"
                                                set:html={noticia.excerpt}
                                            />
                                            <a
                                                href={noticia.link}
                                                class="read-more"
                                            >
                                                Leer más
                                                <svg
                                                    xmlns="http://www.w3.org/2000/svg"
                                                    width="16"
                                                    height="16"
                                                    viewBox="0 0 24 24"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    stroke-width="2"
                                                >
                                                    <path d="M5 12h14M12 5l7 7-7 7" />
                                                </svg>
                                            </a>
                                        </div>
                                    </article>
                                ))}
                        </div>
                    ) : (
                        <p class="no-category-news">
                            No hay noticias de UWCL disponibles.
                        </p>
                    )
                }
            </>
        </div>
        ) }
    </main>

    <script is:inline>
        const WP_URL =
            "https://cms.madridfemeninoxtra.com/wp-json/wp/v2/posts?per_page=50&_embed=true";

        function formatDate(dateString) {
            const date = new Date(dateString);
            return new Intl.DateTimeFormat("es-ES", {
                year: "numeric",
                month: "long",
                day: "numeric",
            }).format(date);
        }

        function createNewsCard(noticia) {
            const featuredImage =
                noticia._embedded?.["wp:featuredmedia"]?.[0]?.source_url;
            const featuredImageAlt =
                noticia._embedded?.["wp:featuredmedia"]?.[0]?.alt_text ||
                noticia.title.rendered;
            const categories =
                noticia._embedded?.["wp:term"]?.[0]?.map((cat) => cat.name) ||
                [];

            const link = `/noticias/${noticia.slug}`;

            return `
                <article class="noticia-card" onclick="window.location.href='${link}'" style="cursor: pointer;">
                    ${
                        featuredImage
                            ? `
                        <div class="noticia-image">
                            <img src="${featuredImage}" alt="${featuredImageAlt}" loading="lazy" />
                        </div>
                    `
                            : ""
                    }
                    <div class="noticia-content">
                        <div class="noticia-meta">
                            <time datetime="${noticia.date}">${formatDate(noticia.date)}</time>
                            ${categories.length > 0 ? `<span class="category">${categories[0]}</span>` : ""}
                        </div>
                        <h2 class="noticia-title">${noticia.title.rendered}</h2>
                        <div class="noticia-excerpt">${noticia.excerpt.rendered}</div>
                        <a href="${link}" class="read-more">
                            Leer más
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M5 12h14M12 5l7 7-7 7" />
                            </svg>
                        </a>
                    </div>
                </article>
            `;
        }

        async function loadNews() {
            try {
                const response = await fetch(WP_URL);
                if (!response.ok) throw new Error("Failed to fetch");

                const posts = await response.json();

                // Find all sections and grids
                const sections = [
                    {
                        filter: (cat) => cat.toLowerCase().includes("previa"),
                        containerIndex: 0,
                    },
                    {
                        filter: (cat) => cat.toLowerCase() === "liga f",
                        containerIndex: 1,
                    },
                    {
                        filter: (cat) => cat.toLowerCase() === "uwcl",
                        containerIndex: 2,
                    },
                    {
                        filter: (cat) =>
                            cat.toLowerCase() === "uncategorized" ||
                            cat.toLowerCase() === "sin categoría",
                        containerIndex: 3,
                    },
                ];

                const grids = document.querySelectorAll(".noticias-grid");
                const noNewsMessages =
                    document.querySelectorAll(".no-category-news");

                sections.forEach((section, idx) => {
                    const filtered = posts.filter((p) =>
                        p._embedded?.["wp:term"]?.[0]?.some((cat) =>
                            section.filter(cat.name),
                        ),
                    );

                    const grid = grids[idx];
                    const noNews = noNewsMessages[idx];

                    if (filtered.length > 0 && grid) {
                        grid.innerHTML = filtered.map(createNewsCard).join("");
                        if (noNews) noNews.style.display = "none";
                    } else if (grid) {
                        grid.style.display = "none";
                    }
                });
            } catch (error) {
                console.error("Error loading news:", error);
            }
        }

        // Load news when page is ready
        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", loadNews);
        } else {
            loadNews();
        }
    </script>
</Layout>
