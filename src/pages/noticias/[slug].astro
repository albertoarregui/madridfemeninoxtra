---
import Layout from "../../layouts/Layout.astro";
import { documentToHtmlString } from "@contentful/rich-text-html-renderer";
import { getAssetUrl } from "../../utils/assets";
import { fetchPlayersDirectly, fetchPlayerStats } from "../../utils/players";
import {
    fetchCoachesDirectly,
    fetchCoachStats,
} from "../../utils/entrenadores";
import { fetchRefereesDirectly } from "../../utils/arbitras";
import { fetchRivalsDirectly, getRivalShieldUrl } from "../../utils/rivales";
import { fetchGames } from "../../utils/partidos";

export const prerender = false;

const { slug } = Astro.params;

let noticia = null;

try {
    const { contentfulClient } = await import("../../lib/contentful");
    const entries = await contentfulClient.getEntries({
        content_type: "noticia",
        "fields.slug": slug,
        limit: 1,
    });

    if (entries && entries.items.length > 0) {
        noticia = entries.items[0].fields;
    }
} catch (e: any) {
    console.warn("Error consultando Contentful:", e);
}

if (!noticia) {
    return Astro.redirect("/404");
}

const { title, subtitle, player, category, focusType, referenceId, id } =
    noticia;

const contentReferenceId = referenceId || id;

const featuredImageUrl = noticia.featuredImage?.fields?.file?.url
    ? `https:${noticia.featuredImage.fields.file.url}`
    : "https://res.cloudinary.com/dnx7vsqbi/image/upload/v1741372500/background/stadium.webp";

let bodyHtml = ``;

if (noticia.body) {
    try {
        if (typeof noticia.body === "string") {
            bodyHtml = `<p>${noticia.body}</p>`;
        } else if (noticia.body.nodeType === "document") {
            bodyHtml = documentToHtmlString(noticia.body);
        } else {
            bodyHtml = `<p>Error de formato.</p>`;
        }
    } catch (e) {
        console.error("Error al procesar el Rich Text de Contentful:", e);
        bodyHtml = `<p>Ocurrió un error leyendo el contenido.</p>`;
    }
}

let playerData: any = null;
let playerStats: any = null;
let coachData: any = null;
let coachStats: any = null;
let clubData: any = null;
let refereeData: any = null;
let matchData: any = null;
let matchLineup: any[] = [];

if (focusType === "player" && (contentReferenceId || player)) {
    const allPlayers = await fetchPlayersDirectly();
    playerData =
        allPlayers.find(
            (p) => p.nombre.toLowerCase() === player?.toLowerCase(),
        ) ||
        allPlayers.find((p) =>
            p.nombre.toLowerCase().includes(player?.toLowerCase() || ""),
        ) ||
        allPlayers.find(
            (p) => String(p.id_jugadora) === String(contentReferenceId),
        );

    if (playerData) {
        const statsResponse = await fetchPlayerStats(
            playerData.id_jugadora,
            playerData.posicion === "Portera",
        );

        if (statsResponse?.estadisticas?.length > 0) {
            const sortedSeasons = [...statsResponse.estadisticas].sort(
                (a: any, b: any) =>
                    (b.temporada || "").localeCompare(a.temporada || ""),
            );
            const currentSeason = sortedSeasons[0];

            playerStats = {
                ...statsResponse,
                current_official: currentSeason.official_total,
                season_name: currentSeason.temporada,
            };
        } else {
            playerStats = statsResponse;
        }
    }
}

if (focusType === "coach") {
    const coaches = await fetchCoachesDirectly();
    coachData = contentReferenceId
        ? coaches.find(
              (c) => String(c.id_entrenador) === String(contentReferenceId),
          )
        : coaches.find((c) => c.nombre?.toLowerCase().includes("toril"));

    if (coachData) {
        const statsResp = await fetchCoachStats(coachData.id_entrenador);
        if (statsResp?.estadisticas?.length > 0) {
            const sorted = [...statsResp.estadisticas].sort((a: any, b: any) =>
                (b.temporada || "").localeCompare(a.temporada || ""),
            );
            const currentSeason = sorted[0];
            const officialComps = [
                "Liga F",
                "UWCL",
                "Copa de la Reina",
                "Supercopa de España",
            ];
            const officialTotal = currentSeason.competiciones
                .filter((c: any) => officialComps.includes(c.competicion))
                .reduce(
                    (acc: any, c: any) => ({
                        partidos: acc.partidos + c.partidos,
                        victorias: acc.victorias + c.victorias,
                        empates: acc.empates + c.empates,
                        derrotas: acc.derrotas + c.derrotas,
                        goles_favor: acc.goles_favor + c.goles_favor,
                        goles_contra: acc.goles_contra + c.goles_contra,
                    }),
                    {
                        partidos: 0,
                        victorias: 0,
                        empates: 0,
                        derrotas: 0,
                        goles_favor: 0,
                        goles_contra: 0,
                    },
                );
            coachStats = {
                current_official: officialTotal,
                season_name: currentSeason.temporada,
            };
        }
    }
}

if (focusType === "referee") {
    const referees = await fetchRefereesDirectly();
    refereeData = contentReferenceId
        ? referees.find(
              (r) => String(r.id_arbitra) === String(contentReferenceId),
          )
        : referees[0];
}

if (focusType === "club") {
    const rivals = await fetchRivalsDirectly();
    clubData = contentReferenceId
        ? rivals.find((r) => String(r.id_club) === String(contentReferenceId))
        : rivals[0];
}

if (focusType === "match" && contentReferenceId) {
    try {
        const allMatches = await fetchGames();
        matchData = allMatches.find(
            (m: any) => String(m.id_partido) === String(contentReferenceId),
        );
        if (matchData) {
            const { getPlayersDbClient } = await import("../../db/client");
            const client = await getPlayersDbClient();
            if (client) {
                const lineupResult = await client.execute({
                    sql: `SELECT al.*, j.nombre, j.posicion, j.foto_url,
                            (SELECT COUNT(*) FROM goles_y_asistencias g WHERE g.id_partido = al.id_partido AND g.goleadora = al.id_jugadora) as goles,
                            (SELECT COUNT(*) FROM goles_y_asistencias g WHERE g.id_partido = al.id_partido AND g.asistente = al.id_jugadora) as asistencias
                          FROM alineaciones al
                          JOIN jugadoras j ON al.id_jugadora = j.id_jugadora
                          WHERE al.id_partido = ? AND al.titular = 1
                          ORDER BY j.posicion`,
                    args: [contentReferenceId],
                });
                matchLineup = (lineupResult?.rows || []) as any[];
            }
        }
    } catch (e) {
        console.warn("Error fetching match data:", e);
    }
}

const posOrder = ["Portera", "Defensa", "Centrocampista", "Delantera"];
const matchRows: Record<string, any[]> = {};
matchLineup.forEach((p: any) => {
    const pos = p.posicion || "Centrocampista";
    const key =
        posOrder.find((o) =>
            pos.toLowerCase().startsWith(o.slice(0, 4).toLowerCase()),
        ) || "Centrocampista";
    if (!matchRows[key]) matchRows[key] = [];
    matchRows[key].push(p);
});
const matchRowsOrdered = posOrder
    .map((k) => ({ key: k, players: matchRows[k] || [] }))
    .filter((r) => r.players.length > 0);
---

<Layout
    title={`${title} | Madrid Femenino Xtra`}
    description={`Descubre el hito histórico de ${player} en el Real Madrid Femenino.`}
>
    <article class="news-detail-page">
        <div class="news-full-white-row">
            <div class="news-content-limit">
                <div class="news-back-link-wrapper">
                    <a href="/" class="news-back-link">
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                        </svg>
                        Volver a la página principal
                    </a>
                </div>

                <div class="news-featured-photo">
                    <img
                        src={featuredImageUrl}
                        alt={title}
                        class="featured-news-img"
                    />
                </div>

                <div class="news-main-body-content">
                    <header class="news-header-section centered">
                        <span class="news-category-capsule">
                            {category}
                        </span>

                        <h1 class="news-main-title">{title}</h1>

                        <p class="news-main-subtitle">
                            {subtitle}
                        </p>

                        <div class="news-social-icons">
                            <a href="#" class="social-circle x" aria-label="X">
                                <img src={getAssetUrl("redes", "x")} alt="X" />
                            </a>
                            <a
                                href="#"
                                class="social-circle instagram"
                                aria-label="Instagram"
                            >
                                <img
                                    src={getAssetUrl("redes", "instagram")}
                                    alt="Instagram"
                                />
                            </a>
                            <a
                                href="#"
                                class="social-circle tiktok"
                                aria-label="TikTok"
                            >
                                <img
                                    src={getAssetUrl("redes", "tiktok")}
                                    alt="TikTok"
                                />
                            </a>
                        </div>

                        <div class="news-meta-row">
                            <time class="news-publish-date">
                                {
                                    noticia.publishDate
                                        ? new Date(noticia.publishDate)
                                              .toLocaleDateString("es-ES", {
                                                  year: "numeric",
                                                  month: "long",
                                                  day: "numeric",
                                              })
                                              .toUpperCase()
                                        : "7 DE AGOSTO DE 2026"
                                }
                            </time>
                        </div>

                        <div class="news-separator-thin"></div>
                    </header>

                    <div class="news-article-rich-text">
                        <div set:html={bodyHtml} />
                    </div>

                    <hr class="section-separator-simple" />

                    <div class="news-footer-widgets">
                        {
                            focusType === "player" && (
                                <div class="dashboard-widget-card-refined">
                                    <div class="widget-top-info">
                                        <div class="widget-avatar-wrapper">
                                            <img
                                                src={
                                                    playerData?.imageUrl ||
                                                    "https://res.cloudinary.com/dnx7vsqbi/image/upload/v1741372500/jugadoras/default.webp"
                                                }
                                                alt={player}
                                                class="widget-avatar"
                                            />
                                        </div>
                                        <div class="widget-name-box">
                                            <h3 class="widget-title-small">
                                                {player}
                                            </h3>
                                            <span class="widget-subtitle-pos">
                                                {playerData?.posicion ||
                                                    "JUGADORA"}
                                            </span>
                                        </div>
                                    </div>

                                    <div
                                        class={`widget-stats-grid-compact ${playerData?.posicion?.toLowerCase() === "portera" ? "grid-3" : "grid-4"}`}
                                    >
                                        <div class="widget-stat-unit">
                                            <span class="stat-num">
                                                {playerStats?.current_official
                                                    ?.partidos ?? "0"}
                                            </span>
                                            <span class="stat-tag">
                                                PARTIDOS
                                            </span>
                                        </div>
                                        <div class="widget-stat-unit">
                                            <span class="stat-num">
                                                {playerStats?.current_official
                                                    ?.minutos ?? "0"}
                                            </span>
                                            <span class="stat-tag">
                                                MINUTOS
                                            </span>
                                        </div>
                                        {playerData?.posicion?.toLowerCase() ===
                                        "portera" ? (
                                            <div class="widget-stat-unit">
                                                <span class="stat-num">
                                                    {playerStats
                                                        ?.current_official
                                                        ?.porterias_cero ?? "0"}
                                                </span>
                                                <span class="stat-tag">
                                                    P. CERO
                                                </span>
                                            </div>
                                        ) : (
                                            <>
                                                <div class="widget-stat-unit">
                                                    <span class="stat-num">
                                                        {playerStats
                                                            ?.current_official
                                                            ?.goles ?? "0"}
                                                    </span>
                                                    <span class="stat-tag">
                                                        GOLES
                                                    </span>
                                                </div>
                                                <div class="widget-stat-unit">
                                                    <span class="stat-num">
                                                        {playerStats
                                                            ?.current_official
                                                            ?.asistencias ??
                                                            "0"}
                                                    </span>
                                                    <span class="stat-tag">
                                                        ASISTENCIAS
                                                    </span>
                                                </div>
                                            </>
                                        )}
                                    </div>
                                    <a
                                        href={`/jugadoras/${playerData?.slug || player?.toLowerCase().replace(/ /g, "-")}`}
                                        class="widget-cta-btn-premium"
                                    >
                                        VER PERFIL COMPLETO
                                    </a>
                                </div>
                            )
                        }

                        {
                            focusType === "coach" && coachData && (
                                <div class="dashboard-widget-card-refined">
                                    <div class="widget-top-info">
                                        <div class="widget-avatar-wrapper">
                                            <img
                                                src={coachData.imageUrl}
                                                alt={coachData.nombre}
                                                class="widget-avatar"
                                            />
                                        </div>
                                        <div class="widget-name-box">
                                            <h3 class="widget-title-small">
                                                {coachData.nombre.toUpperCase()}
                                            </h3>
                                            <span class="widget-subtitle-pos">
                                                ENTRENADORA
                                            </span>
                                        </div>
                                    </div>
                                    <p class="widget-season-label">
                                        {coachStats?.season_name} · Competición
                                        oficial
                                    </p>
                                    <div class="widget-stats-grid-compact grid-4">
                                        <div class="widget-stat-unit">
                                            <span class="stat-num">
                                                {coachStats?.current_official
                                                    ?.victorias ?? 0}
                                            </span>
                                            <span class="stat-tag">
                                                VICTORIAS
                                            </span>
                                        </div>
                                        <div class="widget-stat-unit">
                                            <span class="stat-num">
                                                {coachStats?.current_official
                                                    ?.empates ?? 0}
                                            </span>
                                            <span class="stat-tag">
                                                EMPATES
                                            </span>
                                        </div>
                                        <div class="widget-stat-unit">
                                            <span class="stat-num">
                                                {coachStats?.current_official
                                                    ?.derrotas ?? 0}
                                            </span>
                                            <span class="stat-tag">
                                                DERROTAS
                                            </span>
                                        </div>
                                        <div class="widget-stat-unit">
                                            <span class="stat-num">
                                                {coachStats?.current_official
                                                    ?.goles_favor ?? 0}
                                                -
                                                {coachStats?.current_official
                                                    ?.goles_contra ?? 0}
                                            </span>
                                            <span class="stat-tag">GF-GC</span>
                                        </div>
                                    </div>
                                    <a
                                        href={`/entrenadores/${coachData.slug}`}
                                        class="widget-cta-btn-premium"
                                    >
                                        VER PERFIL COMPLETO
                                    </a>
                                </div>
                            )
                        }

                        {
                            focusType === "referee" && refereeData && (
                                <div class="dashboard-widget-card-refined">
                                    <div class="widget-top-info">
                                        <div class="widget-avatar-wrapper">
                                            <img
                                                src={
                                                    refereeData.foto_url ||
                                                    "https://res.cloudinary.com/dnx7vsqbi/image/upload/v1741372500/jugadoras/default.webp"
                                                }
                                                alt={refereeData.nombre}
                                                class="widget-avatar"
                                            />
                                        </div>
                                        <div class="widget-name-box">
                                            <h3 class="widget-title-small">
                                                {refereeData.nombre.toUpperCase()}
                                            </h3>
                                            <span class="widget-subtitle-pos">
                                                ÁRBITRO ·{" "}
                                                {refereeData.colegio || ""}
                                            </span>
                                        </div>
                                    </div>
                                    <p class="widget-season-label">
                                        Balance global en partidos oficiales
                                    </p>
                                    <div class="widget-stats-grid-compact grid-3">
                                        <div class="widget-stat-unit">
                                            <span class="stat-num">
                                                {refereeData.stats?.wins ?? 0}
                                            </span>
                                            <span class="stat-tag">
                                                VICTORIAS
                                            </span>
                                        </div>
                                        <div class="widget-stat-unit">
                                            <span class="stat-num">
                                                {refereeData.stats?.draws ?? 0}
                                            </span>
                                            <span class="stat-tag">
                                                EMPATES
                                            </span>
                                        </div>
                                        <div class="widget-stat-unit">
                                            <span class="stat-num">
                                                {refereeData.stats?.losses ?? 0}
                                            </span>
                                            <span class="stat-tag">
                                                DERROTAS
                                            </span>
                                        </div>
                                    </div>
                                    <div class="widget-cards-row">
                                        <div class="card-pill yellow">
                                            <span class="card-icon">🟨</span>
                                            <span>
                                                {refereeData.stats
                                                    ?.yellowCards ?? 0}{" "}
                                                a favor
                                            </span>
                                            <span class="card-sep">·</span>
                                            <span>
                                                {refereeData.stats
                                                    ?.yellowCardsAgainst ??
                                                    0}{" "}
                                                en contra
                                            </span>
                                        </div>
                                        <div class="card-pill red">
                                            <span class="card-icon">🟥</span>
                                            <span>
                                                {refereeData.stats?.redCards ??
                                                    0}{" "}
                                                a favor
                                            </span>
                                            <span class="card-sep">·</span>
                                            <span>
                                                {refereeData.stats
                                                    ?.redCardsAgainst ?? 0}{" "}
                                                en contra
                                            </span>
                                        </div>
                                    </div>
                                    <a
                                        href={`/arbitras/${refereeData.id_arbitra}`}
                                        class="widget-cta-btn-premium"
                                    >
                                        VER PERFIL COMPLETO
                                    </a>
                                </div>
                            )
                        }

                        {
                            focusType === "club" && clubData && (
                                <div class="dashboard-widget-card-refined club-widget">
                                    <div class="club-widget-header">
                                        <img
                                            src={getRivalShieldUrl(clubData)}
                                            alt={clubData.nombre}
                                            class="club-shield"
                                            onerror="this.style.display='none'"
                                        />
                                        <div class="widget-name-box">
                                            <h3 class="widget-title-small">
                                                {clubData.nombre.toUpperCase()}
                                            </h3>
                                            <span class="widget-subtitle-pos">
                                                {clubData.ciudad ||
                                                    clubData.pais}
                                            </span>
                                        </div>
                                    </div>
                                    <p class="widget-season-label">
                                        Balance en partidos oficiales
                                    </p>
                                    <div class="widget-stats-grid-compact grid-4">
                                        <div class="widget-stat-unit">
                                            <span class="stat-num">
                                                {clubData.stats?.wins ?? 0}
                                            </span>
                                            <span class="stat-tag">
                                                VICTORIAS
                                            </span>
                                        </div>
                                        <div class="widget-stat-unit">
                                            <span class="stat-num">
                                                {clubData.stats?.draws ?? 0}
                                            </span>
                                            <span class="stat-tag">
                                                EMPATES
                                            </span>
                                        </div>
                                        <div class="widget-stat-unit">
                                            <span class="stat-num">
                                                {clubData.stats?.losses ?? 0}
                                            </span>
                                            <span class="stat-tag">
                                                DERROTAS
                                            </span>
                                        </div>
                                        <div class="widget-stat-unit">
                                            <span class="stat-num">
                                                {clubData.stats?.gf ?? 0}-
                                                {clubData.stats?.ga ?? 0}
                                            </span>
                                            <span class="stat-tag">GF-GC</span>
                                        </div>
                                    </div>
                                    <a
                                        href={`/rivales/${clubData.slug}`}
                                        class="widget-cta-btn-premium"
                                    >
                                        VER BALANCE COMPLETO
                                    </a>
                                </div>
                            )
                        }

                        {
                            focusType === "match" && matchData && (
                                <div class="match-widget-full">
                                    <div class="match-header-scores">
                                        <div class="mh-team">
                                            <img
                                                src={getAssetUrl(
                                                    "escudos",
                                                    "real-madrid",
                                                )}
                                                alt="Real Madrid"
                                                class="mh-shield"
                                                onerror="this.src='/favicon.svg'"
                                            />
                                            <span class="mh-name">
                                                REAL MADRID
                                            </span>
                                        </div>
                                        <div class="mh-score">
                                            <span class="mh-goals">
                                                {matchData.goles_rm ?? 0} -{" "}
                                                {matchData.goles_rival ?? 0}
                                            </span>
                                            <span class="mh-meta">
                                                {matchData.fecha
                                                    ? new Date(
                                                          matchData.fecha,
                                                      ).toLocaleDateString(
                                                          "es-ES",
                                                          {
                                                              day: "numeric",
                                                              month: "long",
                                                              year: "numeric",
                                                          },
                                                      )
                                                    : ""}
                                                {matchData.hora
                                                    ? ` · ${matchData.hora}`
                                                    : ""}
                                            </span>
                                            {matchData.estadio && (
                                                <span class="mh-stadium">
                                                    {matchData.estadio}
                                                </span>
                                            )}
                                        </div>
                                        <div class="mh-team">
                                            <img
                                                src={getRivalShieldUrl({
                                                    nombre: matchData.rival,
                                                    foto_url:
                                                        matchData.rival_foto_url,
                                                })}
                                                alt={matchData.rival}
                                                class="mh-shield"
                                                onerror="this.style.opacity='0'"
                                            />
                                            <span class="mh-name">
                                                {(
                                                    matchData.rival || ""
                                                ).toUpperCase()}
                                            </span>
                                        </div>
                                    </div>

                                    <div class="football-pitch">
                                        <div class="pitch-inner">
                                            <div class="pitch-lines">
                                                <div class="pitch-center-circle" />
                                                <div class="pitch-center-line" />
                                                <div class="pitch-penalty-top" />
                                                <div class="pitch-penalty-bottom" />
                                            </div>

                                            {matchLineup.length === 0 && (
                                                <div class="pitch-no-data">
                                                    XI inicial no disponible
                                                </div>
                                            )}

                                            {matchRowsOrdered.map((rowData) => (
                                                <div class="pitch-row">
                                                    {rowData.players.map(
                                                        (p: any) => (
                                                            <div
                                                                class={`pitch-player ${Number(p.goles) > 0 ? "scored" : ""} ${Number(p.asistencias) > 0 ? "assisted" : ""}`}
                                                            >
                                                                <div class="pp-avatar">
                                                                    {p.foto_url ? (
                                                                        <img
                                                                            src={
                                                                                p.foto_url
                                                                            }
                                                                            alt={
                                                                                p.nombre
                                                                            }
                                                                        />
                                                                    ) : (
                                                                        <span class="pp-initials">
                                                                            {(
                                                                                p.nombre ||
                                                                                "?"
                                                                            )
                                                                                .split(
                                                                                    " ",
                                                                                )
                                                                                .map(
                                                                                    (
                                                                                        n: string,
                                                                                    ) =>
                                                                                        n[0],
                                                                                )
                                                                                .slice(
                                                                                    0,
                                                                                    2,
                                                                                )
                                                                                .join(
                                                                                    "",
                                                                                )}
                                                                        </span>
                                                                    )}
                                                                    {Number(
                                                                        p.goles,
                                                                    ) > 0 && (
                                                                        <span class="pp-goal-badge">
                                                                            ⚽{" "}
                                                                            {
                                                                                p.goles
                                                                            }
                                                                        </span>
                                                                    )}
                                                                    {Number(
                                                                        p.asistencias,
                                                                    ) > 0 &&
                                                                        !Number(
                                                                            p.goles,
                                                                        ) && (
                                                                            <span class="pp-assist-badge">
                                                                                🅰
                                                                            </span>
                                                                        )}
                                                                </div>
