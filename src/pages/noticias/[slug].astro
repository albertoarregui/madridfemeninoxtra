---
import Layout from "../../layouts/Layout.astro";
import { documentToHtmlString } from "@contentful/rich-text-html-renderer";
import { getAssetUrl } from "../../utils/assets";
import { fetchPlayersDirectly, fetchPlayerStats } from "../../utils/players";
import {
    fetchCoachesDirectly,
    fetchCoachStats,
} from "../../utils/entrenadores";
import { fetchRefereesDirectly } from "../../utils/arbitras";
import { fetchRivalsDirectly, getRivalShieldUrl } from "../../utils/rivales";
import { fetchGamesDirectly } from "../../utils/partidos";
import { getFlagSrc } from "../../utils/flags";

export const prerender = false;

const { slug } = Astro.params;

let noticia: any = null;

try {
    const { contentfulClient } = await import("../../lib/contentful");
    const entries = await contentfulClient.getEntries({
        content_type: "noticia",
        "fields.slug": slug,
        limit: 1,
    });

    if (entries && entries.items.length > 0) {
        noticia = entries.items[0].fields;
    }
} catch (e: any) {
    console.warn("Error consultando Contentful:", e);
}

if (!noticia) {
    return Astro.redirect("/404");
}

const n = noticia as any;
const { title, subtitle, player, category, focusType, referenceId, id } = n;

const contentReferenceId = referenceId || id;

const featuredImageUrl = n.featuredImage?.fields?.file?.url
    ? `https:${n.featuredImage.fields.file.url}`
    : "https://media.madridfemeninoxtra.com/background/stadium.webp";

let bodyHtml = ``;

if (n.body) {
    try {
        if (typeof n.body === "string") {
            bodyHtml = `<p>${n.body}</p>`;
        } else if (n.body.nodeType === "document") {
            bodyHtml = documentToHtmlString(n.body);
        } else {
            bodyHtml = `<p>Error de formato.</p>`;
        }
    } catch (e) {
        bodyHtml = `<p>Ocurrió un error leyendo el contenido.</p>`;
    }
}

let playerData: any = null;
let playerStats: any = null;
let coachData: any = null;
let coachStats: any = null;
let clubData: any = null;
let refereeData: any = null;
let matchData: any = null;
let matchLineup: any[] = [];

if (focusType === "player" && (contentReferenceId || player)) {
    const allPlayers = await fetchPlayersDirectly();
    playerData =
        allPlayers.find(
            (p) =>
                String(p.nombre).toLowerCase() === String(player).toLowerCase(),
        ) ||
        allPlayers.find((p) =>
            String(p.nombre)
                .toLowerCase()
                .includes(String(player || "").toLowerCase()),
        ) ||
        allPlayers.find(
            (p) => String(p.id_jugadora) === String(contentReferenceId),
        );

    if (playerData) {
        const statsResponse = await fetchPlayerStats(
            playerData.id_jugadora,
            playerData.posicion === "Portera",
        );

        if (statsResponse) {
            playerStats = {
                ...statsResponse,
                current_official: statsResponse.total_official || {
                    partidos: 0,
                    minutos: 0,
                    goles: 0,
                    asistencias: 0,
                    porterias_cero: 0,
                },
                season_name: "TOTAL (OFICIAL)",
            };
        }
    }
}

if (focusType === "coach") {
    const coaches = await fetchCoachesDirectly();
    coachData = contentReferenceId
        ? coaches.find(
              (c) => String(c.id_entrenador) === String(contentReferenceId),
          )
        : coaches.find((c) => String(c.nombre).toLowerCase().includes("toril"));

    if (coachData) {
        const statsResp = await fetchCoachStats(coachData.id_entrenador);
        if (statsResp?.estadisticas?.length > 0) {
            const officialComps = [
                "Liga F",
                "UWCL",
                "Copa de la Reina",
                "Supercopa de España",
            ];

            const officialTotal = (statsResp.estadisticas as any[]).reduce(
                (accTotal: any, season: any) => {
                    const comps = (season.competiciones || []) as any[];
                    const seasonOfficial = comps
                        .filter((c: any) =>
                            officialComps.includes(c.competicion),
                        )
                        .reduce(
                            (acc: any, c: any) => ({
                                partidos: acc.partidos + c.partidos,
                                victorias: acc.victorias + c.victorias,
                                empates: acc.empates + c.empates,
                                derrotas: acc.derrotas + c.derrotas,
                                goles_favor: acc.goles_favor + c.goles_favor,
                                goles_contra: acc.goles_contra + c.goles_contra,
                            }),
                            {
                                partidos: 0,
                                victorias: 0,
                                empates: 0,
                                derrotas: 0,
                                goles_favor: 0,
                                goles_contra: 0,
                            },
                        );

                    return {
                        partidos: accTotal.partidos + seasonOfficial.partidos,
                        victorias:
                            accTotal.victorias + seasonOfficial.victorias,
                        empates: accTotal.empates + seasonOfficial.empates,
                        derrotas: accTotal.derrotas + seasonOfficial.derrotas,
                        goles_favor:
                            accTotal.goles_favor + seasonOfficial.goles_favor,
                        goles_contra:
                            accTotal.goles_contra + seasonOfficial.goles_contra,
                    };
                },
                {
                    partidos: 0,
                    victorias: 0,
                    empates: 0,
                    derrotas: 0,
                    goles_favor: 0,
                    goles_contra: 0,
                },
            );

            coachStats = {
                current_official: officialTotal,
                season_name: "TOTAL (OFICIAL)",
            };
        }
    }
}

if (focusType === "referee") {
    const referees = await fetchRefereesDirectly();
    refereeData = contentReferenceId
        ? referees.find(
              (r) => String(r.id_arbitra) === String(contentReferenceId),
          )
        : referees[0];
}

if (focusType === "club") {
    const rivals = await fetchRivalsDirectly();
    clubData = contentReferenceId
        ? rivals.find((r) => String(r.id_club) === String(contentReferenceId))
        : rivals[0];

    const isRMRequested =
        String(contentReferenceId) === "1" ||
        String(player || "")
            .toLowerCase()
            .includes("madrid");

    if (!clubData || (isRMRequested && String(clubData.id_club) !== "1")) {
        const { getPlayersDbClient } = await import("../../db/client");
        const client = await getPlayersDbClient();
        if (client) {
            const clubRes = await client.execute({
                sql: `SELECT c.*, e.nombre as estadio, e.capacidad, e.lat as estadio_lat, e.lng as estadio_lng 
                      FROM clubes c 
                      LEFT JOIN estadios e ON c.estadio = e.id_estadio 
                      WHERE ${isRMRequested ? "c.id_club = 1" : "c.id_club = ?"}`,
                args: isRMRequested ? [] : [contentReferenceId as any],
            });
            if (clubRes.rows.length > 0) {
                const row = clubRes.rows[0];
                const cleanNombre = row.nombre || "Real Madrid";
                const allMatches = await fetchGamesDirectly();
                const playedMatches = allMatches.filter(
                    (m: any) =>
                        m.resultado !== "P" &&
                        !String(m.competicion_nombre)
                            .toLowerCase()
                            .includes("amistoso"),
                );

                let wins = 0,
                    draws = 0,
                    losses = 0,
                    gf = 0,
                    ga = 0,
                    cleanSheets = 0;
                playedMatches.forEach((m: any) => {
                    const gRM = Number(m.goles_rm) || 0;
                    const gRiv = Number(m.goles_rival) || 0;
                    gf += gRM;
                    ga += gRiv;
                    if (gRiv === 0) cleanSheets++;
                    if (m.resultado === "V") wins++;
                    else if (m.resultado === "D") losses++;
                    else draws++;
                });

                clubData = {
                    id_club: row.id_club,
                    nombre: cleanNombre,
                    ciudad: row.ciudad || "Madrid",
                    pais: row.pais || "España",
                    iso: row.iso || "ES",
                    slug: row.slug || "real-madrid",
                    estadio: row.estadio || "Alfredo Di Stéfano",
                    shieldUrl:
                        "https://media.madridfemeninoxtra.com/escudos/real-madrid.png",
                    stats: {
                        played: playedMatches.length,
                        wins,
                        draws,
                        losses,
                        gf,
                        ga,
                        gd: gf - ga,
                        cleanSheets,
                    },
                };
            }
        }
    }
}

if (focusType === "match" && contentReferenceId) {
    try {
        const allMatches = await fetchGamesDirectly();
        matchData = allMatches.find(
            (m: any) => String(m.id_partido) === String(contentReferenceId),
        );
        if (matchData) {
            const { getPlayersDbClient } = await import("../../db/client");
            const client = await getPlayersDbClient();
            if (client) {
                const lineupResult = await client.execute({
                    sql: `SELECT al.*, j.nombre, j.posicion, j.foto_url,
                            (SELECT COUNT(*) FROM goles_y_asistencias g WHERE g.id_partido = al.id_partido AND g.goleadora = al.id_jugadora) as goles,
                            (SELECT COUNT(*) FROM goles_y_asistencias g WHERE g.id_partido = al.id_partido AND g.asistente = al.id_jugadora) as asistencias
                          FROM alineaciones al
                          JOIN jugadoras j ON al.id_jugadora = j.id_jugadora
                          WHERE al.id_partido = ? AND al.titular = 1
                          ORDER BY j.posicion`,
                    args: [contentReferenceId],
                });
                matchLineup = (lineupResult?.rows || []) as any[];
            }
        }
    } catch (e) {
        console.warn("Error fetching match data:", e);
    }
}

const posOrder = ["Portera", "Defensa", "Centrocampista", "Delantera"];
const matchRows: Record<string, any[]> = {};
matchLineup.forEach((p: any) => {
    const pos = p.posicion || "Centrocampista";
    const key =
        posOrder.find((o) =>
            pos.toLowerCase().startsWith(o.slice(0, 4).toLowerCase()),
        ) || "Centrocampista";
    if (!matchRows[key]) matchRows[key] = [];
    matchRows[key].push(p);
});
const matchRowsOrdered = posOrder
    .map((k) => ({ key: k, players: matchRows[k] || [] }))
    .filter((r) => r.players.length > 0);
const publishDateISO = noticia?.publishDate
    ? new Date(noticia.publishDate).toISOString()
    : new Date().toISOString();
const articleUrl = `https://www.madridfemeninoxtra.com/noticias/${slug}`;

const newsSchema = {
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    headline: title,
    description: subtitle || title,
    image: featuredImageUrl ? [featuredImageUrl] : [],
    datePublished: publishDateISO,
    dateModified: publishDateISO,
    author: {
        "@type": "Organization",
        name: "Madrid Femenino Xtra",
        url: "https://www.madridfemeninoxtra.com",
    },
    publisher: {
        "@type": "Organization",
        name: "Madrid Femenino Xtra",
        url: "https://www.madridfemeninoxtra.com",
        logo: {
            "@type": "ImageObject",
            url: "https://www.madridfemeninoxtra.com/favicon.png",
        },
    },
    mainEntityOfPage: { "@type": "WebPage", "@id": articleUrl },
    url: articleUrl,
    inLanguage: "es",
    keywords: [
        "Real Madrid Femenino",
        category || "fútbol femenino",
        player || "",
    ]
        .filter(Boolean)
        .join(", "),
};

const sitemapUrl = encodeURIComponent(
    "https://www.madridfemeninoxtra.com/sitemap.xml",
);
Promise.allSettled([
    fetch(`https://www.google.com/ping?sitemap=${sitemapUrl}`),
    fetch(`https://www.bing.com/ping?sitemap=${sitemapUrl}`),
]).catch(() => {});
---

<Layout
    title={`${title} | Madrid Femenino Xtra`}
    description={subtitle || `${title} - Madrid Femenino Xtra`}
    image={featuredImageUrl || undefined}
>
    <script
        type="application/ld+json"
        set:html={JSON.stringify(newsSchema)}
        slot="head"
    />
    <meta property="og:type" content="article" slot="head" />
    <meta property="og:url" content={articleUrl} slot="head" />
    <meta
        property="article:published_time"
        content={publishDateISO}
        slot="head"
    />
    <meta
        property="article:author"
        content="Madrid Femenino Xtra"
        slot="head"
    />
    <meta name="twitter:image:alt" content={title} slot="head" />
    {
        featuredImageUrl && (
            <meta property="og:image:width" content="1200" slot="head" />
        )
    }
    {
        featuredImageUrl && (
            <meta property="og:image:height" content="630" slot="head" />
        )
    }
    <article class="news-detail-page">
        <div class="news-full-white-row">
            <div class="news-content-limit">
                <div class="news-back-link-wrapper">
                    <a href="/home" class="news-back-link">
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                        </svg>
                        Volver a la página principal
                    </a>
                </div>

                <div class="news-featured-photo">
                    <img
                        src={featuredImageUrl}
                        alt={title}
                        class="featured-news-img"
                    />
                </div>

                <div class="news-main-body-content">
                    <header class="news-header-section centered">
                        <span class="news-category-capsule">
                            {category}
                        </span>

                        <h1 class="news-main-title">{title}</h1>

                        <p class="news-main-subtitle">
                            {subtitle}
                        </p>

                        <div class="news-social-icons">
                            <a
                                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(`https://www.madridfemeninoxtra.com/noticias/${slug}`)}`}
                                class="social-circle share-btn"
                                aria-label="Compartir en X"
                                target="_blank"
                                rel="noopener noreferrer"
                                title="Compartir en X"
                            >
                                <img
                                    src={getAssetUrl("redes", "x")}
                                    alt="X"
                                    style="width:20px;height:20px;object-fit:contain;"
                                />
                            </a>

                            <a
                                href={`https://www.facebook.com/sharer.php?u=${encodeURIComponent(`https://www.madridfemeninoxtra.com/noticias/${slug}`)}&t=${encodeURIComponent(title)}`}
                                class="social-circle share-btn"
                                aria-label="Compartir en Facebook"
                                target="_blank"
                                rel="noopener noreferrer"
                                title="Compartir en Facebook"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><path
                                        stroke="none"
                                        d="M0 0h24v24H0z"
                                        fill="none"></path><path
                                        d="M7 10v4h3v7h4v-7h3l1 -4h-4v-2a1 1 0 0 1 1 -1h3v-4h-3a5 5 0 0 0 -5 5v2h-3"
                                    ></path></svg
                                >
                            </a>

                            <a
                                href={`https://wa.me/?text=${encodeURIComponent(`${title} https://www.madridfemeninoxtra.com/noticias/${slug}`)}`}
                                class="social-circle share-btn"
                                aria-label="Compartir en WhatsApp"
                                target="_blank"
                                rel="noopener noreferrer"
                                title="Compartir en WhatsApp"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><path
                                        stroke="none"
                                        d="M0 0h24v24H0z"
                                        fill="none"></path><path
                                        d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"
                                    ></path><path
                                        d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"
                                    ></path></svg
                                >
                            </a>

                            <a
                                href={`https://t.me/share/url?url=${encodeURIComponent(`https://www.madridfemeninoxtra.com/noticias/${slug}`)}&text=${encodeURIComponent(title)}`}
                                class="social-circle share-btn"
                                aria-label="Compartir en Telegram"
                                target="_blank"
                                rel="noopener noreferrer"
                                title="Compartir en Telegram"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><path
                                        stroke="none"
                                        d="M0 0h24v24H0z"
                                        fill="none"></path><path
                                        d="M15 10l-4 4l6 6l4 -16l-18 7l4 2l2 6l3 -4"
                                    ></path></svg
                                >
                            </a>

                            <button
                                id="copyLinkBtn"
                                class="social-circle share-btn"
                                aria-label="Copiar enlace"
                                data-url={`https://www.madridfemeninoxtra.com/noticias/${slug}`}
                                title="Copiar enlace"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><path
                                        stroke="none"
                                        d="M0 0h24v24H0z"
                                        fill="none"></path><path d="M9 15l6 -6"
                                    ></path><path
                                        d="M11 6l.463 -.536a5 5 0 0 1 7.071 7.072l-.534 .464"
                                    ></path><path
                                        d="M13 18l-.397 .534a5.068 5.068 0 0 1 -7.127 0a4.972 4.972 0 0 1 0 -7.071l.524 -.463"
                                    ></path></svg
                                >
                            </button>
                        </div>

                        <script>
                            const copyBtn =
                                document.getElementById("copyLinkBtn");
                            if (copyBtn) {
                                copyBtn.addEventListener("click", () => {
                                    const url =
                                        copyBtn.getAttribute("data-url") ||
                                        window.location.href;
                                    navigator.clipboard
                                        .writeText(url)
                                        .then(() => {
                                            copyBtn.classList.add("copied");
                                            copyBtn.title = "¡Enlace copiado!";
                                            setTimeout(() => {
                                                copyBtn.classList.remove(
                                                    "copied",
                                                );
                                                copyBtn.title = "Copiar enlace";
                                            }, 2000);
                                        });
                                });
                            }
                        </script>

                        <div class="news-meta-row">
                            <time class="news-publish-date">
                                {
                                    noticia.publishDate
                                        ? new Date(noticia.publishDate)
                                              .toLocaleDateString("es-ES", {
                                                  year: "numeric",
                                                  month: "long",
                                                  day: "numeric",
                                              })
                                              .toUpperCase()
                                        : "7 DE AGOSTO DE 2026"
                                }
                            </time>
                        </div>

                        <div class="news-separator-thin"></div>
                    </header>

                    <div class="news-article-rich-text">
                        <div set:html={bodyHtml} />
                    </div>

                    <hr class="section-separator-simple" />

                    <div class="news-footer-widgets">
                        {
                            focusType === "player" && (
                                <div class="dashboard-widget-card-refined">
                                    <div class="widget-top-info">
                                        <div class="widget-avatar-wrapper">
                                            <img
                                                src={
                                                    playerData?.imageUrl ||
                                                    "https://media.madridfemeninoxtra.com/jugadoras/default.webp"
                                                }
                                                alt={player}
                                                class="widget-avatar"
                                            />
                                        </div>
                                        <div class="widget-name-box">
                                            <div class="widget-name-row">
                                                <h3 class="widget-title-small">
                                                    {player}
                                                </h3>
                                                {playerData?.iso && (
                                                    <img
                                                        src={getFlagSrc(
                                                            playerData.iso,
                                                        )}
                                                        alt={playerData.iso}
                                                        class="widget-flag"
                                                    />
                                                )}
                                            </div>
                                            <span class="widget-subtitle-pos">
                                                {playerData?.posicion ||
                                                    "JUGADORA"}
                                            </span>
                                        </div>
                                    </div>

                                    <div
                                        class={`widget-stats-grid-compact ${playerData?.posicion?.toLowerCase() === "portera" ? "grid-3" : "grid-4"}`}
                                    >
                                        <div class="widget-stat-unit">
                                            <span class="stat-num">
                                                {playerStats?.current_official
                                                    ?.partidos ?? "0"}
                                            </span>
                                            <span class="stat-tag">
                                                PARTIDOS
                                            </span>
                                        </div>
                                        <div class="widget-stat-unit">
                                            <span class="stat-num">
                                                {playerStats?.current_official
                                                    ?.minutos ?? "0"}
                                            </span>
                                            <span class="stat-tag">
                                                MINUTOS
                                            </span>
                                        </div>
                                        {playerData?.posicion?.toLowerCase() ===
                                        "portera" ? (
                                            <div class="widget-stat-unit">
                                                <span class="stat-num">
                                                    {playerStats
                                                        ?.current_official
                                                        ?.porterias_cero ?? "0"}
                                                </span>
                                                <span class="stat-tag">
                                                    P. CERO
                                                </span>
                                            </div>
                                        ) : (
                                            <>
                                                <div class="widget-stat-unit">
                                                    <span class="stat-num">
                                                        {playerStats
                                                            ?.current_official
                                                            ?.goles ?? "0"}
                                                    </span>
                                                    <span class="stat-tag">
                                                        GOLES
                                                    </span>
                                                </div>
                                                <div class="widget-stat-unit">
                                                    <span class="stat-num">
                                                        {playerStats
                                                            ?.current_official
                                                            ?.asistencias ??
                                                            "0"}
                                                    </span>
                                                    <span class="stat-tag">
                                                        ASISTENCIAS
                                                    </span>
                                                </div>
                                            </>
                                        )}
                                    </div>
                                    <a
                                        href={`/jugadoras/${playerData?.slug || player?.toLowerCase().replace(/ /g, "-")}`}
                                        class="widget-cta-btn-premium"
                                    >
                                        VER PERFIL COMPLETO
                                    </a>
                                </div>
                            )
                        }

                        {
                            focusType === "coach" && coachData && (
                                <div class="dashboard-widget-card-refined">
                                    <div class="widget-top-info">
                                        <div class="widget-avatar-wrapper">
                                            <img
                                                src={coachData.imageUrl}
                                                alt={coachData.nombre}
                                                class="widget-avatar"
                                            />
                                        </div>
                                        <div class="widget-name-box">
                                            <div class="widget-name-row">
                                                <h3 class="widget-title-small">
                                                    {coachData.nombre.toUpperCase()}
                                                </h3>
                                                {coachData.iso && (
                                                    <img
                                                        src={getFlagSrc(
                                                            coachData.iso,
                                                        )}
                                                        alt={coachData.iso}
                                                        class="widget-flag"
                                                    />
                                                )}
                                            </div>
                                            <span class="widget-subtitle-pos">
                                                ENTRENADORA
                                            </span>
                                        </div>
                                    </div>
                                    <p class="widget-season-label">
