                                                                        p.asistencias,
                                                                    ) > 0 &&
                                                                        !Number(
                                                                            p.goles,
                                                                        ) && (
                                                                            <span class="pp-assist-badge">
                                                                                🅰
                                                                            </span>
                                                                        )}
                                                                </div>
                                                                <span class="pp-name">
                                                                    {(
                                                                        p.nombre ||
                                                                        ""
                                                                    )
                                                                        .split(
                                                                            " ",
                                                                        )
                                                                        .pop()}
                                                                </span>
                                                            </div>
                                                        ),
                                                    )}
                                                </div>
                                            ))}
                                        </div>
                                    </div>

