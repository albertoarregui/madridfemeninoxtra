                                                                                p.nombre
                                                                            }
                                                                        />
                                                                    ) : (
                                                                        <span class="pp-initials">
                                                                            {(
                                                                                p.nombre ||
                                                                                "?"
                                                                            )
                                                                                .split(
                                                                                    " ",
                                                                                )
                                                                                .map(
                                                                                    (
                                                                                        n: string,
                                                                                    ) =>
                                                                                        n[0],
                                                                                )
                                                                                .slice(
                                                                                    0,
                                                                                    2,
                                                                                )
                                                                                .join(
                                                                                    "",
                                                                                )}
                                                                        </span>
                                                                    )}
                                                                    {Number(
                                                                        p.goles,
