---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import "../../styles/noticias.css";

const PAGE_TITLE = "UWCL";
const CATEGORY_FILTER = "uwcl";
const WP_URL =
    "https://cms.madridfemeninoxtra.com/wp-json/wp/v2/posts?per_page=30&_embed=true";

interface WPPost {
    id: number;
    date: string;
    slug: string;
    title: { rendered: string };
    excerpt: { rendered: string };
    _embedded?: {
        "wp:featuredmedia"?: Array<{ source_url: string; alt_text: string }>;
        "wp:term"?: Array<Array<{ name: string }>>;
    };
}

let filteredNews: WPPost[] = [];
let error = false;

try {
    const response = await fetch(WP_URL);
    if (!response.ok) throw new Error("Failed to fetch");
    const posts: WPPost[] = await response.json();
    filteredNews = posts.filter((p: WPPost) =>
        p._embedded?.["wp:term"]?.[0]?.some(
            (cat) => cat.name.toLowerCase() === CATEGORY_FILTER,
        ),
    );
} catch (e) {
    console.error("Error fetching news:", e);
    error = true;
}

function formatDate(dateString: string) {
    const date = new Date(dateString);
    return new Intl.DateTimeFormat("es-ES", {
        year: "numeric",
        month: "long",
        day: "numeric",
    }).format(date);
}

const noIndex = filteredNews.length === 0;
---

<Layout
    title={`${PAGE_TITLE} | Madrid Femenino Xtra`}
    description={`Últimas noticias de la ${PAGE_TITLE} relacionadas con el Real Madrid Femenino.`}
    noindex={noIndex}
>
    <main class="noticias-page">
        <div class="container">
            <header>
                <h1 class="section-title">{PAGE_TITLE}</h1>
                <h2 class="content-h2">
                    Última hora del Real Madrid femenino en directo: actualidad,
                    próximos partidos y fichajes en Liga F, UWCL, Copa de la
                    Reina y Supercopa de España.
                </h2>
            </header>

            {
                filteredNews.length > 0 ? (
                    <div class="noticias-grid">
                        {filteredNews.map((noticia: WPPost) => {
                            const featuredImage =
                                noticia._embedded?.["wp:featuredmedia"]?.[0]
                                    ?.source_url;
                            const featuredImageAlt =
                                noticia._embedded?.["wp:featuredmedia"]?.[0]
                                    ?.alt_text || noticia.title.rendered;
                            const link = `/noticias/${noticia.slug}`;
                            return (
                                <article class="noticia-card">
                                    <a
                                        href={link}
                                        class="card-link-wrapper"
                                        aria-label={`Leer más sobre ${noticia.title.rendered}`}
                                    />
                                    {featuredImage && (
                                        <div class="noticia-image">
                                            <img
                                                src={featuredImage}
                                                alt={featuredImageAlt}
                                                loading="lazy"
                                            />
                                        </div>
                                    )}
                                    <div class="noticia-content">
                                        <div class="noticia-meta">
                                            <time datetime={noticia.date}>
                                                {formatDate(noticia.date)}
                                            </time>
                                        </div>
                                        <h2
                                            class="noticia-title"
                                            set:html={noticia.title.rendered}
                                        />
                                        <div
                                            class="noticia-excerpt"
                                            set:html={noticia.excerpt.rendered}
                                        />
                                        <div class="read-more">
                                            Leer más
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                width="16"
                                                height="16"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="2"
                                            >
                                                <path d="M5 12h14M12 5l7 7-7 7" />
                                            </svg>
                                        </div>
                                    </div>
                                </article>
                            );
                        })}
                    </div>
                ) : (
                    <p class="no-category-news">
                        {error
                            ? "Error al cargar las noticias."
                            : "No hay noticias disponibles en esta categoría."}
                    </p>
                )
            }
        </div>
    </main>

    <style>
        .card-link-wrapper {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 10;
        }
        .noticia-card {
            position: relative;
        }
        .read-more {
            margin-top: auto;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--primary);
            font-weight: 600;
        }
    </style>
</Layout>
