        font-family: 'Bebas Neue', sans-serif;
        font-size: 2rem;
        color: #ddd;
        font-weight: 700;
    }

    /* MVP GRID */
    .mvp-grid {
        display: grid; 
        grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); 
        gap: 1.2rem;
        padding: 1rem;
        justify-items: center;
    }

    .mvp-chip {
        display: flex; 
        flex-direction: column; 
        align-items: center; 
        gap: 0.8rem; 
        padding: 1rem;
        background: white; 
        border-radius: 12px; 
        cursor: pointer; 
        transition: all 0.3s ease;
        position: relative;
        text-align: center; 
        user-select: none;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        border: 2px solid transparent;
        width: 100%;
    }

    .mvp-chip:hover { transform: none; box-shadow: 0 8px 20px rgba(0,0,0,0.1); }

    /* MVP Selector Corners */
    .mvp-chip::before, .mvp-chip::after {
        content: ""; position: absolute; width: 15px; height: 15px; border: 3px solid transparent;
        transition: all 0.3s ease; opacity: 0; pointer-events: none;
    }
    .mvp-chip::before { top: -2px; left: -2px; border-top-color: var(--accent); border-left-color: var(--accent); border-radius: 4px 0 0 0; }
    .mvp-chip::after { bottom: -2px; right: -2px; border-bottom-color: var(--accent); border-right-color: var(--accent); border-radius: 0 0 4px 0; }
    
    /* Desktop-only hover effects to prevent sticky hover on mobile */
    @media (hover: hover) {
        .mvp-chip:hover::before, .mvp-chip:hover::after { opacity: 1; }
        .mvp-chip:hover .chip-image-container { transform: scale(1.05); }
    }
    
    .mvp-chip.selected::before, .mvp-chip.selected::after { opacity: 1; }
    .mvp-chip.selected::before, .mvp-chip.selected::after { border-width: 4px; }
    
    .mvp-chip.selected { background: #fffdf5; }

    .chip-image-container {
        width: 70px; height: 70px; border-radius: 50%; overflow: hidden; 
        background: #f0f0f0; border: 3px solid white; 
        box-shadow: 0 4px 8px rgba(0,0,0,0.1); transition: transform 0.3s ease;
    }

    .chip-img { width: 100%; height: 100%; object-fit: cover; object-position: top center; }
    
    .chip-info { 
        display: flex; 
        flex-direction: column; 
        line-height: 1.2; 
        gap: 0.3rem;
        width: 100%;
        overflow: hidden;
    }
    .player-num { font-size: 0.8rem; font-weight: 800; color: #ccc; }
    .player-name-chip { 
        font-size: 0.85rem; 
        font-weight: 700; 
        color: #444;
        white-space: normal;
        word-break: break-word;
        line-height: 1.2;
        overflow-wrap: break-word;
        width: 100%;
    }
    .mvp-chip.selected .player-name-chip { color: var(--primary); }
    .mvp-chip.selected .player-num { color: var(--accent); }

    .match-date-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }
    
    .match-date-day {
