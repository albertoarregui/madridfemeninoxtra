    .match-info-simple {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        padding: 2rem 1rem;
    }

    .comp-logo-center {
        height: 60px;
        width: auto;
        object-fit: contain;
    }

    .match-date-display {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.1rem;
    }

    .date-text {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--primary);
        text-transform: capitalize;
    }

    .time-text {
        font-size: 0.95rem;
        color: #666;
        font-weight: 500;
    }

    .teams-simple {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 3rem;
        padding: 1.5rem 1rem;
        border-top: 1px solid #f0f0f0;
        width: 100%;
    }

    .team-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.8rem;
    }

    .shield-simple {
        width: 80px;
        height: 80px;
        object-fit: contain;
    }

    .team-label {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--primary);
        text-transform: uppercase;
    }

