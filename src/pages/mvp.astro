    }

    .team-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.8rem;
    }

    .shield-simple {
        width: 80px;
        height: 80px;
        object-fit: contain;
    }

    .team-label {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--primary);
        text-transform: uppercase;
        text-align: center;
    }

    .vs-img {
        width: 60px;
        height: auto;
        object-fit: contain;
    }

    #ratings-form {
        margin: 0;
        padding: 0;
        display: block;
    }

    .mvp-page-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    @media (min-width: 1024px) {
        .mvp-page-grid {
            grid-template-columns: 1fr 1fr; 
            gap: 2rem; 
            align-items: start;
        }
    }

    .unified-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(0, 0, 0, 0.05);
        padding: 2rem 1.5rem 2.5rem 1.5rem; 
        position: relative;
    }

    .section-divider-internal {
        height: 1px;
        background: #f0f0f0;
        margin: 2rem 0;
        width: 100%;
    }

    .subsection-header {
        text-align: center;
        margin-bottom: 2rem;
    }
    
    .subsection-header h2 {
        font-family: "Bebas Neue", sans-serif;
        font-size: 2rem;
        color: var(--primary);
        letter-spacing: 1px;
    }

    .sidebar-column {
    }

    .leaderboard-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(0, 0, 0, 0.05);
        padding: 3rem 1.5rem 1.5rem 1.5rem;
        position: relative;
    }

    .card-title-overlay.small {
        font-size: 1.6rem;
        padding: 0.5rem 1.5rem;
        left: 30px; 
        transform: skew(-10deg);
        top: -18px; 
        white-space: nowrap;
    }

    .leaderboard-list {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
    }

    .leaderboard-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.8rem;
        border-radius: 8px;
        background: #f9f9f9;
        transition: transform 0.2s;
    }
    .leaderboard-item:hover {
        transform: translateX(3px);
        background: #fffdf5;
         border: 1px solid var(--accent);
    }

    .rank-number {
        font-family: "Bebas Neue", sans-serif;
        font-size: 1.5rem;
        color: #ddd;
        width: 20px;
        text-align: center;
    }
    .leaderboard-item:nth-child(1) .rank-number { color: #ffd700; }
    .leaderboard-item:nth-child(2) .rank-number { color: #c0c0c0; }
    .leaderboard-item:nth-child(3) .rank-number { color: #cd7f32; }

    .lb-player-img {
        width: 50px;
        height: 50px;
        border-radius: 6px; 
        overflow: hidden;
        border: 2px solid white;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        flex-shrink: 0;
    }
    .lb-player-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top center; 
    }

    .lb-player-info {
        display: flex;
        flex-direction: column;
        line-height: 1.1;
        flex: 1;
        min-width: 0;
    }
    .lb-name {
        font-weight: 700;
        font-size: 0.9rem;
        color: var(--primary);
        white-space: normal; 
        overflow: visible; 
        display: block;
    }
    .lb-votes {
        font-size: 0.8rem;
        color: #888;
    }

    .empty-lb {
        text-align: center;
        padding: 2rem 0;
        color: #999;
        font-size: 0.9rem;
        font-style: italic;
    }

    .mvp-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
        gap: 1.2rem;
        padding: 0; 
        justify-items: center;
    }

    .mvp-chip {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.8rem;
        padding: 1rem 0.5rem 0.8rem 0.5rem; 
        background: white;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        text-align: center;
        user-select: none;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        border: 2px solid transparent; 
        width: 100%;
        height: 100%;
        border-color: #f0f0f0; 
    }

    .mvp-chip:hover {
        transform: none;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
    }

    .mvp-chip::before,
    .mvp-chip::after {
        content: "";
        position: absolute;
        width: 15px;
        height: 15px;
        border: 3px solid transparent;
        transition: all 0.3s ease;
        opacity: 0;
        pointer-events: none;
    }
