        --primary: #2b2b2b;
        --accent: #ffde59;
        --text-primary: #2b2b2b;
    }
 
    .vote-percent-bar {
        width: 100%;
        margin-top: auto;
        background: #f0f0f0;
        border-radius: 4px;
        height: 20px;
        position: relative;
        overflow: hidden;
        flex-shrink: 0;
    }
    .percent-fill {
        background: var(--accent);
        height: 100%;
        position: absolute;
        top: 0;
        left: 0;
        z-index: 1;
    }
    .percent-text {
        position: absolute;
        width: 100%;
        text-align: center;
        font-size: 0.7rem;
        font-weight: 700;
        line-height: 18px;
        z-index: 2;
        color: #2b2b2b;
    }

    .match-info-simple {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        padding: 0 1rem 2rem; 
    }
    .unified-match-info {
        padding-top: 0;
    }

    .notas-page {
        font-family: "Poppins", sans-serif;
    }

    .match-card {
        position: relative;
        background: white;
        border-radius: 12px;
        padding: 3.5rem 2rem 2.5rem 2rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(0, 0, 0, 0.05);
        text-align: center;
    }

    .card-title-overlay {
        position: absolute;
        top: -18px;
        left: 30px;
        transform: skew(-10deg);
        background: var(--accent);
        color: #2b2b2b;
        padding: 0.5rem 1.5rem;
        font-family: "Bebas Neue", sans-serif;
        font-size: 1.6rem;
        font-weight: 700;
        letter-spacing: 1px;
        box-shadow: 4px 4px 0px rgba(0, 0, 0, 0.1);
        z-index: 10;
        line-height: 1;
    }

    .match-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 2rem;
    }
    .comp-logo {
        height: 50px;
        width: auto;
    }
    .competition-text {
        font-weight: 700;
        font-size: 1.1rem;
        text-transform: uppercase;
        color: var(--primary);
    }
    .match-date {
        color: #888;
        font-weight: 500;
        text-transform: capitalize;
    }

    .teams-container {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 2rem;
    }
    .team {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        width: 120px;
    }
    .team-shield {
        width: 80px;
        height: 80px;
        object-fit: contain;
        filter: drop-shadow(0 4px 4px rgba(0, 0, 0, 0.05));
    }
    .team-name {
        font-weight: 900;
        font-size: 1rem;
        text-transform: uppercase;
        color: var(--primary);
        line-height: 1.1;
    }
    .vs-text {
        font-family: "Archivo Black", sans-serif;
        font-size: 1.5rem;
        color: #ddd;
    }

    .section-header-cnt {
        text-align: center;
        margin-bottom: 2rem;
    }
    .subsection-title {
        font-size: 1.2rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--primary);
        text-align: center;
        letter-spacing: 1px;
