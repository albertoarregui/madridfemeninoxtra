    }

    .match-date-display {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.1rem;
    }

    .date-text {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--primary);
    }

    .time-text {
        font-size: 0.95rem;
        color: #666;
        font-weight: 500;
    }

    .teams-simple {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 3rem;
        padding: 1.5rem 1rem;
        border-top: 1px solid #f0f0f0;
