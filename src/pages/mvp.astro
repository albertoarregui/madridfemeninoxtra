---
import Layout from "../layouts/Layout.astro";
import { turso } from "../lib/turso";
import { CALENDAR } from "../consts/calendar";
import { SQUAD } from "../consts/squad";
import { SignInButton, SignedIn, SignedOut, UserButton } from "@clerk/astro/components";
import { getPlayerImage, getShield, getCompetitionLogo } from "../lib/assetHelpers";

// 1. Find Last Played Match
// Smart match selection with new voting window
const now = new Date();
const pastMatches = CALENDAR.filter((m) => new Date(m.date) < now);
const lastMatch = pastMatches.length > 0 ? pastMatches[pastMatches.length - 1] : null;
const nextMatch = CALENDAR.find(m => new Date(m.date) >= now) || null;

let targetMatch = null;
let isVotingOpen = false;

if (lastMatch) {
    const matchDate = new Date(lastMatch.date);
    const msSince = now.getTime() - matchDate.getTime();
    const hoursSince = msSince / (1000 * 60 * 60);

    if (hoursSince < 2) {
        // Less than 2 hours since start: Locked
        targetMatch = lastMatch;
        isVotingOpen = false;
    } else if (hoursSince >= 2 && hoursSince <= 24) {
        // Between 2h and 24h: Open
        targetMatch = lastMatch;
        isVotingOpen = true;
    } else {
        // More than 24h: Show next match (Locked)
        targetMatch = nextMatch;
        isVotingOpen = false;
    }
} else {
    targetMatch = nextMatch;
    isVotingOpen = false;
}

// Prepare match assets
const homeShield = targetMatch ? await getShield(targetMatch.team1) : '';
const awayShield = targetMatch ? await getShield(targetMatch.team2) : '';
const compLogo = targetMatch ? await getCompetitionLogo(targetMatch.competition) : '';

// 2. Fetch User's Previous Votes (if any)
const { userId } = Astro.locals.auth();
let existingRatings: Record<string, number> = {};
let existingMVP: string | null = null;
const squad: any[] = SQUAD;

if (userId && targetMatch && isVotingOpen) {
    try {
        // Fetch Ratings
        const ratingsResult = await turso.execute({
            sql: "SELECT player_id, rating FROM ratings WHERE user_id = ? AND match_id = ?",
            args: [userId, targetMatch.id],
        });
        ratingsResult.rows.forEach((row: any) => {
            existingRatings[row.player_id] = row.rating;
        });

        // Fetch MVP
        const mvpResult = await turso.execute({
            sql: "SELECT player_id FROM mvp_votes WHERE user_id = ? AND match_id = ?",
            args: [userId, targetMatch.id],
        });
        if (mvpResult.rows.length > 0) {
            existingMVP = mvpResult.rows[0].player_id;
        }

    } catch (e) {
        console.error("Error fetching ratings", e);
    }
}

// Prepare squad details with images
const squadWithImages = await Promise.all(squad.map(async (p) => ({
    ...p,
    image: await getPlayerImage(p.id)
})));

// 3. Fetch Fan Rankings
import { getFanRankings } from "../lib/fanRankings";
const fanRankings = await getFanRankings();

// Helper for direct image access in loop (since we need synchronous access in render loop)
// Re-importing globs here locally if needed or just use the helper function logic?
// Actually simpler to use the pre-loaded images from assetHelpers if possible, but they are async.
// Let's use the glob directly as in other files for synchronous access if they are static.
// OR map player IDs to the images we already loaded in squadWithImages?
// Yes, let's create a map for easier access
const playerImageMap = new Map(squadWithImages.map(p => [p.id, p.image]));

// Update: In the template, I used playerImages[...] which is not available in scope if I removed it previously?
// Ah, checking file content, I removed the inline globs in step 541!
// So I MUST use a map or find from squadWithImages.
// I will check the template replacement I just made.
// It used `playerImages[...]`. This will fail.
// I should fix the previous replacement step or fix this one to provide `playerImages` or change template logic.
// I'll define playerImages here OR change template to use squadWithImages.find().image
// But `squadWithImages` is async loaded.

// Fix: I will define playerImages glob again here for synchronous access if needed, OR just use the squadWithImages map.
// Using `playerImages` glob is standard in Astro for this project.
const playerImages = import.meta.glob('/src/assets/jugadoras/*.{png,jpg,jpeg,webp}', { eager: true });

---

<Layout title="MVP | Madrid Femenino Xtra">
    <div class="notas-page max-w-7xl mx-auto px-2 sm:px-6 lg:px-8 py-6">
        <header class="text-center mb-8 max-w-4xl mx-auto">
            <h1 class="page-title" style="color: var(--text-primary);">NOTAS Y MVP</h1>
            <!-- v2.3.0 -->
            <p class="content-h2 mx-auto" style="text-align: center;">
                Valora el rendimiento de las jugadoras y elige a la MVP del último partido.
            </p>
             <div class="auth-controls mt-6 flex justify-center">
                <SignedOut>
                    <SignInButton mode="modal" as="button" class="header-login-btn">
                        INICIAR SESIÓN
                    </SignInButton>
                </SignedOut>
                <SignedIn>
                    <UserButton />
                </SignedIn>
            </div>
        </header>

        {targetMatch ? (
            <div class="content-container" data-match-id={targetMatch.id}>
                
                <!-- MATCH CARD -->
                <section class="match-card mb-12">
                    <div class="card-title-overlay">
                        {isVotingOpen ? "PARTIDO PARA VALORAR" : "PRÓXIMO PARTIDO"}
                    </div>
                    
                    <div class="match-info-simple">
                        {compLogo && <img src={compLogo} alt={targetMatch.competition} class="comp-logo-center" />}
                        
                        <div class="match-date-display">
                            <span class="date-text">{new Date(targetMatch.date).toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' })}</span>
                            <span class="time-text">{targetMatch.time}</span>
                        </div>
                    </div>

                    <div class="teams-simple">
                        <div class="team-item">
                            {homeShield && <img src={homeShield} alt={targetMatch.team1} class="shield-simple" />}
                            <span class="team-label">{targetMatch.team1}</span>
                        </div>
                        <div class="vs-divider">VS</div>
                        <div class="team-item">
                            {awayShield && <img src={awayShield} alt={targetMatch.team2} class="shield-simple" />}
                            <span class="team-label">{targetMatch.team2}</span>
                        </div>
                    </div>
                </section>

                <form id="ratings-form">
                    
                    <div class="voting-layout-grid">
                        <!-- MVP Selection -->
                        <section class="mvp-section ranking-col" style="padding-top: 3.5rem; position: relative; border-radius: 12px; background: white;">
                             <div class="card-title-overlay">ELIGE TU MVP</div>
                            
                            <div class="mvp-grid">
                                {squadWithImages.map(player => (
                                    <div 
                                        class={`mvp-chip ${existingMVP === player.id ? 'selected' : ''}`}
                                        data-player-id={player.id}
                                        onclick="selectMvp(this)"
                                        title={player.name}
                                    >
                                        <div class="chip-image-container">
                                                <img src={player.image} alt={player.name} class="chip-img" loading="lazy" />
                                        </div>
                                        <div class="chip-info">
                                            <span class="player-num">#{player.number}</span>
                                            <span class="player-name-chip">{player.name}</span>
                                        </div>
                                        <div class="mvp-badge">MVP</div>
                                    </div>
                                ))}
                            </div>
                            <input type="hidden" id="mvp-input" value={existingMVP || ''} />
                        </section>
                        
                        <!-- Player Ratings -->
                        <section class="ratings-section ranking-col" style="padding-top: 3.5rem; position: relative; border-radius: 12px; background: white;">
                             <div class="card-title-overlay">PON NOTA (1-10)</div>

                            <div class="players-ratings-grid">
                                {squadWithImages.map((player) => (
                                    <div class="rating-card-v2">
                                        <div class="rating-img-wrapper">
                                            <img src={player.image} alt={player.name} />
                                        </div>
                                        <div class="rating-text">
                                            <span class="player-number-text">#{player.number}</span>
                                            <span class="player-name-text">{player.name}</span>
                                        </div>
                                        
                                        <div class="rating-control-group">
                                            <div class="rating-control-wrapper">
                                                <button type="button" class="rate-btn minus" onclick={`adjustRating('${player.id}', -1)`}>-</button>
                                                <input 
                                                    type="text" 
                                                    id={`rating-${player.id}`}
                                                    class="rating-input"
                                                    value={existingRatings[player.id] || '5'} 
                                                    readonly
                                                    data-player-id={player.id}
                                                />
                                                <button type="button" class="rate-btn plus" onclick={`adjustRating('${player.id}', 1)`}>+</button>
                                            </div>
                                            <button type="button" class="sc-btn" id={`sc-${player.id}`} onclick={`toggleSC('${player.id}')`} title="No Valorable">
                                                N/V
                                            </button>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </section>
                    </div>

                    <div class="actions mt-12">
                        {!userId ? (
                            <p class="login-prompt">Inicia sesión para enviar tus notas</p>
                        ) : !isVotingOpen ? (
                            <div class="locked-submit-area">
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lock-icon-btn"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 13a2 2 0 0 1 2 -2h10a2 2 0 0 1 2 2v6a2 2 0 0 1 -2 2h-10a2 2 0 0 1 -2 -2v-6z" /><path d="M11 16a1 1 0 1 0 2 0a1 1 0 0 0 -2 0" /><path d="M8 11v-4a4 4 0 1 1 8 0v4" /></svg>
                                <p class="locked-text">La votación se abrirá 2 horas después del inicio del partido</p>
                            </div>
                        ) : (
                            <button type="submit" id="submit-ratings" class="submit-btn">
                                ENVIAR VALORACIONES
                            </button>
                        )}
                         <p id="form-feedback" class="feedback-msg hidden"></p>
                    </div>
                </form>

            </div>
        ) : (
            <div class="no-match-card">
                <p>No hay partidos recientes para valorar.</p>
            </div>
        )}

    </div>
</Layout>

<script is:inline>
    // Global functions for inline handlers
    function selectMvp(element) {
        document.querySelectorAll('.mvp-chip').forEach(el => el.classList.remove('selected'));
        element.classList.add('selected');
        const pid = element.dataset.playerId;
        const input = document.getElementById('mvp-input');
        if(input) input.value = pid;
        // MVP is selected, so form might be valid now if ratings are blocked
        validateForm();
    }

    function adjustRating(playerId, delta) {
        const input = document.getElementById(`rating-${playerId}`);
        if (!input) return;

        // If card is in S/C mode, auto-disable S/C and set to 5 (or calc)
        const scBtn = document.getElementById(`sc-${playerId}`);
        if (scBtn && scBtn.classList.contains('active')) {
             toggleSC(playerId); // This resets to 5
             return; // toggleSC sets to 5, so we apply delta next click or now? 
             // Better UX: Just turn off S/C and set to 5 (or 5+delta).
             // Let's just return after toggleSC, which sets it to 5.
        }

        let val = parseInt(input.value);
        if (isNaN(val) || val === 0) {
            val = 5;
        } else {
            val += delta;
        }

        // Bounds 1-10
        if (val < 1) val = 1;
        if (val > 10) val = 10;

        input.value = val;
        updateCardState(playerId);
        validateForm();
    }

    function toggleSC(playerId) {
        const btn = document.getElementById(`sc-${playerId}`);
        const input = document.getElementById(`rating-${playerId}`);
        const wrapper = input.parentElement; // rating-control-wrapper
        
        if (!btn || !input) return;

        const isActive = btn.classList.toggle('active');
        
        if (isActive) {
            input.value = '0'; // 0 represents S/C
            wrapper.classList.add('disabled');
        } else {
            input.value = '5'; // Reset to default 5
            wrapper.classList.remove('disabled');
        }
        
        updateCardState(playerId);
        validateForm();
    }

    function updateCardState(playerId) {
        const input = document.getElementById(`rating-${playerId}`);
        const card = input.closest('.rating-card');
        const val = input.value;
        
        // Remove states
        card.classList.remove('pending', 'ready', 'sc-active');

        if (val === '0') {
            card.classList.add('ready', 'sc-active'); 
        } else {
             // With default 5, it's always "ready" technically, unless we want to distinguish "touched" vs "default".
             // User wants default 5. So it is ready by default?
             // "solo deja enviar las valoraciones si marca en todas" 
             // If default is 5, then "marca" is implicitly done for everyone?
             // Yes, typically defaults mean you don't HAVE to touch everyone.
            card.classList.add('ready'); 
        }
    }

    function validateForm() {
        const submitBtn = document.getElementById('submit-ratings');
        if (!submitBtn) return;

        // If default is 5, validation is always true for ratings being present.
        // Unless we require MVP? User said "solo deja enviar... ya sea la nota o que no es valorable".
        // With default 5, "nota" is always present.
        
        submitBtn.disabled = false;
        submitBtn.innerHTML = 'ENVIAR VALORACIONES';
        submitBtn.classList.remove('disabled-btn');
    }

    // Initialize state
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.rating-input').forEach(input => {
            const pid = input.dataset.playerId;
            const val = input.value;
            
            if (val === '0') {
                const scBtn = document.getElementById(`sc-${pid}`);
                if (scBtn) scBtn.classList.add('active');
                const wrapper = input.parentElement;
                if (wrapper) wrapper.classList.add('disabled');
            }
            // Ensure visual state matches
            updateCardState(pid);
        });
        validateForm();
    });
</script>

<script>
    // Pass isVotingOpen to the script logic context if needed, but easier to just check presence of overlay
    const form = document.getElementById('ratings-form');
    const isLocked = form?.classList.contains('locked-form');

    if (!isLocked) {
        // Handlers are now mainly inline for simplicity in Astro, 
        // but submit needs to gather data properly including 0s.

        // Submit Form
        document.getElementById('submit-ratings')?.addEventListener('click', async (e) => {
            e.preventDefault(); 
             const btn = document.getElementById('submit-ratings');
             if (btn.disabled) return;

             btn.disabled = true;
             btn.textContent = 'Enviando...';

             // Collect MVP
             const mvpInput = document.getElementById('mvp-input');
             const mvp = mvpInput ? mvpInput.value : '';

             // Collect Ratings
             const ratings = [];
             document.querySelectorAll('.rating-input').forEach(input => {
                 const pid = input.getAttribute('data-player-id');
                 const val = input.value;
                 
                 // Push if valid number (including 0 for S/C)
                 if (pid && val !== '' && val !== null) {
                     ratings.push({
                         player_id: pid,
                         rating: parseInt(val)
                     });
                 }
             });

             // We only submit if validation passed (btn not disabled), 
             // but double check or just send. 
             // Logic says: send 0s as well.

             // Send to API
             try {
                const matchId = document.querySelector('.content-container')?.getAttribute('data-match-id');
                const feedbackMsg = document.getElementById('form-feedback');
                
                const response = await fetch('/api/ratings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        match_id: matchId,
                        mvp_vote: mvp,
                        ratings: ratings
                    })
                });

                if (response.ok) {
                    btn.textContent = "¡GUARDADO!";
                    if(feedbackMsg) {
                        feedbackMsg.textContent = "¡Votaciones enviadas correctamente! Gracias por participar.";
                        feedbackMsg.className = 'feedback-msg success';
                        feedbackMsg.classList.remove('hidden');
                    }
                    setTimeout(() => {
                        window.location.reload();
                    }, 2000);
                } else {
                    throw new Error('Error al enviar');
                }

             } catch (e) {
                 console.error(e);
                 btn.textContent = "ERROR";
                 btn.disabled = false;
                 const feedbackMsg = document.getElementById('form-feedback');
                 if(feedbackMsg) {
                    feedbackMsg.textContent = "Hubo un error al enviar tus votaciones. Inténtalo de nuevo.";
                    feedbackMsg.className = 'feedback-msg error';
                    feedbackMsg.classList.remove('hidden');
                 }
                 setTimeout(() => {
                     btn.textContent = 'ENVIAR VALORACIONES';
                     validateForm(); // Re-check state
                 }, 3000);
             }
        });
    }
</script>

<style>
    :root {
        --primary: #2b2b2b;
        --accent: #ffde59;
        --text-primary: #2b2b2b;
    }

    .notas-page {
        font-family: 'Poppins', sans-serif;
    }

    /* MATCH CARD */
    .match-card {
        position: relative;
        background: white;
        border-radius: 12px;
        padding: 3.5rem 2rem 2.5rem 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        border: 1px solid rgba(0,0,0,0.05);
        text-align: center;
    }

    .card-title-overlay {
        position: absolute;
        top: -18px;
        left: 30px;
        transform: skew(-10deg);
        background: var(--accent);
        color: #2b2b2b;
        padding: 0.5rem 1.5rem;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 1.6rem;
        font-weight: 700;
        letter-spacing: 1px;
        box-shadow: 4px 4px 0px rgba(0,0,0,0.1);
        z-index: 10;
        line-height: 1;
    }

    .match-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 2rem;
    }
    .comp-logo { height: 50px; width: auto; }
    .competition-text { font-weight: 700; font-size: 1.1rem; text-transform: uppercase; color: var(--primary); }
    .match-date { color: #888; font-weight: 500; text-transform: capitalize; }

    .teams-container {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 2rem;
    }
    .team { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; width: 120px;}
    .team-shield { width: 80px; height: 80px; object-fit: contain; filter: drop-shadow(0 4px 4px rgba(0,0,0,0.05)); }
    .team-name { font-weight: 900; font-size: 1rem; text-transform: uppercase; color: var(--primary); line-height: 1.1; }
    .vs-text { font-family: 'Archivo Black', sans-serif; font-size: 1.5rem; color: #ddd; }

    /* SECTION TITLES */
    .section-header-cnt {
        text-align: center;
        margin-bottom: 2rem;
    }
    .subsection-title {
        font-size: 1.2rem; 
        font-weight: 800; 
        text-transform: uppercase; 
        color: var(--primary); 
        text-align: center; 
        letter-spacing: 1px;
        position: relative;
        display: inline-block;
    }
    .subsection-title::after {
        content: '';
        display: block;
        width: 60px;
        height: 4px;
        background: var(--accent);
        margin: 5px auto 0;
        border-radius: 2px;
    }

    .section-divider {
        border: 0;
        height: 1px;
        background: #f0f0f0;
