---
import Layout from "../layouts/Layout.astro";
import { turso } from "../lib/turso";
import { CALENDAR } from "../consts/calendar";
import { SQUAD } from "../consts/squad";
import {
    SignInButton,
    SignedIn,
    SignedOut,
    UserButton,
} from "@clerk/astro/components";
import {
    getPlayerImage,
    getShield,
    getCompetitionLogo,
} from "../lib/assetHelpers";
import vsImage from "../assets/vs.png";

const now = new Date();
const pastMatches = CALENDAR.filter((m) => new Date(m.date) < now);
const lastMatch =
    pastMatches.length > 0 ? pastMatches[pastMatches.length - 1] : null;
const nextMatch = CALENDAR.find((m) => new Date(m.date) >= now) || null;

let targetMatch = null;
let isVotingOpen = false;

if (lastMatch) {
    const matchDate = new Date(lastMatch.date);
    const msSince = now.getTime() - matchDate.getTime();
    const hoursSince = msSince / (1000 * 60 * 60);

    if (hoursSince < 2) {
        targetMatch = lastMatch;
        isVotingOpen = false;
    } else if (hoursSince >= 2 && hoursSince <= 24) {
        targetMatch = lastMatch;
        isVotingOpen = true;
    } else {
        targetMatch = nextMatch;
        isVotingOpen = false;
    }
} else {
    targetMatch = nextMatch;
    isVotingOpen = true; // FORCED OPEN FOR TESTING
}

const homeShield = targetMatch ? await getShield(targetMatch.team1) : "";
const awayShield = targetMatch ? await getShield(targetMatch.team2) : "";
const compLogo = targetMatch
    ? await getCompetitionLogo(targetMatch.competition)
    : "";

const { userId } = Astro.locals.auth();
let existingMVP: string | null = null;
const squad: any[] = SQUAD;

if (userId && targetMatch && isVotingOpen) {
    try {
        const mvpResult = await turso.execute({
            sql: "SELECT player_id FROM mvp_votes WHERE user_id = ? AND match_id = ?",
            args: [userId, targetMatch.id],
        });
        if (mvpResult.rows.length > 0) {
            existingMVP = String(mvpResult.rows[0].player_id);
        }
    } catch (e) {
        console.error("Error fetching MVP vote", e);
    }
}

let voteStats: Record<string, number> = {};
let totalMatchVotes = 0;

if (targetMatch) {
    try {
        const allVotesResult = await turso.execute({
            sql: "SELECT player_id, COUNT(*) as c FROM mvp_votes WHERE match_id = ? GROUP BY player_id",
            args: [targetMatch.id]
        });
        
        allVotesResult.rows.forEach((row: any) => {
            const pid = String(row.player_id);
            const count = Number(row.c);
            voteStats[pid] = count;
            totalMatchVotes += count;
        });
    } catch (e) {
        console.error("Error fetching vote stats", e);
    }
}

const squadWithImages = await Promise.all(
    squad.map(async (p) => ({
        ...p,
        image: await getPlayerImage(p.id),
    })),
);

import { getFanRankings } from "../lib/fanRankings";
const fanRankings = await getFanRankings();

const playerImageMap = new Map(squadWithImages.map((p) => [p.id, p.image]));

const playerImages = import.meta.glob(
    "/src/assets/jugadoras/*.{png,jpg,jpeg,webp}",
    { eager: true },
);
---

<Layout title="MVP | Madrid Femenino Xtra">
    <div class="notas-page w-full max-w-[95%] mx-auto px-2 sm:px-6 lg:px-8 py-6">
        <header class="text-center mb-16 max-w-4xl mx-auto">
            <h1 class="page-title" style="color: var(--text-primary);">
                MVP
            </h1>
            <p class="content-h2 mx-auto" style="text-align: center;">
                Elige a la mejor jugadora del partido.
            </p>
            <div class="auth-controls mt-6 flex justify-center">
                <SignedOut>
                    <SignInButton
                        mode="modal"
                        as="button"
                        class="header-login-btn"
                    >
                        INICIAR SESIÓN
                    </SignInButton>
                </SignedOut>
                <SignedIn>
                    <UserButton />
                </SignedIn>
            </div>
        </header>

        <div class="mvp-page-grid">
            <div class="main-column">
                {
                    targetMatch ? (
                        <div class="voting-wrapper" data-match-id={targetMatch.id}>
                            <form id="ratings-form">
                                <section class="unified-card">
                                    <!-- MATCH HEADER (Inside unified card) -->
                                    <div class="unified-match-info">
                                         <div class="card-title-overlay">
                                            ELIGE TU MVP
                                        </div>
                                        
                                        <div class="match-info-simple">
                                            {compLogo && (
                                                <img
                                                    src={compLogo}
                                                    alt={targetMatch.competition}
                                                    class="comp-logo-center"
                                                />
                                            )}

                                            <div class="match-date-display">
                                                <span class="date-text">
                                                    {(() => {
                                                        const s = new Date(targetMatch.date).toLocaleDateString("es-ES", {
                                                            weekday: "long",
                                                            day: "numeric",
                                                            month: "long",
                                                        });
                                                        return s.charAt(0).toUpperCase() + s.slice(1);
                                                    })()}
                                                </span>
                                                <span class="time-text">
                                                    {targetMatch.time.replace(" ", "h ")}
                                                </span>
                                            </div>

                                            <div class="teams-simple">
                                                <div class="team-item">
                                                    {homeShield && (
                                                        <img
                                                            src={homeShield}
                                                            alt={targetMatch.team1}
                                                            class="shield-simple"
                                                        />
                                                    )}
                                                    <span class="team-label">
                                                        {targetMatch.team1}
                                                    </span>
                                                </div>
                                                <img src={vsImage.src} class="vs-img" alt="VS" />
                                                <div class="team-item">
                                                    {awayShield && (
                                                        <img
                                                            src={awayShield}
                                                            alt={targetMatch.team2}
                                                            class="shield-simple"
                                                        />
                                                    )}
                                                    <span class="team-label">
                                                        {targetMatch.team2}
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- DIVIDER REMOVED -->


                                    <!-- VOTING SECTION -->
                                    <div class="mvp-voting-area">
                                        <div class="mvp-grid">
                                            {squadWithImages.map((player) => {
                                                const pVotes = voteStats[player.id] || 0;
                                                const percent = totalMatchVotes > 0 ? ((pVotes / totalMatchVotes) * 100).toFixed(1) : "0";
                                                const showPercent = !!existingMVP; 
                                                return (
                                                <div
                                                    class={`mvp-chip ${existingMVP === player.id ? "selected" : ""}`}
                                                    data-player-id={player.id}
                                                    onclick="selectMvp(this)"
                                                    title={player.name}
                                                >
                                                    <div class="chip-image-container">
                                                        <img
                                                            src={player.image}
                                                            alt={player.name}
                                                            class="chip-img"
                                                            loading="lazy"
                                                        />
                                                    </div>
                                                    <div class="chip-info">
                                                        <span class="player-num">
                                                            #{player.number}
                                                        </span>
                                                        <span class="player-name-chip">
                                                            {player.name}
                                                        </span>
                                                    </div>
                                                    
                                                    {showPercent && (
                                                        <div class="vote-percent-bar">
                                                            <div class="percent-text">{percent}%</div>
                                                            <div class="percent-fill" style={`width:${percent}%`}></div>
                                                        </div>
                                                    )}

                                                    <div class="mvp-badge">MVP</div>
                                                </div>
                                            )})}
                                        </div>
                                        <input
                                            type="hidden"
                                            id="mvp-input"
                                            value={existingMVP || ""}
                                        />
                                    </div>

                                    <!-- ACTIONS FOOTER -->
                                    <div class="actions pb-4" style="margin-top: 3.5rem;">
                                        {!userId ? (
                                            <p class="login-prompt">
                                                Inicia sesión para enviar tu voto.
                                            </p>
                                        ) : !isVotingOpen ? (
                                            <div class="locked-submit-area">
                                                <svg
                                                    xmlns="http://www.w3.org/2000/svg"
                                                    width="32"
                                                    height="32"
                                                    viewBox="0 0 24 24"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    stroke-width="2"
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    class="lock-icon-btn"
                                                >
                                                    <path
                                                        stroke="none"
                                                        d="M0 0h24v24H0z"
                                                        fill="none"
                                                        stroke-width="0"
                                                    />
                                                    <path d="M5 13a2 2 0 0 1 2 -2h10a2 2 0 0 1 2 2v6a2 2 0 0 1 -2 2h-10a2 2 0 0 1 -2 -2v-6z" />
                                                    <path d="M11 16a1 1 0 1 0 2 0a1 1 0 0 0 -2 0" />
                                                    <path d="M8 11v-4a4 4 0 1 1 8 0v4" />
                                                </svg>
                                                <p class="locked-text">
                                                    La votación se abrirá 2 horas después
                                                    del inicio del partido
                                                </p>
                                            </div>
                                        ) : (
                                            <button
                                                type="submit"
                                                id="submit-ratings"
                                                class="submit-btn"
                                            >
                                                ENVIAR VOTO MVP
                                            </button>
                                        )}
                                        <p id="form-feedback" class="feedback-msg hidden" />
                                    </div>
                                </section>
                            </form>
                        </div>
                    ) : (
                        <div class="no-match-card">
                            <p>No hay partidos recientes para valorar.</p>
                        </div>
                    )
                }
            </div>

            <aside class="sidebar-column">
                <div class="leaderboard-card">
                    <div class="card-title-overlay small">
                        CLASIFICACIÓN
                    </div>
                    
                    <div class="leaderboard-list">
                         {fanRankings.mvp && fanRankings.mvp.length > 0 ? (
                            fanRankings.mvp.map((player: any, index: number) => {
                                const pInfo = squadWithImages.find(p => p.id === player.id);
                                return (
                                    <div class="leaderboard-item">
                                        <div class="rank-number">{index + 1}</div>
                                        <div class="lb-player-img">
                                             <img 
                                                src={pInfo?.image || "/img/players/default-player.webp"} 
                                                alt={pInfo?.name || player.id}
                                                loading="lazy"
                                                onerror="this.src='/img/players/default-player.webp'"
                                            />
                                        </div>
                                        <div class="lb-player-info">
                                            <span class="lb-name" title={pInfo?.name || player.id}>{pInfo?.name || `ID: ${player.id}`}</span>
                                            <span class="lb-votes">{player.count} MVP{player.count !== 1 ? 's' : ''}</span>
                                        </div>
                                    </div>
                                );
                            })
                        ) : (
                            <div class="empty-lb">
                                <p>Aún no hay votos registrados esta temporada.</p>
                            </div>
                        )}
                    </div>
                </div>
            </aside>
        </div>

    </div>
</Layout>

<script is:inline>
    function selectMvp(element) {
        document
            .querySelectorAll(".mvp-chip")
            .forEach((el) => el.classList.remove("selected"));
        element.classList.add("selected");
        const pid = element.dataset.playerId;
        const input = document.getElementById("mvp-input");
        if (input) input.value = pid;
        validateForm();
    }

    function validateForm() {
        const submitBtn = document.getElementById("submit-ratings");
        if (!submitBtn) return;

        submitBtn.disabled = false;
        submitBtn.innerHTML = "ENVIAR VOTO MVP";
        submitBtn.classList.remove("disabled-btn");
    }

    document.addEventListener("DOMContentLoaded", () => {
        validateForm();
    });
</script>

<script>
    const form = document.getElementById("ratings-form");
    const isLocked = form?.classList.contains("locked-form");

    if (!isLocked) {
        document
            .getElementById("submit-ratings")
            ?.addEventListener("click", async (e) => {
                e.preventDefault();
                const btn = document.getElementById(
                    "submit-ratings",
                ) as HTMLButtonElement;
                if (!btn || btn.disabled) return;

                btn.disabled = true;
                btn.textContent = "Enviando...";

                const mvpInput = document.getElementById(
                    "mvp-input",
                ) as HTMLInputElement;
                const mvp = mvpInput ? mvpInput.value : "";

                try {
                    const matchId = document
                        .querySelector(".voting-wrapper")
                        ?.getAttribute("data-match-id");
                    const feedbackMsg =
                        document.getElementById("form-feedback");

                    const response = await fetch("/api/ratings", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            match_id: matchId,
                            mvp_vote: mvp,
                            ratings: [], 
                        }),
                    });

                    if (response.ok) {
                        btn.textContent = "¡GUARDADO!";
                        if (feedbackMsg) {
                            feedbackMsg.textContent =
                                "¡Voto enviado correctamente! Gracias por participar.";
                            feedbackMsg.className = "feedback-msg success";
                            feedbackMsg.classList.remove("hidden");
                        }
                        setTimeout(() => {
                            window.location.reload();
                        }, 2000);
                    } else {
                        throw new Error("Error al enviar");
                    }
                } catch (e) {
                    console.error(e);
                    btn.textContent = "ERROR";
                    btn.disabled = false;
                    const feedbackMsg =
                        document.getElementById("form-feedback");
                    if (feedbackMsg) {
                        feedbackMsg.textContent =
                            "Hubo un error al enviar tu voto. Inténtalo de nuevo.";
                        feedbackMsg.className = "feedback-msg error";
                        feedbackMsg.classList.remove("hidden");
                    }
                }
            });
    }
</script>

<style>
