import Layout from "../layouts/Layout.astro";
import { fetchAllGoals } from "../utils/partidos";
import { fetchAllClubShields } from "../utils/rivales";
import { getAssetUrl } from "../utils/assets";

const allGoalsRaw = await fetchAllGoals();
const clubShields = await fetchAllClubShields();

const officialCompsIds = [
    "Liga F",
    "UWCL",
    "Copa de la Reina",
    "Supercopa de España",
];

const officialGoalsRaw = allGoalsRaw.filter(
    (g) => g.competicion && officialCompsIds.includes(g.competicion),
);

const officialComps = [
    { id: "Liga F", name: "Liga F", icon: "liga_f" },
    { id: "UWCL", name: "UWCL", icon: "uwcl" },
    {
        id: "Copa de la Reina",
        name: "Copa de la Reina",
        icon: "copa_de_la_reina",
    },
    {
        id: "Supercopa de España",
        name: "Supercopa",
        icon: "supercopa_de_espana",
    },
];

const highlightedNumbers = [
    1, 100, 200, 300, 400, 500, 600, 700, 800, 900, 1000,
];

const sortGoals = (goals: any[]) =>
    goals.sort((a, b) => {
        const dateA = new Date(a.fecha).getTime();
        const dateB = new Date(b.fecha).getTime();
        if (dateA !== dateB) return dateA - dateB;
        return parseInt(a.minuto || "0") - parseInt(b.minuto || "0");
    });

const calculateMilestones = (goals: any[]) => {
    return sortGoals(goals)
        .map((g, index) => {
            // Numbering based on the sequence of the provided (filtered) array
            const goalNumber = index + 1;
            return {
                ...g,
                goalNumber,
                rival:
                    g.club_local === "Real Madrid"
                        ? g.club_visitante
                        : g.club_local,
                isMilestone:
                    goalNumber === 1 ||
                    goalNumber % 10 === 0 ||
                    highlightedNumbers.includes(goalNumber),
                isHighlighted: highlightedNumbers.includes(goalNumber),
            };
        })
        .filter((g) => g.isMilestone);
};

// Global official milestones
const globalMilestones = calculateMilestones(officialGoalsRaw);

// Milestones per competition
const compMilestones: Record<string, any[]> = {};
officialComps.forEach((comp) => {
    compMilestones[comp.id] = calculateMilestones(
        officialGoalsRaw.filter((g) => g.competicion === comp.id),
    );
});

const formatShortDate = (dateString: string | null | undefined): string => {
    if (!dateString) return "-";
    try {
        const date = new Date(dateString.split("T")[0]);
        if (isNaN(date.getTime())) return "-";
        return date.toLocaleDateString("es-ES", {
            day: "2-digit",
            month: "2-digit",
            year: "numeric",
        });
    } catch {
        return "-";
    }
};
