                                                                .normalize(
                                                                    "NFD",
                                                                )
                                                                .replace(
                                                                    /[\u0300-\u036f]/g,
                                                                    "",
                                                                )
                                                        ] ||
                                                        getAssetUrl(
                                                            "escudos",
                                                            m.rival,
