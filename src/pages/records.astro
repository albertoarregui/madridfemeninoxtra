---
import Layout from "../layouts/Layout.astro";
import { fetchAllGoals } from "../utils/partidos";
import { fetchAllClubShields } from "../utils/rivales";
import { getAssetUrl } from "../utils/assets";

const allGoals = await fetchAllGoals();
const clubShields = await fetchAllClubShields();

const officialComps = [
    { id: "Liga F", name: "Liga F", icon: "liga_f" },
    { id: "UWCL", name: "UWCL", icon: "uwcl" },
    {
        id: "Copa de la Reina",
        name: "Copa de la Reina",
        icon: "copa_de_la_reina",
    },
    {
        id: "Supercopa de España",
        name: "Supercopa",
        icon: "supercopa_de_espana",
    },
];

const milestonesByComp = officialComps
    .map((comp) => {
        const compGoals = allGoals
            .filter((g) => g.competicion === comp.id)
            .sort((a, b) => {
                const dateA = new Date(a.fecha).getTime();
                const dateB = new Date(b.fecha).getTime();
                if (dateA !== dateB) return dateA - dateB;
                return parseInt(a.minuto) - parseInt(b.minuto);
            })
            .map((g, index) => ({
                ...g,
                goalNumber: index + 1,
                rival:
                    g.club_local === "Real Madrid"
                        ? g.club_visitante
                        : g.club_local,
            }))
            .filter((g) => g.goalNumber % 10 === 0);

        return {
            ...comp,
            goals: compGoals,
        };
    })
    .filter((c) => c.goals.length > 0);

const formatShortDate = (dateString: string | null | undefined): string => {
    if (!dateString) return "-";
    try {
        const date = new Date(dateString.split("T")[0]);
        if (isNaN(date.getTime())) return "-";
        return date.toLocaleDateString("es-ES", {
            day: "2-digit",
            month: "2-digit",
            year: "numeric",
        });
    } catch {
        return "-";
    }
};
---

<Layout
    title="Récords | Madrid Femenino Xtra"
    description="Marcas de goles redondos a lo largo de la historia del Real Madrid femenino."
>
    <main class="records-page">
        <header class="records-header">
            <h1 class="page-title">RÉCORDS</h1>
            <p class="subtitle">
                Marcas de goles redondos a lo largo de la historia del Real
                Madrid femenino.
            </p>
        </header>

        {
            milestonesByComp.map((comp) => (
                <section class="comp-records-section">
                    <div class="comp-header">
                        <img
                            src={getAssetUrl("competiciones", comp.icon)}
                            alt={comp.name}
                            class="comp-icon-title"
                        />
                        <h2 class="comp-title">{comp.name}</h2>
                    </div>

                    <div class="table-container floating-table">
                        <table class="records-table">
                            <thead>
                                <tr>
                                    <th class="col-milestone">Hito</th>
                                    <th class="col-player">Goleadora</th>
                                    <th class="col-rival">Rival</th>
                                    <th class="col-date">Fecha</th>
                                    <th class="col-video">Vídeo</th>
                                </tr>
                            </thead>
                            <tbody>
                                {comp.goals.map((m) => (
                                    <tr
                                        class={
                                            m.video_url ? "row-has-video" : ""
                                        }
                                    >
                                        <td class="cell-milestone">
                                            <span class="goal-tag">
                                                GOL {m.goalNumber}
                                            </span>
                                        </td>
                                        <td class="cell-player">
                                            <div class="player-info-cell">
                                                <div class="player-img-wrapper">
                                                    <img
                                                        src={
                                                            m.foto_goleadora ||
                                                            getAssetUrl(
                                                                "jugadoras",
                                                                "placeholder",
                                                            )
                                                        }
                                                        alt={m.nombre_goleadora}
                                                        class="player-thumb"
                                                    />
                                                </div>
                                                <span class="player-name-text">
                                                    {m.nombre_goleadora}
                                                </span>
                                            </div>
                                        </td>
                                        <td class="cell-rival">
                                            <div class="rival-info-cell">
                                                <img
                                                    src={
                                                        clubShields[m.rival] ||
                                                        getAssetUrl(
                                                            "escudos",
                                                            m.rival,
                                                        )
                                                    }
                                                    alt={m.rival}
                                                    class="rival-shield-thumb"
                                                />
                                                <span class="rival-name-text">
                                                    {m.rival}
                                                </span>
                                            </div>
                                        </td>
                                        <td class="cell-date">
                                            <span class="date-text">
                                                {formatShortDate(m.fecha)}
                                            </span>
                                        </td>
                                        <td class="cell-video">
                                            {m.video_url ? (
                                                <button
                                                    class="play-btn-small"
                                                    onclick={`openVideoModal('${m.video_url}', '${m.nombre_goleadora.replace(/'/g, "\\'")}')`}
                                                    title="Ver gol"
                                                >
                                                    <svg
                                                        xmlns="http://www.w3.org/2000/svg"
                                                        width="20"
                                                        height="20"
                                                        viewBox="0 0 24 24"
                                                        fill="currentColor"
                                                    >
                                                        <path
                                                            stroke="none"
                                                            d="M0 0h24v24H0z"
                                                            fill="none"
                                                        />
                                                        <path d="M6 4v16a1 1 0 0 0 1.524 .852l13 -8a1 1 0 0 0 0 -1.704l-13 -8a1 1 0 0 0 -1.524 .852z" />
                                                    </svg>
                                                </button>
                                            ) : (
                                                <span class="no-video">-</span>
                                            )}
                                        </td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                </section>
            ))
        }

        <!-- Video Modal -->
        <div id="video-modal" class="video-modal-overlay">
            <div class="video-modal-container">
                <div class="video-modal-header">
                    <h3 id="video-modal-title">Gol</h3>
                    <button class="video-close-btn" onclick="closeVideoModal()">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><line x1="18" y1="6" x2="6" y2="18"></line><line
                                x1="6"
                                y1="6"
                                x2="18"
                                y2="18"></line></svg
                        >
                    </button>
                </div>
                <div class="video-modal-body">
                    <video
                        id="goal-video-player"
                        controls
                        class="goal-video-element"
                    >
                        <source id="video-source" src="" type="video/mp4" />
                    </video>
                </div>
            </div>
        </div>
    </main>
</Layout>

<script is:inline>
    function openVideoModal(url, scorer) {
        const modal = document.getElementById("video-modal");
        const video = document.getElementById("goal-video-player");
        const source = document.getElementById("video-source");
        const title = document.getElementById("video-modal-title");
        title.textContent = `Gol de ${scorer}`;
        source.src = url;
        video.load();
        modal.style.display = "flex";
        video.play().catch((e) => console.log("Auto-play prevented", e));
        modal.onclick = function (e) {
            if (e.target === modal) closeVideoModal();
        };
    }
    function closeVideoModal() {
        const modal = document.getElementById("video-modal");
        const video = document.getElementById("goal-video-player");
        video.pause();
        modal.style.display = "none";
    }
</script>

<style>
    .records-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 1.5rem;
    }

    /* Header Styling matching other pages */
    .records-header {
        text-align: center;
        margin-bottom: 5rem;
    }
    .page-title {
        font-size: 3.5rem;
        font-weight: 900;
        color: #151e42;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        position: relative;
        display: inline-block;
        letter-spacing: -1px;
    }
    .page-title::after {
        content: "";
        position: absolute;
        bottom: -15px;
        left: 50%;
        transform: translateX(-50%);
        width: 120px; /* Wider yellow line as requested */
        height: 6px;
        background: #ffde59;
        border-radius: 3px;
    }
    .subtitle {
        font-size: 1.25rem;
        color: #4b5563;
        font-weight: 500;
        max-width: 700px;
        margin: 1rem auto 0;
        line-height: 1.6;
    }

    /* Section & Competition Header */
    .comp-records-section {
        margin-bottom: 5rem;
    }
    .comp-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
        padding-left: 0.5rem;
    }
    .comp-icon-title {
        height: 40px;
        width: auto;
        object-fit: contain;
    }
    .comp-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: #151e42;
        text-transform: uppercase;
    }

    /* Floating White Table Styles */
    .floating-table {
        background: white;
        border-radius: 20px;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        border: 1px solid #f0f0f0;
    }
    .records-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

    /* Table Header */
    .records-table th {
        background: #f8fafc;
        padding: 1.25rem 1.5rem;
        font-size: 0.8rem;
        font-weight: 800;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-bottom: 2px solid #f1f5f9;
    }

    /* Table Rows */
    .records-table td {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
    }
    .records-table tr:last-child td {
        border-bottom: none;
    }

    /* Goal Tag */
    .goal-tag {
        background: #151e42;
        color: #ffde59;
        font-family: "Bebas Neue", sans-serif;
        font-size: 1.2rem;
        padding: 0.4rem 1rem;
        border-radius: 8px;
        display: inline-block;
        font-weight: 700;
        min-width: 90px;
        text-align: center;
        letter-spacing: 1px;
    }

    /* Player Info Cell */
    .player-info-cell {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .player-img-wrapper {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        overflow: hidden;
        border: 2px solid #ffde59;
        background: #f1f5f9;
        flex-shrink: 0;
    }
    .player-thumb {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top; /* Prevents cutting from top as requested */
    }
    .player-name-text {
        font-weight: 700;
        color: #151e42;
        font-size: 1.05rem;
    }

    /* Rival Info Cell */
    .rival-info-cell {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .rival-shield-thumb {
        width: 32px;
        height: 32px;
        object-fit: contain;
    }
    .rival-name-text {
        font-weight: 600;
        color: #4b5563;
    }

    /* Date & Video Cells */
    .date-text {
        color: #64748b;
        font-weight: 500;
        font-family: monospace;
    }
    .play-btn-small {
        background: #ffde59;
        color: #151e42;
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 4px 10px rgba(255, 222, 89, 0.4);
    }
    .play-btn-small:hover {
        transform: scale(1.1);
        background: #151e42;
        color: #ffde59;
    }
    .no-video {
        color: #cbd5e1;
    }

    /* Modal Styling */
    .video-modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.9);
        z-index: 10000;
        align-items: center;
        justify-content: center;
        padding: 20px;
        backdrop-filter: blur(8px);
    }
    .video-modal-container {
        background: #151e42;
        width: 100%;
        max-width: 1000px;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5);
    }
    .video-modal-header {
        padding: 1.25rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #ffde59;
    }
    .video-modal-header h3 {
        margin: 0;
        color: #151e42;
        font-weight: 900;
        text-transform: uppercase;
    }
    .video-close-btn {
        background: none;
        border: none;
        color: #151e42;
        cursor: pointer;
    }
    .video-modal-body {
        position: relative;
        padding-top: 56.25%;
    }
    .goal-video-element {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    @media (max-width: 768px) {
        .page-title {
            font-size: 2.5rem;
        }
        .records-table th:nth-child(4),
        .records-table td:nth-child(4) {
            display: none;
        }
        .player-name-text {
            font-size: 0.9rem;
        }
        .goal-tag {
            font-size: 1rem;
            min-width: 70px;
        }
    }
</style>
