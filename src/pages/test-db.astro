---
import { fetchPlayersDirectly, fetchPlayerStats } from "../utils/players";

let debugInfo = [];

try {
    // 1. Fetch all players to verify DB connection and get an ID
    const players = await fetchPlayersDirectly();
    debugInfo.push(`Players found: ${players.length}`);

    if (players.length > 0) {
        // 2. Pick a player (e.g. Misa or the first one)
        const player =
            players.find((p) => p.nombre.includes("Misa")) || players[0];
        debugInfo.push(
            `Testing stats for: ${player.nombre} (ID: ${player.id_jugadora})`,
        );

        // 3. Fetch stats for this player
        const isGoalkeeper = player.posicion === "Portera";
        const stats = await fetchPlayerStats(player.id_jugadora, isGoalkeeper);

        debugInfo.push("Stats Result:");
        debugInfo.push(stats);
    } else {
        debugInfo.push("No players returned by fetchPlayersDirectly");
    }
} catch (e) {
    debugInfo.push(`Error: ${e.message}`);
    debugInfo.push(e.stack);
}
---

<html>
    <body>
        <h1>Stats Debug</h1>
        <pre
            id="debug-output"
            style="white-space: pre-wrap;">{JSON.stringify(debugInfo, null, 2)}</pre>
    </body>
</html>
