---
import Layout from "../layouts/Layout.astro";
import Form from "../components/Form.astro";
import X from "../assets/svg/x.svg";
import YouTube from "../assets/svg/youtube.svg";
import "../styles/global.css";
---

<Layout
    title="Contacto | Madrid Femenino Xtra"
    description="¿Quieres anunciarte o colaborar? Ponte en contacto con el equipo de Madrid Femenino Xtra, el medio de referencia para la afición del Real Madrid Femenino."
>
    <main class="contacto-container">
        <section class="header-section">
            <h1 class="page-title">CONECTA CON NOSOTROS</h1>
            <p class="section-subtitle">
                Tu canal directo con la redacción de Madrid Femenino Xtra para
                consultas, información y sugerencias sobre el equipo blanco.
            </p>
            <div class="separator-line"></div>
        </section>

        <div class="contact-grid">
            <div class="contact-methods">
                <div class="email-info-box">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                        ></path>
                        <polyline points="22,6 12,13 2,6"></polyline>
                    </svg>
                    <section>
                        <h3>Email</h3>
                        <a href="mailto:contacto@madridfemeninoxtra.com"
                            >contacto@madridfemeninoxtra.com</a
                        >
                    </section>
                </div>
            </div>

            <div class="form-wrapper">
                <Form />
            </div>
        </div>

        <div class="advertising-section">
            <h1 class="page-title">COLABORACIONES</h1>
            <p class="section-subtitle">
                Amplifica tu marca llegando a la mayor comunidad de seguidores
                del Real Madrid Femenino a través de nuestras opciones de
                patrocinio.
            </p>
            <div class="separator-line"></div>

            <div class="stats-grid">
                <div class="stat-card platform-card">
                    <div class="card-header">
                        <div class="icon-wrapper x-icon"><X /></div>
                        <span class="platform-name">Twitter / X</span>
                    </div>
                    <div class="stat-main">
                        <span class="stat-number">+7.5K</span>
                        <span class="stat-label">Seguidores</span>
                    </div>
                    <div class="stat-details">
                        <div class="detail-item">
                            <strong>18.9M</strong> Impresiones
                        </div>
                        <div class="detail-item">
                            <strong>1.5M</strong> Interacciones
                        </div>
                    </div>
                </div>

                <div class="stat-card platform-card">
                    <div class="card-header">
                        <div class="icon-wrapper yt-icon"><YouTube /></div>
                        <span class="platform-name">YouTube</span>
                    </div>
                    <div class="stat-main">
                        <span class="stat-number">+2.8K</span>
                        <span class="stat-label">Suscriptores</span>
                    </div>
                    <div class="stat-details">
                        <div class="detail-item">
                            <strong>+400K</strong> Visualizaciones
                        </div>
                        <div class="detail-item">
                            <strong>20.9K</strong> Audiencia Mensual
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</Layout>

<style>
    :root {
        --color-fondo-claro: #ffffff;
        --color-texto-oscuro: #2b2b2b;
        --color-acento: #ffde59;
        --color-borde-claro: #cccccc;
    }

    .contacto-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .header-section {
        text-align: center;
        margin-bottom: 2rem;
    }

    .section-subtitle {
        font-family: "Poppins", sans-serif;
        font-size: 1.1rem;
        color: #666;
        margin: 0 auto;
        max-width: 800px;
    }

    .separator-line {
        border-bottom: 1px solid #ddd;
        margin-top: 2rem;
        margin-bottom: 3rem;
        width: 100%;
    }

    .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        margin-bottom: 4rem;
        align-items: center; /* Vertically align email box with form */
    }

    .contact-methods {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        width: 100%;
    }

    .email-info-box {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 20px;
        background-color: var(--color-fondo-claro);
        border-radius: 8px;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        width: 100%;
        max-width: 450px;
        /* margin removed as grid handles spacing */
    }

    .email-info-box svg {
        color: var(--color-acento);
        min-width: 28px;
        min-height: 28px;
        stroke-width: 2;
    }

    .email-info-box h3 {
        color: var(--color-texto-oscuro);
        font-size: 1.1em;
        margin: 0;
        font-weight: bold;
    }

    .email-info-box a {
        color: var(--color-texto-oscuro);
        font-size: 1.2em;
        font-weight: normal;
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .email-info-box a:hover {
        color: var(--color-acento);
        text-decoration: underline;
    }

    /* Advertising Section Styles */
    .advertising-section {
        margin: 4rem auto 2rem; /* Increased top margin */
        text-align: center;
        max-width: 1000px; /* Increased max-width for cleaner layout */
        padding: 0 1rem;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: white;
        padding: 2rem;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        border: 1px solid #f0f0f0;
        transition: transform 0.3s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
    }

    /* Responsive adjustments */
    @media (max-width: 900px) {
        .contact-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
            text-align: center;
        }

        .contact-methods {
            order: 1; /* Email first */
            width: 100%;
            display: flex;
            justify-content: center;
        }

        .form-wrapper {
            order: 2; /* Form second */
            width: 100%;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }
    }

    .card-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 0.5rem;
    }

    .icon-wrapper {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .icon-wrapper svg {
        width: 100%;
        height: 100%;
    }

    .x-icon {
        color: #000;
    }
    .yt-icon {
        color: #ff0000;
    }

    .platform-name {
        font-family: "Poppins", sans-serif;
        font-weight: 700;
        font-size: 1.2rem;
        color: #333;
    }

    .stat-main {
        margin-bottom: 0.5rem;
    }

    .stat-number {
        font-family: "Archivo Black", sans-serif;
        font-size: 3rem;
        color: var(--color-texto-oscuro);
        line-height: 1;
        text-shadow: 2px 2px 0px rgba(255, 222, 89, 0.4);
    }

    .stat-label {
        display: block;
        font-family: "Poppins", sans-serif;
        font-weight: 600;
        color: #666;
        text-transform: uppercase;
        font-size: 0.9rem;
        letter-spacing: 1px;
        margin-top: 0.5rem;
    }

    .stat-details {
        width: 100%;
        border-top: 1px solid #eee;
        padding-top: 1.5rem;
        display: flex;
        justify-content: space-around;
        gap: 1rem;
    }

    .detail-item {
        font-size: 0.9rem;
        color: #555;
        line-height: 1.4;
    }

    .detail-item strong {
        display: block;
        font-size: 1.1rem;
        color: var(--color-texto-oscuro);
    }

    .cta-box {
        background: #f9f9f9;
        padding: 1.5rem;
        border-radius: 12px;
        display: inline-block;
        border-left: 4px solid var(--color-acento);
        font-size: 1.1rem;
    }

    @media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }
        .stat-details {
            flex-direction: column;
            gap: 0.5rem;
        }
    }
</style>
