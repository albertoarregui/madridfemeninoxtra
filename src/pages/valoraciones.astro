---
import Layout from "../layouts/Layout.astro";
import { getFanRankings } from "../lib/fanRankings";
import { SQUAD } from "../consts/squad";
import { getPlayerImage } from "../lib/assetHelpers";

// Fetch rankings
const fanRankings = await getFanRankings();

// Load player images
const squadWithImages = await Promise.all(
    SQUAD.sort((a, b) => a.number - b.number).map(async (p) => ({
        ...p,
        image: await getPlayerImage(p.id),
    })),
);

const playerImageMap = new Map(squadWithImages.map((p) => [p.id, p.image]));
const squad: any[] = SQUAD;
---

<Layout title="Valoraciones de la Afición | Madrid Femenino Xtra">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <h1 class="page-title">LAS MÁS VALORADAS DE LA TEMPORADA</h1>

        <p class="content-h2 text-center text-pretty max-w-4xl mx-auto mb-12">
            Descubre a las jugadoras mejor valoradas por la afición en
            diferentes períodos y las más votadas como MVP
        </p>

        <div class="rankings-grid">
            {/* 1. MATCH RANKING */}
            <div class="ranking-col">
                <div class="card-title-overlay">JORNADA</div>
                <div class="ranking-list">
                    {
                        fanRankings.match.map((p: any, i: number) => {
                            const player = squad.find((s) => s.id === p.id);
                            if (!player) return null;
                            return (
                                <div class="ranking-item">
                                    <span class="rank-pos">{i + 1}</span>
                                    <div class="rank-img-wrapper">
                                        <img
                                            src={
                                                playerImageMap.get(player.id) ||
                                                ""
                                            }
                                            alt={player.name}
                                            class="rank-img"
                                        />
                                    </div>
                                    <div class="rank-info">
                                        <span class="rank-name">
                                            {player.name}
                                        </span>
                                        <span class="rank-val">
                                            {p.avg.toFixed(1)}
                                        </span>
                                    </div>
                                </div>
                            );
                        })
                    }
                    {
                        fanRankings.match.length === 0 && (
                            <p class="empty-rank">Sin datos</p>
                        )
                    }
                </div>
            </div>

            {/* 2. MONTH RANKING */}
            <div class="ranking-col">
                <div class="card-title-overlay">MES</div>
                <div class="ranking-list">
                    {
                        fanRankings.month.map((p: any, i: number) => {
                            const player = squad.find((s) => s.id === p.id);
                            if (!player) return null;
                            return (
                                <div class="ranking-item">
                                    <span class="rank-pos">{i + 1}</span>
                                    <div class="rank-img-wrapper">
                                        <img
                                            src={
                                                playerImageMap.get(player.id) ||
                                                ""
                                            }
                                            alt={player.name}
                                            class="rank-img"
                                        />
                                    </div>
                                    <div class="rank-info">
                                        <span class="rank-name">
                                            {player.name}
                                        </span>
                                        <span class="rank-val">
                                            {p.avg.toFixed(1)}
                                        </span>
                                    </div>
                                </div>
                            );
                        })
                    }
                    {
                        fanRankings.month.length === 0 && (
                            <p class="empty-rank">Sin datos</p>
                        )
                    }
                </div>
            </div>

            {/* 3. SEASON RANKING */}
            <div class="ranking-col">
                <div class="card-title-overlay">TEMPORADA</div>
                <div class="ranking-list">
                    {
                        fanRankings.season.map((p: any, i: number) => {
                            const player = squad.find((s) => s.id === p.id);
                            if (!player) return null;
                            return (
                                <div class="ranking-item">
                                    <span class="rank-pos">{i + 1}</span>
                                    <div class="rank-img-wrapper">
                                        <img
                                            src={
                                                playerImageMap.get(player.id) ||
                                                ""
                                            }
                                            alt={player.name}
                                            class="rank-img"
                                        />
                                    </div>
                                    <div class="rank-info">
                                        <span class="rank-name">
                                            {player.name}
                                        </span>
                                        <span class="rank-val">
                                            {p.avg.toFixed(1)}
                                        </span>
                                    </div>
                                </div>
                            );
                        })
                    }
                    {
                        fanRankings.season.length === 0 && (
                            <p class="empty-rank">Sin datos</p>
                        )
                    }
                </div>
            </div>

            {/* 4. MVP RANKING */}
            <div class="ranking-col">
                <div class="card-title-overlay">TOTAL MVPs</div>
                <div class="ranking-list">
                    {
                        fanRankings.mvp.map((p: any, i: number) => {
                            const player = squad.find((s) => s.id === p.id);
                            if (!player) return null;
                            return (
                                <div class="ranking-item">
                                    <span class="rank-pos">{i + 1}</span>
                                    <div class="rank-img-wrapper">
                                        <img
                                            src={
                                                playerImageMap.get(player.id) ||
                                                ""
                                            }
                                            alt={player.name}
                                            class="rank-img"
                                        />
                                    </div>
                                    <div class="rank-info">
                                        <span class="rank-name">
                                            {player.name}
                                        </span>
                                        <span class="rank-val">{p.count}</span>
                                    </div>
                                </div>
                            );
                        })
                    }
                    {
                        fanRankings.mvp.length === 0 && (
                            <p class="empty-rank">Sin datos</p>
                        )
                    }
                </div>
            </div>
        </div>
    </main>
</Layout>

<style>
    :root {
        --primary: #2b2b2b;
        --accent: #ffde59;
        --text-primary: #2b2b2b;
    }

    .rankings-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
        margin-top: 3rem;
    }

    /* Card Style matching Pronosticos */
    .ranking-col {
        position: relative;
        background: white;
        border-radius: 12px;
        padding: 3.5rem 1.5rem 1.5rem 1.5rem; /* Increased top padding for overlay */
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(0, 0, 0, 0.05);
    }

    .card-title-overlay {
        position: absolute;
        top: -18px;
        left: 20px;
        background: var(--accent);
        color: #2b2b2b;
        padding: 0.5rem 1.5rem;
        font-family: "Bebas Neue", sans-serif;
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: 1px;
        transform: skew(-10deg);
        box-shadow: 4px 4px 0px rgba(0, 0, 0, 0.1);
        z-index: 10;
        line-height: 1;
    }

    .ranking-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .ranking-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding-bottom: 0.8rem;
        border-bottom: 1px solid #f0f0f0;
    }
    .ranking-item:last-child {
        border-bottom: none;
    }

    .rank-pos {
        font-family: "Archivo Black", sans-serif;
        font-size: 1.2rem;
        color: #ddd;
        width: 25px;
        text-align: center;
    }

    .rank-img-wrapper {
        width: 50px;
        height: 50px;
        background: #f4f4f4;
        border-radius: 8px; /* Square with slight rounding */
        overflow: hidden;
        border: 1px solid #eee;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .rank-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top center; /* Focus on face */
    }

    .rank-info {
        flex: 1;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .rank-name {
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        color: #333;
    }
    .rank-val {
        font-weight: 800;
        font-size: 1rem;
        color: var(--primary);
        background: #f0f0f0;
        padding: 0.2rem 0.5rem;
        border-radius: 6px;
    }

    .empty-rank {
        text-align: center;
        color: #ccc;
        font-style: italic;
        font-size: 0.9rem;
        padding: 2rem 0;
    }

    @media (max-width: 600px) {
        .rankings-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
