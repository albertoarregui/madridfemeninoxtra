---
import { Image } from "astro:assets";
import "../styles/global.css";
import { getAssetMetadata } from "../utils/assets";
import heartbeatAudio from "../assets/audio/heartbeat.mp3";

const milestones = [
  {
    displayDate: "MAYO 2019",
    title: "EL ORIGEN",
    description:
      "El CD Tacón logra el ascenso a Primera Iberdrola. La semilla de lo que sería el Real Madrid Femenino.",
    icon: "📍",
    image: getAssetMetadata("intro", "01-ascenso"),
  },
  {
    displayDate: "JUNIO 2019",
    title: "COMUNICADO OFICIAL",
    description:
      "El Real Madrid anuncia la absorción del CD Tacón. Comienza una nueva era en la historia del club.",
    icon: "📜",
    image: getAssetMetadata("intro", "02-comunicado"),
  },
  {
    displayDate: "JULIO 2019",
    title: "LA PRIMERA GALÁCTICA",
    description:
      "Kosovare Asllani se convierte en la primera galáctica. La sueca lideraría el proyecto en su año de transición.",
    icon: "⭐",
    image: getAssetMetadata("intro", "03-kosovare_asllani"),
  },
  {
    displayDate: "JULIO 2020",
    title: "EL SUEÑO ES REAL",
    description:
      "El 1 de julio de 2020 nace oficialmente el Real Madrid Femenino. Un día marcado en oro para el fútbol femenino mundial.",
    icon: "🆕",
    image: getAssetMetadata("intro", "04-comienzo"),
  },
  {
    displayDate: "OCTUBRE 2020",
    title: "EL PRIMER CLÁSICO",
    description: "Debut oficial en Primera Iberdrola con un Clásico histórico.",
    icon: "⚔️",
    image: getAssetMetadata("intro", "05-debut"),
  },
  {
    displayDate: "OCTUBRE 2020",
    title: "EL PRIMER GRITO",
    description:
      "Kosovare Asllani marca el primer gol oficial de la historia del Real Madrid Femenino contra el Valencia.",
    icon: "⚽",
    image: getAssetMetadata("intro", "06-primer_gol"),
  },
  {
    displayDate: "FEBRERO 2021",
    title: "LA REINA",
    description:
      "154 segundos: Kosovare Asllani marca el hat-trick más rápido, no solo de la historia del club, sino del fútbol femenino mundial.",
    icon: "👑",
    image: getAssetMetadata("intro", "07-hat_trick_mas_rapido"),
  },
  {
    displayDate: "MARZO 2021",
    title: "PRIMER DERBI GANADO",
    description:
      "Primera victoria contra el Atlético de Madrid. 0-1, con gol de Sofia Jakosbsson.",
    icon: "🔥",
    image: getAssetMetadata("intro", "08-derbi"),
  },
  {
    displayDate: "JUNIO 2021",
    title: "OBJETIVO CUMPLIDO",
    description:
      "Clasificación a la UWCL en la primera temporada. En solo un año, el equipo ya era de élite europea.",
    icon: "🗺️",
    image: getAssetMetadata("intro", "09-clasificacion_uwcl"),
  },
  {
    displayDate: "SEPTIEMBRE 2021",
    title: "NOCHE MÁGICA",
    description:
      "Contra todo pronóstico, eliminamos al Manchester City en la previa de UWCL. Europa nos saluda.",
    icon: "🏆",
    image: getAssetMetadata("intro", "10-victoria_vs_city"),
  },
  {
    displayDate: "NOVIEMBRE 2021",
    title: "ERA TORIL",
    description:
      "Alberto Toril asume el mando del equipo, tras la destitución de David Aznar, en el momento más delicado del equipo.",
    icon: "👔",
    image: getAssetMetadata("intro", "11-alberto_toril"),
  },
  {
    displayDate: "MARZO 2022",
    title: "ENTRE LAS 8 MEJORES",
    description:
      "Debut histórico en Cuartos de Final de la UWCL. El escudo del Madrid brilla entre las mejores del viejo continente.",
    icon: "🏟️",
    image: getAssetMetadata("intro", "12-debut_cuartos_uwcl"),
  },
  {
    displayDate: "JULIO 2022",
    title: "LA CABRA",
    description:
      "Caroline Weir llega para dar un nuevo salto de calidad, con una primera temporada histórica sumando 28 goles y 18 asistencias.",
    icon: "🏴󠁧󠁢󠁳󠁣󠁴󠁿",
    image: getAssetMetadata("intro", "13-caroline_weir"),
  },
  {
    displayDate: "AGOSTO 2022",
    title: "DOBLE ELIMINACIÓN AL MANCHESTER CITY",
    description:
      "Caroline Weir marca una obra de arte para eliminar nuevamente al Manchester City, su exequipo.",
    icon: "🎯",
    image: getAssetMetadata("intro", "14-caroline_weir_vs_city"),
  },
  {
    displayDate: "FEBRERO 2023",
    title: "DIAMANTE EN BRUTO",
    description:
      "Linda Caicedo elige al Real Madrid. El mayor talento joven del planeta se viste de blanco.",
    icon: "🦋",
    image: getAssetMetadata("intro", "15-linda_caicedo"),
  },
  {
    displayDate: "MAYO 2023",
    title: "PRIMERA FINAL",
    description:
      "La primera final en la historia del club llegó en la Copa de la Reina.",
    icon: "🥈",
    image: getAssetMetadata("intro", "16-primera_final"),
  },
  {
    displayDate: "AGOSTO 2023",
    title: "CAMPEONAS DEL MUNDO",
    description:
      "Hasta 8 jugadoras del Real Madrid tocaron el cielo con la selección española en Sydney. Olga Carmona marcó el gol de la victoria.",
    icon: "🌍",
    image: getAssetMetadata("intro", "17-mundial"),
  },
  {
    displayDate: "MARZO 2025",
    title: "SUDOR, BARRO Y CORAZÓN",
    description:
      "Primera victoria en un partido de los Cuartos de Final de la UWCL. El equipo sigue rompiendo barreras en Europa.",
    icon: "💪",
    image: getAssetMetadata("intro", "18-primera_victoria_cuartos_uwcl"),
  },
  {
    displayDate: "MARZO 2025",
    title: "MONTJUIC CONQUISTADO",
    description:
      "El Real Madrid Femenino consigue su primera victoria en un Clásico contra el FC Barcelona, con un doblete de Caroline Weir y un gol de Alba Redondo, en Montjuic.",
    icon: "🤍",
    image: getAssetMetadata("intro", "20_clasico"),
  },
  {
    displayDate: "JUNIO 2024",
    title: "HOY",
    description:
      "Pau Quesada toma las riendas del Real Madrid Femenino, tras la marcha de Alberto Toril. Empieza una nueva etapa.",
    icon: "💎",
    image: getAssetMetadata("intro", "19-pau_quesada"),
  },
];
const heroBg = getAssetMetadata("background", "background");
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Timeline | Madrid Femenino Xtra</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700;900&display=swap"
      rel="stylesheet"
    />
    <link is:inline rel="prefetch" href="/home" />
    <script is:inline>
      try {
        if (localStorage.getItem("madridxtra_intro_seen") === "true") {
          window.location.href = "/home";
        }
      } catch (e) {}
    </script>
  </head>
  <body class="bg-slate-900 text-white overflow-x-hidden antialiased">
    <div class="fixed inset-0 z-[-1]">
      <div class="absolute inset-0 bg-[#0a0f1e]"></div>
      <div
        class="absolute inset-0 bg-gradient-to-r from-[#0a0f1e] via-transparent to-[#0a0f1e] z-10"
      >
      </div>
      {
        heroBg && (
          <Image
            src={heroBg}
            alt="Background"
            class="w-full h-full object-cover opacity-20 blur-sm scale-110 animate-pulse-slow"
            width={1920}
            height={1080}
            format="webp"
            loading="eager"
          />
        )
      }
    </div>

    <a
      href="/home"
      data-astro-prefetch="load"
      class="fixed top-6 right-6 z-50 flex items-center gap-2 px-6 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/20 hover:bg-white/20 transition-all group text-sm font-bold tracking-widest uppercase"
    >
      Saltar Intro
      <span class="group-hover:translate-x-1 transition-transform">→</span>
    </a>

    <audio id="heartbeat-audio" src={heartbeatAudio} preload="auto"></audio>

    <div
      id="particles-container"
      class="fixed inset-0 pointer-events-none z-0 overflow-hidden"
    >
    </div>

    <div class="relative w-full min-h-screen py-24 md:py-40">
      <header class="text-center mb-40 px-4 animate-fade-in-down relative z-10">
        <h1
          class="text-7xl md:text-[8rem] font-black font-['Outfit'] tracking-tighter bg-clip-text text-transparent bg-gradient-to-b from-gray-100 to-gray-600 drop-shadow-2xl"
        >
          NUESTRO LEGADO
        </h1>
        <p
          class="text-xl md:text-3xl text-gray-400 font-serif italic mt-6 max-w-4xl mx-auto leading-relaxed px-4"
        >
          De cero a la élite. Así se forja la historia de la sección femenina
          del mejor club del mundo.
        </p>
      </header>

      <div class="relative w-full max-w-7xl mx-auto px-4 mt-20 mb-40">
        <div
          class="absolute left-4 lg:left-1/2 top-0 bottom-0 w-[4px] bg-[#ffde59] -translate-x-1/2 shadow-[0_0_15px_#ffde59] rounded-full z-0 transition-all duration-700 ease-in-out"
        >
        </div>

        <div
          class="absolute left-4 lg:left-1/2 -top-4 -translate-x-1/2 w-8 h-8 bg-[#ffde59] rotate-45 shadow-[0_0_20px_#ffde59] z-10 transition-all duration-700 ease-in-out"
        >
        </div>

        <div class="flex flex-col gap-32 pt-24 pb-24">
          {
            milestones.map((item, index) => (
              <div
                class={`relative flex items-center w-full ${index % 2 === 0 ? "lg:flex-row-reverse" : "lg:flex-row"} flex-col pl-12 lg:pl-0 group timeline-item transition-all duration-700 ease-in-out`}
              >
                <div class="absolute left-4 lg:left-1/2 top-1/2 -translate-y-1/2 -translate-x-1/2 w-4 h-4 bg-[#ffde59] rounded-full z-10 shadow-[0_0_10px_#ffde59] transition-all duration-700 ease-in-out" />

                <svg
                  class={`absolute top-1/2 -translate-y-1/2 z-0 overflow-visible w-[140px] h-[30px] opacity-0 lg:opacity-100 transition-opacity duration-700 ease-in-out
                                    ${index % 2 === 0 ? "left-1/2" : "right-1/2 -scale-x-100"}`}
                  viewBox="0 0 140 30"
                >
                  <path
                    d="M0,15 L30,15 L40,5 L50,25 L60,15 L140,15"
                    fill="none"
                    stroke="#ffde59"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="drop-shadow-[0_0_5px_#ffde59]"
                  />
                </svg>

                <div
                  class={`absolute top-1/2 -translate-y-1/2 w-6 h-6 bg-[#ffde59] rotate-45 shadow-[0_0_15px_#ffde59] z-20 transition-all duration-500 group-hover:scale-125 group-hover:bg-white opacity-0 lg:opacity-100
                                    ${index % 2 === 0 ? "left-[calc(50%+10vw)] lg:left-[calc(50%+140px)]" : "right-[calc(50%+10vw)] lg:right-[calc(50%+140px)]"}`}
                />

                <div
                  class={`w-full lg:w-1/2 flex p-4 relative transition-all duration-700 ease-in-out ${index % 2 === 0 ? "lg:justify-start lg:pl-[220px]" : "lg:justify-end lg:pr-[220px]"}`}
                >
                  <div class="absolute left-4 top-1/2 -translate-y-1/2 w-8 h-[2px] bg-[#ffde59] lg:opacity-0 transition-opacity duration-700" />

                  <div
                    class="relative w-full max-w-md transform transition-all duration-700 hover:scale-105 cursor-pointer timeline-content"
                    onclick="this.scrollIntoView({behavior: 'smooth', block: 'center'}); if(window.playHeartbeat) window.playHeartbeat();"
                  >
                    <div class="relative">
                      {item.image ? (
                        <Image
                          src={item.image}
                          alt={item.title}
                          class="w-full h-full object-cover rounded-2xl shadow-[0_0_30px_rgba(0,0,0,0.5)] border border-white/10"
                          width={600}
                          height={400}
                          format="webp"
                          loading="lazy"
                          decoding="async"
                        />
                      ) : (
                        <div class="w-full h-64 bg-slate-800 rounded-2xl shadow-[0_0_30px_rgba(0,0,0,0.5)] border border-white/10 flex items-center justify-center">
                          <span class="text-4xl">{item.icon}</span>
                        </div>
                      )}
                      <div
                        class={`absolute -top-6 ${index % 2 === 0 ? "-right-6" : "-left-6"} w-14 h-14 bg-[#ffde59] text-slate-900 rounded-full flex items-center justify-center font-bold text-2xl shadow-lg border-4 border-slate-900 z-30`}
                      >
                        {item.icon}
                      </div>
                    </div>

                    <div
                      class={`mt-6 ${index % 2 === 0 ? "text-left" : "lg:text-right"}`}
                    >
                      <div class="text-[#ffde59] font-bold tracking-[0.2em] text-sm mb-1 uppercase drop-shadow-md">
                        {item.displayDate}
                      </div>
                      <h3 class="text-3xl font-black text-white font-['Outfit'] uppercase leading-none mb-3 drop-shadow-lg">
                        {item.title}
                      </h3>
                      <p class="text-gray-300 text-sm font-medium leading-relaxed max-w-sm ml-0 inline-block">
                        {item.description}
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>

        <div
          class="absolute left-4 lg:left-1/2 bottom-0 translate-y-1/2 -translate-x-1/2 w-8 h-8 bg-[#ffde59] rotate-45 shadow-[0_0_20px_#ffde59] z-10 transition-all duration-700 ease-in-out"
        >
        </div>
      </div>

      <div class="text-center relative z-20 pb-20">
        <a
          href="/home"
          data-astro-prefetch="load"
          class="inline-flex items-center gap-4 px-8 md:px-12 py-4 md:py-6 bg-gradient-to-br from-[#ffd700] via-[#ffed4e] to-[#ffd700] text-[#2b2b2b] font-black text-lg md:text-2xl tracking-widest rounded-full hover:-translate-y-[2px] transition-all shadow-[0_2px_8px_rgba(0,0,0,0.1)] hover:shadow-[0_4px_12px_rgba(0,0,0,0.2)]"
        >
          ENTRA EN MFX
        </a>
      </div>

      <footer class="relative z-20 text-center pb-8 px-4">
        <p class="text-gray-500 text-xs md:text-sm font-light opacity-60">
          © 2026 Madrid Femenino Xtra. Todos los derechos reservados.
        </p>
      </footer>
    </div>

    <script>
      window.playHeartbeat = function () {
        const audio = document.getElementById("heartbeat-audio");
        if (audio) {
          console.log("Playing heartbeat...");
          audio.volume = 1.0;
          audio.currentTime = 0;
          audio.play().catch((e) => console.error("Audio play failed:", e));
        } else {
          console.error("Audio element not found");
        }
      };

      document.addEventListener("DOMContentLoaded", () => {
        const observerOptions = {
          threshold: 0.15,
          rootMargin: "0px 0px -50px 0px",
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
            }
          });
        }, observerOptions);

        document.querySelectorAll(".timeline-item").forEach((item) => {
          observer.observe(item);
        });

        const particlesContainer = document.getElementById(
          "particles-container",
        );
        if (particlesContainer) {
          const particleCount = 40;
          for (let i = 0; i < particleCount; i++) {
            const p = document.createElement("div");
            const size = Math.random() * 3 + 1;
            const isGold = Math.random() > 0.7;
            p.style.width = `${size}px`;
            p.style.height = `${size}px`;
            p.style.background = isGold ? "#ffde59" : "rgba(255,255,255,0.3)";
            p.style.position = "absolute";
            p.style.borderRadius = "50%";
            p.style.left = `${Math.random() * 100}vw`;
            p.style.top = `${Math.random() * 100}vh`;
            p.style.animation = `float ${Math.random() * 10 + 10}s linear infinite`;
            particlesContainer.appendChild(p);
          }
        }
      });
    </script>

    <style>
      .no-scrollbar::-webkit-scrollbar {
        display: none;
      }
      .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }

      .animate-pulse-slow {
        animation: pulse 8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
      }
      @keyframes pulse {
        0%,
        100% {
          opacity: 0.2;
          transform: scale(1.1);
        }
        50% {
          opacity: 0.15;
          transform: scale(1);
        }
      }
      .animate-fade-in-down {
        animation: fadeInDown 1.5s ease-out forwards;
      }
      @keyframes fadeInDown {
        from {
          opacity: 0;
          transform: translateY(-20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @keyframes float {
        0% {
          transform: translateY(0) translateX(0);
          opacity: 0;
        }
        10% {
          opacity: 1;
        }
        90% {
          opacity: 1;
        }
        100% {
          transform: translateY(-100px) translateX(50px);
          opacity: 0;
        }
      }

      .text-glow {
        text-shadow:
          0 0 30px rgba(0, 0, 0, 0.8),
          0 0 60px rgba(0, 0, 0, 0.4);
      }
      .text-glow-small {
        text-shadow: 0 0 15px rgba(255, 222, 89, 0.3);
      }

      .timeline-content {
        transition:
          opacity 1s ease-out,
          transform 1s ease-out;
      }
      .timeline-item.is-visible .timeline-content {
        opacity: 1;
        transform: translateY(0);
      }

      body {
        overflow-x: hidden;
      }
    </style>
  </body>
</html>
