---
import { Image } from "astro:assets";
import "../styles/global.css";
import heroBg from "../assets/background/background.jpg"; 
// Import assets for timeline
import uwclLogo from "../assets/competiciones/uwcl.png";
import taconImg from "../assets/sidebar/mapa_partidos.png"; // Placeholder
import bernabeuImg from "../assets/background/background.jpg";
import currentImg from "../assets/widgets/player_month/feller_mahoudiciembre.jpg";
import foundationImg from "../assets/sidebar/mapa_jugadoras.png"; // Placeholder

const milestones = [
  {
    displayDate: "SEPT 2019",
    title: "EL PRÓLOGO",
    description: "El CD Tacón viste por primera vez de blanco. Aún no somos oficiales, pero el escudo ya late en Valdebebas. Comienza la transición.",
    icon: "🌱",
    image: taconImg
  },
  {
    displayDate: "JULIO 2020",
    title: "NACE LA LEYENDA",
    description: "Comunicado Oficial: El Real Madrid Femenino es una realidad. Misa, Maite Oroz y Teresa Abelleira lideran la primera generación dorada.",
    icon: "🛡️",
    image: foundationImg
  },
  {
    displayDate: "SEPT 2021",
    title: "EUROPA ES NUESTRA",
    description: "Contra todo pronóstico, eliminamos al Manchester City. Claudia Zornoza marca y nos mete en la Fase de Grupos de la Champions League.",
    icon: "⭐",
    image: uwclLogo
  },
  {
    displayDate: "MARZO 2022",
    title: "NOCHE EN EL BERNABÉU",
    description: "Récord histórico. El templo abre sus puertas para la Champions. La afición responde y demuestra que este equipo no camina solo.",
    icon: "🏟️",
    image: bernabeuImg
  },
  {
    displayDate: "HOY",
    title: "A POR LA GLORIA",
    description: "Con Linda Caicedo, Weir y Feller, el objetivo es claro: Levantar el primer título. La historia se escribe partido a partido.",
    icon: "🤍",
    image: currentImg
  }
];
---

<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nuestra Historia | Real Madrid Femenino</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700;900&display=swap" rel="stylesheet">
    <script is:inline>
        try {
            if (localStorage.getItem('madridxtra_intro_seen') === 'true') {
                window.location.href = '/home';
            }
        } catch (e) {}
    </script>
</head>
<body class="bg-slate-900 text-white overflow-x-hidden antialiased">
    
    <!-- Background Fixed -->
    <div class="fixed inset-0 z-[-1]">
        <div class="absolute inset-0 bg-[#0a0f1e]"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-[#0a0f1e] via-transparent to-[#0a0f1e] z-10"></div>
        <img src={heroBg.src} alt="Background" class="w-full h-full object-cover opacity-20 blur-sm scale-110 animate-pulse-slow">
    </div>

    <!-- Skip Button -->
    <!-- Skip Button -->
    <a href="/home" class="fixed top-6 right-6 z-50 flex items-center gap-2 px-6 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/20 hover:bg-white/20 transition-all group text-sm font-bold tracking-widest uppercase">
        Saltar Intro
        <span class="group-hover:translate-x-1 transition-transform">→</span>
    </a>

    <main class="relative z-10 container mx-auto px-4 py-24 md:py-32 max-w-5xl">
        
        <!-- Header -->
        <header class="text-center mb-32 opacity-0 animate-fade-in-down">
            <h1 class="text-5xl md:text-8xl font-black font-['Outfit'] tracking-tighter mb-4 text-transparent bg-clip-text bg-gradient-to-r from-white via-gray-200 to-gray-500">
                HISTORIA
            </h1>
            <p class="text-xl md:text-2xl text-[#ffde59] font-light tracking-widest uppercase">
                Real Madrid Femenino
            </p>
        </header>

        <!-- Timeline -->
        <div class="relative">
            <!-- Central Line -->
            <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-transparent via-[#ffde59]/50 to-transparent"></div>

            <div class="space-y-32 md:space-y-48">
                {milestones.map((item, index) => (
                    <div class={`timeline-item flex flex-col md:flex-row items-center gap-8 ${index % 2 === 0 ? 'md:flex-row-reverse' : ''} opacity-0 translate-y-10 transition-all duration-1000 ease-out`}>
                        
                        <!-- Content -->
                        <div class="flex-1 w-full text-center md:text-left">
                           <div class={`rounded-2xl bg-white/5 backdrop-blur-lg border border-white/10 hover:border-[#ffde59]/50 transition-colors shadow-2xl relative overflow-hidden group ${index % 2 === 0 ? 'md:text-left' : 'md:text-right'}`}>
                                
                                <!-- Image Header -->
                                <div class="relative h-48 md:h-64 cursor-pointer overflow-hidden border-b border-white/5">
                                    <div class="absolute inset-0 bg-gradient-to-t from-[#0a0f1e] to-transparent z-10 opacity-60"></div>
                                    <Image 
                                        src={item.image} 
                                        alt={item.title} 
                                        class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700 ease-out"
                                    />
                                    <!-- Year Overlay on Image -->
                                    <span class={`absolute bottom-4 ${index % 2 === 0 ? 'left-4' : 'right-4'} z-20 text-4xl md:text-5xl font-black text-white drop-shadow-lg font-['Outfit']`}>
                                        {item.displayDate}
                                    </span>
                                </div>

                                <div class="p-8 relative z-10">
                                    <!-- Glow effect -->
                                    <div class="absolute -inset-1 bg-gradient-to-r from-[#ffde59]/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity blur-xl z-[-1]"></div>
                                    
                                    <h3 class="text-3xl font-black mb-2 text-[#ffde59] uppercase font-['Outfit'] leading-none">{item.title}</h3>
                                    <p class="text-gray-300 leading-relaxed text-lg mt-4 font-light">{item.description}</p>
                                </div>
                           </div>
                        </div>

                        <!-- Icon / Dot -->
                        <div class="relative z-10 flex-shrink-0">
                            <div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-[#1a1f35] border-2 border-[#ffde59] flex items-center justify-center text-3xl md:text-4xl shadow-[0_0_30px_rgba(255,222,89,0.3)] relative group">
                                <span class="group-hover:scale-125 transition-transform duration-300">{item.icon}</span>
                            </div>
                        </div>

                        <!-- Empty space for layout balance -->
                        <div class="flex-1 hidden md:block"></div>
                    </div>
                ))}
            </div>
        </div>

        <!-- CTA Final -->
        <div class="text-center mt-48 mb-24 opacity-0 transition-opacity duration-1000 delay-500" id="final-cta">
            <h2 class="text-4xl font-bold mb-8">El futuro es nuestro</h2>
            <a href="/home" class="inline-flex items-center gap-4 px-12 py-6 bg-[#ffde59] text-black font-black text-2xl tracking-widest rounded-full hover:scale-105 hover:bg-white transition-all shadow-[0_0_50px_rgba(255,222,89,0.5)]">
                ENTRAR EN XTRA
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
            </a>
        </div>

    </main>

    <script>


        document.addEventListener('DOMContentLoaded', () => {
            // Set verify flag on click for skip and enter buttons
            const setSeen = () => localStorage.setItem('madridxtra_intro_seen', 'true');
            
            // Apply to all links pointing to home (Skip & Enter CTA)
            document.querySelectorAll('a[href="/home"]').forEach(link => {
                link.addEventListener('click', setSeen);
            });

            // Intersection Observer for Scroll Animation
            const observerOptions = {
                threshold: 0.2,
                rootMargin: "0px"
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.remove('opacity-0', 'translate-y-10');
                        entry.target.classList.add('opacity-100', 'translate-y-0');
                    }
                });
            }, observerOptions);

            // Observe timeline items
            document.querySelectorAll('.timeline-item').forEach((item, index) => {
                // Add staggered delay
                item.style.transitionDelay = `${index * 100}ms`;
                observer.observe(item);
            });

            // Observe header
            const header = document.querySelector('header');
            if(header) {
                header.classList.remove('opacity-0');
                header.classList.add('animate-fade-in-down');
            }

            // Observe final CTA
            const cta = document.getElementById('final-cta');
            if(cta) observer.observe(cta);
        });
    </script>
    
    <style>
        .animate-pulse-slow {
            animation: pulse 8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 0.2; transform: scale(1.1); }
            50% { opacity: 0.15; transform: scale(1); }
        }
        .animate-fade-in-down {
            animation: fadeInDown 1.5s ease-out forwards;
        }
        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</body>
</html>
