---
import { Image } from "astro:assets";
import "../styles/global.css";
import heroBg from "../assets/background/background.jpg"; 
// Import assets for timeline
import uwclLogo from "../assets/competiciones/uwcl.png";
import taconImg from "../assets/sidebar/mapa_partidos.png"; // Placeholder
import bernabeuImg from "../assets/background/background.jpg";
import currentImg from "../assets/widgets/player_month/feller_mahoudiciembre.jpg";
import foundationImg from "../assets/sidebar/mapa_jugadoras.png"; // Placeholder

const milestones = [
  {
    displayDate: "SEPT 2019",
    title: "EL PRÓLOGO",
    description: "El CD Tacón viste por primera vez de blanco. Aún no somos oficiales, pero el escudo ya late en Valdebebas.",
    icon: "🌱",
    image: taconImg
  },
  {
    displayDate: "JULIO 2020",
    title: "NACE LA LEYENDA",
    description: "Comunicado Oficial: El Real Madrid Femenino es una realidad. Misa, Maite Oroz y Teresa Abelleira lideran la primera generación.",
    icon: "🛡️",
    image: foundationImg
  },
  {
    displayDate: "SEPT 2021",
    title: "EUROPA ES NUESTRA",
    description: "Contra todo pronóstico, eliminamos al Manchester City. Claudia Zornoza marca y nos mete en la Fase de Grupos de la Champions League.",
    icon: "⭐",
    image: uwclLogo
  },
  {
    displayDate: "MARZO 2022",
    title: "NOCHE EN EL BERNABÉU",
    description: "Récord histórico. El templo abre sus puertas para la Champions. La afición responde y demuestra que este equipo no camina solo.",
    icon: "🏟️",
    image: bernabeuImg
  },
  {
    displayDate: "HOY",
    title: "A POR LA GLORIA",
    description: "Con Linda Caicedo, Weir y Feller, el objetivo es claro: Levantar el primer título. La historia se escribe partido a partido.",
    icon: "🤍",
    image: currentImg
  }
];
---

<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nuestra Historia | Real Madrid Femenino</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700;900&display=swap" rel="stylesheet">
    <script is:inline>
        try {
            if (localStorage.getItem('madridxtra_intro_seen') === 'true') {
                window.location.href = '/home';
            }
        } catch (e) {}
    </script>
</head>
<body class="bg-slate-900 text-white overflow-hidden antialiased">
    
    <!-- Background Fixed -->
    <div class="fixed inset-0 z-[-1]">
        <div class="absolute inset-0 bg-[#0a0f1e]"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-[#0a0f1e] via-transparent to-[#0a0f1e] z-10"></div>
        <img src={heroBg.src} alt="Background" class="w-full h-full object-cover opacity-20 blur-sm scale-110 animate-pulse-slow">
    </div>

    <!-- Skip Button -->
    <a href="/home" class="fixed top-6 right-6 z-50 flex items-center gap-2 px-6 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/20 hover:bg-white/20 transition-all group text-sm font-bold tracking-widest uppercase">
        Saltar Intro
        <span class="group-hover:translate-x-1 transition-transform">→</span>
    </a>

    <!-- Horizontal Scroll Container -->
    <div id="scroll-container" class="h-screen w-full overflow-x-auto overflow-y-hidden flex items-center relative scroll-smooth no-scrollbar">
        
        <!-- Curved Line SVG Background (Absolute behind content) -->
        <div class="absolute top-0 left-0 h-full pointer-events-none z-0" style="width: 400vw;">
            <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 4000 1000">
                <!-- White curved line -->
                <path d="M 0 500 C 400 500, 400 200, 800 200 S 1200 800, 1600 800 S 2000 200, 2400 200 S 2800 800, 3200 800 S 3600 500, 4000 500" 
                      fill="none" stroke="white" stroke-width="4" stroke-opacity="0.3" vector-effect="non-scaling-stroke" />
                <!-- Glow effect layer -->
                <path d="M 0 500 C 400 500, 400 200, 800 200 S 1200 800, 1600 800 S 2000 200, 2400 200 S 2800 800, 3200 800 S 3600 500, 4000 500" 
                      fill="none" stroke="#ffde59" stroke-width="10" stroke-opacity="0.1" stroke-linecap="round" vector-effect="non-scaling-stroke" class="blur-md" />
            </svg>
        </div>

        <!-- Section 1: Intro Title -->
        <section class="h-screen min-w-[100vw] flex items-center justify-center relative z-10 shrink-0">
             <header class="text-center opacity-0 animate-fade-in-down p-8 bg-black/30 backdrop-blur-sm rounded-3xl border border-white/5">
                <h1 class="text-6xl md:text-9xl font-black font-['Outfit'] tracking-tighter mb-4 text-transparent bg-clip-text bg-gradient-to-r from-white via-gray-200 to-gray-500">
                    HISTORIA
                </h1>
                <p class="text-xl md:text-3xl text-[#ffde59] font-light tracking-widest uppercase">
                    Real Madrid Femenino
                </p>
                <div class="mt-8 text-gray-400 text-sm animate-bounce">
                    Haz scroll para navegar →
                </div>
            </header>
        </section>

        <!-- Milestones -->
        {milestones.map((item, index) => (
            <section class="h-screen min-w-[80vw] md:min-w-[60vw] flex items-center justify-center relative z-10 shrink-0 snap-center">
                <div class={`flex flex-col items-center gap-8 max-w-2xl w-full p-4 transform transition-all duration-1000 opacity-50 scale-90 hover:opacity-100 hover:scale-100 slide-content ${index % 2 === 0 ? '-translate-y-24' : 'translate-y-24'}`}>
                    
                    <!-- Line Connector Dot -->
                    <div class={`absolute left-1/2 -translate-x-1/2 w-1 h-32 bg-gradient-to-b from-white/20 to-transparent ${index % 2 === 0 ? 'top-full' : 'bottom-full bg-gradient-to-t'}`}></div>
                    
                    <!-- Content Card -->
                    <div class="w-full rounded-2xl bg-[#1a1f35]/90 backdrop-blur-xl border border-white/10 hover:border-[#ffde59]/50 transition-colors shadow-2xl relative overflow-hidden group">
                        
                         <!-- Image Header -->
                         <div class="relative h-56 md:h-72 cursor-pointer overflow-hidden border-b border-white/5">
                            <div class="absolute inset-0 bg-gradient-to-t from-[#0a0f1e] to-transparent z-10 opacity-60"></div>
                            <Image 
                                src={item.image} 
                                alt={item.title} 
                                class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700 ease-out"
                            />
                            <!-- Date Overlay -->
                            <span class="absolute bottom-4 left-6 z-20 text-5xl md:text-6xl font-black text-white drop-shadow-lg font-['Outfit'] tracking-tighter">
                                {item.displayDate}
                            </span>
                        </div>

                        <div class="p-8 relative z-10">
                            <!-- Glow effect -->
                            <div class="absolute -inset-1 bg-gradient-to-r from-[#ffde59]/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity blur-xl z-[-1]"></div>
                            
                            <div class="flex items-center gap-4 mb-4">
                                <span class="text-3xl">{item.icon}</span>
                                <h3 class="text-3xl font-black text-[#ffde59] uppercase font-['Outfit'] leading-none">{item.title}</h3>
                            </div>
                            <p class="text-gray-300 leading-relaxed text-lg font-light">{item.description}</p>
                        </div>
                    </div>

                </div>
            </section>
        ))}

        <!-- Section Final: CTA -->
        <section class="h-screen min-w-[100vw] flex items-center justify-center relative z-10 shrink-0">
             <div class="text-center p-12 bg-white/5 backdrop-blur-md rounded-3xl border border-white/10" id="final-cta">
                <h2 class="text-5xl font-bold mb-12">El futuro es nuestro</h2>
                <a href="/home" class="inline-flex items-center gap-4 px-12 py-6 bg-[#ffde59] text-black font-black text-2xl tracking-widest rounded-full hover:scale-105 hover:bg-white transition-all shadow-[0_0_50px_rgba(255,222,89,0.5)]">
                    ENTRAR EN XTRA
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                </a>
            </div>
        </section>

    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Horizontal Scroll Logic
            const scrollContainer = document.getElementById('scroll-container');
            
            if (scrollContainer) {
                // Transform vertical scroll to horizontal
                scrollContainer.addEventListener('wheel', (evt) => {
                    evt.preventDefault();
                    scrollContainer.scrollLeft += evt.deltaY;
                });
            }

            // Set verify flag on click
            const setSeen = () => localStorage.setItem('madridxtra_intro_seen', 'true');
            document.querySelectorAll('a[href="/home"]').forEach(link => {
                link.addEventListener('click', setSeen);
            });

            // Intersection Observer for Animation
            const observerOptions = {
                threshold: 0.5,
                root: scrollContainer
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.remove('opacity-50', 'scale-90');
                        entry.target.classList.add('opacity-100', 'scale-100');
                    } else {
                         // Optional: Fade out when leaving center
                         // entry.target.classList.add('opacity-50', 'scale-90');
                         // entry.target.classList.remove('opacity-100', 'scale-100');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('.slide-content').forEach((item) => {
                observer.observe(item);
            });
        });
    </script>
    
    <style>
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        .animate-pulse-slow {
            animation: pulse 8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 0.2; transform: scale(1.1); }
            50% { opacity: 0.15; transform: scale(1); }
        }
        .animate-fade-in-down {
            animation: fadeInDown 1.5s ease-out forwards;
        }
        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</body>
</html>
