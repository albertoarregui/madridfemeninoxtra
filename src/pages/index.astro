---
import { Image } from "astro:assets";
import "../styles/global.css";
import heroBg from "../assets/background/background.jpg"; 
// Import assets for timeline
import uwclLogo from "../assets/competiciones/uwcl.png";
import taconImg from "../assets/sidebar/mapa_partidos.png"; // Placeholder
import bernabeuImg from "../assets/background/background.jpg";
import currentImg from "../assets/widgets/player_month/feller_mahoudiciembre.jpg";
import foundationImg from "../assets/sidebar/mapa_jugadoras.png"; // Placeholder

const milestones = [
  {
    displayDate: "SEPT 2019",
    title: "EL PRÓLOGO",
    description: "El CD Tacón viste por primera vez de blanco. Aún no somos oficiales, pero el escudo ya late en Valdebebas.",
    icon: "🌱",
    image: taconImg
  },
  {
    displayDate: "JULIO 2020",
    title: "NACE LA LEYENDA",
    description: "Comunicado Oficial: El Real Madrid Femenino es una realidad. Misa, Maite Oroz y Teresa Abelleira lideran la primera generación.",
    icon: "🛡️",
    image: foundationImg
  },
  {
    displayDate: "SEPT 2021",
    title: "EUROPA ES NUESTRA",
    description: "Contra todo pronóstico, eliminamos al Manchester City. Claudia Zornoza marca y nos mete en la Fase de Grupos de la Champions League.",
    icon: "⭐",
    image: uwclLogo
  },
  {
    displayDate: "MARZO 2022",
    title: "NOCHE EN EL BERNABÉU",
    description: "Récord histórico. El templo abre sus puertas para la Champions. La afición responde y demuestra que este equipo no camina solo.",
    icon: "🏟️",
    image: bernabeuImg
  },
  {
    displayDate: "HOY",
    title: "A POR LA GLORIA",
    description: "Con Linda Caicedo, Weir y Feller, el objetivo es claro: Levantar el primer título. La historia se escribe partido a partido.",
    icon: "🤍",
    image: currentImg
  }
];
---

<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nuestra Historia | Real Madrid Femenino</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700;900&display=swap" rel="stylesheet">
    <script is:inline>
        try {
            if (localStorage.getItem('madridxtra_intro_seen') === 'true') {
                window.location.href = '/home';
            }
        } catch (e) {}
    </script>
</head>
<body class="bg-slate-900 text-white overflow-hidden antialiased">
    
    <!-- Background Fixed -->
    <div class="fixed inset-0 z-[-1]">
        <div class="absolute inset-0 bg-[#0a0f1e]"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-[#0a0f1e] via-transparent to-[#0a0f1e] z-10"></div>
        <img src={heroBg.src} alt="Background" class="w-full h-full object-cover opacity-20 blur-sm scale-110 animate-pulse-slow">
    </div>

    <!-- Skip Button -->
    <a href="/home" class="fixed top-6 right-6 z-50 flex items-center gap-2 px-6 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/20 hover:bg-white/20 transition-all group text-sm font-bold tracking-widest uppercase">
        Saltar Intro
        <span class="group-hover:translate-x-1 transition-transform">→</span>
    </a>

    <!-- Particle Container -->
    <div id="particles-container" class="fixed inset-0 pointer-events-none z-0 overflow-hidden"></div>

    <!-- Horizontal Scroll Container -->
    <div id="scroll-container" class="h-screen w-full overflow-x-auto overflow-y-hidden flex items-center relative no-scrollbar">
        
        <!-- Zig-Zag Line SVG Background -->
        <!-- Logic: 7 Sections (Intro + 5 Milestones + Outro). Each is ~100vw. Total ~700vw. -->
        <!-- Y=50 (Center), Y=30 (Top), Y=70 (Bottom) to reduce vertical spread (was 20/80) -->
        <div class="absolute top-0 left-0 h-full pointer-events-none z-0" style="width: 700vw;">
            <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 7000 1000">
                <!-- 
                   X Coordinates (Centers of screens): 
                   Intro: 500
                   M1: 1500 (Up)
                   M2: 2500 (Down)
                   M3: 3500 (Up)
                   M4: 4500 (Down)
                   M5: 5500 (Up)
                   Outro: 6500 (Center)
                   
                   Y Coordinates:
                   Center: 500
                   Top: 300 (was 200) -> Less amplitude
                   Bottom: 700 (was 800) -> Less amplitude
                -->
                <path d="M 500 500 L 1500 300 L 2500 700 L 3500 300 L 4500 700 L 5500 300 L 6500 500" 
                      fill="none" stroke="white" stroke-width="8" stroke-opacity="0.9" stroke-linejoin="round" vector-effect="non-scaling-stroke" />
                
                <!-- Glow -->
                <path d="M 500 500 L 1500 300 L 2500 700 L 3500 300 L 4500 700 L 5500 300 L 6500 500" 
                      fill="none" stroke="#ffde59" stroke-width="20" stroke-opacity="0.3" stroke-linejoin="round" vector-effect="non-scaling-stroke" class="blur-xl" />
            </svg>
        </div>

        <!-- Section 1: Intro Title -->
        <section class="h-screen min-w-[100vw] flex items-center justify-center relative z-10 shrink-0">
             <header class="text-center opacity-0 animate-fade-in-down p-8 bg-black/30 backdrop-blur-sm rounded-3xl border border-white/5 relative bg-slate-900/50">
                <h1 class="text-6xl md:text-9xl font-black font-['Outfit'] tracking-tighter mb-4 text-transparent bg-clip-text bg-gradient-to-r from-white via-gray-200 to-gray-500 relative z-10">
                    HISTORIA
                </h1>
                <p class="text-xl md:text-3xl text-[#ffde59] font-light tracking-widest uppercase relative z-10">
                    Real Madrid Femenino
                </p>
                <div class="mt-8 text-gray-400 text-sm animate-bounce relative z-10">
                    Haz scroll para navegar →
                </div>
            </header>
        </section>

        <!-- Milestones -->
        {milestones.map((item, index) => (
            <section class="h-screen min-w-[100vw] flex items-center justify-center relative z-10 shrink-0 snap-center">
                <!-- Layout: 100vw width to align with SVG peaks. -->
                <!-- Translates reduced to 20vh (was 30vh) to avoid edge crowding -->
                
                <div 
                    class={`flex flex-col items-center gap-6 max-w-xl w-full p-4 transform transition-all duration-1000 opacity-50 hover:opacity-100 slide-content cursor-pointer click-focus-item relative ${index % 2 === 0 ? '-translate-y-[20vh]' : 'translate-y-[20vh]'}`}
                    data-index={index}
                >
                    
                    <!-- Nexus Point (Gold Dot) -->
                    <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-6 h-6 bg-[#ffde59] rounded-full shadow-[0_0_25px_#ffde59] z-20 border-4 border-white animate-pulse"></div>
                    
                    <!-- Standalone Image (Centered on Nexus) -->
                    <div class="relative w-full aspect-video rounded-3xl overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.5)] border-2 border-white/20 group z-10 bg-slate-900">
                        <div class="absolute inset-0 bg-gradient-to-t from-[#0a0f1e]/80 to-transparent z-10"></div>
                        <Image 
                            src={item.image} 
                            alt={item.title} 
                            class="w-full h-full object-cover transition-transform duration-700 ease-out"
                        />
                         <!-- Year Overlay on Image -->
                         <span class="absolute bottom-6 left-8 z-20 text-5xl md:text-6xl font-black text-white drop-shadow-lg font-['Outfit'] tracking-tighter">
                            {item.displayDate}
                        </span>
                        
                        <!-- Icon Badge -->
                         <div class="absolute top-4 right-4 z-20 w-12 h-12 bg-white/10 backdrop-blur-md rounded-full flex items-center justify-center border border-white/20">
                            <span class="text-2xl">{item.icon}</span>
                         </div>
                    </div>

                    <!-- Text Below (Dynamic Position?) -->
                    <!-- If translateY is negative (UP), text could be below. If DOWN, text above? -->
                    <!-- keeping consistent below for readability -->
                    <div class={`text-center relative z-10 max-w-lg ${index % 2 === 0 ? 'mt-4' : 'mt-4'}`}>
                         <h3 class="text-4xl font-black text-[#ffde59] uppercase font-['Outfit'] leading-none drop-shadow-md mb-2">{item.title}</h3>
                        <p class="text-gray-300 leading-relaxed text-lg font-light text-balance drop-shadow-md bg-black/40 backdrop-blur-sm p-4 rounded-xl border border-white/5">{item.description}</p>
                    </div>

                </div>
            </section>
        ))}

        <!-- Section Final: CTA -->
        <section class="h-screen min-w-[100vw] flex items-center justify-center relative z-10 shrink-0">
             <div class="text-center p-12 bg-white/5 backdrop-blur-md rounded-3xl border border-white/10 relative" id="final-cta">
                 <!-- Connector line end -->
                 <div class="absolute top-1/2 left-0 w-full h-0.5 bg-transparent border-t border-dashed border-white/20 -translate-x-full"></div>

                <h2 class="text-5xl font-bold mb-12">El futuro es nuestro</h2>
                <a href="/home" class="inline-flex items-center gap-4 px-12 py-6 bg-[#ffde59] text-black font-black text-2xl tracking-widest rounded-full hover:scale-105 hover:bg-white transition-all shadow-[0_0_50px_rgba(255,222,89,0.5)]">
                    ENTRAR EN XTRA
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                </a>
            </div>
        </section>

    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {

            // Particle System
            const particlesContainer = document.getElementById('particles-container');
            if (particlesContainer) {
                const particleCount = 60; // Increased count
                for (let i = 0; i < particleCount; i++) {
                    const p = document.createElement('div');
                    const size = Math.random() * 4 + 2; 
                    const isGold = Math.random() > 0.5;
                    
                    p.style.width = `${size}px`;
                    p.style.height = `${size}px`;
                    p.style.background = isGold ? '#ffde59' : '#ffffff';
                    p.style.position = 'absolute';
                    p.style.borderRadius = '50%';
                    p.style.opacity = Math.random() * 0.5 + 0.1 + '';
                    p.style.left = `${Math.random() * 100}vw`;
                    p.style.top = `${Math.random() * 100}vh`;
                    p.style.boxShadow = isGold ? '0 0 10px #ffde59' : '0 0 5px white';
                    
                    // Faster float animation (2-5s instead of 10-20s)
                    const duration = Math.random() * 3 + 2; 
                    p.style.animation = `float ${duration}s linear infinite`;
                    p.style.animationDelay = `-${Math.random() * 5}s`;
                    
                    particlesContainer.appendChild(p);
                }
            }

             // Horizontal Scroll Logic with Inertia (Lerp)
            const scrollContainer = document.getElementById('scroll-container');
            const svgLine = document.querySelector('#scroll-container svg'); // Select the SVG to animate
            
            if (scrollContainer) {
                let targetScroll = 0;
                let currentScroll = 0;
                const ease = 0.08; 

                targetScroll = scrollContainer.scrollLeft;
                currentScroll = targetScroll;

                scrollContainer.addEventListener('wheel', (evt) => {
                    evt.preventDefault();
                    const speed = 1.5; 
                    targetScroll += evt.deltaY * speed;
                    const maxScroll = scrollContainer.scrollWidth - scrollContainer.clientWidth;
                    targetScroll = Math.max(0, Math.min(targetScroll, maxScroll));
                }, { passive: false });

                // Click to Focus Logic
                document.querySelectorAll('.click-focus-item').forEach(item => {
                    item.addEventListener('click', () => {
                        const section = item.closest('section');
                        if (section && section instanceof HTMLElement) {
                            const viewportWidth = scrollContainer.clientWidth;
                            const sectionLeft = section.offsetLeft;
                            const sectionWidth = section.clientWidth;
                            const centeredPosition = sectionLeft - (viewportWidth / 2) + (sectionWidth / 2);
                            const maxScroll = scrollContainer.scrollWidth - scrollContainer.clientWidth;
                            targetScroll = Math.max(0, Math.min(centeredPosition, maxScroll));
                        }
                    });
                });

                function animateScroll() {
                    if (Math.abs(targetScroll - currentScroll) > 0.5) {
                        currentScroll += (targetScroll - currentScroll) * ease;
                        scrollContainer.scrollLeft = currentScroll;
                        
                        // Parallax effect for the line: Move it slightly slower than scroll to create depth/movement
                        // modifying transform of the SVG container div
                        if(svgLine && svgLine.parentElement) {
                             // Effect: The line moves WITH the content but slightly shifted or static relative to viewport?
                             // User wants: "que también pase con la línea".
                             // Content moves left. Background usually stays. 
                             // To make the line move, we can translate it.
                             // Actually, since the SVG is absolute width 700vw and inside the scroll container, it SCROLLS with it by default.
                             // But previously I set it to position: absolute left:0. 
                             // Wait, if it is inside scroll-container, and pos absolute, it stays relative to the top-left of the CONTAINER (the visible window) or the SCROLLABLE CONTENT?
                             // It is relative to the nearest positioned ancestor. scroll-container has relative.
                             // So the line IS scrolling with the content 1:1. 
                             
                             // User says: "Me gusta el efecto de las fotos al pasar pero que también pase con la línea para que no quede raro"
                             // Perhaps they mean the line should have a parallax effect or "draw" itself?
                             // Or maybe they feel the line is static while photos move?
                             // If the SVG is 700vw and inside scroll-container, it moves 1:1.
                             
                             // Let's add a slight parallax or distinct movement to make it dynamic.
                             // Or maybe the opposite: Make the line fixed so content moves OVER it? 
                             // NO, the line connects specific points (Nexus). It MUST move 1:1 with photos.
                             
                             // Maybe they mean the "reveal" effect? "Efecto de las fotos al pasar" might refer to the fade/scale animation.
                             // I will add a parallax layer or verify if the line aligns perfectly.
                        }

                        requestAnimationFrame(animateScroll);
                    } else {
                        currentScroll = targetScroll;
                        scrollContainer.scrollLeft = currentScroll;
                        requestAnimationFrame(animateScroll);
                    }
                }
                requestAnimationFrame(animateScroll);
            }

            const setSeen = () => localStorage.setItem('madridxtra_intro_seen', 'true');
            document.querySelectorAll('a[href="/home"]').forEach(link => {
                link.addEventListener('click', setSeen);
            });

            const observerOptions = {
                threshold: 0.5,
                root: scrollContainer
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.remove('opacity-50', 'scale-90');
                        entry.target.classList.add('opacity-100', 'scale-100');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('.slide-content').forEach((item) => {
                observer.observe(item);
            });
        });
    </script>
    
    <style>
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        .animate-pulse-slow { animation: pulse 8s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
        @keyframes pulse {
            0%, 100% { opacity: 0.2; transform: scale(1.1); }
            50% { opacity: 0.15; transform: scale(1); }
        }
        .animate-fade-in-down { animation: fadeInDown 1.5s ease-out forwards; }
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes float {
            0% { transform: translateY(0) translateX(0); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateY(-100px) translateX(50px); opacity: 0; }
        }
    </style>
</body>
</html>
