---
import Layout from "../../layouts/Layout.astro";
import { StatsExplorer } from "../../components/stats/StatsExplorer";

const playerImages = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/jugadoras/*.{png,jpg,jpeg,webp}",
    { eager: true },
);

const playerImageMap = Object.fromEntries(
    Object.entries(playerImages).map(([path, mod]) => {
        const fileName = path.split("/").pop()?.split(".")[0];
        return [fileName, mod.default.src];
    }),
);
---

<Layout
    title="Estadísticas Avanzadas - Madrid Femenino Xtra"
    description="Consulta las estadísticas avanzadas del Real Madrid Femenino: goles, asistencias, xG, disparos y más. Datos de FBref."
>
    <main class="w-full max-w-[1400px] mx-auto px-4 py-8">
        <div class="mb-8 flex flex-col items-center">
            <h1 class="page-title text-center">ESTADÍSTICAS AVANZADAS</h1>
            <h2 class="content-h2 text-center text-pretty max-w-3xl mx-auto">
                Explora en profundidad el rendimiento del equipo. Filtra por
                competición, temporada y tipo de estadística (ofensiva,
                defensiva, posesión...).
            </h2>
        </div>

        <StatsExplorer client:load playerImageMap={playerImageMap} />

        <p class="text-xs text-gray-500 mt-4 text-left">
            Datos procedentes de <a
                href="https://fbref.com"
                target="_blank"
                class="underline hover:text-gray-900">FBref.com</a
            >. Actualizados diariamente.
        </p>
    </main>
</Layout>
```
