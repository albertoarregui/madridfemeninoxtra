                                                    match.competicion
                                                ] && match.competicion}
                                            </td>
                                            <td
                                                class={
                                                    match.club_local
                                                        .toLowerCase()
                                                        .includes("real madrid")
                                                        ? "font-bold"
                                                        : ""
                                                }
                                            >
                                                {match.club_local}
                                            </td>
                                            <td
                                                class={`font-bold ${
                                                    match.resultado === "V"
                                                        ? "text-green-600"
                                                        : match.resultado ===
                                                            "E"
                                                          ? "text-orange-500"
                                                          : "text-red-500"
                                                }`}
                                            >
                                                {match.goles_rm} -{" "}
                                                {match.goles_rival}
                                            </td>
                                            <td
                                                class={
                                                    match.club_visitante
                                                        .toLowerCase()
                                                        .includes("real madrid")
                                                        ? "font-bold"
                                                        : ""
                                                }
                                            >
                                                {match.club_visitante}
                                            </td>
                                            <td>
                                                {match.arbitra_nombre && (
                                                    <a
                                                        href={`/arbitras/${generateSlug(match.arbitra_nombre)}`}
                                                        class="hover:text-[#ffde59] transition-colors"
                                                    >
                                                        {match.arbitra_nombre}
                                                    </a>
                                                )}
                                            </td>
                                        </tr>
                                    ))
                                }
                            </tbody>
                        </table>
                    </div>
                    {
                        matches.length > 10 && (
                            <div class="matches-footer">
                                <button id="show-more-matches" class="btn-more">
                                    Ver todos los partidos ({matches.length})
                                </button>
                            </div>
                        )
                    }
                </section>
            </div>

            <div class="right-column">
                <section class="stadium-card">
                    <h2 class="section-header">MAPA</h2>
                    {/* Removed circular photo above map as requested */}
                    {
                        stadium.coordinates ? (
                            <div
                                class="map-placeholder bg-gray-100 rounded text-center overflow-hidden"
                                style="height: 300px; width: 100%;"
                            >
                                <iframe
                                    width="100%"
                                    height="100%"
                                    frameborder="0"
                                    scrolling="no"
                                    marginheight="0"
                                    marginwidth="0"
                                    src={`https://maps.google.com/maps?q=${stadium.coordinates.lat},${stadium.coordinates.lng}&hl=es&z=14&output=embed`}
                                />
                            </div>
                        ) : (
                            <div class="p-4 text-center text-gray-500">
                                Ubicación de mapa no disponible
                            </div>
                        )
                    }
                </section>
            </div>
        </div>
    </main>
</Layout>

<script define:vars={{ initialMatches: matches }}>
    // Toggle Season Logic
    window.toggleSeason = function (season) {
        const rows = document.querySelectorAll(
            `.competition-row.season-${season}`,
        );
        const icon = document.querySelector(
            `.season-total-row[onclick*="${season}"] .toggle-icon`,
        );

        rows.forEach((row) => {
            if (row.style.display === "none") {
                row.style.display = "table-row";
                if (icon) icon.textContent = "▲";
            } else {
                row.style.display = "none";
                if (icon) icon.textContent = "▼";
            }
        });
    };

    // Filters and Charts Logic
    function calculateStatsDoubleFilter(matches) {
        const stats = {
            pj: 0,
            pg: 0,
            pe: 0,
            pp: 0,
            gf: 0,
            gc: 0,
            cleanSheets: 0,
            conceded: 0,
        };

        matches.forEach((match) => {
            const golesRM = parseInt(match.golesRM) || 0;
            const golesRival = parseInt(match.golesRival) || 0;

            stats.pj++;
            stats.gf += golesRM;
            stats.gc += golesRival;

            if (match.cleanSheet) stats.cleanSheets++;
            else stats.conceded++;

            if (match.resultado === "V") stats.pg++;
            else if (match.resultado === "E") stats.pe++;
            else stats.pp++;
        });
        return stats;
    }

    function updateCharts(stats) {
        const circumference = 220;
        const totalMatches = stats.pj;

        const updateCircle = (id, idx, val, total, offset = 0) => {
            const chart = document.getElementById(id);
            if (!chart) return;
            const circle = chart.querySelectorAll("circle")[idx];
            if (!circle) return;

            const arc =
                total > 0 ? Math.round((val / total) * circumference) : 0;
            circle.setAttribute(
                "stroke-dasharray",
                `${arc} ${circumference - arc}`,
            );
            if (offset !== 0) circle.setAttribute("stroke-dashoffset", -offset);
            return arc;
        };

        // Results
        const winsArc = updateCircle(
            "results-chart",
            0,
            stats.pg,
            totalMatches,
        );
        const drawsArc = updateCircle(
            "results-chart",
            1,
            stats.pe,
            totalMatches,
            winsArc,
        );
        updateCircle(
            "results-chart",
            2,
            stats.pp,
            totalMatches,
            winsArc + drawsArc,
        );

        document.querySelector(
            "#results-legend div:nth-child(1) .dot",
        ).nextSibling.textContent = ` Ganados (${stats.pg})`;
        document.querySelector(
            "#results-legend div:nth-child(2) .dot",
        ).nextSibling.textContent = ` Empatados (${stats.pe})`;
        document.querySelector(
            "#results-legend div:nth-child(3) .dot",
        ).nextSibling.textContent = ` Perdidos (${stats.pp})`;

        // Goals
        const totalGoals = stats.gf + stats.gc;
        const goalsForArc = updateCircle(
            "goals-chart",
            0,
            stats.gf,
            totalGoals,
        );
        updateCircle("goals-chart", 1, stats.gc, totalGoals, goalsForArc);

        document.querySelector(
            "#goals-legend div:nth-child(1) .dot",
        ).nextSibling.textContent = ` A favor (${stats.gf})`;
        document.querySelector(
            "#goals-legend div:nth-child(2) .dot",
        ).nextSibling.textContent = ` En contra (${stats.gc})`;

        // Clean Sheets
        const cleanSheetsArc = updateCircle(
            "clean-sheets-chart",
            0,
            stats.cleanSheets,
            totalMatches,
        );
        updateCircle(
            "clean-sheets-chart",
            1,
            stats.conceded,
            totalMatches,
            cleanSheetsArc,
        );

        document.querySelector(
            "#clean-sheets-legend div:nth-child(1) .dot",
        ).nextSibling.textContent = ` P. a cero (${stats.cleanSheets})`;
        document.querySelector(
            "#clean-sheets-legend div:nth-child(2) .dot",
        ).nextSibling.textContent = ` Con gol (${stats.conceded})`;
    }

    const seasonFilter = document.getElementById("season-filter");
    const competitionFilter = document.getElementById("competition-filter");
    const allMatches = initialMatches; // from define:vars

    function applyFilters() {
        const selectedSeason = seasonFilter.value;
        const selectedComp = competitionFilter.value;

        let filtered = allMatches;

        if (selectedSeason !== "all") {
            filtered = filtered.filter((m) => m.season === selectedSeason);
        }
        if (selectedComp !== "all") {
            filtered = filtered.filter((m) => m.competicion === selectedComp);
        }

        const stats = calculateStatsDoubleFilter(filtered);
        updateCharts(stats);
    }

    if (seasonFilter) seasonFilter.addEventListener("change", applyFilters);
    if (competitionFilter)
        competitionFilter.addEventListener("change", applyFilters);

    const showMoreBtn = document.getElementById("show-more-matches");
    if (showMoreBtn) {
        showMoreBtn.addEventListener("click", () => {
            document.querySelectorAll(".hidden-match").forEach((row) => {
                row.style.display = "table-row";
                row.classList.remove("hidden-match");
            });
            showMoreBtn.style.display = "none";
        });
    }
</script>

