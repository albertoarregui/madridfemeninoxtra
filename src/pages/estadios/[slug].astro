---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import {
    fetchAllStadiumsWithStats,
    fetchMatchesByStadium,
} from "../../utils/estadios";
import { generateSlug } from "../../utils/url-helper";

import ligaFLogo from "../../assets/competiciones/liga_f.png";
import uwclLogo from "../../assets/competiciones/uwcl.png";
import copaLogo from "../../assets/competiciones/copa_de_la_reina.png";
import supercopaLogo from "../../assets/competiciones/supercopa_de_espana.png";

const competitionLogos: Record<string, any> = {
    "Liga F": ligaFLogo,
    UWCL: uwclLogo,
    "Copa de la Reina": copaLogo,
    "Supercopa de España": supercopaLogo,
};

export const prerender = true;

export async function getStaticPaths() {
    const stadiums = await fetchAllStadiumsWithStats();
    return stadiums.map((s) => ({
        params: { slug: s.slug },
    }));
}

const { slug } = Astro.params;

const allStadiums = await fetchAllStadiumsWithStats();
const stadium = allStadiums.find((s) => s.slug === slug);

if (!stadium) {
    return Astro.redirect("/404");
}

const rawMatches = await fetchMatchesByStadium(stadium.name);

// Process matches for statistics
const matches = rawMatches.map((m) => {
    const isLocal =
        m.club_local.toLowerCase().trim().includes("real madrid") ||
        m.club_local.toLowerCase().trim() === "real madrid cf";

    // Determine season from date
    const d = new Date(m.fecha);
    const year = d.getFullYear();
    const month = d.getMonth() + 1;
    const startYear = month >= 8 ? year : year - 1;
    const endYear = startYear + 1;
    const season = `${startYear}/${endYear.toString().slice(-2)}`;

    return {
        ...m,
        esLocal: isLocal,
        golesRM: m.goles_rm,
        golesRival: m.goles_rival,
        season,
        competicion: m.competicion,
        resultado: (() => {
            const rm = parseInt(m.goles_rm) || 0;
            const rival = parseInt(m.goles_rival) || 0;
            if (rm > rival) return "V";
            if (rm < rival) return "D";
            // Check penalties if draw
            if (m.penaltis === 1 || m.penaltis === "1") return "V";
            if (m.penaltis === 0 || m.penaltis === "0") return "D";
            return "E";
        })(),
        cleanSheet: (parseInt(m.goles_rival) || 0) === 0,
        conceded: (parseInt(m.goles_rival) || 0) > 0,
    };
});

// Calculate Detailed Stats (Season > Competition)
interface StatBlock {
    pj: number;
    pg: number;
    pe: number;
    pp: number;
    gf: number;
    gc: number;
    cleanSheets: number;
    conceded: number;
}

const initialStatBlock = (): StatBlock => ({
    pj: 0,
    pg: 0,
    pe: 0,
    pp: 0,
    gf: 0,
    gc: 0,
    cleanSheets: 0,
    conceded: 0,
});

const calculateBlock = (block: StatBlock, m: any) => {
    block.pj++;
    block.gf += parseInt(m.golesRM) || 0;
    block.gc += parseInt(m.golesRival) || 0;
    if (m.resultado === "V") block.pg++;
    else if (m.resultado === "E") block.pe++;
    else block.pp++;

    if (m.cleanSheet) block.cleanSheets++;
    else block.conceded++;
};

const seasonsMap = new Map<string, any>();

matches.forEach((m) => {
    if (!seasonsMap.has(m.season)) {
        seasonsMap.set(m.season, {
            temporada: m.season,
            total: initialStatBlock(),
            competiciones: new Map<string, any>(),
        });
    }
    const seasonData = seasonsMap.get(m.season);
    calculateBlock(seasonData.total, m);

    if (!seasonData.competiciones.has(m.competicion)) {
        seasonData.competiciones.set(m.competicion, {
            competicion: m.competicion,
            ...initialStatBlock(),
        });
    }
    calculateBlock(seasonData.competiciones.get(m.competicion), m);
});

// Convert Map to Array for rendering
const stadiumDeepStats = Array.from(seasonsMap.values())
    .map((s) => ({
        ...s,
        competiciones: Array.from(s.competiciones.values()),
    }))
    .sort((a, b) => (a.temporada < b.temporada ? 1 : -1)); // Newest first

// Total All Time for simple calc if needed
const totalStats = initialStatBlock();
matches.forEach((m) => calculateBlock(totalStats, m));

const addPercents = (s: StatBlock) => ({
    ...s,
    percPG: s.pj > 0 ? ((s.pg / s.pj) * 100).toFixed(1) : "0.0",
    percPE: s.pj > 0 ? ((s.pe / s.pj) * 100).toFixed(1) : "0.0",
    percPP: s.pj > 0 ? ((s.pp / s.pj) * 100).toFixed(1) : "0.0",
    avg: s.pj > 0 ? (s.gf / s.pj).toFixed(2) : "0.00",
    dif: s.gf - s.gc,
});

const totalStatsEnhanced = addPercents(totalStats);

// Filters Setup
const uniqueSeasons = [...new Set(matches.map((m) => m.season))]
    .sort()
    .reverse();
const uniqueCompetitions = [
    ...new Set(matches.map((m) => m.competicion)),
].sort();

// Arc Calculations for Server Render (Initial view uses Total)
const circumference = 220;
const totalMatches = totalStats.pj;
const winsArc =
    totalMatches > 0
        ? Math.round((totalStats.pg / totalMatches) * circumference)
        : 0;
const drawsArc =
    totalMatches > 0
        ? Math.round((totalStats.pe / totalMatches) * circumference)
        : 0;
const lossesArc =
    totalMatches > 0
        ? Math.round((totalStats.pp / totalMatches) * circumference)
        : 0;

const totalGoals = totalStats.gf + totalStats.gc;
const goalsForArc =
    totalGoals > 0
        ? Math.round((totalStats.gf / totalGoals) * circumference)
        : 0;
const goalsAgainstArc =
    totalGoals > 0
        ? Math.round((totalStats.gc / totalGoals) * circumference)
        : 0;

const cleanSheetsArc =
    totalMatches > 0
        ? Math.round((totalStats.cleanSheets / totalMatches) * circumference)
        : 0;
const concededArc =
    totalMatches > 0
        ? Math.round((totalStats.conceded / totalMatches) * circumference)
        : 0;
---

<Layout
    title={`${stadium.name} | Madrid Femenino Xtra`}
    description={`Estadísticas e historial de partidos del Real Madrid Femenino en el estadio ${stadium.name}.`}
>
    <main class="rival-details-page">
        <a href="/rivales/estadios" class="back-link">
