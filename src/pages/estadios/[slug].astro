                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {season.total.pe}
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {season.total.pp}
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {season.total.gf}
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {season.total.gc}
                                                        </strong>
