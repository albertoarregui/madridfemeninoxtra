                <section class="matches-card">
                    <h3 class="section-subheader">
                        PARTIDOS EN {stadium.name.toUpperCase()}
                    </h3>
                    <div class="table-wrapper">
                        <table class="matches-table">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Competición</th>
                                    <th>Local</th>
                                    <th>Res.</th>
                                    <th>Visitante</th>
                                    <th>Árbitra</th>
                                </tr>
                            </thead>
                            <tbody>
                                {
                                    matches.map((match, index) => (
                                        <tr
                                            class={`match-row ${index >= 10 ? "hidden-match" : ""}`}
