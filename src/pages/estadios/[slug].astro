---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import { getAllStadiums, fetchMatchesByStadium } from "../../utils/estadios";
import { generateSlug } from "../../utils/url-helper";

const { slug } = Astro.params;

const allStadiums = getAllStadiums();
const stadium = allStadiums.find((s) => s.slug === slug);

if (!stadium) {
    return Astro.redirect("/404");
}

const rawMatches = await fetchMatchesByStadium(stadium.name);

// Process matches for statistics
const matches = rawMatches.map((m) => {
    const isLocal =
        m.club_local.toLowerCase().trim().includes("real madrid") ||
        m.club_local.toLowerCase().trim() === "real madrid cf";

    // Determine season from date
    const d = new Date(m.fecha);
    const year = d.getFullYear();
    const month = d.getMonth() + 1;
    const startYear = month >= 8 ? year : year - 1;
    const endYear = startYear + 1;
    const season = `${startYear}/${endYear.toString().slice(-2)}`;

    return {
        ...m,
        esLocal: isLocal,
        golesRM: m.goles_rm,
        golesRival: m.goles_rival,
        season,
        competicion: m.competicion,
        resultado: (() => {
            const rm = parseInt(m.goles_rm) || 0;
            const rival = parseInt(m.goles_rival) || 0;
            if (rm > rival) return "V";
            if (rm < rival) return "D";
            // Check penalties if draw
            if (m.penaltis === 1 || m.penaltis === "1") return "V";
            if (m.penaltis === 0 || m.penaltis === "0") return "D";
            return "E";
        })(),
    };
});

// Calculate Stats (Server Side)
const calculateStats = (matchList: any[]) => {
    const stats = {
        home: {
            pj: 0,
            pg: 0,
            pe: 0,
            pp: 0,
            gf: 0,
            gc: 0,
            cleanSheets: 0,
            conceded: 0,
            yellowCards: 0,
            redCards: 0,
        },
        away: {
            pj: 0,
            pg: 0,
            pe: 0,
            pp: 0,
            gf: 0,
            gc: 0,
            cleanSheets: 0,
            conceded: 0,
            yellowCards: 0,
            redCards: 0,
        },
        total: {
            pj: 0,
            pg: 0,
            pe: 0,
            pp: 0,
            gf: 0,
            gc: 0,
            cleanSheets: 0,
            conceded: 0,
            yellowCards: 0,
            redCards: 0,
        },
    };

    matchList.forEach((match) => {
        const golesRM = parseInt(match.golesRM) || 0;
        const golesRival = parseInt(match.golesRival) || 0;
        const isHome = match.esLocal; // This logic depends on RM perspective
        // WARN: In Rival page, 'home' means RM played as LOCAL against that rival.
        // Here, 'home' means RM played as LOCAL at this stadium.
        // If the stadium is NOT Di Stefano, RM usually plays as visitor (away).
        // Exceptions: Finals played at neutral stadiums where RM might be 'local' administratively.

        const location = isHome ? stats.home : stats.away;

        location.pj++;
        location.gf += golesRM;
        location.gc += golesRival;

        if (golesRival === 0) location.cleanSheets++;
        else location.conceded++;

        if (golesRM > golesRival) location.pg++;
        else if (golesRM < golesRival) location.pp++;
        else {
            // Check penalties if draw (simplified for now without full penaltis data in some queries)
            if (match.penaltis === 1 || match.penaltis === "1") location.pg++;
            else if (match.penaltis === 0 || match.penaltis === "0")
                location.pp++;
            else location.pe++;
        }
    });

    // Aggregation
    const keys = [
        "pj",
        "pg",
        "pe",
        "pp",
        "gf",
        "gc",
        "cleanSheets",
        "conceded",
        "yellowCards",
        "redCards",
    ] as const;
    keys.forEach((key) => {
        stats.total[key] = stats.home[key] + stats.away[key];
    });

    const addFields = (obj: any) => ({
        ...obj,
        percPG: obj.pj > 0 ? ((obj.pg / obj.pj) * 100).toFixed(1) : "0.0",
        percPE: obj.pj > 0 ? ((obj.pe / obj.pj) * 100).toFixed(1) : "0.0",
        percPP: obj.pj > 0 ? ((obj.pp / obj.pj) * 100).toFixed(1) : "0.0",
        avg: obj.pj > 0 ? (obj.gf / obj.pj).toFixed(2) : "0.00",
        dif: obj.gf - obj.gc,
    });

    return {
        home: addFields(stats.home),
        away: addFields(stats.away),
        total: addFields(stats.total),
    };
};

const stadiumStats = calculateStats(matches);

// Filters Setup
const uniqueSeasons = [...new Set(matches.map((m) => m.season))]
    .sort()
    .reverse();
const uniqueCompetitions = [
    ...new Set(matches.map((m) => m.competicion)),
].sort();

// Arc Calculations for Server Render
const circumference = 220;
const totalMatches = stadiumStats.total.pj;
const winsArc =
    totalMatches > 0
        ? Math.round((stadiumStats.total.pg / totalMatches) * circumference)
        : 0;
const drawsArc =
    totalMatches > 0
        ? Math.round((stadiumStats.total.pe / totalMatches) * circumference)
        : 0;
const lossesArc =
    totalMatches > 0
        ? Math.round((stadiumStats.total.pp / totalMatches) * circumference)
        : 0;

const totalGoals = stadiumStats.total.gf + stadiumStats.total.gc;
const goalsForArc =
    totalGoals > 0
        ? Math.round((stadiumStats.total.gf / totalGoals) * circumference)
        : 0;
const goalsAgainstArc =
    totalGoals > 0
        ? Math.round((stadiumStats.total.gc / totalGoals) * circumference)
        : 0;

const cleanSheetsArc =
    totalMatches > 0
        ? Math.round(
              (stadiumStats.total.cleanSheets / totalMatches) * circumference,
          )
        : 0;
const concededArc =
    totalMatches > 0
        ? Math.round(
              (stadiumStats.total.conceded / totalMatches) * circumference,
          )
        : 0;

export const prerender = true;
---

<Layout
    title={`${stadium.name} | Madrid Femenino Xtra`}
    description={`Estadísticas e historial de partidos del Real Madrid Femenino en el estadio ${stadium.name}.`}
>
    <main class="rival-details-page">
        <a href="/rivales/estadios" class="back-link">
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Volver a Estadios
        </a>

        <div class="rival-grid">
            <div class="left-column">
                <section class="rival-card">
                    <h2 class="section-header">FICHA DE ESTADIO</h2>
                    <div class="rival-info">
                        <div class="rival-shield">
                            {
                                stadium.imageUrl ? (
                                    <img
                                        src={stadium.imageUrl}
                                        alt={stadium.name}
                                        class="object-cover w-full h-full rounded-md"
                                    />
                                ) : (
                                    <div class="w-full h-full bg-gray-200 flex items-center justify-center text-gray-400">
                                        <span>Sin imagen</span>
                                    </div>
                                )
                            }
                        </div>
                        <div class="rival-details">
                            <div class="info-row">
                                <span class="label">Nombre:</span>
                                <span class="value">{stadium.name}</span>
                            </div>
                            <div class="info-row">
                                <span class="label">Ciudad:</span>
                                <span class="value">{stadium.city}</span>
                            </div>
                            <div class="info-row">
                                <span class="label">Capacidad:</span>
                                <span class="value"
                                    >{
                                        stadium.capacity
                                            ? Number(
                                                  stadium.capacity,
                                              ).toLocaleString()
                                            : "-"
                                    }</span
                                >
                            </div>
                        </div>
                    </div>
                </section>

                <section class="stats-table-card">
                    <h3 class="section-subheader">
                        ESTADÍSTICAS EN ESTE ESTADIO
                    </h3>
                    <div class="table-wrapper">
                        <table class="stats-table">
                            <thead>
                                <tr>
                                    <th>C. LECHERA</th>
                                    <th>PJ</th>
                                    <th>PG</th>
                                    <th>%PG</th>
                                    <th>PE</th>
                                    <th>%PE</th>
                                    <th>PP</th>
                                    <th>%PP</th>
                                    <th class="highlight-yellow">⚽</th>
                                    <th class="highlight-red">⚽</th>
                                    <th class="highlight-blue">📊</th>
                                    <th>Avg.</th>
                                    <th>Dif.</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>LOCAL</td>
                                    <td>{stadiumStats.home.pj}</td>
                                    <td>{stadiumStats.home.pg}</td>
                                    <td>{stadiumStats.home.percPG}%</td>
                                    <td>{stadiumStats.home.pe}</td>
                                    <td>{stadiumStats.home.percPE}%</td>
                                    <td>{stadiumStats.home.pp}</td>
                                    <td>{stadiumStats.home.percPP}%</td>
                                    <td class="highlight-yellow"
                                        >{stadiumStats.home.gf}</td
                                    >
                                    <td class="highlight-red"
                                        >{stadiumStats.home.gc}</td
                                    >
                                    <td class="highlight-blue"
                                        >{stadiumStats.home.dif > 0 ? "+" : ""}{
                                            stadiumStats.home.dif
                                        }</td
                                    >
                                    <td>{stadiumStats.home.avg}</td>
                                    <td>{stadiumStats.home.dif}</td>
                                </tr>
                                <tr>
                                    <td>VISITANTE</td>
                                    <td>{stadiumStats.away.pj}</td>
                                    <td>{stadiumStats.away.pg}</td>
                                    <td>{stadiumStats.away.percPG}%</td>
                                    <td>{stadiumStats.away.pe}</td>
                                    <td>{stadiumStats.away.percPE}%</td>
                                    <td>{stadiumStats.away.pp}</td>
                                    <td>{stadiumStats.away.percPP}%</td>
                                    <td class="highlight-yellow"
                                        >{stadiumStats.away.gf}</td
                                    >
                                    <td class="highlight-red"
                                        >{stadiumStats.away.gc}</td
                                    >
                                    <td class="highlight-blue"
                                        >{stadiumStats.away.dif > 0 ? "+" : ""}{
                                            stadiumStats.away.dif
                                        }</td
                                    >
                                    <td>{stadiumStats.away.avg}</td>
                                    <td>{stadiumStats.away.dif}</td>
                                </tr>
