                                    <td>{stadiumStats.total.pe}</td>
                                    <td>{stadiumStats.total.percPE}%</td>
                                    <td>{stadiumStats.total.pp}</td>
                                    <td>{stadiumStats.total.percPP}%</td>
                                    <td class="highlight-yellow"
                                        >{stadiumStats.total.gf}</td
                                    >
                                    <td class="highlight-red"
                                        >{stadiumStats.total.gc}</td
                                    >
