                                                {new Date(
                                                    match.fecha,
                                                ).toLocaleDateString("es-ES")}
                                            </td>
                                            <td>
                                                {competitionLogos[
                                                    match.competicion
                                                ] && (
                                                    <img
                                                        src={
                                                            competitionLogos[
                                                                match
                                                                    .competicion
                                                            ].src
                                                        }
                                                        alt={match.competicion}
                                                        class="competition-logo-small"
                                                        title={
                                                            match.competicion
                                                        }
                                                    />
                                                )}
