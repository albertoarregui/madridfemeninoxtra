                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="filter-icon"
                                ><path
                                    stroke="none"
                                    d="M0 0h24v24H0z"
                                    fill="none"></path><path d="M6 9l6 6l6 -6"
                                ></path></svg
                            >
                        </div>
                    </div>
                    <div class="charts-row">
                        <div class="chart-item">
                            <svg
                                viewBox="0 0 100 100"
                                class="pie-chart"
                                id="results-chart"
                            >
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#c8e6c9"
                                    stroke-width="20"
                                    stroke-dasharray={`${winsArc} ${circumference - winsArc}`}
                                    transform="rotate(-90 50 50)"></circle>
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#fff9c4"
                                    stroke-width="20"
                                    stroke-dasharray={`${drawsArc} ${circumference - drawsArc}`}
                                    stroke-dashoffset={-winsArc}
                                    transform="rotate(-90 50 50)"></circle>
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#ffcdd2"
                                    stroke-width="20"
                                    stroke-dasharray={`${lossesArc} ${circumference - lossesArc}`}
                                    stroke-dashoffset={-(winsArc + drawsArc)}
                                    transform="rotate(-90 50 50)"></circle>
                            </svg>
                            <div class="chart-legend" id="results-legend">
                                <div>
                                    <span class="dot green"></span> Ganados ({
                                        stadiumStats.total.pg
                                    })
                                </div>
                                <div>
                                    <span class="dot orange"></span> Empatados ({
                                        stadiumStats.total.pe
                                    })
                                </div>
                                <div>
                                    <span class="dot red"></span> Perdidos ({
                                        stadiumStats.total.pp
                                    })
                                </div>
                            </div>
                        </div>
                        <div class="chart-item">
                            <svg
                                viewBox="0 0 100 100"
                                class="pie-chart"
                                id="goals-chart"
                            >
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#c8e6c9"
                                    stroke-width="20"
                                    stroke-dasharray={`${goalsForArc} ${circumference - goalsForArc}`}
                                    transform="rotate(-90 50 50)"></circle>
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#ffcdd2"
                                    stroke-width="20"
                                    stroke-dasharray={`${goalsAgainstArc} ${circumference - goalsAgainstArc}`}
                                    stroke-dashoffset={-goalsForArc}
                                    transform="rotate(-90 50 50)"></circle>
                            </svg>
                            <div class="chart-legend" id="goals-legend">
                                <div>
                                    <span class="dot green"></span> A favor ({
                                        stadiumStats.total.gf
                                    })
                                </div>
                                <div>
                                    <span class="dot red"></span> En contra ({
                                        stadiumStats.total.gc
                                    })
                                </div>
                            </div>
                        </div>
                        <div class="chart-item">
                            <svg
                                viewBox="0 0 100 100"
                                class="pie-chart"
                                id="clean-sheets-chart"
                            >
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#c8e6c9"
                                    stroke-width="20"
                                    stroke-dasharray={`${cleanSheetsArc} ${circumference - cleanSheetsArc}`}
                                    transform="rotate(-90 50 50)"></circle>
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#ffcdd2"
                                    stroke-width="20"
                                    stroke-dasharray={`${concededArc} ${circumference - concededArc}`}
                                    stroke-dashoffset={-cleanSheetsArc}
                                    transform="rotate(-90 50 50)"></circle>
                            </svg>
                            <div class="chart-legend" id="clean-sheets-legend">
                                <div>
                                    <span class="dot green"></span> P. a cero ({
                                        stadiumStats.total.cleanSheets
                                    })
                                </div>
                                <div>
                                    <span class="dot red"></span> Con gol ({
                                        stadiumStats.total.conceded
                                    })
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="matches-card">
                    <h3 class="section-subheader">PARTIDOS DISPUTADOS</h3>
                    <div class="table-wrapper">
                        <table class="matches-table">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Competición</th>
                                    <th>Local</th>
                                    <th>Res.</th>
                                    <th>Visitante</th>
                                    <th>Árbitra</th>
                                </tr>
                            </thead>
                            <tbody>
                                {
                                    matches.map((match, index) => (
                                        <tr
                                            class={`match-row ${index >= 10 ? "hidden-match" : ""}`}
                                            style={
                                                index >= 10
                                                    ? "display: none;"
                                                    : ""
                                            }
                                        >
                                            <td>
                                                {new Date(
                                                    match.fecha,
                                                ).toLocaleDateString("es-ES")}
                                            </td>
                                            <td>{match.competicion}</td>
                                            <td
                                                class={
                                                    match.club_local
                                                        .toLowerCase()
                                                        .includes("real madrid")
                                                        ? "font-bold"
                                                        : ""
                                                }
                                            >
                                                {match.club_local}
                                            </td>
                                            <td
                                                class={`font-bold ${
                                                    match.resultado === "V"
                                                        ? "text-green-600"
                                                        : match.resultado ===
                                                            "E"
                                                          ? "text-orange-500"
                                                          : "text-red-500"
                                                }`}
                                            >
                                                {match.goles_rm} -{" "}
                                                {match.goles_rival}
                                            </td>
                                            <td
                                                class={
                                                    match.club_visitante
                                                        .toLowerCase()
                                                        .includes("real madrid")
                                                        ? "font-bold"
                                                        : ""
                                                }
                                            >
                                                {match.club_visitante}
                                            </td>
                                            <td>
                                                {match.arbitra_nombre && (
                                                    <a
                                                        href={`/arbitras/${generateSlug(match.arbitra_nombre)}`}
                                                        class="hover:text-[#ffde59] transition-colors"
                                                    >
                                                        {match.arbitra_nombre}
                                                    </a>
                                                )}
                                            </td>
                                        </tr>
                                    ))
                                }
                            </tbody>
                        </table>
                    </div>
                    {
                        matches.length > 10 && (
                            <div class="matches-footer">
                                <button id="show-more-matches" class="btn-more">
                                    Ver todos los partidos ({matches.length})
                                </button>
                            </div>
                        )
                    }
                </section>
            </div>

            <div class="right-column">
                <section class="stadium-card">
                    <h2 class="section-header">MAPA</h2>
                    {
                        stadium.coordinates ? (
                            <div
                                class="map-placeholder bg-gray-100 p-4 rounded text-center"
                                style="height: 300px;"
                            >
                                {/** Interactive Map could go here if we had the component ready, for now placeholder like logic */}
                                <iframe
                                    width="100%"
                                    height="100%"
                                    frameborder="0"
                                    scrolling="no"
                                    marginheight="0"
                                    marginwidth="0"
                                    src={`https://maps.google.com/maps?q=${stadium.coordinates.lat},${stadium.coordinates.lng}&hl=es&z=14&output=embed`}
                                />
                            </div>
                        ) : (
                            <div class="p-4 text-center text-gray-500">
                                Ubicación no disponible
                            </div>
                        )
                    }
                </section>
            </div>
        </div>
    </main>
</Layout>

<script define:vars={{ initialMatches: matches }}>
    function calculateStatsLocal(matches) {
        const stats = {
            home: {
                pj: 0,
                pg: 0,
                pe: 0,
                pp: 0,
                gf: 0,
                gc: 0,
                cleanSheets: 0,
                conceded: 0,
            },
            away: {
                pj: 0,
                pg: 0,
                pe: 0,
                pp: 0,
                gf: 0,
                gc: 0,
                cleanSheets: 0,
                conceded: 0,
            },
            total: {
                pj: 0,
                pg: 0,
                pe: 0,
                pp: 0,
                gf: 0,
                gc: 0,
                cleanSheets: 0,
                conceded: 0,
            },
        };

        matches.forEach((match) => {
            const golesRM = parseInt(match.golesRM) || 0;
            const golesRival = parseInt(match.golesRival) || 0;

            // Check if RM was local in this match
            const isHome = match.club_local
                .toLowerCase()
                .includes("real madrid");
            const location = isHome ? stats.home : stats.away;

            location.pj++;
            location.gf += golesRM;
            location.gc += golesRival;

            if (golesRival === 0) location.cleanSheets++;
            else location.conceded++;

            if (golesRM > golesRival) location.pg++;
            else if (golesRM < golesRival) location.pp++;
            else {
                if (match.penaltis === 1 || match.penaltis === "1")
                    location.pg++;
                else if (match.penaltis === 0 || match.penaltis === "0")
                    location.pp++;
                else location.pe++;
            }
        });

        // Totals
        const keys = [
            "pj",
            "pg",
            "pe",
            "pp",
            "gf",
            "gc",
            "cleanSheets",
            "conceded",
        ];
        keys.forEach((k) => (stats.total[k] = stats.home[k] + stats.away[k]));

        const addFields = (obj) => ({
            ...obj,
            percPG: obj.pj > 0 ? ((obj.pg / obj.pj) * 100).toFixed(1) : "0.0",
            percPE: obj.pj > 0 ? ((obj.pe / obj.pj) * 100).toFixed(1) : "0.0",
            percPP: obj.pj > 0 ? ((obj.pp / obj.pj) * 100).toFixed(1) : "0.0",
            avg: obj.pj > 0 ? (obj.gf / obj.pj).toFixed(2) : "0.00",
            dif: obj.gf - obj.gc,
        });

        return {
            home: addFields(stats.home),
            away: addFields(stats.away),
            total: addFields(stats.total),
        };
    }

    function updateCharts(stats) {
        const circumference = 220;
        const totalMatches = stats.total.pj;
        const totalGoals = stats.total.gf + stats.total.gc;

        const updateCircle = (id, idx, val, total, offset = 0) => {
            const chart = document.getElementById(id);
            if (!chart) return;
            const circle = chart.querySelectorAll("circle")[idx];
            if (!circle) return;

            const arc =
                total > 0 ? Math.round((val / total) * circumference) : 0;
            circle.setAttribute(
                "stroke-dasharray",
                `${arc} ${circumference - arc}`,
            );
            if (offset !== 0) circle.setAttribute("stroke-dashoffset", -offset);
            return arc;
        };

        const winsArc = updateCircle(
            "results-chart",
            0,
            stats.total.pg,
            totalMatches,
        );
        const drawsArc = updateCircle(
            "results-chart",
            1,
            stats.total.pe,
            totalMatches,
            winsArc,
        );
        updateCircle(
            "results-chart",
            2,
            stats.total.pp,
            totalMatches,
            winsArc + drawsArc,
        );

        const gfArc = updateCircle(
            "goals-chart",
            0,
            stats.total.gf,
            totalGoals,
        );
        updateCircle("goals-chart", 1, stats.total.gc, totalGoals, gfArc);

        const csArc = updateCircle(
            "clean-sheets-chart",
            0,
            stats.total.cleanSheets,
            totalMatches,
        );
        updateCircle(
            "clean-sheets-chart",
            1,
            stats.total.conceded,
            totalMatches,
            csArc,
        );

        // Update Legends text
        const updateLegend = (id, idx, text) => {
            const el = document.getElementById(id);
            if (el && el.querySelectorAll("div")[idx])
                el.querySelectorAll("div")[idx].innerHTML = text;
        };

        updateLegend(
            "results-legend",
            0,
            `<span class="dot green"></span> Ganados (${stats.total.pg})`,
        );
        updateLegend(
            "results-legend",
            1,
            `<span class="dot orange"></span> Empatados (${stats.total.pe})`,
        );
        updateLegend(
            "results-legend",
            2,
            `<span class="dot red"></span> Perdidos (${stats.total.pp})`,
        );

        updateLegend(
            "goals-legend",
            0,
            `<span class="dot green"></span> A favor (${stats.total.gf})`,
        );
        updateLegend(
            "goals-legend",
            1,
            `<span class="dot red"></span> En contra (${stats.total.gc})`,
        );

        updateLegend(
            "clean-sheets-legend",
            0,
            `<span class="dot green"></span> P. a cero (${stats.total.cleanSheets})`,
        );
        updateLegend(
            "clean-sheets-legend",
            1,
            `<span class="dot red"></span> Con gol (${stats.total.conceded})`,
        );
    }

    function updateTable(stats) {
        const table = document.querySelector(".stats-table tbody");
        if (!table) return;
        const row = (label, d) =>
            `<td>${label}</td><td>${d.pj}</td><td>${d.pg}</td><td>${d.percPG}%</td><td>${d.pe}</td><td>${d.percPE}%</td><td>${d.pp}</td><td>${d.percPP}%</td><td class="highlight-yellow">${d.gf}</td><td class="highlight-red">${d.gc}</td><td class="highlight-blue">${d.dif > 0 ? "+" : ""}${d.dif}</td><td>${d.avg}</td><td>${d.dif}</td>`;
        table.innerHTML = `<tr>${row("LOCAL", stats.home)}</tr><tr>${row("VISITANTE", stats.away)}</tr><tr class="total-row">${row("<strong>TOTAL</strong>", stats.total)}</tr>`;
    }

    const seasonFilter = document.getElementById("season-filter");
    if (seasonFilter) {
        seasonFilter.addEventListener("change", () => {
            const selected = seasonFilter.value;
            const filtered =
                selected === "all"
                    ? initialMatches
                    : initialMatches.filter((m) => m.season === selected);
            const newStats = calculateStatsLocal(filtered);
            updateCharts(newStats);
            updateTable(newStats);
        });
    }

    const showMore = document.getElementById("show-more-matches");
    if (showMore) {
        showMore.addEventListener("click", () => {
            document.querySelectorAll(".hidden-match").forEach((r) => {
                r.classList.remove("hidden-match");
                r.style.display = "table-row";
            });
            showMore.parentElement.style.display = "none";
        });
    }
</script>

