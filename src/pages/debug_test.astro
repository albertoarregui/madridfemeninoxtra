---
import { fetchGamesDirectly, fetchAllGoals } from "../utils/partidos";

const games = await fetchGamesDirectly();
const goals = await fetchAllGoals();

const totalGoalsRM = games.reduce(
    (acc, g) => acc + (Number(g.goles_rm) || 0),
    0,
);
const totalGoalsRival = games.reduce(
    (acc, g) => acc + (Number(g.goles_rival) || 0),
    0,
);

const goalsBySeason = games.reduce(
    (acc, g) => {
        acc[g.temporada_nombre] =
            (acc[g.temporada_nombre] || 0) + (Number(g.goles_rm) || 0);
        return acc;
    },
    {} as Record<string, number>,
);
---

<html>
    <body>
        <h1>Debug Data</h1>
        <p>Games Count: {games.length}</p>
        <p>Goals (Chart Data) Count: {goals.length}</p>
        <p>Total Goals RM (Games Sum): {totalGoalsRM}</p>
        <p>Total Goals Rival (Games Sum): {totalGoalsRival}</p>

        <h2>Goals Sample (First 5)</h2>
        <pre>{JSON.stringify(goals.slice(0, 5), null, 2)}</pre>

        <h2>Goals by Season (Games)</h2>
        <pre>{JSON.stringify(goalsBySeason, null, 2)}</pre>

        <h2>Season List (Games)</h2>
        <ul>
            {
                games
                    .map((g) => (
                        <li>
                            {g.temporada_nombre} - {g.club_local} vs{" "}
                            {g.club_visitante}: {g.goles_rm}-{g.goles_rival} (
                            {g.competicion_nombre})
                        </li>
                    ))
                    .slice(0, 20)
            }
        </ul>
    </body>
</html>
