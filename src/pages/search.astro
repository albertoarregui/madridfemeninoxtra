---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import { Image } from "astro:assets";

const query = Astro.url.searchParams.get("q") || "";

interface SearchResult {
    type: "player" | "rival" | "match" | "coach";
    title: string;
    subtitle: string;
    url: string;
    slug: string;
    relevance: number;
}

let results: SearchResult[] = [];
let error = "";

if (query) {
    try {
        const response = await fetch(
            `${Astro.url.origin}/api/search?q=${encodeURIComponent(query)}`,
        );
        if (response.ok) {
            const data = await response.json();
            results = data.results || [];
        } else {
            error = "Error al realizar la búsqueda";
        }
    } catch (e) {
        console.error("Search error:", e);
        error = "Error al realizar la búsqueda";
    }
}

// Image resolution logic
const playerImages = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/jugadoras/*.{png,jpg,jpeg,webp}",
);
// rivalImages removed since we use public path
const coachImages = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/entrenadores/*.{png,jpg,jpeg,webp}",
);

async function getImage(result: SearchResult) {
    if (result.type === "rival") {
        const slugUnderscored = result.slug.replace(/-/g, "_").toLowerCase();
        // Assuming PNG as per previous standards and file listing
        return { src: `/assets/escudos/${slugUnderscored}.png` };
    }

    let imagesRecord: Record<
        string,
        () => Promise<{ default: ImageMetadata }>
    > = {};
    let folderName = "";

    if (result.type === "player") {
        imagesRecord = playerImages;
        folderName = "jugadoras";
    } else if (result.type === "coach") {
        imagesRecord = coachImages;
        folderName = "entrenadores";
    } else {
        return null;
    }

    // Normalize slug: explicitly replace hyphens with underscores + lowercase
    const slugUnderscored = result.slug.replace(/-/g, "_").toLowerCase();
    const slugNormal = result.slug.toLowerCase();

    // Construct valid keys for direct lookup using absolute paths
    const candidates = [
        `/src/assets/${folderName}/${slugUnderscored}.png`,
        `/src/assets/${folderName}/${slugNormal}.png`,
        `/src/assets/${folderName}/${slugUnderscored}.jpg`,
        `/src/assets/${folderName}/${slugNormal}.jpg`,
    ];

    for (const key of candidates) {
        if (imagesRecord[key]) {
            return (await imagesRecord[key]()).default;
        }
    }

    // Fallback: Find matching key in the glob record by checking filenames case-insensitive
    const matchingPath = Object.keys(imagesRecord).find((path) => {
        const fileName = path.split("/").pop()?.split(".")[0].toLowerCase();
        return fileName === slugNormal || fileName === slugUnderscored;
    });

    if (matchingPath) {
        return (await imagesRecord[matchingPath]()).default;
    }

    return null;
}

const playerResults = results.filter((r) => r.type === "player");
const rivalResults = results.filter((r) => r.type === "rival");
const coachResults = results.filter((r) => r.type === "coach");
const matchResults = results.filter((r) => r.type === "match");

// Resolve images ensuring no async map in JSX
let playerResultsWithImages: any[] = [];
let rivalResultsWithImages: any[] = [];
let coachResultsWithImages: any[] = [];

try {
    playerResultsWithImages = await Promise.all(
        playerResults.map(async (r) => ({
            ...r,
            image: await getImage(r).catch((e) => {
                console.error(`Error loading image for ${r.title}:`, e);
                return null;
            }),
        })),
    );

    rivalResultsWithImages = await Promise.all(
        rivalResults.map(async (r) => ({
            ...r,
            image: await getImage(r).catch((e) => {
                console.error(`Error loading image for ${r.title}:`, e);
                return null;
            }),
        })),
    );

    coachResultsWithImages = await Promise.all(
        coachResults.map(async (r) => ({
            ...r,
            image: await getImage(r).catch((e) => {
                console.error(`Error loading image for ${r.title}:`, e);
                return null;
            }),
        })),
    );
} catch (e) {
    console.error("Critical error resolving search images:", e);
}
---

<Layout
    title={`Búsqueda: ${query} - Madrid Femenino Xtra`}
    noindex={true}
    showAds={false}
>
    <div class="search-page">
        <div class="search-container">
            <h1 class="page-title">Resultados de búsqueda</h1>

            <div class="search-box">
                <form action="/search" method="get" class="search-form">
                    <input
                        type="search"
                        name="q"
                        value={query}
                        placeholder="Buscar jugadoras, entrenadores, rivales..."
                        class="search-input"
                        autofocus
                    />
                    <button type="submit" class="search-button">Buscar</button>
                </form>
            </div>

            {
                query && (
                    <div class="search-results">
                        {error && <p class="error-message">{error}</p>}

                        {!error && results.length === 0 && (
                            <div class="no-results">
                                <p>
                                    No se encontraron resultados para "
                                    <strong>{query}</strong>"
                                </p>
                                <p class="suggestion">
                                    Intenta con otros términos de búsqueda
                                </p>
                            </div>
                        )}

                        {!error && results.length > 0 && (
                            <div class="results-summary">
                                <p>
                                    Se encontraron{" "}
                                    <strong>{results.length}</strong>{" "}
                                    resultado(s) para "<strong>{query}</strong>"
                                </p>
                            </div>
                        )}

                        {playerResultsWithImages.length > 0 && (
                            <section class="results-section">
                                <h2 class="section-title">
                                    Jugadoras ({playerResultsWithImages.length})
                                </h2>
                                <div class="results-grid">
                                    {playerResultsWithImages.map((result) => (
                                        <a
                                            href={result.url}
                                            class="result-card"
                                        >
                                            {result.image && (
                                                <div class="result-image-container player-image">
                                                    <img
                                                        src={result.image.src}
                                                        alt={result.title}
                                                        width="60"
                                                        height="60"
                                                        class="result-image"
                                                    />
                                                </div>
                                            )}
                                            <div class="result-info">
                                                <h3 class="result-title">
                                                    {result.title}
                                                </h3>
                                                <p class="result-subtitle">
                                                    {result.subtitle}
                                                </p>
                                            </div>
                                        </a>
                                    ))}
                                </div>
                            </section>
                        )}

                        {rivalResultsWithImages.length > 0 && (
                            <section class="results-section">
                                <h2 class="section-title">
                                    Rivales ({rivalResultsWithImages.length})
                                </h2>
                                <div class="results-grid">
                                    {rivalResultsWithImages.map((result) => (
                                        <a
                                            href={result.url}
                                            class="result-card"
                                        >
                                            {result.image && (
                                                <div class="result-image-container">
                                                    <img
                                                        src={result.image.src}
                                                        alt={result.title}
                                                        width="60"
                                                        height="60"
                                                        class="result-image"
                                                    />
                                                </div>
                                            )}
                                            <div class="result-info">
                                                <h3 class="result-title">
                                                    {result.title}
                                                </h3>
                                                <p class="result-subtitle">
                                                    {result.subtitle}
                                                </p>
                                            </div>
                                        </a>
                                    ))}
                                </div>
                            </section>
                        )}

                        {coachResultsWithImages.length > 0 && (
                            <section class="results-section">
                                <h2 class="section-title">
                                    Entrenadores (
                                    {coachResultsWithImages.length})
                                </h2>
                                <div class="results-grid">
                                    {coachResultsWithImages.map((result) => (
                                        <a
                                            href={result.url}
                                            class="result-card"
                                        >
                                            {result.image && (
                                                <div class="result-image-container player-image">
                                                    <img
                                                        src={result.image.src}
                                                        alt={result.title}
                                                        width="60"
                                                        height="60"
                                                        class="result-image"
                                                    />
                                                </div>
                                            )}
                                            <div class="result-info">
                                                <h3 class="result-title">
                                                    {result.title}
                                                </h3>
                                                <p class="result-subtitle">
                                                    {result.subtitle}
                                                </p>
                                            </div>
                                        </a>
                                    ))}
                                </div>
                            </section>
                        )}

                        {matchResults.length > 0 && (
                            <section class="results-section">
                                <h2 class="section-title">
                                    Partidos ({matchResults.length})
                                </h2>
                                <div class="results-grid">
                                    {matchResults.map((result) => (
                                        <a
                                            href={result.url}
                                            class="result-card"
                                        >
                                            <div class="result-info">
                                                <h3 class="result-title">
                                                    {result.title}
                                                </h3>
                                                <p class="result-subtitle">
                                                    {result.subtitle}
                                                </p>
                                            </div>
                                        </a>
                                    ))}
                                </div>
                            </section>
                        )}
                    </div>
                )
            }
        </div>
    </div>
</Layout>

<style>
    .search-page {
        min-height: 100vh;
        background: #f5f5f5;
        padding: 2rem 1rem;
    }

    .search-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .page-title {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--negro, #333);
        margin-bottom: 2rem;
        text-align: center;
    }

    .search-box {
        background: white;
        padding: 2rem;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        margin-bottom: 2rem;
    }

    .search-form {
        display: flex;
        gap: 1rem;
        max-width: 800px;
        margin: 0 auto;
    }

    .search-input {
        flex: 1;
        padding: 1rem 1.5rem;
        border: 2px solid #ddd;
        border-radius: 8px;
        font-size: 1rem;
        transition: border-color 0.3s ease;
    }

    .search-input:focus {
        outline: none;
        border-color: #ffde59;
    }

    .search-button {
        padding: 1rem 2rem;
        background: #ffde59;
        color: #2b2b2b;
        border: none;
        border-radius: 8px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        text-transform: uppercase;
        font-size: 0.9rem;
    }

    .search-button:hover {
        background: #2b2b2b;
        color: #ffffff;
    }

    .search-results {
        background: white;
        padding: 2rem;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        margin-bottom: 2rem;
    }

    .results-summary {
        margin-bottom: 2rem;
        padding: 1rem;
        background: #f9f9f9;
        border-left: 4px solid #ffde59;
        border-radius: 4px;
    }

    .no-results {
        text-align: center;
        padding: 3rem;
        color: #666;
    }

    .no-results strong {
        color: #333;
    }

    .suggestion {
        margin-top: 1rem;
        font-size: 0.9rem;
        color: #999;
    }

    .error-message {
        padding: 1rem;
        background: #fee;
        color: #c33;
        border-radius: 8px;
        text-align: center;
    }

    .results-section {
        margin-bottom: 3rem;
    }

    .results-section:last-child {
        margin-bottom: 0;
    }

    .section-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 1.5rem;
        padding-left: 1rem;
        border-left: 4px solid #ffde59;
    }

    .results-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }

    .result-card {
        background: white;
        padding: 1.5rem;
        border-radius: 8px;
        border: 2px solid #eee;
        text-decoration: none;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .result-card:hover {
        border-color: #ffde59;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(255, 222, 89, 0.3);
    }

    .result-image-container {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .player-image .result-image {
        border-radius: 50%;
        object-fit: cover;
    }

    .result-image {
        max-width: 100%;
        max-height: 100%;
        width: auto;
        height: auto;
    }

    .result-info {
        flex: 1;
    }

    .result-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #2b2b2b;
        margin-bottom: 0.5rem;
        line-height: 1.2;
    }

    .result-subtitle {
        font-size: 0.9rem;
        color: #666;
        margin: 0;
    }

    @media (max-width: 768px) {
        .search-form {
            flex-direction: column;
        }

        .results-grid {
            grid-template-columns: 1fr;
        }

        .page-title {
            font-size: 2rem;
        }
    }
</style>
