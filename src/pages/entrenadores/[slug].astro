---
import Layout from "../../layouts/Layout.astro";
import {
    fetchCoachesDirectly,
    fetchCoachStats,
    fetchCoachTrajectory,
} from "../../utils/entrenadores";
import { fetchCoachRecords } from "../../utils/coach-records";
import { fetchCoachStreaks } from "../../utils/coach-streaks";

import { getAssetMetadata, getAssetUrl } from "../../utils/assets";

const competitionLogos: Record<string, any> = {
    "Liga F": getAssetMetadata("competiciones", "liga_f"),
    UWCL: getAssetMetadata("competiciones", "uwcl"),
    "Copa de la Reina": getAssetMetadata("competiciones", "copa_de_la_reina"),
    "Supercopa de España": getAssetMetadata(
        "competiciones",
        "supercopa_de_espana",
    ),
};

const { slug } = Astro.params;

const allCoaches = await fetchCoachesDirectly();
const coach = allCoaches.find(
    (c) =>
        c.slug.toLowerCase() === slug?.toLowerCase() ||
        c.id?.toLowerCase() === slug?.toLowerCase(),
);

if (!coach) {
    return Astro.redirect("/404");
}

const coachStats = await fetchCoachStats(coach.id_entrenador);
const coachRecords = await fetchCoachRecords(coach.id_entrenador);
const coachStreaks = await fetchCoachStreaks(coach.id_entrenador);
const trajectory = await fetchCoachTrajectory(coach.id_entrenador);

const flagUrl = coach.flagUrl || "";

const formatDate = (dateString: string | null | undefined): string => {
    if (!dateString) return "-";
    try {
        const date = new Date(dateString.split("T")[0]);
        if (isNaN(date.getTime())) return "-";
        return date.toLocaleDateString("es-ES", {
            day: "2-digit",
            month: "2-digit",
            year: "numeric",
        });
    } catch {
        return "-";
    }
};

const fechaNacimiento = formatDate(coach.fecha_nacimiento);
---

<Layout
    title={`${coach.nombre} | Madrid Femenino Xtra`}
    description={`Perfil completo de ${coach.nombre}, entrenador del Real Madrid Femenino. Estadísticas, récords y trayectoria.`}
>
    <main class="coach-details-page">
        <a href="/entrenadores" class="back-link">
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Volver al resto de entrenadores
        </a>

        <div class="coach-grid-layout">
            <section class="ficha-section">
                <h2 class="section-header">Ficha de {coach.nombre}</h2>
                <div class="ficha-content">
                    <div class="player-photo-container">
                        <img
                            src={coach.imageUrl ||
                                getAssetUrl("entrenadores", "placeholder")}
                            alt={`Foto de ${coach.nombre}`}
                            class="player-photo"
                        />
                    </div>
                    <div class="player-info">
                        <div class="info-row">
                            <span class="info-label">Nombre completo:</span>
                            <span class="info-value">{coach.nombre}</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Fecha de nacimiento:</span>
                            <span class="info-value">{fechaNacimiento}</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Lugar de nacimiento:</span>
                            <span class="info-value">{coach.ciudad || "-"}</span
                            >
                        </div>
                        <div class="info-row">
                            <span class="info-label">Nacionalidad:</span>
                            <span class="info-value">
                                {coach.pais || "-"}
                                {
                                    flagUrl && (
                                        <img
                                            src={flagUrl}
                                            alt={`Bandera de ${coach.pais}`}
                                            class="country-flag"
                                        />
                                    )
                                }
                            </span>
                        </div>
                    </div>
                </div>
            </section>

            <section class="teams-card">
                <h2 class="section-header">TRAYECTORIA</h2>
                <div class="teams-content">
                    {
                        trajectory && trajectory.length > 0 ? (
                            <div class="trajectory-timeline">
                                {trajectory.map((item) => (
                                    <div class="timeline-item">
                                        <div class="timeline-marker" />
                                        <div class="timeline-content">
                                            <div class="timeline-years">
                                                {item.anio_inicio} -{" "}
                                                {item.anio_fin || "Act."}
                                            </div>
                                            <div class="timeline-club">
                                                {item.club}
                                            </div>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        ) : (
                            <p class="no-data">Sin datos disponibles</p>
                        )
                    }
                </div>
            </section>

            <section class="records-card">
                <h2 class="section-header">RÉCORDS</h2>
                <div class="records-list">
                    {
                        coachRecords ? (
                            <div class="records-grid">
                                {coachRecords.mas_partido && (
                                    <div class="record-item">
                                        <span class="record-label">
                                            Más partidos:
                                        </span>
                                        <span class="record-value">
                                            {coachRecords.mas_partido.rival} -{" "}
                                            {coachRecords.mas_partido.partidos}
                                        </span>
                                    </div>
                                )}
                                {coachRecords.mas_victorias && (
                                    <div class="record-item">
                                        <span class="record-label">
                                            Más victorias:
                                        </span>
                                        <span class="record-value">
                                            {coachRecords.mas_victorias.rival} -{" "}
                                            {
                                                coachRecords.mas_victorias
                                                    .victorias
                                            }
                                        </span>
                                    </div>
                                )}
                                {coachRecords.mas_empates && (
                                    <div class="record-item">
                                        <span class="record-label">
                                            Más empates:
                                        </span>
                                        <span class="record-value">
                                            {coachRecords.mas_empates.rival} -{" "}
                                            {coachRecords.mas_empates.empates}
                                        </span>
                                    </div>
                                )}
                                {coachRecords.mayor_victoria && (
                                    <div class="record-item">
                                        <span class="record-label">
                                            Mayor victoria:
                                        </span>
                                        <span class="record-value">
                                            {
                                                coachRecords.mayor_victoria
                                                    .goles_rm
                                            }
                                            -
                                            {
                                                coachRecords.mayor_victoria
                                                    .goles_rival
                                            }{" "}
                                            vs{" "}
                                            {coachRecords.mayor_victoria.rival}
                                        </span>
                                    </div>
                                )}
                                {coachRecords.mayor_derrota && (
                                    <div class="record-item">
                                        <span class="record-label">
                                            Mayor derrota:
                                        </span>
                                        <span class="record-value">
                                            {
                                                coachRecords.mayor_derrota
                                                    .goles_rm
                                            }
                                            -
                                            {
                                                coachRecords.mayor_derrota
                                                    .goles_rival
                                            }{" "}
                                            vs{" "}
                                            {coachRecords.mayor_derrota.rival}
                                        </span>
                                    </div>
                                )}
                                {coachRecords.mas_repetido && (
                                    <div class="record-item">
                                        <span class="record-label">
                                            Más repetido:
                                        </span>
                                        <span class="record-value">
                                            {
                                                coachRecords.mas_repetido
                                                    .resultado
                                            }{" "}
                                            - {coachRecords.mas_repetido.veces}{" "}
                                            veces
                                        </span>
                                    </div>
                                )}
                            </div>
                        ) : (
                            <p class="no-data">Sin datos disponibles</p>
                        )
                    }
                </div>
            </section>

            <section class="streaks-card">
                <h2 class="section-header">RACHAS</h2>
                <div class="streaks-content">
                    {
                        coachStreaks ? (
                            <div class="streaks-list">
                                <div class="streak-item">
                                    <span class="streak-label">Ganando</span>
                                    <span class="streak-value">
                                        {coachStreaks.best.ganando}
                                    </span>
                                </div>
                                <div class="streak-item">
                                    <span class="streak-label">Empatando</span>
                                    <span class="streak-value">
                                        {coachStreaks.best.empatando}
                                    </span>
                                </div>
                                <div class="streak-item">
                                    <span class="streak-label">Perdiendo</span>
                                    <span class="streak-value">
                                        {coachStreaks.best.perdiendo}
                                    </span>
                                </div>
                                <div class="streak-item">
                                    <span class="streak-label">Sin perder</span>
                                    <span class="streak-value">
                                        {coachStreaks.best.sin_perder}
                                    </span>
                                </div>
                                <div class="streak-item">
                                    <span class="streak-label">Sin ganar</span>
                                    <span class="streak-value">
                                        {coachStreaks.best.sin_ganar}
                                    </span>
                                </div>
                                <div class="streak-item">
                                    <span class="streak-label">Sin marcar</span>
                                    <span class="streak-value">
                                        {coachStreaks.best.sin_marcar}
                                    </span>
                                </div>
                                <div class="streak-item">
                                    <span class="streak-label">Marcando</span>
                                    <span class="streak-value">
                                        {coachStreaks.best.marcando}
                                    </span>
                                </div>
                                <div class="streak-item">
                                    <span class="streak-label">Encajando</span>
                                    <span class="streak-value">
                                        {coachStreaks.best.encajando}
                                    </span>
                                </div>
                                <div class="streak-item">
                                    <span class="streak-label">
                                        Sin encajar
                                    </span>
                                    <span class="streak-value">
                                        {coachStreaks.best.sin_encajar}
                                    </span>
                                </div>
                                <div class="streak-item">
                                    <span class="streak-label">Sin goles</span>
                                    <span class="streak-value">
                                        {coachStreaks.best.sin_goles}
                                    </span>
                                </div>
                            </div>
                        ) : (
                            <p class="no-data">Sin datos disponibles</p>
                        )
                    }
                </div>
            </section>

            <section class="stats-card full-width">
                <h2 class="section-header">ESTADÍSTICAS</h2>
                <div class="table-wrapper">
                    {
                        coachStats &&
                        coachStats.estadisticas &&
                        coachStats.estadisticas.length > 0 ? (
                            <table class="stats-table">
                                <thead>
                                    <tr>
                                        <th>Temporada</th>
                                        <th title="Partidos">PJ</th>
                                        <th title="Victorias">V</th>
                                        <th title="% Victorias">%V</th>
                                        <th title="Empates">E</th>
                                        <th title="% Empates">%E</th>
                                        <th title="Derrotas">D</th>
                                        <th title="% Derrotas">%D</th>
                                        <th title="Goles a Favor">GF</th>
                                        <th title="Goles en Contra">GC</th>
                                        <th title="Diferencia">Dif</th>
                                        <th title="Porterías a Cero">PC</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {coachStats.estadisticas.map(
                                        (season: any) => (
                                            <>
                                                <tr
                                                    class="season-total-row clickable"
                                                    data-season={season.temporada.replace(
                                                        /\//g,
                                                        "-",
                                                    )}
                                                >
                                                    <td>
                                                        <strong>
                                                            {season.temporada}
                                                        </strong>
                                                        <span class="toggle-icon">
                                                            &#9660;
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {
                                                                season.total
                                                                    .partidos
                                                            }
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {
                                                                season.total
                                                                    .victorias
                                                            }
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {
                                                                season.total
                                                                    .porcentaje_victorias
                                                            }
                                                            %
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {
                                                                season.total
                                                                    .empates
                                                            }
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {
                                                                season.total
                                                                    .porcentaje_empates
                                                            }
                                                            %
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {
                                                                season.total
                                                                    .derrotas
                                                            }
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {
                                                                season.total
                                                                    .porcentaje_derrotas
                                                            }
                                                            %
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {
                                                                season.total
                                                                    .goles_favor
                                                            }
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {
                                                                season.total
                                                                    .goles_contra
                                                            }
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {season.total
                                                                .goles_favor -
                                                                season.total
                                                                    .goles_contra}
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {
                                                                season.total
                                                                    .porterias_cero
                                                            }
                                                        </strong>
                                                    </td>
                                                </tr>

                                                {season.competiciones.map(
                                                    (comp: any) => (
                                                        <tr
                                                            class={`competition-row season-${season.temporada.replace(/\//g, "-")}`}
                                                            style="display: none;"
                                                        >
                                                            <td class="competition-name">
                                                                {competitionLogos[
                                                                    comp
                                                                        .competicion
                                                                ] && (
                                                                    <img
                                                                        src={
                                                                            competitionLogos[
                                                                                comp
                                                                                    .competicion
                                                                            ]
                                                                                .src
                                                                        }
                                                                        alt={
                                                                            comp.competicion
                                                                        }
                                                                        class="competition-logo"
                                                                    />
                                                                )}
                                                                {
                                                                    comp.competicion
                                                                }
                                                            </td>
                                                            <td>
                                                                {comp.partidos}
                                                            </td>
                                                            <td>
                                                                {comp.victorias}
                                                            </td>
                                                            <td>
                                                                {
                                                                    comp.porcentaje_victorias
                                                                }
                                                                %
                                                            </td>
                                                            <td>
                                                                {comp.empates}
                                                            </td>
                                                            <td>
                                                                {
                                                                    comp.porcentaje_empates
                                                                }
                                                                %
                                                            </td>
                                                            <td>
                                                                {comp.derrotas}
                                                            </td>
                                                            <td>
                                                                {
                                                                    comp.porcentaje_derrotas
                                                                }
                                                                %
                                                            </td>
                                                            <td>
                                                                {
                                                                    comp.goles_favor
                                                                }
                                                            </td>
                                                            <td>
                                                                {
                                                                    comp.goles_contra
                                                                }
                                                            </td>
                                                            <td>
                                                                {comp.goles_favor -
                                                                    comp.goles_contra}
                                                            </td>
                                                            <td>
                                                                {
                                                                    comp.porterias_cero
                                                                }
                                                            </td>
                                                        </tr>
                                                    ),
                                                )}
                                            </>
                                        ),
                                    )}

                                    <tr class="career-total-row">
                                        <td>
                                            <strong>TOTAL</strong>
                                        </td>
                                        <td>
                                            <strong>
                                                {
                                                    coachStats.total_carrera
                                                        .partidos
                                                }
                                            </strong>
                                        </td>
                                        <td>
                                            <strong>
                                                {
                                                    coachStats.total_carrera
                                                        .victorias
                                                }
                                            </strong>
                                        </td>
                                        <td>
                                            <strong>
                                                {
                                                    coachStats.total_carrera
                                                        .porcentaje_victorias
                                                }
                                                %
                                            </strong>
                                        </td>
                                        <td>
                                            <strong>
                                                {
                                                    coachStats.total_carrera
                                                        .empates
                                                }
                                            </strong>
                                        </td>
                                        <td>
                                            <strong>
                                                {
                                                    coachStats.total_carrera
                                                        .porcentaje_empates
                                                }
                                                %
                                            </strong>
                                        </td>
                                        <td>
                                            <strong>
                                                {
                                                    coachStats.total_carrera
                                                        .derrotas
                                                }
                                            </strong>
                                        </td>
                                        <td>
                                            <strong>
                                                {
                                                    coachStats.total_carrera
                                                        .porcentaje_derrotas
                                                }
                                                %
                                            </strong>
                                        </td>
                                        <td>
                                            <strong>
                                                {
                                                    coachStats.total_carrera
                                                        .goles_favor
                                                }
                                            </strong>
                                        </td>
                                        <td>
                                            <strong>
                                                {
                                                    coachStats.total_carrera
                                                        .goles_contra
                                                }
                                            </strong>
                                        </td>
                                        <td>
                                            <strong>
                                                {coachStats.total_carrera
                                                    .goles_favor -
                                                    coachStats.total_carrera
                                                        .goles_contra}
                                            </strong>
                                        </td>
                                        <td>
                                            <strong>
                                                {
                                                    coachStats.total_carrera
                                                        .porterias_cero
                                                }
                                            </strong>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        ) : (
                            <table class="stats-table">
                                <thead>
                                    <tr>
                                        <th>Temporada</th>
                                        <th>PJ</th>
                                        <th>V</th>
                                        <th>E</th>
                                        <th>D</th>
                                        <th>GF</th>
                                        <th>GC</th>
                                        <th>Dif</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td colspan="8" class="no-data-cell">
                                            Sin datos disponibles
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        )
                    }
                </div>
            </section>
        </div>
    </main>

    <script is:inline>
        (function () {
            const seasonRows = document.querySelectorAll(
                ".season-total-row.clickable",
            );

            seasonRows.forEach((row) => {
                row.addEventListener("click", function () {
                    const season = this.getAttribute("data-season");
                    const competitionRows = document.querySelectorAll(
                        `.competition-row.season-${season}`,
                    );
                    const icon = this.querySelector(".toggle-icon");

                    competitionRows.forEach((compRow) => {
                        if (
                            compRow.style.display === "none" ||
                            compRow.style.display === ""
                        ) {
                            compRow.style.display = "table-row";
                        } else {
                            compRow.style.display = "none";
                        }
                    });

                    if (icon) {
                        icon.innerHTML =
                            icon.innerHTML.trim() === "▼" ? "▲" : "▼";
                    }
                });
            });
        })();
    </script>

    <style>
        .coach-details-page {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: #666;
            text-decoration: none;
            font-weight: 600;
            margin-bottom: 1.5rem;
            transition: color 0.3s;
        }

        .back-link:hover {
            color: #ffde59;
        }

        .coach-grid-layout {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 1.5rem;
        }

        .ficha-section {
            grid-column: 1 / -1;
            grid-row: 1;
        }

        .teams-card {
            grid-column: 1;
            grid-row: 2;
        }

        .records-card {
            grid-column: 2;
            grid-row: 2;
        }

        .streaks-card {
            grid-column: 3;
            grid-row: 2;
        }

        .stats-card {
            grid-column: 1 / -1;
            grid-row: 3;
        }

        .trajectory-timeline {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            position: relative;
            padding-left: 1.5rem;
            border-left: 2px solid #eee;
            margin-top: 1rem;
        }

        .timeline-item {
            position: relative;
        }

        .timeline-marker {
            position: absolute;
            left: -1.85rem;
            top: 0.4rem;
            width: 0.7rem;
            height: 0.7rem;
            background: #ffde59;
            border-radius: 50%;
            border: 2px solid white;
            box-shadow: 0 0 0 1px #eee;
        }

        .timeline-content {
            display: flex;
            flex-direction: column;
            gap: 0.2rem;
        }

        .timeline-years {
            font-size: 0.9rem;
            color: #666;
            font-weight: 500;
        }

        .timeline-club {
            font-weight: 700;
            font-size: 1rem;
            color: #333;
        }
        .section-header {
            background: #ffde59;
            color: #2b2b2b;
            padding: 1rem 1.25rem;
            margin: 0;
            font-size: 1.1rem;
            font-weight: bold;
            text-transform: uppercase;
        }

        .coach-card,
        .stats-card,
        .teams-card,
        .records-card {
            background: white;
            border: 1px solid #ddd;
            border-radius: 8px;
            overflow: hidden;
            height: 100%;
        }

        .full-width {
            width: 100%;
        }

        .ficha-section {
            background: white;
            border: 1px solid #ddd;
            border-radius: 8px;
            overflow: hidden;
            height: 100%;
        }

        .ficha-content {
            padding: 1.5rem;
            display: flex;
            gap: 1.5rem;
            align-items: stretch;
        }

        .player-photo-container {
            margin-bottom: 0;
            text-align: center;
            flex-shrink: 0;
            display: flex;
        }

        .player-photo {
            max-width: 280px;
            height: 100%;
            width: auto;
            object-fit: cover;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .player-info {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            flex: 1;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 0.5rem 0;
            border-bottom: 1px solid #eee;
        }

        .info-label {
            font-weight: 600;
            color: #333;
        }

        .info-value {
            color: #666;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .country-flag {
            width: 24px;
            height: 16px;
            object-fit: cover;
            border: 1px solid #ddd;
