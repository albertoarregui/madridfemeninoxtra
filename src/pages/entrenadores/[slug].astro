---
import Layout from "../../layouts/Layout.astro";
import { fetchCoachesDirectly } from "../../utils/entrenadores";

export async function getStaticPaths() {
    const allCoaches = await fetchCoachesDirectly();

    return allCoaches.map((coach) => ({
        params: { slug: coach.slug },
        props: { coach },
    }));
}

const { coach } = Astro.props;

const formatDate = (dateString: string | null | undefined): string => {
    if (!dateString) return "-";
    try {
        const date = new Date(dateString.split("T")[0]);
        if (isNaN(date.getTime())) return "-";
        return date.toLocaleDateString("es-ES", {
            day: "2-digit",
            month: "2-digit",
            year: "numeric",
        });
    } catch {
        return "-";
    }
};

const fechaNacimiento = formatDate(coach.fecha_nacimiento);
---

<Layout
    title={`${coach.nombre} - Entrenador | Madrid Femenino Xtra`}
    description={`Perfil completo de ${coach.nombre}, entrenador del Real Madrid Femenino. Estadísticas, récords y trayectoria.`}
>
    <main class="coach-details-page">
        <a href="/entrenadores" class="back-link">
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Volver al resto de entrenadores
        </a>

        <div class="coach-grid-layout">
            <!-- TOP: FICHA DE ENTRENADOR (Full Width) -->
            <section class="coach-card full-width">
                <h2 class="section-header">
                    Ficha de entrenador: {coach.nombre}
                </h2>
                <div class="coach-info">
                    <div class="coach-photo">
                        <img
                            src={coach.imageUrl}
                            alt={`Foto de ${coach.nombre}`}
                            onerror="this.onerror=null; this.src='/images/placeholder.png';"
                        />
                    </div>
                    <div class="coach-details">
                        <div class="info-row">
                            <span class="label">Nombre completo:</span>
                            <span class="value">{coach.nombre}</span>
                        </div>
                        <div class="info-row">
                            <span class="label">Fecha de nacimiento:</span>
                            <span class="value">{fechaNacimiento}</span>
                        </div>
                        <div class="info-row">
                            <span class="label">Lugar de nacimiento:</span>
                            <span class="value"
                                >{coach.ciudad || "-"} ({
                                    coach.pais || "-"
                                })</span
                            >
                        </div>
                        <div class="info-row">
                            <span class="label">Nacionalidad:</span>
                            <span class="value"
                                >{coach.pais || "-"}
                                {coach.pais === "España" ? "🇪🇸" : ""}</span
                            >
                        </div>
                    </div>
                </div>
            </section>

            <!-- MIDDLE: TRAYECTORIA (Left) & RECORDS (Right) -->
            <div class="middle-section">
                <!-- TRAYECTORIA -->
                <section class="teams-card">
                    <h2 class="section-header">TRAYECTORIA</h2>
                    <div class="teams-content">
                        <p class="no-data">Sin datos disponibles</p>
                    </div>
                </section>

                <!-- RECORDS -->
                <section class="records-card">
                    <h2 class="section-header">RÉCORDS</h2>
                    <div class="records-list">
                        <p class="no-data">Sin datos disponibles</p>
                    </div>
                </section>
            </div>

            <!-- BOTTOM: ESTADÍSTICAS (Full Width) -->
            <section class="stats-card full-width">
                <h2 class="section-header">ESTADÍSTICAS</h2>
                <div class="table-wrapper">
                    <table class="stats-table">
                        <thead>
                            <tr>
                                <th>Temporada</th>
                                <th>PJ</th>
                                <th>PG</th>
                                <th>%PG</th>
                                <th>PE</th>
                                <th>%PE</th>
                                <th>PP</th>
                                <th>%PP</th>
                                <th>GF</th>
                                <th>GC</th>
                                <th>Dif</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="11" class="no-data-cell"
                                    >Sin datos disponibles</td
                                >
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </main>

    <style>
        .coach-details-page {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: #666;
            text-decoration: none;
            font-weight: 600;
            margin-bottom: 1.5rem;
            transition: color 0.3s;
        }

        .back-link:hover {
            color: #ffde59;
        }

        .coach-grid-layout {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .middle-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }

        .section-header {
            background: #ffde59;
            color: #2b2b2b;
            padding: 0.75rem 1rem;
            margin: 0;
            font-size: 1rem;
            font-weight: bold;
            text-transform: uppercase;
        }

        /* CARDS */
        .coach-card,
        .stats-card,
        .teams-card,
        .records-card {
            background: white;
            border: 1px solid #ddd;
            border-radius: 8px;
            overflow: hidden;
        }

        .full-width {
            width: 100%;
        }

        /* COACH INFO */
        .coach-info {
            padding: 1.5rem;
            display: flex;
            gap: 1.5rem;
        }

        .coach-photo {
            flex-shrink: 0;
        }

        .coach-photo img {
            width: 150px;
            height: 200px;
            object-fit: cover;
            border-radius: 8px;
        }

        .coach-details {
            flex: 1;
        }

        .info-row {
            display: flex;
            padding: 0.5rem 0;
            border-bottom: 1px solid #eee;
        }

        .info-row .label {
            font-weight: 600;
            width: 180px;
        }

        .info-row .value {
            flex: 1;
        }

        /* CONTENT PADDING */
        .teams-content,
        .records-list {
            padding: 1.5rem;
        }

        .no-data {
            color: #999;
            font-style: italic;
            text-align: center;
            padding: 2rem;
            margin: 0;
        }

        .no-data-cell {
            text-align: center;
            padding: 2rem;
            color: #999;
            font-style: italic;
        }

        /* STATS TABLE */
        .table-wrapper {
            overflow-x: auto;
        }

        .stats-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }

        .stats-table th,
        .stats-table td {
            padding: 0.75rem 0.5rem;
            text-align: center;
            border: 1px solid #ddd;
        }

        .stats-table th {
            background: #333;
            color: white;
            font-weight: 600;
        }

        .stats-table tbody tr:nth-child(odd) {
            background: #fff5e6;
        }

        @media (max-width: 1024px) {
            .middle-section {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .coach-info {
                flex-direction: column;
            }

            .coach-photo img {
                width: 100%;
                max-width: 200px;
                margin: 0 auto;
            }

            .info-row {
                flex-direction: column;
            }

            .info-row .label {
                width: 100%;
                margin-bottom: 0.25rem;
            }
        }
    </style>
</Layout>
