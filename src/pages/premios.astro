---
import Layout from '../layouts/Layout.astro';
import { fetchPlayersDirectly, getPlayerImageUrl } from '../utils/players';

const allPlayers = await fetchPlayersDirectly();
const allSeasons  = allPlayers.flatMap((p: any) => p.temporadas || []);
const latestSeason = [...new Set(allSeasons)].sort().reverse()[0] as string;

const squadPlayers = allPlayers.filter((p: any) => {
    const d = p.dorsales?.[latestSeason];
    return d !== undefined && Number(d) >= 1 && Number(d) <= 24;
});

function getNormPos(pos: string): string {
    const p = (pos || '').toLowerCase();
    if (p.includes('portera')) return 'portera';
    if (p.includes('defensa') || p.includes('lateral') || p.includes('central')) return 'defensa';
    if (p.includes('medio') || p.includes('centro') || p.includes('pivote') || p.includes('interior')) return 'centrocampista';
    if (p.includes('delantera') || p.includes('extremo') || p.includes('punta') || p.includes('ariete')) return 'delantera';
    return 'otros';
}

const players = squadPlayers.map((p: any) => {
    const profilePhoto = p.profile_photos?.[latestSeason];
    const seasonPhoto  = p.season_photos?.[latestSeason];
    const birthYear    = p.fecha_nacimiento ? new Date(p.fecha_nacimiento).getFullYear() : 0;
    return {
        id:       String(p.id_jugadora),
        name:     p.nombre as string,
        slug:     p.slug as string,
        number:   String(p.dorsales[latestSeason] ?? ''),
        position: getNormPos(p.posicion || ''),
        imageUrl: getPlayerImageUrl({ ...p, foto_url: seasonPhoto || profilePhoto }),
        isU21:    birthYear >= 2004,
    };
}).sort((a: any, b: any) => Number(a.number) - Number(b.number));

const porteras        = players.filter((p: any) => p.position === 'portera');
const defensas        = players.filter((p: any) => p.position === 'defensa');
const centrocampistas = players.filter((p: any) => p.position === 'centrocampista');
const delanteras      = players.filter((p: any) => p.position === 'delantera');
const sub21Players    = players.filter((p: any) => p.isU21);
const outfield        = players.filter((p: any) => p.position !== 'portera');

function norm(s: string) {
    return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
}

// Busca en ALL el DB (no solo temporada actual) y construye el objeto jugadora
function findAnyPlayer(name: string): any | null {
    const needle = norm(name.split(' ').pop()!);
    // 1. Buscar en el squad de temporada (tienen foto actual)
    const fromSquad = players.find((p: any) => norm(p.name).includes(needle));
    if (fromSquad) return fromSquad;
    // 2. Buscar en todos los registros del DB (sin restricción de dorsal/temporada)
    const raw = allPlayers.find((p: any) => norm(p.nombre).includes(needle));
    if (!raw) return null;
    // Foto: intentar temporada actual, luego la más reciente disponible
    const seasons = Object.keys({ ...(raw.season_photos || {}), ...(raw.profile_photos || {}) }).sort().reverse();
    const bestSeason = seasons.find(s => raw.season_photos?.[s]) || seasons[0];
    const foto = raw.season_photos?.[bestSeason] || raw.profile_photos?.[bestSeason];
    return {
        id:       String(raw.id_jugadora),
        name:     raw.nombre as string,
        slug:     raw.slug as string,
        number:   String(raw.dorsales?.[latestSeason] ?? ''),
        position: getNormPos(raw.posicion || ''),
        imageUrl: getPlayerImageUrl({ ...raw, foto_url: foto }),
        isU21:    false,
    };
}

function byNames(names: string[]): any[] {
    return names.map(findAnyPlayer).filter(Boolean);
}

// Listas curatoriales
const mejorJugadoraList = byNames([
    'Misa Rodríguez', 'María Méndez', 'Eva Navarro', 'Caroline Weir', 'Linda Caicedo',
]);
const mejorFichajeList = byNames([
    'Merle Frohms', 'Sara Holmgaard', 'Bella Andersson', 'Sara Däbritz', 'Hanna Bennison', 'Lotte Keukelaar',
]);

// Sub-21: base + extras (sin duplicados)
const mejorSub21List = (() => {
    const ids = new Set(sub21Players.map((p: any) => p.id));
    const extras = byNames(['Silvia Cristóbal', 'Irune Dorado', 'Iris Ashley'])
        .filter((p: any) => !ids.has(p.id));
    return [...sub21Players, ...extras];
})();

// XI con jugadoras extra por posición (sin duplicados)
function mergeUnique(base: any[], names: string[]): any[] {
    const ids = new Set(base.map((p: any) => p.id));
    const extras = byNames(names).filter((p: any) => !ids.has(p.id));
    return [...base, ...extras];
}
const defensasXI        = mergeUnique(defensas,        ['Silvia Cristóbal']);
const centrocampistasXI = mergeUnique(centrocampistas, ['Irune Dorado']);
const delanterasXI      = mergeUnique(delanteras,      ['Iris Ashley']);

// Goals para "Mejor Gol" — mapping id_gol → video_id + info
const goalsData = [
    { id: '536', videoId: '8M8Z7OrDRcU', scorer: 'Sara Däbritz',   rival: 'Atlético de Madrid', date: 'Temporada 2025/26' },
    { id: '553', videoId: 'ZOljp2g2vUU', scorer: 'Caroline Weir',  rival: 'Arsenal',            date: 'Temporada 2025/26' },
    { id: '558', videoId: 'G93cBJD-ng0', scorer: 'María Méndez',   rival: 'Wolfsburgo',        date: 'Temporada 2025/26' },
    { id: '585', videoId: 'ozJVLFglRAs', scorer: 'Linda Caicedo',  rival: 'París FC',          date: 'Temporada 2025/26' },
    { id: '598', videoId: 'TKfpDbVdUGg', scorer: 'Linda Caicedo',  rival: 'París FC',          date: 'Temporada 2025/26' },
];
---

<Layout
    title="Premios Madrid Femenino Xtra 2025/26"
    description="Vota por las mejores jugadoras del Real Madrid Femenino de la temporada 2025/26."
    noindex={true}
>

<canvas id="particles-canvas" aria-hidden="true"></canvas>

<main class="premios-page">

    <!-- ══ HERO ══ -->
    <header class="premios-hero">
        <h1 class="premios-main-title">PREMIOS<br/>MADRID FEMENINO XTRA</h1>
        <p class="premios-subtitle">Vota por las mejores jugadoras del Real Madrid Femenino de la temporada 2025/26.</p>
    </header>

    <!-- ══ VOTING GATE ══ -->
    <div id="voting-gate" style="display:none">
        <div class="gate-box">
            <div class="gate-lock" id="gate-lock-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-lock"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 2a5 5 0 0 1 5 5v3a3 3 0 0 1 3 3v6a3 3 0 0 1 -3 3h-10a3 3 0 0 1 -3 -3v-6a3 3 0 0 1 3 -3v-3a5 5 0 0 1 5 -5m0 12a2 2 0 0 0 -1.995 1.85l-.005 .15a2 2 0 1 0 2 -2m0 -10a3 3 0 0 0 -3 3v3h6v-3a3 3 0 0 0 -3 -3"/></svg>
            </div>
            <p class="gate-label" id="gate-label">VOTACIONES CERRADAS</p>
            <div class="gate-countdown" id="gate-countdown" style="display:none">
                <div class="cd-unit"><span class="cd-num" id="cd-days">00</span><span class="cd-name">días</span></div>
                <span class="cd-sep">:</span>
                <div class="cd-unit"><span class="cd-num" id="cd-hours">00</span><span class="cd-name">horas</span></div>
                <span class="cd-sep">:</span>
                <div class="cd-unit"><span class="cd-num" id="cd-mins">00</span><span class="cd-name">min</span></div>
                <span class="cd-sep">:</span>
                <div class="cd-unit"><span class="cd-num" id="cd-secs">00</span><span class="cd-name">seg</span></div>
            </div>
        </div>
    </div>

    <div class="premios-body" id="premios-body">

        <!-- ── MEJOR JUGADORA ── -->
        <section class="award-section">
            <h2 class="award-title">MEJOR JUGADORA</h2>
            <p class="award-hint">Selecciona una jugadora · <span class="sel-count" data-for="mejor-jugadora">0 / 1</span></p>
            <div class="players-scroll">
                {mejorJugadoraList.map((p: any) => (
                    <button class="pcard" data-id={p.id} data-category="mejor-jugadora" title={p.name}>
                        <div class="pcard-photo"><img src={p.imageUrl} alt={p.name} loading="lazy" /></div>
                        <span class="pcard-name"><span class="pcard-fname">{p.name.split(' ')[0]}</span><span class="pcard-lname">{p.name.split(' ').slice(1).join(' ')}</span></span>
                        <span class="pcard-check">✓</span>
                    </button>
                ))}
            </div>
        </section>

        <!-- ── MEJOR FICHAJE ── -->
        <section class="award-section">
            <h2 class="award-title">MEJOR FICHAJE</h2>
            <p class="award-hint">Selecciona una jugadora · <span class="sel-count" data-for="mejor-fichaje">0 / 1</span></p>
            <div class="players-scroll">
                {mejorFichajeList.map((p: any) => (
                    <button class="pcard" data-id={p.id} data-category="mejor-fichaje" title={p.name}>
                        <div class="pcard-photo"><img src={p.imageUrl} alt={p.name} loading="lazy" /></div>
                        <span class="pcard-name"><span class="pcard-fname">{p.name.split(' ')[0]}</span><span class="pcard-lname">{p.name.split(' ').slice(1).join(' ')}</span></span>
                        <span class="pcard-check">✓</span>
                    </button>
                ))}
            </div>
        </section>

        <!-- ── MEJOR SUB-21 ── -->
        <section class="award-section">
            <h2 class="award-title">MEJOR JUGADORA SUB-21</h2>
            <p class="award-hint">Selecciona una jugadora · <span class="sel-count" data-for="mejor-sub21">0 / 1</span></p>
            <div class="players-scroll">
                {mejorSub21List.length > 0
                    ? mejorSub21List.map((p: any) => (
                        <button class="pcard" data-id={p.id} data-category="mejor-sub21" title={p.name}>
                            <div class="pcard-photo"><img src={p.imageUrl} alt={p.name} loading="lazy" /></div>
                            <span class="pcard-name"><span class="pcard-fname">{p.name.split(' ')[0]}</span><span class="pcard-lname">{p.name.split(' ').slice(1).join(' ')}</span></span>
                            <span class="pcard-check">✓</span>
                        </button>
                    ))
                    : <p class="empty-msg">No hay jugadoras sub-21 en la plantilla actual.</p>
                }
            </div>
        </section>

        <!-- ── MEJOR GOL ── -->
        <section class="award-section">
            <h2 class="award-title">MEJOR GOL</h2>
            <p class="award-hint">¿Cuál fue el mejor gol de la temporada? · <span class="sel-count" data-for="mejor-gol">0 / 1</span></p>
            <div class="goals-scroll">
                {goalsData.map((goal: any) => (
                    <button class="goal-card" data-id={goal.id} data-category="mejor-gol" data-video-id={goal.videoId} title={`Gol de ${goal.scorer}`}>
                        <div class="goal-thumbnail">
                            <img src={`https://img.youtube.com/vi/${goal.videoId}/mqdefault.jpg`} alt={`Gol de ${goal.scorer}`} loading="lazy" />
                            <div class="play-overlay">
                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-player-play"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M6 4v16a1 1 0 0 0 1.524 .852l13 -8a1 1 0 0 0 0 -1.704l-13 -8a1 1 0 0 0 -1.524 .852z" /></svg>
                            </div>
                        </div>
                        <div class="goal-info">
                            <span class="goal-scorer">{goal.scorer}</span>
                            <span class="goal-rival">{goal.rival}</span>
                            <span class="goal-date">{goal.date}</span>
                        </div>
                        <span class="goal-check">✓</span>
                    </button>
                ))}
            </div>
        </section>

        <!-- ══ XI DE LA TEMPORADA ══ -->
        <section class="award-section xi-section">
            <h2 class="award-title">XI DE LA TEMPORADA</h2>
            <p class="award-hint">Elige tu once ideal de la temporada</p>

            <div class="formation-board">
                <div class="formation-rows">
                    <div class="formation-row">
                        {[0,1,2].map(i => <div class="form-slot empty" data-slot={`delantera-${i}`}><span>DEL</span></div>)}
                    </div>
                    <div class="formation-row">
                        {[0,1,2].map(i => <div class="form-slot empty" data-slot={`centrocampista-${i}`}><span>MED</span></div>)}
                    </div>
                    <div class="formation-row">
                        {[0,1,2,3].map(i => <div class="form-slot empty" data-slot={`defensa-${i}`}><span>DEF</span></div>)}
                    </div>
                    <div class="formation-row">
                        <div class="form-slot empty" data-slot="portera-0"><span>POR</span></div>
                    </div>
                </div>
            </div>

            {[
                { pos: 'portera',        label: 'PORTERA',         max: 1, list: porteras },
                { pos: 'defensa',        label: 'DEFENSAS',        max: 4, list: defensasXI },
                { pos: 'centrocampista', label: 'CENTROCAMPISTAS', max: 3, list: centrocampistasXI },
                { pos: 'delantera',      label: 'DELANTERAS',      max: 3, list: delanterasXI },
            ].map(({ pos, label, max, list }) => (
                <div class="xi-group">
                    <div class="xi-group-header">
                        <h3 class="xi-pos-label">{label}</h3>
                        <span class="xi-counter" data-xi-counter={pos}>0 / {max}</span>
                    </div>
                    <div class="players-scroll">
                        {list.map((p: any) => (
                            <button class="pcard pcard-xi" data-id={p.id} data-xi-pos={pos} data-xi-max={max} title={p.name}>
                                <div class="pcard-photo"><img src={p.imageUrl} alt={p.name} loading="lazy" /></div>
                                <span class="pcard-name"><span class="pcard-fname">{p.name.split(' ')[0]}</span><span class="pcard-lname">{p.name.split(' ').slice(1).join(' ')}</span></span>
                                <span class="pcard-check">✓</span>
                            </button>
                        ))}
                    </div>
                </div>
            ))}
        </section>

        <!-- SUBMIT -->
        <div class="premios-submit">
            <div class="submit-summary" id="submit-summary"></div>
            <button class="submit-btn" id="submit-btn" style="display:none">ENVIAR VOTOS</button>
            <button class="submit-btn login-btn" id="login-btn" data-action="signin-google" style="display:none">INICIA SESIÓN PARA VOTAR</button>
            <p class="submit-note" id="submit-note">Debes estar registrado para participar</p>
        </div>

    </div>
</main>

<!-- ── GOAL VIDEO MODAL ── -->
<div id="goal-modal" class="goal-modal" style="display:none">
    <div class="modal-backdrop"></div>
    <div class="modal-container">
        <button class="modal-close" id="modal-close" aria-label="Cerrar">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M18 6l-12 12"/><path d="M6 6l12 12"/></svg>
        </button>
        <div class="modal-content">
            <iframe id="goal-video" class="goal-video" width="100%" height="100%" src="" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        </div>
    </div>
</div>

</Layout>

<script is:inline define:vars={{ playersData: players }}>
(function () {

    function checkAuthAndUpdateUI() {
        if (window.Clerk && typeof window.Clerk.session !== 'undefined') {
            var isAuth = window.Clerk.session !== null;
        } else {
            var isAuth = document.cookie.indexOf('__session') !== -1;
        }

        var submitBtn = document.getElementById('submit-btn');
        var loginBtn = document.getElementById('login-btn');
        var submitNote = document.getElementById('submit-note');

        if (isAuth) {
            submitBtn.style.display = '';
            loginBtn.style.display = 'none';
            submitNote.textContent = 'Solo se contabilizará un voto por usuario';
        } else {
            submitBtn.style.display = 'none';
            loginBtn.style.display = '';
            submitNote.textContent = 'Debes estar registrado para participar';
        }
    }

    checkAuthAndUpdateUI();

    var VOTE_OPEN  = new Date('2026-05-11T10:00:00Z').getTime();
    var VOTE_CLOSE = new Date('2026-05-28T21:59:00Z').getTime();

    function pad2(n) { return String(n).padStart(2, '0'); }

    function updateGate() {
        var now   = Date.now();
        var gate  = document.getElementById('voting-gate');
        var body  = document.getElementById('premios-body');
        var label = document.getElementById('gate-label');
        var cd    = document.getElementById('gate-countdown');

        if (now >= VOTE_OPEN && now <= VOTE_CLOSE) {
            gate.style.display = 'none';
            body.style.display = '';
            return false;
        }

        gate.style.display = 'flex';
        body.style.display = 'none';

        if (now < VOTE_OPEN) {
            label.textContent = 'VOTACIONES ABIERTAS EN';
            cd.style.display  = 'flex';
            var diff = VOTE_OPEN - now;
            var days  = Math.floor(diff / 86400000);
            var hours = Math.floor((diff % 86400000) / 3600000);
            var mins  = Math.floor((diff % 3600000) / 60000);
            var secs  = Math.floor((diff % 60000) / 1000);
            document.getElementById('cd-days').textContent  = pad2(days);
            document.getElementById('cd-hours').textContent = pad2(hours);
            document.getElementById('cd-mins').textContent  = pad2(mins);
            document.getElementById('cd-secs').textContent  = pad2(secs);
        } else {
            label.textContent = 'VOTACIONES CERRADAS';
            cd.style.display  = 'none';
        }
        return true;
    }

    if (updateGate()) {
        var gateInterval = setInterval(function () {
            if (!updateGate()) clearInterval(gateInterval);
        }, 1000);
    }

    var canvas = document.getElementById('particles-canvas');
    var ctx = canvas.getContext('2d');

    function resizeCanvas() {
        canvas.width  = window.innerWidth;
        canvas.height = window.innerHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    var pts = Array.from({ length: 80 }, function () {
        return {
            x:          Math.random() * window.innerWidth,
            y:          Math.random() * window.innerHeight,
            r:          Math.random() * 2.8 + 0.6,
            speed:      Math.random() * 0.9 + 0.3,
            swing:      Math.random() * Math.PI * 2,
            swingSpeed: Math.random() * 0.022 + 0.004,
            opacity:    Math.random() * 0.6 + 0.15,
            isRect:     Math.random() > 0.45,
        };
    });

    function animateParticles() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        pts.forEach(function (p) {
            p.y     += p.speed;
            p.swing += p.swingSpeed;
            p.x     += Math.sin(p.swing) * 0.45;
            if (p.y > canvas.height + 12) { p.y = -12; p.x = Math.random() * canvas.width; }
            ctx.save();
            ctx.globalAlpha = p.opacity;
            ctx.fillStyle   = Math.random() > 0.35 ? '#ffde59' : '#b8860b';
            ctx.translate(p.x, p.y);
            ctx.rotate(p.swing * 1.5);
            if (p.isRect) {
                ctx.fillRect(-p.r * 1.8, -p.r * 0.5, p.r * 3.6, p.r);
            } else {
                ctx.beginPath();
                ctx.arc(0, 0, p.r, 0, Math.PI * 2);
                ctx.fill();
            }
            ctx.restore();
        });
        requestAnimationFrame(animateParticles);
    }
    animateParticles();


    var glitterDataUrl = (function () {
        var gc = document.createElement('canvas');
        gc.width = 200; gc.height = 200;
        var gx = gc.getContext('2d');
        var colors = ['#ffde59','#ffd700','#f0c040','#d4af37','#ffe87c','#c8960c','#ffb400'];
        for (var i = 0; i < 1800; i++) {
            var x = Math.random() * gc.width;
            var y = Math.pow(Math.random(), 1.4) * gc.height;
            var r = Math.random() * 2.2 + 0.3;
            var alpha = (1 - y / gc.height) * (Math.random() * 0.85 + 0.15);
            gx.save();
            gx.globalAlpha = Math.max(alpha, 0.06);
            gx.fillStyle = colors[Math.floor(Math.random() * colors.length)];
            if (Math.random() > 0.48) {
                gx.translate(x, y);
                gx.rotate(Math.random() * Math.PI);
                gx.fillRect(-r * 1.8, -r * 0.45, r * 3.6, r * 0.9);
            } else {
                gx.beginPath();
                gx.arc(x, y, r, 0, Math.PI * 2);
                gx.fill();
            }
            gx.restore();
        }
        return gc.toDataURL('image/png');
    })();

    function applyGlitter(el) {
        el.style.backgroundImage = 'url(' + glitterDataUrl + ')';
        el.style.backgroundSize  = 'cover';
    }

    document.querySelectorAll('.pcard-photo').forEach(applyGlitter);

    var SVG_LEFT  = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M15 6l-6 6l6 6"/></svg>';
    var SVG_RIGHT = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 6l6 6l-6 6"/></svg>';

    document.querySelectorAll('.players-scroll, .goals-scroll').forEach(function (scroll) {
        var wrapper = document.createElement('div');
        wrapper.className = 'scroll-wrapper';
        scroll.parentNode.insertBefore(wrapper, scroll);
        wrapper.appendChild(scroll);

        var btnL = document.createElement('button');
        btnL.className = 'scroll-arrow scroll-arrow-left';
        btnL.setAttribute('aria-label', 'Anterior');
        btnL.innerHTML = SVG_LEFT;

        var btnR = document.createElement('button');
        btnR.className = 'scroll-arrow scroll-arrow-right';
        btnR.setAttribute('aria-label', 'Siguiente');
        btnR.innerHTML = SVG_RIGHT;

        wrapper.insertBefore(btnL, scroll);
        wrapper.appendChild(btnR);

        var STEP = 320;
        btnL.addEventListener('click', function () { scroll.scrollBy({ left: -STEP, behavior: 'smooth' }); });
        btnR.addEventListener('click', function () { scroll.scrollBy({ left:  STEP, behavior: 'smooth' }); });

        function updateArrows() {
            var needsScroll = scroll.scrollWidth > scroll.clientWidth + 4;
            btnL.style.display = needsScroll ? 'flex' : 'none';
            btnR.style.display = needsScroll ? 'flex' : 'none';
            scroll.style.justifyContent = needsScroll ? 'flex-start' : 'center';
            if (needsScroll) {
                btnL.style.opacity = scroll.scrollLeft > 4 ? '1' : '0.25';
                btnR.style.opacity = scroll.scrollLeft < scroll.scrollWidth - scroll.clientWidth - 4 ? '1' : '0.25';
            }
        }
        updateArrows();
        scroll.addEventListener('scroll', updateArrows, { passive: true });
        window.addEventListener('resize', updateArrows, { passive: true });

        var isDown = false, startX = 0, startScrollLeft = 0;
        scroll.addEventListener('mousedown', function (e) {
            isDown = true;
            scroll.classList.add('dragging');
            startX = e.pageX - scroll.getBoundingClientRect().left;
            startScrollLeft = scroll.scrollLeft;
        });
        document.addEventListener('mouseup',   function () { isDown = false; scroll.classList.remove('dragging'); });
        scroll.addEventListener('mouseleave',  function () { isDown = false; scroll.classList.remove('dragging'); });
        scroll.addEventListener('mousemove',   function (e) {
            if (!isDown) return;
            e.preventDefault();
            var x    = e.pageX - scroll.getBoundingClientRect().left;
            var walk = (x - startX) * 1.4;
            scroll.scrollLeft = startScrollLeft - walk;
        });
    });

    var votes  = { 'mejor-jugadora': null, 'mejor-fichaje': null, 'mejor-sub21': null, 'mejor-gol': null };
    var xi     = { portera: [], defensa: [], centrocampista: [], delantera: [] };
    var xiMax  = { portera: 1, defensa: 4, centrocampista: 3, delantera: 3 };

    document.querySelectorAll('.pcard:not(.pcard-xi)').forEach(function (card) {
        card.addEventListener('click', function () {
            var cat = card.dataset.category;
            var id  = card.dataset.id;
            if (votes[cat] === id) {
                votes[cat] = null;
                card.classList.remove('selected');
            } else {
                if (votes[cat]) {
                    var prev = document.querySelector('.pcard[data-category="' + cat + '"][data-id="' + votes[cat] + '"]');
                    if (prev) prev.classList.remove('selected');
                }
                votes[cat] = id;
                card.classList.add('selected');
            }
            updateCount(cat);
            updateSummary();
        });
    });
    var modalEl = document.getElementById('goal-modal');
    var iframeEl = document.getElementById('goal-video');
    var modalCloseBtn = document.getElementById('modal-close');
    var isSelectingGoal = false;

    document.querySelectorAll('.goal-card').forEach(function (card) {
        card.addEventListener('click', function (e) {
            e.preventDefault();
            var cat = card.dataset.category;
            var id = card.dataset.id;
            var videoId = card.dataset.videoId;

            // Si hace doble click o en el play, abrir modal
            if (isSelectingGoal && votes[cat] === id) {
                // Doble click → abrir video modal
                iframeEl.src = 'https://www.youtube.com/embed/' + videoId + '?autoplay=1';
                modalEl.style.display = 'flex';
                isSelectingGoal = false;
                return;
            }

            // Primer click: seleccionar gol
            isSelectingGoal = votes[cat] === id;
            if (votes[cat] === id) {
                votes[cat] = null;
                card.classList.remove('selected');
                isSelectingGoal = false;
            } else {
                if (votes[cat]) {
                    var prev = document.querySelector('.goal-card[data-category="' + cat + '"][data-id="' + votes[cat] + '"]');
                    if (prev) prev.classList.remove('selected');
                }
                votes[cat] = id;
                card.classList.add('selected');
                isSelectingGoal = true;
            }
            updateCount(cat);
            updateSummary();
        });

        // Click en thumbnail: abrir modal
        var thumbnail = card.querySelector('.goal-thumbnail');
        if (thumbnail) {
            thumbnail.addEventListener('click', function (e) {
                e.stopPropagation();
                var videoId = card.dataset.videoId;
                iframeEl.src = 'https://www.youtube.com/embed/' + videoId + '?autoplay=1';
                modalEl.style.display = 'flex';
            });
        }
    });

    // Cerrar modal
    modalCloseBtn.addEventListener('click', function () {
        modalEl.style.display = 'none';
        iframeEl.src = '';
    });

    // Cerrar modal al hacer click en backdrop
    document.querySelector('.modal-backdrop').addEventListener('click', function () {
        modalEl.style.display = 'none';
        iframeEl.src = '';
    });

    // Cerrar modal con ESC
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && modalEl.style.display === 'flex') {
            modalEl.style.display = 'none';
            iframeEl.src = '';
        }
    });


    function updateCount(cat) {
        var el = document.querySelector('.sel-count[data-for="' + cat + '"]');
        if (!el) return;
        el.textContent = (votes[cat] ? '1' : '0') + ' / 1';
        el.style.color = votes[cat] ? '#4ade80' : '';
    }
    document.querySelectorAll('.pcard-xi').forEach(function (card) {
        card.addEventListener('click', function () {
            var pos = card.dataset.xiPos;
            var id  = card.dataset.id;
            var arr = xi[pos];
            var idx = arr.indexOf(id);
            if (idx > -1) {
                // Ya seleccionada → deseleccionar
                arr.splice(idx, 1);
                card.classList.remove('selected');
                rebuildFormSlots(pos);
            } else {
                if (arr.length >= xiMax[pos]) {
                    // Cupo lleno → quitar la más antigua y sustituir
                    var removedId = arr.shift();
                    var prevCard = document.querySelector('.pcard-xi[data-xi-pos="' + pos + '"][data-id="' + removedId + '"]');
                    if (prevCard) prevCard.classList.remove('selected');
                }
                arr.push(id);
                card.classList.add('selected');
                rebuildFormSlots(pos);
            }
            updateXiCounter(pos);
            updateSummary();
        });
    });

    function fillFormSlot(pos, idx, id) {
        var slot = document.querySelector('.form-slot[data-slot="' + pos + '-' + idx + '"]');
        if (!slot) return;
        var p = playersData.find(function (pl) { return pl.id === id; });
        // Si no está en playersData, buscar en las tarjetas XI (Silvia, Irune, Iris)
        if (!p) {
            var xiCard = document.querySelector('.pcard-xi[data-id="' + id + '"]');
            if (!xiCard) return;
            var nameSpan = xiCard.querySelector('.pcard-name');
            var photoDiv = xiCard.querySelector('.pcard-photo img');
            if (!nameSpan || !photoDiv) return;
            p = {
                name: nameSpan.textContent.trim(),
                imageUrl: photoDiv.src
            };
        }
        slot.classList.remove('empty');
        slot.innerHTML = '<div class="fs-img-wrap"><img src="' + p.imageUrl + '" alt="' + p.name + '" /></div><span>' + p.name + '</span>';
        var wrap = slot.querySelector('.fs-img-wrap');
        if (wrap) applyGlitter(wrap);
    }

    function rebuildFormSlots(pos) {
        var lbl = { portera: 'POR', defensa: 'DEF', centrocampista: 'MED', delantera: 'DEL' };
        document.querySelectorAll('.form-slot[data-slot^="' + pos + '-"]').forEach(function (slot, i) {
            var id = xi[pos][i];
            if (id) { fillFormSlot(pos, i, id); }
            else { slot.classList.add('empty'); slot.innerHTML = '<span>' + lbl[pos] + '</span>'; }
        });
    }

    function updateXiCounter(pos) {
        var el = document.querySelector('.xi-counter[data-xi-counter="' + pos + '"]');
        if (!el) return;
        var n = xi[pos].length;
        el.textContent = n + ' / ' + xiMax[pos];
        el.style.color = n === xiMax[pos] ? '#4ade80' : '';
    }

    var catLabels = { 'mejor-jugadora': 'Mejor Jugadora', 'mejor-fichaje': 'Mejor Fichaje', 'mejor-sub21': 'Mejor Sub-21', 'mejor-gol': 'Mejor Gol' };
    function updateSummary() {
        var el = document.getElementById('submit-summary');
        if (!el) return;
        var parts = [];
        Object.keys(votes).forEach(function (cat) {
            if (!votes[cat]) return;
            var p = playersData.find(function (pl) { return pl.id === votes[cat]; });
            if (p) parts.push('<span class="sum-item"><b>' + catLabels[cat] + ':</b> ' + p.name + '</span>');
        });
        var tot = xi.portera.length + xi.defensa.length + xi.centrocampista.length + xi.delantera.length;
        if (tot) parts.push('<span class="sum-item"><b>XI:</b> ' + tot + ' / 11</span>');
        el.innerHTML = parts.join('');
    }

    document.getElementById('submit-btn').addEventListener('click', async function () {
        var btn = document.getElementById('submit-btn');
        btn.disabled = true;
        btn.textContent = 'ENVIANDO...';

        try {
            var res = await fetch('/api/season-awards', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ votes: votes, xi: xi }),
            });

            if (res.ok) {
                localStorage.setItem('premios_mfx_2526', JSON.stringify({ votes: votes, xi: xi, ts: Date.now() }));
                btn.textContent = 'VOTO ENVIADO';
                btn.style.background = '#16a34a';
                btn.style.color = '#ffffff';
                btn.style.boxShadow = '0 4px 24px rgba(22,163,74,0.4)';
            } else {
                btn.textContent = 'ERROR — INTÉNTALO DE NUEVO';
                btn.style.background = '#dc2626';
                btn.style.color = '#ffffff';
                btn.disabled = false;
            }
        } catch (err) {
            btn.textContent = 'ERROR — INTÉNTALO DE NUEVO';
            btn.style.background = '#dc2626';
            btn.style.color = '#ffffff';
            btn.disabled = false;
        }
    });
    try {
        var saved = JSON.parse(localStorage.getItem('premios_mfx_2526') || 'null');
        if (saved) {
            Object.keys(saved.votes || {}).forEach(function (cat) {
                var id = saved.votes[cat]; if (!id) return;
                votes[cat] = id;
                // Try pcard first (regular awards)
                var c = document.querySelector('.pcard[data-category="' + cat + '"][data-id="' + id + '"]');
                // If not found and it's mejor-gol, try goal-card
                if (!c && cat === 'mejor-gol') c = document.querySelector('.goal-card[data-category="' + cat + '"][data-id="' + id + '"]');
                if (c) c.classList.add('selected');
                updateCount(cat);
            });
            Object.keys(saved.xi || {}).forEach(function (pos) {
                (saved.xi[pos] || []).forEach(function (id) {
                    xi[pos].push(id);
                    var c = document.querySelector('.pcard-xi[data-xi-pos="' + pos + '"][data-id="' + id + '"]');
                    if (c) c.classList.add('selected');
                    fillFormSlot(pos, xi[pos].length - 1, id);
                });
                updateXiCounter(pos);
            });
            updateSummary();
        }
    } catch (e) {}

})();
</script>

