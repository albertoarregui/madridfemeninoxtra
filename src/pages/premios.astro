---
import Layout from "../layouts/Layout.astro";
import CandidateCard from "../components/CandidateCard.astro";
import { SQUAD } from "../../public/consts/squad";
import { SQUAD as ACADEMY_SQUAD } from "../../public/consts/academy_players";
import "@fontsource/archivo-black";

// 1. Data Preparation
const goalkeepers = SQUAD.filter((p) => p.position === "Portera");
const defenders = SQUAD.filter(
    (p) =>
        p.position.toLowerCase().includes("defensa") ||
        p.position.toLowerCase().includes("lateral"),
);
const midfielders = SQUAD.filter((p) => p.position === "Centrocampista");
const forwards = SQUAD.filter(
    (p) =>
        p.position.toLowerCase().includes("delantera") ||
        p.position.toLowerCase().includes("extremo"),
);

// Define U23 (Born after Jan 1, 2002)
const u23Players = SQUAD.filter(
    (p) => new Date(p.date_birth).getFullYear() >= 2002,
);

// Manual Mock Data for other categories
const canteranas = [
    {
        name: "Laia Suárez",
        manualImage:
            "https://www.realmadrid.com/img/horizontal_940px/laia-suarez_1hp2764_chi_h_20240916053358.jpg",
        country: "es",
    },
    {
        name: "Bea Vélez",
        manualImage:
            "https://www.realmadrid.com/img/horizontal_940px/bea-velez_1hp2728_chi_h_20240916053401.jpg",
        country: "es",
    },
    {
        name: "Amaya García",
        manualImage:
            "https://www.realmadrid.com/img/horizontal_940px/amaya_1hp2956_chi_h_20240916053405.jpg",
        country: "es",
    },
    {
        name: "Iris Santiago",
        manualImage:
            "https://www.realmadrid.com/img/horizontal_940px/iris_1hp3022_chi_h_20240916053403.jpg",
        country: "es",
    },
    {
        name: "Noemi Bejarano",
        manualImage:
            "https://www.realmadrid.com/img/horizontal_940px/noemi_1hp2991_chi_h_20240916053400.jpg",
        country: "es",
    },
];

const goals = [
    {
        name: "Sara Däbritz vs Atlético",
        manualImage:
            "https://placehold.co/400x300/0a0e27/ffde59?text=Play+Video",
        country: "de",
    },
    {
        name: "Iris Ashley vs Athletic",
        manualImage:
            "https://placehold.co/400x300/0a0e27/ffde59?text=Play+Video",
        videoUrl: "https://x.com/realmadridfem/status/1878053176717959374?s=20",
        country: "es",
    },
    {
        name: "Linda Caicedo vs Wolfsburgo",
        manualImage:
            "https://placehold.co/400x300/0a0e27/ffde59?text=Play+Video",
        videoUrl: "https://x.com/realmadridfem/status/1998807422446821856?s=20",
        country: "co",
    },
];

const matches = [
    {
        name: "Real Madrid 4-0 Celtic",
        manualImage: "https://img2.rtve.es/i/?w=1600&i=1729193297372.jpg",
        country: "es",
    },
    {
        name: "Real Madrid 3-2 Chelsea",
        manualImage:
            "https://phantom-marca.unidadeditorial.es/1e3b699c278912803b9840228303866a/resize/828/f/jpg/assets/multimedia/imagenes/2024/11/02/17305712615438.jpg",
        country: "es",
    },
];

const signings = SQUAD.filter((p) =>
    [
        "merle_frohms",
        "maria_mendez",
        "sheila_garcia",
        "alba_redondo",
        "maelle_lakrar",
        "antonia_silva",
        "leupolz",
    ].includes(p.id),
);

const categories = [
    { title: "MEJOR JUGADORA (MVP)", candidates: SQUAD },
    { title: "JUGADORA REVELACIÓN", candidates: SQUAD },
    { title: "MEJOR JOVEN (U23)", candidates: u23Players },
    { title: "MEJOR CANTERANA", candidates: ACADEMY_SQUAD },
    { title: "MEJOR FICHAJE", candidates: signings },
    { title: "MEJOR PORTERA", candidates: goalkeepers },
    { title: "MEJOR DEFENSA", candidates: defenders },
    { title: "MEJOR CENTROCAMPISTA", candidates: midfielders },
    { title: "MEJOR DELANTERA", candidates: forwards },
    { title: "MEJOR GOL", candidates: goals },
    { title: "MEJOR PARTIDO", candidates: matches },
];
---

<Layout title="Premios de la Temporada | Madrid Femenino Xtra">
    <div class="awards-page">
        <header class="awards-header">
            <h1 class="gala-title">PREMIOS DE LA TEMPORADA</h1>
            <p class="gala-subtitle">VOTA A LAS MEJORES DEL AÑO</p>
        </header>

        <div class="categories-container">
            {
                categories.map((cat, index) => (
                    <section class="category-section">
                        <h2 class="category-title">
                            <span class="category-number">0{index + 1}</span>
                            {cat.title}
                        </h2>
                        <div class="scroll-container">
                            <button
                                class="scroll-btn left"
                                aria-label="Scroll Left"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="24"
                                    height="24"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="icon icon-tabler icons-tabler-outline icon-tabler-chevron-left"
                                >
                                    <>
                                        <path
                                            stroke="none"
                                            d="M0 0h24v24H0z"
                                            fill="none"
                                        />
                                        <path d="M15 6l-6 6l6 6" />
                                    </>
                                </svg>
                            </button>
                            <div class="scroll-wrapper">
                                <div class="candidates-row">
                                    {cat.candidates.map((candidate: any) => (
                                        <CandidateCard
                                            name={candidate.name}
                                            playerId={candidate.id}
                                            manualImage={candidate.manualImage}
                                            country={candidate.country}
                                            videoUrl={candidate.videoUrl}
                                        />
                                    ))}
                                </div>
                            </div>
                            <button
                                class="scroll-btn right"
                                aria-label="Scroll Right"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="24"
                                    height="24"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="icon icon-tabler icons-tabler-outline icon-tabler-chevron-right"
                                >
                                    <>
                                        <path
                                            stroke="none"
                                            d="M0 0h24v24H0z"
                                            fill="none"
                                        />
                                        <path d="M9 6l6 6l-6 6" />
                                    </>
                                </svg>
                            </button>
                        </div>
                    </section>
                ))
            }
        </div>

        <div class="voting-section">
            <div class="locked-message">
                <span class="lock-icon">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="icon icon-tabler icons-tabler-outline icon-tabler-lock"
                        ><path stroke="none" d="M0 0h24v24H0z" fill="none"
                        ></path><path
                            d="M5 13a2 2 0 0 1 2 -2h10a2 2 0 0 1 2 2v6a2 2 0 0 1 -2 2h-10a2 2 0 0 1 -2 -2v-6z"
                        ></path><path d="M11 16a1 1 0 1 0 2 0a1 1 0 0 0 -2 0"
                        ></path><path d="M8 11v-4a4 4 0 1 1 8 0v4"></path></svg
                    >
                </span>
                VOTACIONES PRÓXIMAMENTE
            </div>
            <button class="vote-button disabled" disabled>ENVIAR VOTOS</button>
        </div>

        <!-- Video Modal -->
        <div id="video-modal" class="video-modal" style="display: none;">
            <div class="modal-content" id="modal-content">
                <button class="close-btn" id="close-modal-btn">×</button>
                <div id="tweet-container"></div>
            </div>
        </div>
    </div>
    <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"
    ></script>
</Layout>

<style>
    :root {
        --awards-bg: #0a0e27;
        --awards-gold: #ffde59;
        --awards-gold-gradient: linear-gradient(
            135deg,
            #ffd700 0%,
            #ffed4e 50%,
            #ffd700 100%
        );
    }

    body {
        background-color: var(--awards-bg);
    }

    .awards-page {
        background-color: var(--awards-bg);
        color: white;
        min-height: 100vh;
        font-family: "Poppins", sans-serif;
    }

    .awards-header {
        text-align: center;
        padding: 3rem 1rem;
        /* integrated into page bg */
    }

    .gala-title {
        font-family: "Archivo Black", sans-serif;
        font-size: 2.5rem;
        text-transform: uppercase;
        color: var(--awards-gold); /* #ffde59 */
        letter-spacing: -1px;
        margin-bottom: 0.5rem;
        /* Removed gradient to match category numbers */
        text-shadow: 0 4px 25px rgba(255, 222, 89, 0.1); /* Reduced glow */
        opacity: 0.9;
    }

    .gala-subtitle {
        font-size: 1rem;
        color: #8892b0;
        letter-spacing: 0.2em;
        text-transform: uppercase;
    }

    .category-section {
        margin-bottom: 3.5rem;
        padding: 1rem 0;
    }

    .category-title {
        background: linear-gradient(
            90deg,
            rgba(255, 255, 255, 0.05) 0%,
            transparent 100%
        );
        color: #fff;
        padding: 0.75rem 1.5rem;
        font-size: 1.2rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        border-left: 4px solid var(--awards-gold);
        margin-left: 1rem;
        margin-right: 1rem;
    }

    .category-number {
        color: var(--awards-gold);
        font-family: "Archivo Black", sans-serif;
        margin-right: 1rem;
        font-size: 1.5rem;
        opacity: 0.7;
    }

    .scroll-container {
        position: relative;
        display: flex;
        align-items: center;
    }

    .scroll-wrapper {
        overflow-x: auto;
        padding: 0 1rem;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        padding-bottom: 20px; /* Space for hover effects */
        width: 100%;
        scroll-behavior: smooth; /* Native smooth scroll */
    }

    .scroll-wrapper::-webkit-scrollbar {
        display: none;
    }

    .scroll-btn {
        background: transparent;
        border: none;
        color: var(--awards-gold);
        width: 50px; /* Larger hit area */
        height: 100%; /* Full height of row? or just centered large icon */
        /* Let's keep it simple icon size but layout-wise centered */
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 10;
        transition: all 0.2s ease;
        flex-shrink: 0;
        opacity: 0.7;
    }

    .scroll-btn:hover {
        background: transparent;
        color: #fff;
        transform: scale(1.2);
        opacity: 1;
    }

    .scroll-btn svg {
        width: 48px; /* Larger arrows */
        height: 48px;
        filter: drop-shadow(
            0 2px 4px rgba(0, 0, 0, 0.5)
        ); /* Shadow for visibility */
    }

    .scroll-btn.left {
        /* position absolute if we want them floating over cards, but flex row is safer to avoid overlap */
        /* Let's try absolute to save space */
        position: absolute;
        left: 0;
        z-index: 20;
    }

    .scroll-btn.right {
        position: absolute;
        right: 0;
        z-index: 20;
    }

    @media (max-width: 768px) {
        .scroll-btn {
            display: none; /* Hide on mobile, touch scroll is better */
        }
    }

    .candidates-row {
        display: flex;
        gap: 1.25rem;
        min-width: min-content;
        padding-left: 0.5rem; /* Optical offset */
    }

    /* Voting Section - Static spacing */
    .voting-section {
        margin-top: 5rem;
        padding: 4rem 1.5rem;
        background: linear-gradient(
            to top,
            rgba(0, 0, 0, 0.4) 0%,
            transparent 100%
        );
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        text-align: center;
    }

    .locked-message {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #8892b0;
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .vote-button {
        width: 100%;
        max-width: 300px;
        padding: 1.2rem;
        font-weight: 800;
        text-transform: uppercase;
        border: none;
        border-radius: 50px;
        font-size: 1.1rem;
        letter-spacing: 1px;
    }

    .vote-button.disabled {
        background: #2a2f45;
        color: #555c7a;
        cursor: not-allowed;
        box-shadow: inset 0 2px 10px rgba(0, 0, 0, 0.2);
    }

    @media (max-width: 768px) {
        .gala-title {
            font-size: 2rem;
        }
    }

    /* Modal Styles */
    .video-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.9);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        backdrop-filter: blur(5px);
        padding: 1rem;
    }

    .video-modal.active {
        display: flex;
    }

    .modal-content {
        position: relative;
        width: 100%;
        max-width: 550px;
        min-height: 200px;
        background: transparent;
        display: flex;
        justify-content: center;
    }

    .close-btn {
        position: absolute;
        top: -50px;
        right: 0;
        background: none;
        border: none;
        color: white;
        font-size: 2.5rem;
        cursor: pointer;
        opacity: 0.8;
        transition: opacity 0.2s;
        z-index: 1010;
    }

    .close-btn:hover {
        opacity: 1;
    }
</style>

<script>
    // Modal Elements
    const modal = document.getElementById("video-modal");
    const closeBtn = document.getElementById("close-modal-btn");
    const container = document.getElementById("tweet-container");

    // Make function global
    window.openVideoModal = (url) => {
        if (!modal || !container) return;

        container.innerHTML = ""; // Clear previous

        // Create Tweet Embed structure
        const blockquote = document.createElement("blockquote");
        blockquote.className = "twitter-tweet";
        blockquote.setAttribute("data-theme", "dark");

        const link = document.createElement("a");
        link.href = url;
        link.textContent = "Loading video...";

        blockquote.appendChild(link);
        container.appendChild(blockquote);

        modal.classList.add("active");

        // Scan for widgets
        if (window.twttr && window.twttr.widgets) {
            window.twttr.widgets.load(container);
        }
    };

    window.closeVideoModal = () => {
        if (modal) {
            modal.classList.remove("active");
            if (container) container.innerHTML = ""; // Stop video playback
        }
    };

    if (closeBtn) {
        closeBtn.addEventListener("click", window.closeVideoModal);
    }

    if (modal) {
        modal.addEventListener("click", (e) => {
            if (e.target === modal) window.closeVideoModal();
        });
    }

    // Scroll Logic
    document.querySelectorAll(".scroll-container").forEach((container) => {
        const leftBtn = container.querySelector(".scroll-btn.left");
        const rightBtn = container.querySelector(".scroll-btn.right");
        const wrapper = container.querySelector(".scroll-wrapper");

        if (!leftBtn || !rightBtn || !wrapper) return;

        leftBtn.addEventListener("click", () => {
            wrapper.scrollBy({ left: -300, behavior: "smooth" });
        });

        rightBtn.addEventListener("click", () => {
            wrapper.scrollBy({ left: 300, behavior: "smooth" });
        });

        const checkScroll = () => {
            const hasOverflow = wrapper.scrollWidth > wrapper.clientWidth;
            const display = hasOverflow ? "flex" : "none";
            if (leftBtn instanceof HTMLElement) leftBtn.style.display = display;
            if (rightBtn instanceof HTMLElement)
                rightBtn.style.display = display;
        };

        checkScroll();
        window.addEventListener("resize", checkScroll);
        setTimeout(checkScroll, 500);
    });
</script>
