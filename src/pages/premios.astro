---
import { turso } from "../lib/turso";
import {
    SignInButton,
    SignedIn,
    SignedOut,
    UserButton,
} from "@clerk/astro/components";
import Layout from "../layouts/Layout.astro";
import CandidateCard from "../components/CandidateCard.astro";
import { SQUAD } from "../../public/consts/squad";
import { SQUAD as ACADEMY_SQUAD } from "../../public/consts/academy_players";
import "@fontsource/archivo-black";
import saraGoal from "../assets/awards/sara_goal.png";
import irisGoal from "../assets/awards/iris_goal.png";
import lindaGoal from "../assets/awards/linda_goal.png";
import matchEintracht from "../assets/awards/match_eintracht.png";
import matchWolfsburg from "../assets/awards/match_wolfsburg.png";
import celticShield from "../assets/escudos/celtic_fc.png";
import chelseaShield from "../assets/escudos/chelsea.png";
import eintrachtShield from "../assets/escudos/eintracht_de_frankfurt.png";
import wolfsburgShield from "../assets/escudos/wolfsburgo.png";

// 1. Data Preparation
const goalkeepers = SQUAD.filter((p) => p.position === "Portera");
const defenders = SQUAD.filter(
    (p) =>
        p.position.toLowerCase().includes("defensa") ||
        p.position.toLowerCase().includes("lateral"),
);
const midfielders = SQUAD.filter((p) => p.position === "Centrocampista");
const forwards = SQUAD.filter(
    (p) =>
        p.position.toLowerCase().includes("delantera") ||
        p.position.toLowerCase().includes("extremo"),
);

// Define U23 (Born after Jan 1, 2002)
const u23Players = SQUAD.filter(
    (p) => new Date(p.date_birth).getFullYear() >= 2002,
);

// Manual Mock Data for other categories
const canteranas = [
    {
        name: "Laia Suárez",
        manualImage:
            "https://www.realmadrid.com/img/horizontal_940px/laia-suarez_1hp2764_chi_h_20240916053358.jpg",
        country: "es",
    },
    {
        name: "Bea Vélez",
        manualImage:
            "https://www.realmadrid.com/img/horizontal_940px/bea-velez_1hp2728_chi_h_20240916053401.jpg",
        country: "es",
    },
    {
        name: "Amaya García",
        manualImage:
            "https://www.realmadrid.com/img/horizontal_940px/amaya_1hp2956_chi_h_20240916053405.jpg",
        country: "es",
    },
    {
        name: "Iris Santiago",
        manualImage:
            "https://www.realmadrid.com/img/horizontal_940px/iris_1hp3022_chi_h_20240916053403.jpg",
        country: "es",
    },
    {
        name: "Noemi Bejarano",
        manualImage:
            "https://www.realmadrid.com/img/horizontal_940px/noemi_1hp2991_chi_h_20240916053400.jpg",
        country: "es",
    },
];

const goals = [
    {
        name: "Sara Däbritz vs Atlético",
        manualImage: saraGoal,
        videoUrl: "https://x.com/DAZN_ES/status/1964051942755156371?s=20",
        country: "de",
    },
    {
        name: "Iris Ashley vs Athletic",
        manualImage: irisGoal,
        videoUrl: "https://x.com/realmadridfem/status/1978053176717959374?s=20",
        country: "es",
        imageScale: 1.6,
        yOffset: -35,
    },
    {
        name: "Linda Caicedo vs Wolfsburgo",
        manualImage: lindaGoal,
        videoUrl:
            "https://www.youtube.com/watch?v=cnErspto5eE&pp=ygUcR29sIExpbmRhIENhaWNlZG8gV29sZnNidXJnbw%3D%3D",
        country: "co",
    },
];

const matches = [
    {
        name: "Real Madrid 3-0 Eintracht",
        manualImage: matchEintracht,
        icon: eintrachtShield,
        videoUrl: "https://www.youtube.com/watch?v=kLZ4Gv_IQ-A",
    },
    {
        name: "Real Madrid 2-0 Wolfsburgo",
        manualImage: matchWolfsburg,
        icon: wolfsburgShield,
        videoUrl: "https://www.youtube.com/watch?v=UrLHY6KvPdo",
    },
];

const signings = SQUAD.filter((p) =>
    [
        "merle_frohms",
        "maria_mendez",
        "sheila_garcia",
        "alba_redondo",
        "maelle_lakrar",
        "antonia_silva",
        "leupolz",
    ].includes(p.id),
);

const categories = [
    { id: "mvp", title: "MEJOR JUGADORA (MVP)", candidates: SQUAD },
    {
        id: "revelacion",
        title: "JUGADORA QUE MÁS HA MEJORADO",
        candidates: SQUAD,
    },
    { id: "u23", title: "MEJOR JOVEN (U23)", candidates: u23Players },
    { id: "cantera", title: "MEJOR CANTERANA", candidates: ACADEMY_SQUAD },
    { id: "fichaje", title: "MEJOR FICHAJE", candidates: signings },
    { id: "portera", title: "MEJOR PORTERA", candidates: goalkeepers },
    { id: "defensa", title: "MEJOR DEFENSA", candidates: defenders },
    {
        id: "centrocampista",
        title: "MEJOR CENTROCAMPISTA",
        candidates: midfielders,
    },
    { id: "delantera", title: "MEJOR DELANTERA", candidates: forwards },
    { id: "gol", title: "MEJOR GOL", candidates: goals },
    { id: "partido", title: "MEJOR PARTIDO", candidates: matches },
];

// Fetch User Votes
const { userId } = Astro.locals.auth();
let userVotes: any[] = [];

if (userId) {
    try {
        const result = await turso.execute({
            sql: "SELECT category_id, candidate_id FROM votes WHERE user_id = ?",
            args: [userId],
        });
        userVotes = result.rows;
    } catch (e) {
        console.error("Error fetching user votes", e);
    }
}
---

<Layout title="Premios de la Temporada | Madrid Femenino Xtra">
    <div class="awards-page">
        <header class="awards-header">
            <h1 class="gala-title">PREMIOS DE LA TEMPORADA</h1>
            <p class="gala-subtitle">VOTA A LAS MEJORES DEL AÑO</p>

            <div class="auth-header-controls">
                <SignedOut>
                    <SignInButton
                        mode="modal"
                        asChild
                        forceRedirectUrl="/premios"
                    >
                        <button class="header-login-btn"
                            >INICIAR SESIÓN PARA VOTAR</button
                        >
                    </SignInButton>
                </SignedOut>
                <SignedIn>
                    <div class="user-status">
                        <span class="user-greeting">Hola, Madridista</span>
                        <UserButton />
                    </div>
                </SignedIn>
            </div>
        </header>

        <div class="categories-container">
            {
                categories.map((cat, index) => (
                    <section class="category-section" data-category-id={cat.id}>
                        <h2 class="category-title">
                            <span class="category-number">{index + 1}</span>
                            {cat.title}
                        </h2>
                        <div class="scroll-container">
                            <button
                                class="scroll-btn left"
                                aria-label="Scroll Left"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="24"
                                    height="24"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="icon icon-tabler icons-tabler-outline icon-tabler-chevron-left"
                                >
                                    <>
                                        <path
                                            stroke="none"
                                            d="M0 0h24v24H0z"
                                            fill="none"
                                        />
                                        <path d="M15 6l-6 6l6 6" />
                                    </>
                                </svg>
                            </button>
                            <div class="scroll-wrapper">
                                <div class="candidates-row">
                                    {cat.candidates.map((candidate: any) => (
                                        <div
                                            class="candidate-wrapper"
                                            data-id={
                                                candidate.id || candidate.name
                                            }
                                            data-category={cat.id}
                                        >
                                            <CandidateCard
                                                name={candidate.name}
                                                playerId={candidate.id}
                                                manualImage={
                                                    candidate.manualImage
                                                }
                                                country={candidate.country}
                                                videoUrl={candidate.videoUrl}
                                                imageScale={
                                                    candidate.imageScale
                                                }
                                                icon={candidate.icon}
                                                yOffset={candidate.yOffset}
                                            />
                                        </div>
                                    ))}
                                </div>
                            </div>
                            <button
                                class="scroll-btn right"
                                aria-label="Scroll Right"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="24"
                                    height="24"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="icon icon-tabler icons-tabler-outline icon-tabler-chevron-right"
                                >
                                    <>
                                        <path
                                            stroke="none"
                                            d="M0 0h24v24H0z"
                                            fill="none"
                                        />
                                        <path d="M9 6l6 6l-6 6" />
                                    </>
                                </svg>
                            </button>
                        </div>
                    </section>
                ))
            }
        </div>

        <div class="voting-section">
            <SignedIn>
                <div
                    style="display: flex; flex-direction: column; align-items: center; gap: 1rem; margin-bottom: 1.5rem;"
                >
                    <span
                        style="color: rgba(255,255,255,0.6); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em;"
                        >Sesión iniciada</span
                    >
                    <UserButton />
                </div>
                <button
                    id="submit-votes-btn"
                    class="vote-button"
                    style="background: var(--awards-gold); color: black; cursor: pointer;"
                    >ENVIAR VOTOS</button
                >
            </SignedIn>
        </div>

        <!-- Video Modal -->
    </div>
    <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"
    ></script>
</Layout>

<style>
    :root {
        --awards-bg: #0a0e27;
        --awards-gold: #ffde59;
        --awards-gold-gradient: linear-gradient(
            135deg,
            #ffd700 0%,
            #ffed4e 50%,
            #ffd700 100%
        );
    }

    body {
        background-color: var(--awards-bg);
    }

    .awards-page {
        background-color: var(--awards-bg);
        color: white;
        min-height: 100vh;
        font-family: "Poppins", sans-serif;
    }

    .awards-header {
        text-align: center;
        padding: 3rem 1rem;
        /* integrated into page bg */
    }

    .gala-title {
        font-family: "Archivo Black", sans-serif;
        font-size: 2.5rem;
        text-transform: uppercase;
        color: var(--awards-gold); /* #ffde59 */
        letter-spacing: -1px;
        margin-bottom: 0.5rem;
        /* Removed gradient to match category numbers */
        text-shadow: 0 4px 25px rgba(255, 222, 89, 0.1); /* Reduced glow */
        opacity: 0.9;
    }

    .gala-subtitle {
        font-size: 1rem;
        color: #8892b0;
        letter-spacing: 0.2em;
        text-transform: uppercase;
    }

    .category-section {
        margin-bottom: 1rem;
        padding: 0;
    }

    .category-title {
        background: linear-gradient(
            90deg,
            rgba(255, 255, 255, 0.05) 0%,
            transparent 100%
        );
        color: #fff;
        padding: 0.75rem 1.5rem;
        font-size: 1.2rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.3rem; /* Reduced from 1.5rem */
        display: flex;
        align-items: center;
        border-left: 4px solid var(--awards-gold);
        margin-left: 1rem;
        margin-right: 1rem;
    }

    .category-number {
        color: var(--awards-gold);
        font-family: "Archivo Black", sans-serif;
        margin-right: 1rem;
        font-size: 1.5rem;
        opacity: 0.7;
    }

    .scroll-container {
        position: relative;
        display: flex;
        align-items: center;
    }

    .scroll-wrapper {
        overflow-x: auto;
        padding: 0 1rem;
        padding-top: 100px; /* Extra space for Scaled Images (1.6x) */
        margin-top: -60px; /* Pull closer to title */
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        padding-bottom: 10px; /* Minimal bottom space */
        width: 100%;
        scroll-behavior: smooth; /* Native smooth scroll */
    }

    .scroll-wrapper::-webkit-scrollbar {
        display: none;
    }

    .scroll-btn {
        background: transparent;
        border: none;
        color: var(--awards-gold);
        width: 50px; /* Larger hit area */
        height: 100%; /* Full height of row? or just centered large icon */
        /* Let's keep it simple icon size but layout-wise centered */
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 10;
        transition: all 0.2s ease;
        flex-shrink: 0;
        opacity: 0.7;
    }

    .scroll-btn:hover {
        background: transparent;
        color: #fff;
        transform: scale(1.2);
        opacity: 1;
    }

    .scroll-btn svg {
        width: 48px; /* Larger arrows */
        height: 48px;
        filter: drop-shadow(
            0 2px 4px rgba(0, 0, 0, 0.5)
        ); /* Shadow for visibility */
    }

    .scroll-btn.left {
        /* position absolute if we want them floating over cards, but flex row is safer to avoid overlap */
        /* Let's try absolute to save space */
        position: absolute;
        left: 0;
        z-index: 20;
    }

    .scroll-btn.right {
        position: absolute;
        right: 0;
        z-index: 20;
    }

    @media (max-width: 768px) {
        .scroll-btn {
            display: none; /* Hide on mobile, touch scroll is better */
        }
    }

    .candidates-row {
        display: flex;
        gap: 1.25rem;
        min-width: min-content;
        padding-left: 0.5rem; /* Optical offset */
    }

    /* Voting Section - Static spacing */
    .voting-section {
        margin-top: 5rem;
        padding: 4rem 1.5rem;
        background: linear-gradient(
            to top,
            rgba(0, 0, 0, 0.4) 0%,
            transparent 100%
        );
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        text-align: center;
    }

    .locked-message {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #8892b0;
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .vote-button {
        width: 100%;
        max-width: 300px;
        padding: 1.2rem;
        font-weight: 800;
        text-transform: uppercase;
        border: none;
        border-radius: 50px;
        font-size: 1.1rem;
        letter-spacing: 1px;
    }

    .vote-button.disabled {
        background: #2a2f45;
        color: #555c7a;
        cursor: not-allowed;
        box-shadow: inset 0 2px 10px rgba(0, 0, 0, 0.2);
    }

    @media (max-width: 768px) {
        .gala-title {
            font-size: 2rem;
        }
    }

    /* Modal Styles */
    .video-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.9);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        backdrop-filter: blur(5px);
        padding: 1rem;
    }

    .video-modal.active {
        display: flex;
    }

    .modal-content {
        position: relative;
        width: 100%;
        max-width: 550px;
        min-height: 200px;
        background: transparent;
        display: flex;
        justify-content: center;
    }

    .close-btn {
        position: absolute;
        top: -50px;
        right: 0;
        background: none;
        border: none;
        color: white;
        font-size: 2.5rem;
        cursor: pointer;
        opacity: 0.8;
        transition: opacity 0.2s;
        z-index: 1010;
    }

    .close-btn:hover {
        opacity: 1;
    }

    .header-login-btn {
        background: #ffde59;
        color: black;
        border: none;
        padding: 1rem 2.5rem;
        font-family: "Archivo Black", sans-serif;
        font-size: 1.1rem;
        cursor: pointer;
        clip-path: polygon(10% 0, 100% 0, 100% 100%, 0% 100%);
        transition: all 0.3s ease;
        text-transform: uppercase;
        box-shadow: 0 4px 15px rgba(255, 222, 89, 0.4);
        display: flex;
        align-items: center;
        gap: 10px;
        animation: pulse-gold 2s infinite;
    }

    .header-login-btn:hover {
        transform: scale(1.05) translateY(-2px);
        box-shadow: 0 6px 20px rgba(255, 222, 89, 0.6);
    }

    @keyframes pulse-gold {
        0% {
            box-shadow: 0 0 0 0 rgba(255, 222, 89, 0.4);
        }
        70% {
            box-shadow: 0 0 0 10px rgba(255, 222, 89, 0);
        }
        100% {
            box-shadow: 0 0 0 0 rgba(255, 222, 89, 0);
        }
    }
</style>

<script is:inline define:vars={{ initialVotes: userVotes }}>
    // Twitter Widgets JS Shim
    window.twttr = (function (d, s, id) {
        var js,
            fjs = d.getElementsByTagName(s)[0],
            t = window.twttr || {};
        if (d.getElementById(id)) return t;
        js = d.createElement(s);
        js.id = id;
        js.src = "https://platform.twitter.com/widgets.js";
        fjs.parentNode.insertBefore(js, fjs);
        t._e = [];
        t.ready = function (f) {
            t._e.push(f);
        };
        return t;
    })(document, "script", "twitter-wjs");

    document.addEventListener("DOMContentLoaded", () => {
        // --- 1. INITIALIZE VOTES ---
        const currentVotes = new Map(); // categoryId -> candidateId

        if (Array.isArray(initialVotes)) {
            console.log("Loading votes:", initialVotes);
            initialVotes.forEach((vote) => {
                const catId = vote.category_id || vote.categoryId;
                const candId = vote.candidate_id || vote.candidateId;
                if (catId && candId) {
                    currentVotes.set(catId, candId);
                    // Mark visually
                    const wrapper = document.querySelector(
                        `.candidate-wrapper[data-category="${catId}"][data-id="${candId}"]`,
                    );
                    if (wrapper) {
                        const card = wrapper.querySelector(".candidate-card");
                        if (card) card.classList.add("selected");
                    }
                }
            });
        }

        // --- 2. SELECTIONS ---
        document.querySelectorAll(".candidate-wrapper").forEach((wrapper) => {
            wrapper.addEventListener("click", (e) => {
                if (
                    e.target.closest("a") ||
                    e.target.closest("button") ||
                    e.target.closest(".play-icon-overlay")
                )
                    return;

                const categoryId = wrapper.dataset.category;
                const candidateId = wrapper.dataset.id;
                const card = wrapper.querySelector(".candidate-card");

                if (!categoryId || !candidateId || !card) return;

                const currentSelected = document.querySelector(
                    `.candidate-wrapper[data-category="${categoryId}"] .candidate-card.selected`,
                );
                if (currentSelected) {
                    currentSelected.classList.remove("selected");
                }

                if (currentSelected !== card) {
                    card.classList.add("selected");
                    currentVotes.set(categoryId, candidateId);
                } else {
                    currentVotes.delete(categoryId);
                }
            });
        });

        // --- 3. SUBMIT ---
        const submitBtn = document.getElementById("submit-votes-btn");
        if (submitBtn) {
            submitBtn.addEventListener("click", async () => {
                const votesArray = Array.from(currentVotes.entries()).map(
                    ([cat, cand]) => ({
                        categoryId: cat,
                        candidateId: cand,
                    }),
                );

                if (votesArray.length === 0) {
                    alert("Por favor, selecciona al menos un candidato.");
                    return;
                }

                const originalText = submitBtn.innerText;
                submitBtn.innerText = "ENVIANDO...";
                submitBtn.disabled = true;

                try {
                    const response = await fetch("/api/vote", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ votes: votesArray }),
                    });

                    if (response.ok) {
                        submitBtn.innerText = "¡VOTOS ENVIADOS!";
                        submitBtn.style.background = "#4ade80"; // Green
                        setTimeout(() => {
                            submitBtn.innerText = "VOTOS ACTUALIZADOS";
                            submitBtn.disabled = false;
                        }, 2000);
                    } else {
                        throw new Error("Error en el envío");
                    }
                } catch (error) {
                    console.error(error);
                    submitBtn.innerText = "ERROR - REINTENTAR";
                    submitBtn.disabled = false;
                }
            });
        }

        // --- 4. MODAL & SCROLL ---
        const modal = document.getElementById("video-modal");
        const container = document.getElementById("tweet-container");

        window.openVideoModal = (url) => {
            if (!modal || !container) return;
            container.innerHTML = `<div style="display:flex;justify-content:center;align-items:center;height:300px;color:white;">Cargando...</div>`;
            modal.style.display = "flex";
            setTimeout(() => modal.classList.add("active"), 10);
            if (window.twttr && window.twttr.widgets)
                window.twttr.widgets.load(container);
        };

        window.closeVideoModal = () => {
            if (modal) {
                modal.classList.remove("active");
                modal.style.display = "none";
                if (container) container.innerHTML = "";
            }
        };

        document.addEventListener("click", (e) => {
            const card = e.target.closest(".candidate-card[data-video-url]");
            if (card) {
                e.preventDefault();
                const url = card.getAttribute("data-video-url");
                if (url) window.openVideoModal(url);
            }
        });

        if (document.getElementById("close-modal-btn")) {
            document
                .getElementById("close-modal-btn")
                .addEventListener("click", (e) => {
                    e.stopPropagation();
                    window.closeVideoModal();
                });
        }
        if (modal)
            modal.addEventListener("click", (e) => {
                if (e.target === modal) window.closeVideoModal();
            });

        document.querySelectorAll(".scroll-container").forEach((container) => {
            const leftBtn = container.querySelector(".scroll-btn.left");
            const rightBtn = container.querySelector(".scroll-btn.right");
            const wrapper = container.querySelector(".scroll-wrapper");
            if (!leftBtn || !rightBtn || !wrapper) return;

            leftBtn.addEventListener("click", () =>
                wrapper.scrollBy({ left: -300, behavior: "smooth" }),
            );
            rightBtn.addEventListener("click", () =>
                wrapper.scrollBy({ left: 300, behavior: "smooth" }),
            );

            const checkScroll = () => {
                const hasOverflow = wrapper.scrollWidth > wrapper.clientWidth;
                const display = hasOverflow ? "flex" : "none";
                leftBtn.style.display = display;
                rightBtn.style.display = display;
            };
            checkScroll();
            window.addEventListener("resize", checkScroll);
        });
    });
</script>
