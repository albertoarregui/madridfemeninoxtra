import Layout from "../../layouts/Layout.astro";
import { turso } from "../../lib/turso";
import { CATEGORIES } from "../../consts/awards-data";

// Auth Logic
const ADMIN_PASSWORD = import.meta.env.ADMIN_PASSWORD;
const isConfigured = !!ADMIN_PASSWORD;
let isAuthenticated = false;
let loginError = "";

// Check Cookie
if (Astro.cookies.has("admin_auth")) {
    const cookieVal = Astro.cookies.get("admin_auth")?.value;
    if (cookieVal === ADMIN_PASSWORD) {
        isAuthenticated = true;
    }
}

// Handle Login POST
if (Astro.request.method === "POST") {
    try {
        const data = await Astro.request.formData();
        const password = data.get("password")?.toString();

        if (password && password === ADMIN_PASSWORD) {
            Astro.cookies.set("admin_auth", password, {
                path: "/",
                httpOnly: true,
                secure: true,
                maxAge: 60 * 60 * 24, // 1 day
            });
            isAuthenticated = true;
        } else {
            loginError = "Contraseña incorrecta";
        }
    } catch (e) {
        loginError = "Error al procesar solicitud";
    }
}

// Fetch Data if Authenticated
let voteStats: Record<string, Record<string, number>> = {};
let totalVotes = 0;

if (isAuthenticated) {
    try {
        const result = await turso.execute("SELECT * FROM votes");
        const votes = result.rows;
        totalVotes = votes.length;

        // Initialize Stats
        CATEGORIES.forEach(cat => {
            voteStats[cat.id] = {};
            cat.candidates.forEach((cand: any) => {
                const cId = cand.id || cand.name; // Logic matching premios.astro
                voteStats[cat.id][cId] = 0;
            });
        });

        // Count Votes
        votes.forEach((row: any) => {
            const catId = row.category_id as string;
            const candId = row.candidate_id as string;
            if (voteStats[catId]) {
                 if (voteStats[catId][candId] !== undefined) {
                    voteStats[catId][candId]++;
                 } else {
                    // Handle unknown candidate (maybe id changed?)
                    voteStats[catId][candId] = 1;
                 }
            }
        });

    } catch (e) {
        console.error("Error fetching admin stats", e);
    }
}
---

<Layout title="Admin Resultados | Madrid Femenino Xtra">
    <div class="admin-page">
        <div class="container">
            <h1 class="page-title">PANEL DE RESULTADOS</h1>

            {!isAuthenticated ? (
                <div class="login-card">
                    <h2>Acceso Restringido</h2>
                    <form method="POST">
                        <input 
                            type="password" 
                            name="password" 
                            placeholder="Contraseña de Administrador" 
                            required 
                        />
                        <button type="submit">ENTRAR</button>
                    </form>
                    {loginError && <p class="error">{loginError}</p>}
                    {!isConfigured && <p class="error" style="color: yellow;">⚠ Error de Servidor: Variable ADMIN_PASSWORD no encontrada.</p>}
                </div>
            ) : (
                <div class="dashboard">
                    </div>

                    <!-- PRONÓSTICOS SECTION -->
                    <div class="predictions-section">
                        <h2 class="section-title">⚽ CALCULAR PUNTOS DE PRONÓSTICOS</h2>
                        <div class="predictions-card">
                            <p class="instructions">
                                Cuando un partido finalice, actualiza el resultado en la base de datos y luego calcula los puntos aquí.
                            </p>
                            
                            <div class="calc-form">
                                <div class="form-group">
                                    <label>ID del Calendario (match_calendar_id)</label>
                                    <input 
                                        type="text" 
                                        id="match_calendar_id" 
                                        placeholder="real-madrid-vs-sevilla"
                                    />
                                    <small>Ejemplo: "real-madrid-vs-sevilla"</small>
                                </div>

                                <div class="form-group">
                                    <label>ID del Partido en BD (partido_id)</label>
                                    <input 
                                        type="number" 
                                        id="partido_id" 
                                        placeholder="123"
                                    />
                                    <small>ID numérico del partido en la tabla partidos</small>
                                </div>

                                <button id="calc-points-btn" class="calc-btn">
                                    CALCULAR PUNTOS
                                </button>

                                <div id="calc-result" class="calc-result"></div>
                            </div>
                        </div>
                    </div>

                    <!-- PREMIOS SECTION -->
                    <h2 class="section-title">🏆 RESULTADOS DE PREMIOS</h2>
                    <div class="summary-card">
                        <h3>Total Votos Registrados: <span class="highlight">{totalVotes}</span></h3>
                        <form method="POST" action="/api/logout-admin"> <!-- or just clear cookie button logic -->
                            <!-- simple reload effectively keeps logged in, logic to logout needs separate endpoint or just clear cookie in browser -->
                        </form>
                    </div>

                    <div class="charts-grid">
                        {CATEGORIES.map(category => (
                            <div class="category-card">
                                <h3>{category.title}</h3>
                                <canvas id={`chart-${category.id}`}></canvas>
                                <div class="stats-table-wrapper">
                                    <table class="stats-table">
                                        <thead>
                                            <tr>
                                                <th>Candidata</th>
                                                <th>Votos</th>
                                                <th>%</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {(() => {
                                                const catVotes = voteStats[category.id] || {};
                                                const totalCatVotes = Object.values(catVotes).reduce((a, b) => a + b, 0);
                                                
                                                // Sort by votes desc
                                                const sorted = Object.entries(catVotes).sort(([,a], [,b]) => b - a);

                                                return sorted.map(([cId, count]) => {
                                                    const candidate = category.candidates.find((c:any) => (c.id || c.name) === cId);
                                                    const name = candidate ? (candidate.name || cId) : cId;
                                                    const percent = totalCatVotes > 0 ? ((count / totalCatVotes) * 100).toFixed(1) : "0";
                                                    
                                                    return (
                                                        <tr>
                                                            <td>{name}</td>
                                                            <td>{count}</td>
                                                            <td>{percent}%</td>
                                                        </tr>
                                                    );
                                                });
                                            })()}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            )}
        </div>
    </div>
</Layout>


{isAuthenticated && (
<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        const calcBtn = document.getElementById('calc-points-btn');
        const resultDiv = document.getElementById('calc-result');
        
        if (calcBtn) {
            calcBtn.addEventListener('click', async () => {
                const matchCalendarId = document.getElementById('match_calendar_id').value.trim();
                const partidoId = document.getElementById('partido_id').value.trim();
                
                if (!matchCalendarId || !partidoId) {
                    resultDiv.innerHTML = '<p class="error">⚠️ Debes completar ambos campos</p>';
                    return;
                }
                
                calcBtn.disabled = true;
                calcBtn.textContent = 'CALCULANDO...';
                resultDiv.innerHTML = '<p class="loading">⏳ Procesando predicciones...</p>';
                
                try {
                    const response = await fetch('/api/calculate-points', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ 
                            match_calendar_id: matchCalendarId,
                            partido_id: parseInt(partidoId)
                        })
                    });
                    
                    const data = await response.json();
                    
                    if (response.ok && data.success) {
                        resultDiv.innerHTML = `
                            <p class="success">✅ ¡Puntos calculados correctamente!</p>
                            <div class="result-details">
                                <p><strong>Partido:</strong> ${data.match_id}</p>
                                <p><strong>Resultado:</strong> ${data.actual_result}</p>
                                <p><strong>Predicciones procesadas:</strong> ${data.predictions_processed}</p>
                                <p><strong>Goleadoras:</strong> ${data.actual_scorers.length} jugadoras</p>
                            </div>
                        `;
                    } else {
                        resultDiv.innerHTML = `<p class="error">❌ Error: ${data.error || 'Error desconocido'}</p>`;
                    }
                } catch (error) {
                    resultDiv.innerHTML = `<p class="error">❌ Error de red: ${error.message}</p>`;
                }
                
                calcBtn.disabled = false;
                calcBtn.textContent = 'CALCULAR PUNTOS';
            });
        }
    });
</script>
)}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

{isAuthenticated && (
<script define:vars={{ categories: CATEGORIES, stats: voteStats }}>
    document.addEventListener('DOMContentLoaded', () => {
        categories.forEach(cat => {
            const ctx = document.getElementById(`chart-${cat.id}`);
            if (!ctx) return;

            const catVotes = stats[cat.id] || {};
            // Sort to match table
            const sorted = Object.entries(catVotes).sort(([,a], [,b]) => b - a);
            
            const labels = sorted.map(([cId]) => {
                 const candidate = cat.candidates.find(c => (c.id || c.name) === cId);
                 return candidate ? (candidate.name || cId) : cId;
            });
            const data = sorted.map(([, count]) => count);

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Votos',
                        data: data,
                        backgroundColor: 'rgba(255, 222, 89, 0.6)',
                        borderColor: '#ffde59',
                        borderWidth: 1
                    }]
                },
                options: {
                    indexAxis: 'y', // Horizontal bar chart better for names
                    responsive: true,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        x: {
                            beginAtZero: true,
                            grid: { color: 'rgba(255,255,255,0.1)' },
                            ticks: { color: '#ccc' }
                        },
                        y: {
                            grid: { display: false },
                            ticks: { 
                                color: '#fff', 
                                font: { size: 11 },
                                autoSkip: false, // Show all labels
                                callback: function(value) {
                                    // Custom truncation/wrapping if needed, but let's rely on Chart.js auto-resizing first.
                                    // For very long labels, Chart.js might still cut them if canvas width is fixed.
                                    // We'll return the value as is, but rely on maintainAspectRatio: false + CSS height.
                                    const label = this.getLabelForValue(value);
                                    if (label.length > 25) {
                                        return label.split(/(?<=^.{15,})\s/); // Simple wrap attempt or just return array
                                        // Actually simplest is just returning the label, Chart.js 3+ handles arrays for multiline.
                                        // Let's just wrap by chunks if really long.
                                        const words = label.split(' ');
                                        const lines = [];
                                        let currentLine = words[0];
                                        for (let i = 1; i < words.length; i++) {
                                            if (currentLine.length + words[i].length < 20) {
                                                currentLine += ' ' + words[i];
                                            } else {
                                                lines.push(currentLine);
                                                currentLine = words[i];
                                            }
                                        }
                                        lines.push(currentLine);
                                        return lines;
                                    }
                                    return label;
                                }
                            } 
                        }
                    }
                }
            });
        });
    });
</script>
)}

