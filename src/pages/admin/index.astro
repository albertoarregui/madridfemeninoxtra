---
import Layout from "../../layouts/Layout.astro";
import { turso } from "../../lib/turso";
import { CATEGORIES } from "../../consts/awards-data";

// Auth Logic
const ADMIN_PASSWORD = import.meta.env.ADMIN_PASSWORD;
const isConfigured = !!ADMIN_PASSWORD;
let isAuthenticated = false;
let loginError = "";

// Check Cookie
if (Astro.cookies.has("admin_auth")) {
    const cookieVal = Astro.cookies.get("admin_auth")?.value;
    if (cookieVal === ADMIN_PASSWORD) {
        isAuthenticated = true;
    }
}

// Handle Login POST
if (Astro.request.method === "POST") {
    try {
        const data = await Astro.request.formData();
        const password = data.get("password")?.toString();

        if (password && password === ADMIN_PASSWORD) {
            Astro.cookies.set("admin_auth", password, {
                path: "/",
                httpOnly: true,
                secure: true,
                maxAge: 60 * 60 * 24, // 1 day
            });
            isAuthenticated = true;
        } else {
            loginError = "Contraseña incorrecta";
        }
    } catch (e) {
        loginError = "Error al procesar solicitud";
    }
}

// Fetch Data if Authenticated
let voteStats: Record<string, Record<string, number>> = {};
let totalVotes = 0;

if (isAuthenticated) {
    try {
        const result = await turso.execute("SELECT * FROM votes");
        const votes = result.rows;
        totalVotes = votes.length;

        // Initialize Stats
        CATEGORIES.forEach(cat => {
            voteStats[cat.id] = {};
            cat.candidates.forEach((cand: any) => {
                const cId = cand.id || cand.name; // Logic matching premios.astro
                voteStats[cat.id][cId] = 0;
            });
        });

        // Count Votes
        votes.forEach((row: any) => {
            const catId = row.category_id as string;
            const candId = row.candidate_id as string;
            if (voteStats[catId]) {
                 if (voteStats[catId][candId] !== undefined) {
                    voteStats[catId][candId]++;
                 } else {
                    // Handle unknown candidate (maybe id changed?)
                    voteStats[catId][candId] = 1;
                 }
            }
        });

    } catch (e) {
        console.error("Error fetching admin stats", e);
    }
}
---

<Layout title="Admin Resultados | Madrid Femenino Xtra">
    <div class="admin-page">
        <div class="container">
            <h1 class="page-title">PANEL DE RESULTADOS</h1>

            {!isAuthenticated ? (
                <div class="login-card">
                    <h2>Acceso Restringido</h2>
                    <form method="POST">
                        <input 
                            type="password" 
                            name="password" 
                            placeholder="Contraseña de Administrador" 
                            required 
                        />
                        <button type="submit">ENTRAR</button>
                    </form>
                    {loginError && <p class="error">{loginError}</p>}
                    {!isConfigured && <p class="error" style="color: yellow;">⚠ Error de Servidor: Variable ADMIN_PASSWORD no encontrada.</p>}
                </div>
            ) : (
                <div class="dashboard">
                    <div class="summary-card">
                        <h3>Total Votos Registrados: <span class="highlight">{totalVotes}</span></h3>
                        <form method="POST" action="/api/logout-admin"> <!-- or just clear cookie button logic -->
                            <!-- simple reload effectively keeps logged in, logic to logout needs separate endpoint or just clear cookie in browser -->
                        </form>
                    </div>

                    <div class="charts-grid">
                        {CATEGORIES.map(category => (
                            <div class="category-card">
                                <h3>{category.title}</h3>
                                <canvas id={`chart-${category.id}`}></canvas>
                                <div class="stats-table-wrapper">
                                    <table class="stats-table">
                                        <thead>
                                            <tr>
                                                <th>Candidata</th>
                                                <th>Votos</th>
                                                <th>%</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {(() => {
                                                const catVotes = voteStats[category.id] || {};
                                                const totalCatVotes = Object.values(catVotes).reduce((a, b) => a + b, 0);
                                                
                                                // Sort by votes desc
                                                const sorted = Object.entries(catVotes).sort(([,a], [,b]) => b - a);

                                                return sorted.map(([cId, count]) => {
                                                    const candidate = category.candidates.find((c:any) => (c.id || c.name) === cId);
                                                    const name = candidate ? (candidate.name || cId) : cId;
                                                    const percent = totalCatVotes > 0 ? ((count / totalCatVotes) * 100).toFixed(1) : "0";
                                                    
                                                    return (
                                                        <tr>
                                                            <td>{name}</td>
                                                            <td>{count}</td>
                                                            <td>{percent}%</td>
                                                        </tr>
                                                    );
                                                });
                                            })()}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            )}
        </div>
    </div>
</Layout>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

{isAuthenticated && (
<script define:vars={{ categories: CATEGORIES, stats: voteStats }}>
    document.addEventListener('DOMContentLoaded', () => {
        categories.forEach(cat => {
            const ctx = document.getElementById(`chart-${cat.id}`);
            if (!ctx) return;

            const catVotes = stats[cat.id] || {};
            // Sort to match table
            const sorted = Object.entries(catVotes).sort(([,a], [,b]) => b - a);
            
            const labels = sorted.map(([cId]) => {
                 const candidate = cat.candidates.find(c => (c.id || c.name) === cId);
                 return candidate ? (candidate.name || cId) : cId;
            });
            const data = sorted.map(([, count]) => count);

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Votos',
                        data: data,
                        backgroundColor: 'rgba(255, 222, 89, 0.6)',
                        borderColor: '#ffde59',
                        borderWidth: 1
                    }]
                },
                options: {
                    indexAxis: 'y', // Horizontal bar chart better for names
                    responsive: true,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        x: {
                            beginAtZero: true,
                            grid: { color: 'rgba(255,255,255,0.1)' },
                            ticks: { color: '#ccc' }
                        },
                        y: {
                            grid: { display: false },
                            ticks: { color: '#fff', font: { size: 11 } }
                        }
                    }
                }
            });
        });
    });
</script>
)}

<style>
    @import "@fontsource/archivo-black";
    @import "@fontsource/poppins";
    @import "@fontsource/permanent-marker";

    .admin-page {
        min-height: 100vh;
        background: linear-gradient(to bottom, #1a1f3c 0%, #050511 100%);
        color: white;
        padding: 4rem 1rem;
        font-family: 'Poppins', sans-serif;
    }
    .container {
        max-width: 1400px;
        margin: 0 auto;
    }
    .page-title {
        text-align: center;
        color: #ffde59;
        font-family: 'Archivo Black', sans-serif;
        margin: 0 auto 3rem;
        font-size: 2.5rem;
        position: relative;
        width: fit-content;
        display: block;
        text-transform: uppercase;
    }

    .page-title::after {
        content: '';
        position: absolute;
        bottom: -10px;
        left: 50%;
        transform: translateX(-50%);
        width: 60%;
        height: 4px;
        background: #ffde59;
        border-radius: 2px;
    }

    /* Login Styles */
    .login-card {
        max-width: 450px;
        margin: 0 auto;
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        padding: 3rem 2rem;
        border-radius: 24px;
        text-align: center;
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }
    .login-card h2 {
        font-family: 'Archivo Black', sans-serif;
        color: #ffde59;
        margin-bottom: 2rem;
        font-size: 1.5rem;
        text-transform: uppercase;
    }
    .login-card input {
        width: 100%;
        padding: 1.2rem;
        margin-bottom: 1.5rem;
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white;
        border-radius: 12px;
        font-family: 'Poppins', sans-serif;
        font-size: 1rem;
        transition: all 0.3s ease;
    }
    .login-card input:focus {
        outline: none;
        border-color: #ffde59;
        box-shadow: 0 0 15px rgba(255, 222, 89, 0.1);
    }
    .login-card button {
        width: 100%;
        padding: 1.2rem;
        background: linear-gradient(135deg, #ffd700 0%, #ffed4e 50%, #ffd700 100%);
        color: #000;
        font-weight: 800;
        font-family: 'Archivo Black', sans-serif;
        text-transform: uppercase;
        border: none;
        border-radius: 50px;
        font-size: 1.1rem;
        cursor: pointer;
        box-shadow: 0 4px 15px rgba(255, 215, 0, 0.3);
        transition: all 0.3s ease;
        letter-spacing: 1px;
    }
    .login-card button:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(255, 215, 0, 0.4);
    }
    .error { color: #ff6b6b; margin-top: 1rem; font-weight: 500; }

    /* Dashboard Styles */
    .dashboard {
        animation: fadeIn 0.5s ease-out;
    }
    
    .summary-card {
        text-align: center;
        margin-bottom: 4rem;
        background: rgba(255, 255, 255, 0.03);
        padding: 2rem;
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        display: inline-block;
        width: 100%;
    }
    .summary-card h3 {
        font-family: 'Archivo Black', sans-serif;
        font-size: 1.8rem;
        color: white;
        margin: 0;
        text-transform: uppercase;
    }
    .highlight { 
        color: #ffde59; 
        font-size: 2.5rem;
        margin-left: 1rem;
        text-shadow: 0 2px 10px rgba(255, 222, 89, 0.2);
    }

    .charts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
        gap: 2rem;
    }
    .category-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(5px);
        padding: 2rem;
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .category-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        border-color: rgba(255, 215, 0, 0.2);
    }
    .category-card h3 {
        color: #ffde59;
        margin-bottom: 2rem;
        text-align: center;
        font-family: 'Archivo Black', sans-serif;
        text-transform: uppercase;
        font-size: 1.3rem;
        border-bottom: 2px solid rgba(255, 255, 255, 0.1);
        padding-bottom: 1rem;
    }
    
    .stats-table-wrapper {
        margin-top: 2rem;
        max-height: 250px;
        overflow-y: auto;
        padding-right: 0.5rem;
        scrollbar-width: thin;
        scrollbar-color: rgba(255, 255, 255, 0.2) transparent;
    }
    .stats-table-wrapper::-webkit-scrollbar {
        width: 6px;
    }
    .stats-table-wrapper::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.2);
        border-radius: 3px;
    }

    .stats-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 0.5rem;
        font-size: 0.95rem;
    }
    .stats-table th {
        text-align: left;
        color: #8892b0;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 0 1rem 0.5rem 1rem;
        font-weight: 600;
    }
    .stats-table td {
        padding: 0.8rem 1rem;
        background: rgba(255, 255, 255, 0.05);
        transition: background 0.2s;
    }
    .stats-table tr td:first-child {
        border-top-left-radius: 8px;
        border-bottom-left-radius: 8px;
        font-weight: 500;
        color: white;
    }
    .stats-table tr td:last-child {
        border-top-right-radius: 8px;
        border-bottom-right-radius: 8px;
        color: #ffde59;
        font-weight: bold;
    }
    .stats-table tr:hover td {
        background: rgba(255, 255, 255, 0.1);
    }
    .stats-table td:nth-child(2), .stats-table td:nth-child(3) {
        text-align: right;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 768px) {
        .admin-page {
            padding: 2rem 1rem;
        }
        .page-title {
            font-size: 1.8rem;
            margin-bottom: 2rem;
        }
        .charts-grid {
            grid-template-columns: 1fr; /* Full width on mobile */
            gap: 1.5rem;
        }
        .category-card {
            padding: 1.5rem;
        }
        .category-card h3 {
            font-size: 1.1rem;
        }
        .highlight {
            font-size: 2rem;
            display: block; /* Stack on mobile */
            margin-left: 0;
            margin-top: 0.5rem;
        }
        .summary-card h3 {
            font-size: 1.2rem;
        }
        .stats-table th, .stats-table td {
            padding: 0.5rem;
            font-size: 0.8rem;
        }
    }
</style>
