                                                        </span>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {season.total.pj}
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {season.total.pg}
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {season.total.pe}
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {season.total.pp}
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {season.total.ta}
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {season.total.tr}
                                                        </strong>
                                                    </td>
                                                    <td>
