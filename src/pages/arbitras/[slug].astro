                                                            {season.total.pc}
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong class="text-yellow-600">
                                                            {season.total.ta}
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong class="text-red-600">
                                                            {season.total.tr}
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong class="text-yellow-700">
                                                            {season.total.ta_c}
                                                        </strong>
                                                    </td>
                                                    <td>
