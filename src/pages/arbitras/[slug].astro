---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import {
    fetchRefereesDirectly,
    fetchMatchesByReferee,
} from "../../utils/arbitras";
import { generateSlug } from "../../utils/url-helper";

import ligaFLogo from "../../assets/competiciones/liga_f.png";
import uwclLogo from "../../assets/competiciones/uwcl.png";
import copaLogo from "../../assets/competiciones/copa_de_la_reina.png";
import supercopaLogo from "../../assets/competiciones/supercopa_de_espana.png";

const competitionLogos: Record<string, any> = {
    "Liga F": ligaFLogo,
    UWCL: uwclLogo,
    "Copa de la Reina": copaLogo,
    "Supercopa de España": supercopaLogo,
};

export const prerender = true;

export async function getStaticPaths() {
    const referees = await fetchRefereesDirectly();
    return referees.map((ref) => ({
        params: { slug: generateSlug(ref.nombre) },
    }));
}

const { slug } = Astro.params;
const referees = await fetchRefereesDirectly();
const referee = referees.find((r) => generateSlug(r.nombre) === slug);

if (!referee) {
    return Astro.redirect("/404");
}

const rawMatches = await fetchMatchesByReferee(referee.nombre);

// Process matches for statistics
const matches = rawMatches.map((m) => {
    const isLocal =
        m.club_local.toLowerCase().trim().includes("real madrid") ||
        m.club_local.toLowerCase().trim() === "real madrid cf";

    const d = new Date(m.fecha);
    const year = d.getFullYear();
    const month = d.getMonth() + 1;
    const startYear = month >= 8 ? year : year - 1;
    const endYear = startYear + 1;
    const season = `${startYear}/${endYear.toString().slice(-2)}`;

    return {
        ...m,
        esLocal: isLocal,
        golesRM: parseInt(m.goles_rm) || 0,
        golesRival: parseInt(m.goles_rival) || 0,
        yellowCards: parseInt(m.amarillas) || 0,
        redCards: parseInt(m.rojas) || 0,
        season,
        resultado: (() => {
            const rm = parseInt(m.goles_rm) || 0;
            const rival = parseInt(m.goles_rival) || 0;
            if (rm > rival) return "V";
            if (rm < rival) return "D";
            if (m.penaltis === 1 || m.penaltis === "1") return "V";
            if (m.penaltis === 0 || m.penaltis === "0") return "D";
            return "E";
        })(),
        cleanSheet: (parseInt(m.goles_rival) || 0) === 0,
        conceded: (parseInt(m.goles_rival) || 0) > 0,
    };
});

// Calculate Detailed Stats (Season > Competition)
interface StatBlock {
    pj: number;
    pg: number;
    pe: number;
    pp: number;
    ta: number;
    tr: number;
}

const initialStatBlock = (): StatBlock => ({
    pj: 0,
    pg: 0,
    pe: 0,
    pp: 0,
    ta: 0,
    tr: 0,
});

const calculateBlock = (block: StatBlock, m: any) => {
    block.pj++;
    block.ta += m.yellowCards;
    block.tr += m.redCards;

    if (m.resultado === "V") block.pg++;
    else if (m.resultado === "E") block.pe++;
    else block.pp++;
};

const seasonsMap = new Map<string, any>();

matches.forEach((m) => {
    if (!seasonsMap.has(m.season)) {
        seasonsMap.set(m.season, {
            temporada: m.season,
            total: initialStatBlock(),
            competiciones: new Map<string, any>(),
        });
    }
    const seasonData = seasonsMap.get(m.season);
    calculateBlock(seasonData.total, m);

    if (!seasonData.competiciones.has(m.competicion)) {
        seasonData.competiciones.set(m.competicion, {
            competicion: m.competicion,
            ...initialStatBlock(),
        });
    }
    calculateBlock(seasonData.competiciones.get(m.competicion), m);
});

// Convert Map to Array for rendering
const refereeDeepStats = Array.from(seasonsMap.values())
    .map((s) => ({
        ...s,
        competiciones: Array.from(s.competiciones.values()),
    }))
    .sort((a, b) => (a.temporada < b.temporada ? 1 : -1));

// Total All Time
const totalStats = initialStatBlock();
matches.forEach((m) => calculateBlock(totalStats, m));

// Filter lists
const uniqueSeasons = [...new Set(matches.map((m) => m.season))]
    .sort()
    .reverse();
const uniqueCompetitions = [
    ...new Set(matches.map((m) => m.competicion)),
].sort();

// Charts Initial Data
const circumference = 220;
const totalMatches = totalStats.pj;
const winsArc =
    totalMatches > 0
        ? Math.round((totalStats.pg / totalMatches) * circumference)
        : 0;
const drawsArc =
    totalMatches > 0
        ? Math.round((totalStats.pe / totalMatches) * circumference)
        : 0;
const lossesArc =
    totalMatches > 0
        ? Math.round((totalStats.pp / totalMatches) * circumference)
        : 0;

const totalCards = totalStats.ta + totalStats.tr;
const yellowArc =
    totalCards > 0
        ? Math.round((totalStats.ta / totalCards) * circumference)
        : 0;
const redArc =
    totalCards > 0
        ? Math.round((totalStats.tr / totalCards) * circumference)
        : 0;
---

<Layout
    title={`Ficha de ${referee.nombre} | Madrid Femenino Xtra`}
    description={`Historial de arbitraje de ${referee.nombre} con el Real Madrid Femenino.`}
>
    <main class="rival-details-page">
        <a href="/arbitras" class="back-link">
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Volver a Árbitras
        </a>

        <div class="rival-grid">
            <div class="left-column">
                <section class="rival-card">
                    <h2 class="section-header">
                        FICHA DE {referee.nombre.toUpperCase()}
                    </h2>
                    <div class="rival-info">
                        <div class="rival-details w-full">
                            <div class="info-row">
                                <span class="label">Nombre:</span>
                                <span class="value font-bebas text-4xl"
                                    >{referee.nombre}</span
                                >
                            </div>
                            <div class="info-row">
                                <span class="label">Partidos:</span>
                                <span class="value font-bold text-2xl"
                                    >{totalStats.pj}</span
                                >
                            </div>
                            <div class="info-row">
                                <span class="label">Total Tarjetas:</span>
                                <span class="value gap-3">
                                    <span
                                        class="flex items-center gap-2 text-yellow-600 font-bold text-2xl"
                                    >
                                        <span
                                            class="w-5 h-7 bg-yellow-400 rounded-sm inline-block border border-yellow-500"
                                        ></span>
                                        {totalStats.ta}
                                    </span>
                                    <span
                                        class="flex items-center gap-2 text-red-600 font-bold text-2xl"
                                    >
                                        <span
                                            class="w-5 h-7 bg-red-600 rounded-sm inline-block border border-red-700"
                                        ></span>
                                        {totalStats.tr}
                                    </span>
                                </span>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="stats-table-card">
                    <h3 class="section-subheader">ESTADÍSTICAS</h3>
                    <div class="table-wrapper">
                        {
                            refereeDeepStats.length > 0 ? (
                                <table class="stats-table detailed-table">
                                    <thead>
                                        <tr>
                                            <th>TEMPORADA</th>
                                            <th>PJ</th>
                                            <th>PG</th>
                                            <th>PE</th>
                                            <th>PP</th>
                                            <th>TA</th>
                                            <th>TR</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {refereeDeepStats.map((season) => (
                                            <>
                                                <tr
                                                    class="season-total-row"
                                                    onclick={`toggleSeason('${season.temporada.replace(/\//g, "-")}')`}
                                                    style="cursor: pointer;"
                                                >
                                                    <td>
                                                        <strong>
                                                            {season.temporada}
                                                        </strong>
                                                        <span class="toggle-icon">
                                                            ▼
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {season.total.pj}
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {season.total.pg}
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {season.total.pe}
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {season.total.pp}
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {season.total.ta}
                                                        </strong>
                                                    </td>
                                                    <td>
                                                        <strong>
                                                            {season.total.tr}
                                                        </strong>
                                                    </td>
                                                </tr>
                                                {season.competiciones.map(
                                                    (comp) => (
                                                        <tr
                                                            class={`competition-row season-${season.temporada.replace(/\//g, "-")}`}
                                                            style="display: none;"
                                                        >
                                                            <td class="competition-name">
                                                                {competitionLogos[
                                                                    comp
                                                                        .competicion
                                                                ] && (
                                                                    <img
                                                                        src={
                                                                            competitionLogos[
                                                                                comp
                                                                                    .competicion
                                                                            ]
                                                                                .src
                                                                        }
                                                                        alt={
                                                                            comp.competicion
                                                                        }
                                                                        class="competition-logo"
                                                                    />
                                                                )}
                                                                {
                                                                    comp.competicion
                                                                }
                                                            </td>
                                                            <td>{comp.pj}</td>
                                                            <td>{comp.pg}</td>
                                                            <td>{comp.pe}</td>
                                                            <td>{comp.pp}</td>
                                                            <td>{comp.ta}</td>
                                                            <td>{comp.tr}</td>
                                                        </tr>
                                                    ),
                                                )}
                                            </>
                                        ))}
                                        <tr class="total-row career-total-row">
                                            <td>
                                                <strong>TOTAL HISTÓRICO</strong>
                                            </td>
                                            <td>{totalStats.pj}</td>
                                            <td>{totalStats.pg}</td>
                                            <td>{totalStats.pe}</td>
                                            <td>{totalStats.pp}</td>
                                            <td>{totalStats.ta}</td>
                                            <td>{totalStats.tr}</td>
                                        </tr>
                                    </tbody>
                                </table>
                            ) : (
                                <div class="p-4 text-center text-gray-500">
                                    No hay estadísticas disponibles
                                </div>
                            )
                        }
                    </div>
                </section>

                <section class="charts-card">
                    <h2 class="section-header">GRÁFICAS</h2>
                    <div class="filters-container">
                        <div class="filter-wrapper">
                            <select id="season-filter">
                                <option value="all">Todas las Temporadas</option
                                >
                                {
                                    uniqueSeasons.map((season) => (
                                        <option value={season}>{season}</option>
                                    ))
                                }
                            </select>
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="filter-icon"
                                ><path
                                    stroke="none"
                                    d="M0 0h24v24H0z"
                                    fill="none"></path><path d="M6 9l6 6l6 -6"
                                ></path></svg
                            >
                        </div>
                        <div class="filter-wrapper">
                            <select id="competition-filter">
                                <option value="all"
                                    >Todas las Competiciones</option
                                >
                                {
                                    uniqueCompetitions.map((comp) => (
                                        <option value={comp}>{comp}</option>
                                    ))
                                }
                            </select>
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="filter-icon"
                                ><path
                                    stroke="none"
                                    d="M0 0h24v24H0z"
                                    fill="none"></path><path d="M6 9l6 6l6 -6"
                                ></path></svg
                            >
                        </div>
                    </div>
                    <div class="charts-row">
                        <div class="chart-item">
                            <h4 class="text-sm font-bold mb-2">RESULTADOS</h4>
                            <svg
                                viewBox="0 0 100 100"
                                class="pie-chart"
                                id="results-chart"
                            >
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#c8e6c9"
                                    stroke-width="20"
                                    stroke-dasharray={`${winsArc} ${circumference - winsArc}`}
                                    transform="rotate(-90 50 50)"></circle>
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#fff9c4"
                                    stroke-width="20"
                                    stroke-dasharray={`${drawsArc} ${circumference - drawsArc}`}
                                    stroke-dashoffset={-winsArc}
                                    transform="rotate(-90 50 50)"></circle>
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#ffcdd2"
                                    stroke-width="20"
                                    stroke-dasharray={`${lossesArc} ${circumference - lossesArc}`}
                                    stroke-dashoffset={-(winsArc + drawsArc)}
                                    transform="rotate(-90 50 50)"></circle>
                            </svg>
                            <div class="chart-legend" id="results-legend">
                                <div>
                                    <span class="dot green"></span> Ganados ({
                                        totalStats.pg
                                    })
                                </div>
                                <div>
                                    <span class="dot orange"></span> Empatados ({
                                        totalStats.pe
                                    })
                                </div>
                                <div>
                                    <span class="dot red"></span> Perdidos ({
                                        totalStats.pp
                                    })
                                </div>
                            </div>
                        </div>

                        <div class="chart-item">
                            <h4 class="text-sm font-bold mb-2">TARJETAS</h4>
                            <svg
                                viewBox="0 0 100 100"
                                class="pie-chart"
                                id="cards-chart"
                            >
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#fff176"
                                    stroke-width="20"
                                    stroke-dasharray={`${yellowArc} ${circumference - yellowArc}`}
                                    transform="rotate(-90 50 50)"></circle>
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#e57373"
                                    stroke-width="20"
                                    stroke-dasharray={`${redArc} ${circumference - redArc}`}
                                    stroke-dashoffset={-yellowArc}
                                    transform="rotate(-90 50 50)"></circle>
                            </svg>
                            <div class="chart-legend" id="cards-legend">
                                <div>
                                    <span class="dot yellow"></span> Amarillas ({
                                        totalStats.ta
                                    })
                                </div>
                                <div>
                                    <span class="dot red"></span> Rojas ({
                                        totalStats.tr
                                    })
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="matches-card">
                    <h3 class="section-subheader">PARTIDOS DIRIGIDOS</h3>
                    <div class="table-wrapper">
                        <table class="matches-table">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Competición</th>
                                    <th>Local</th>
                                    <th>Res.</th>
                                    <th>Visitante</th>
                                    <th>Estadio</th>
                                </tr>
                            </thead>
                            <tbody>
                                {
                                    matches.map((match, index) => (
                                        <tr
                                            class={`match-row ${index >= 10 ? "hidden-match" : ""}`}
                                            style={
                                                index >= 10
                                                    ? "display: none;"
                                                    : ""
                                            }
                                        >
                                            <td>
                                                {new Date(
                                                    match.fecha,
                                                ).toLocaleDateString("es-ES")}
                                            </td>
                                            <td>{match.competicion}</td>
                                            <td
                                                class={
                                                    match.club_local
                                                        .toLowerCase()
                                                        .includes("real madrid")
                                                        ? "font-bold"
                                                        : ""
                                                }
                                            >
                                                {match.club_local}
                                            </td>
                                            <td
                                                class={`font-bold ${
                                                    match.resultado === "V"
                                                        ? "text-green-600"
                                                        : match.resultado ===
                                                            "E"
                                                          ? "text-orange-500"
                                                          : "text-red-500"
                                                }`}
                                            >
                                                {match.goles_rm} -{" "}
                                                {match.goles_rival}
                                            </td>
                                            <td
                                                class={
                                                    match.club_visitante
                                                        .toLowerCase()
                                                        .includes("real madrid")
                                                        ? "font-bold"
                                                        : ""
                                                }
                                            >
                                                {match.club_visitante}
                                            </td>
                                            <td>
                                                {match.estadio && (
                                                    <a
                                                        href={`/estadios/${generateSlug(match.estadio)}`}
                                                        class="hover:text-[#ffde59] transition-colors"
                                                    >
                                                        {match.estadio}
                                                    </a>
                                                )}
                                            </td>
                                        </tr>
                                    ))
                                }
                            </tbody>
                        </table>
                    </div>
                    {
                        matches.length > 10 && (
                            <div class="matches-footer">
                                <button id="show-more-matches" class="btn-more">
                                    Ver todos los partidos ({matches.length})
                                </button>
                            </div>
                        )
                    }
                </section>
            </div>
        </div>
    </main>
</Layout>

<script define:vars={{ initialMatches: matches }}>
    // Toggle Season Logic
    window.toggleSeason = function (season) {
        const rows = document.querySelectorAll(
            `.competition-row.season-${season}`,
        );
        const icon = document.querySelector(
            `.season-total-row[onclick*="${season}"] .toggle-icon`,
        );

        rows.forEach((row) => {
            if (row.style.display === "none") {
                row.style.display = "table-row";
                if (icon) icon.textContent = "▲";
            } else {
                row.style.display = "none";
                if (icon) icon.textContent = "▼";
            }
        });
    };

    function calculateStatsDoubleFilter(matches) {
        const stats = {
            pj: 0,
            pg: 0,
            pe: 0,
            pp: 0,
            ta: 0,
            tr: 0,
        };

        matches.forEach((m) => {
            stats.pj++;
            stats.ta += parseInt(m.yellowCards) || 0;
            stats.tr += parseInt(m.redCards) || 0;

            if (m.resultado === "V") stats.pg++;
            else if (m.resultado === "E") stats.pe++;
            else stats.pp++;
        });
        return stats;
    }

    function updateCharts(stats) {
        const circumference = 220;
        const totalMatches = stats.pj;

        const updateCircle = (id, idx, val, total, offset = 0) => {
            const chart = document.getElementById(id);
            if (!chart) return;
            const circle = chart.querySelectorAll("circle")[idx];
            if (!circle) return;

            const arc =
                total > 0 ? Math.round((val / total) * circumference) : 0;
            circle.setAttribute(
                "stroke-dasharray",
                `${arc} ${circumference - arc}`,
            );
            if (offset !== 0) circle.setAttribute("stroke-dashoffset", -offset);
            return arc;
        };

        const winsArc = updateCircle(
            "results-chart",
            0,
            stats.pg,
            totalMatches,
        );
        const drawsArc = updateCircle(
            "results-chart",
            1,
            stats.pe,
            totalMatches,
            winsArc,
        );
        updateCircle(
            "results-chart",
            2,
            stats.pp,
            totalMatches,
            winsArc + drawsArc,
        );

        // Legends
        document.querySelector(
            "#results-legend div:nth-child(1) .dot",
        ).nextSibling.textContent = ` Ganados (${stats.pg})`;
        document.querySelector(
            "#results-legend div:nth-child(2) .dot",
        ).nextSibling.textContent = ` Empatados (${stats.pe})`;
        document.querySelector(
            "#results-legend div:nth-child(3) .dot",
        ).nextSibling.textContent = ` Perdidos (${stats.pp})`;

        // Cards
        const totalCards = stats.ta + stats.tr;
        const yellowArc = updateCircle("cards-chart", 0, stats.ta, totalCards);
        updateCircle("cards-chart", 1, stats.tr, totalCards, yellowArc);

        document.querySelector(
            "#cards-legend div:nth-child(1) .dot",
        ).nextSibling.textContent = ` Amarillas (${stats.ta})`;
        document.querySelector(
            "#cards-legend div:nth-child(2) .dot",
        ).nextSibling.textContent = ` Rojas (${stats.tr})`;
    }

    // Event Listeners for filters
    const seasonFilter = document.getElementById("season-filter");
    const competitionFilter = document.getElementById("competition-filter");

    const allMatches = initialMatches; // from define:vars

    function applyFilters() {
        const selectedSeason = seasonFilter.value;
        const selectedComp = competitionFilter.value;

        let filtered = allMatches;

        if (selectedSeason !== "all") {
            filtered = filtered.filter((m) => m.season === selectedSeason);
        }
        if (selectedComp !== "all") {
            filtered = filtered.filter((m) => m.competicion === selectedComp);
        }

        const stats = calculateStatsDoubleFilter(filtered);
        updateCharts(stats);
    }

    if (seasonFilter) seasonFilter.addEventListener("change", applyFilters);
    if (competitionFilter)
        competitionFilter.addEventListener("change", applyFilters);

    const showMoreBtn = document.getElementById("show-more-matches");
    if (showMoreBtn) {
        showMoreBtn.addEventListener("click", () => {
            document.querySelectorAll(".hidden-match").forEach((row) => {
                row.style.display = "table-row";
                row.classList.remove("hidden-match");
            });
            showMoreBtn.style.display = "none";
        });
    }
</script>

<style>
    .rival-details-page {
        max-width: 1400px;
        margin: 0 auto;
        padding: 2rem 1rem;
        overflow-x: hidden;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #666;
        text-decoration: none;
        font-weight: 600;
        margin-bottom: 1.5rem;
        transition: color 0.3s;
    }

    .back-link:hover {
        color: #ffde59;
    }

    .rival-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 1.5rem;
    }

    .left-column,
    .right-column {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        width: 100%;
        overflow-x: hidden;
    }

    /* Remove grid if right column is empty or let it handle responsive */
    .right-column:empty {
        display: none;
    }

    @media (max-width: 1024px) {
        .rival-grid {
            grid-template-columns: 1fr;
        }
    }

    .section-header {
        background: #ffde59;
        color: #2b2b2b;
        padding: 0.75rem 1rem;
        margin: 0;
        font-size: 1rem;
        font-weight: bold;
    }

    .section-subheader {
        background: #ffde59;
        color: #000;
        padding: 0.75rem 1rem;
        margin: 0;
