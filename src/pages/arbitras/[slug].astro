                                            class="w-3 h-4 bg-yellow-400 rounded-sm inline-block border border-yellow-500"
                                        ></span>
                                        {refereeStats.total.yellowCards}</span
                                    >
                                    <span
                                        class="flex items-center gap-1 text-red-600 font-bold"
                                        ><span
                                            class="w-3 h-4 bg-red-600 rounded-sm inline-block border border-red-700"
                                        ></span>
                                        {refereeStats.total.redCards}</span
                                    >
