---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import {
    fetchRefereesDirectly,
    fetchMatchesByReferee,
} from "../../utils/arbitras";
import { generateSlug } from "../../utils/url-helper";

export const prerender = true;

export async function getStaticPaths() {
    const referees = await fetchRefereesDirectly();
    return referees.map((ref) => ({
        params: { slug: generateSlug(ref.nombre) },
    }));
}

const { slug } = Astro.params;
const referees = await fetchRefereesDirectly();
const referee = referees.find((r) => generateSlug(r.nombre) === slug);

if (!referee) {
    return Astro.redirect("/404");
}

const rawMatches = await fetchMatchesByReferee(referee.nombre);

// Process matches for statistics
const matches = rawMatches.map((m) => {
    // RM Perspective: Usually matches data comes with RM goals and Rival goals.
    // If we fetched using fetchMatchesByReferee, we assume the data structure
    // from get_filtered_matches which has 'goles_rm', 'goles_rival', 'club_local', 'club_visitante'

    // Determine if RM is home or away is needed for "Home/Away" stats split?
    // Usually Stats are "RM Home" vs "RM Away" no matter who the referee is.
    const isLocal =
        m.club_local.toLowerCase().trim().includes("real madrid") ||
        m.club_local.toLowerCase().trim() === "real madrid cf";

    // Comp stats
    const d = new Date(m.fecha);
    const year = d.getFullYear();
    const month = d.getMonth() + 1;
    const startYear = month >= 8 ? year : year - 1;
    const endYear = startYear + 1;
    const season = `${startYear}/${endYear.toString().slice(-2)}`;

    return {
        ...m,
        esLocal: isLocal,
        // Ensure numbers
        golesRM: parseInt(m.goles_rm) || 0,
        golesRival: parseInt(m.goles_rival) || 0,
        season,
        resultado: (() => {
            const rm = parseInt(m.goles_rm) || 0;
            const rival = parseInt(m.goles_rival) || 0;
            if (rm > rival) return "V";
            if (rm < rival) return "D";
            // Check penalties if draw
            if (m.penaltis === 1 || m.penaltis === "1") return "V";
            if (m.penaltis === 0 || m.penaltis === "0") return "D";
            return "E";
        })(),
    };
});

// Calculate Stats (Server Side)
const calculateStats = (matchList: any[]) => {
    const stats = {
        home: {
            pj: 0,
            pg: 0,
            pe: 0,
            pp: 0,
            gf: 0,
            gc: 0,
            cleanSheets: 0,
            conceded: 0,
            yellowCards: 0,
            redCards: 0,
        },
        away: {
            pj: 0,
            pg: 0,
            pe: 0,
            pp: 0,
            gf: 0,
            gc: 0,
            cleanSheets: 0,
            conceded: 0,
            yellowCards: 0,
            redCards: 0,
        },
        total: {
            pj: 0,
            pg: 0,
            pe: 0,
            pp: 0,
            gf: 0,
            gc: 0,
            cleanSheets: 0,
            conceded: 0,
            yellowCards: 0,
            redCards: 0,
        },
    };

    matchList.forEach((match) => {
        const golesRM = match.golesRM;
        const golesRival = match.golesRival;
        const isHome = match.esLocal;

        const location = isHome ? stats.home : stats.away;

        location.pj++;
        location.gf += golesRM;
        location.gc += golesRival;

        // Cards logic - assuming match object has 'amarillas' and 'rojas' total for the match?
        // Or specific to RM? Usually referee stats count ALL cards shown in the match.
        // But our dataset might only have cards for RM or total?
        // Let's assume 'tarjetas' field exists or we use what we have.
        // Looking at arbitras stats normally, it shows "Cards shown".
        // The fetchMatchesByReferee might not return card details per match unless we modify query.
        // For now, let's try to use 'amarillas' and 'rojas' if available, otherwise 0.
        // The generic match query might not have these.
        // We will trust what is available.

        // Actually the `referee.stats` object already has aggregated stats from the DB helper `fetchRefereesDirectly`.
        // However, if we want dynamic filtering (by season/home/away), we need to recalculate from matches.
        // If matches don't have card data, we can't recalculate cards dynamically.
        // Let's check `fetchMatchesByReferee`: It selects `p.*` and joins.
        // Does `partidos` table have `amarillas` / `rojas`?
        // Assuming yes or similar columns. If not, we skip cards in dynamic stats or use defaults.

        location.yellowCards += parseInt(match.amarillas) || 0;
        location.redCards += parseInt(match.rojas) || 0;

        if (golesRival === 0) location.cleanSheets++;
        else location.conceded++;

        if (golesRM > golesRival) location.pg++;
        else if (golesRM < golesRival) location.pp++;
        else {
            if (match.penaltis === 1 || match.penaltis === "1") location.pg++;
            else if (match.penaltis === 0 || match.penaltis === "0")
                location.pp++;
            else location.pe++;
        }
    });

    const keys = [
        "pj",
        "pg",
        "pe",
        "pp",
        "gf",
        "gc",
        "cleanSheets",
        "conceded",
        "yellowCards",
        "redCards",
    ] as const;
    keys.forEach((key) => {
        stats.total[key] = stats.home[key] + stats.away[key];
    });

    const addFields = (obj: any) => ({
        ...obj,
        percPG: obj.pj > 0 ? ((obj.pg / obj.pj) * 100).toFixed(1) : "0.0",
        percPE: obj.pj > 0 ? ((obj.pe / obj.pj) * 100).toFixed(1) : "0.0",
        percPP: obj.pj > 0 ? ((obj.pp / obj.pj) * 100).toFixed(1) : "0.0",
        avg: obj.pj > 0 ? (obj.gf / obj.pj).toFixed(2) : "0.00",
        dif: obj.gf - obj.gc,
    });

    return {
        home: addFields(stats.home),
        away: addFields(stats.away),
        total: addFields(stats.total),
    };
};

const refereeStats = calculateStats(matches);
const uniqueSeasons = [...new Set(matches.map((m) => m.season))]
    .sort()
    .reverse();

// Charts Data
const circumference = 220;
const totalMatches = refereeStats.total.pj;
const winsArc =
    totalMatches > 0
        ? Math.round((refereeStats.total.pg / totalMatches) * circumference)
        : 0;
const drawsArc =
    totalMatches > 0
        ? Math.round((refereeStats.total.pe / totalMatches) * circumference)
        : 0;
const lossesArc =
    totalMatches > 0
        ? Math.round((refereeStats.total.pp / totalMatches) * circumference)
        : 0;

const totalCards = refereeStats.total.yellowCards + refereeStats.total.redCards;
const yellowArc =
    totalCards > 0
        ? Math.round(
              (refereeStats.total.yellowCards / totalCards) * circumference,
          )
        : 0;
const redArc =
    totalCards > 0
        ? Math.round((refereeStats.total.redCards / totalCards) * circumference)
        : 0;
---

<Layout
    title={`${referee.nombre} | Madrid Femenino Xtra`}
    description={`Historial de arbitraje de ${referee.nombre} con el Real Madrid Femenino: balance de victorias, tarjetas y lista de partidos dirigidos.`}
>
