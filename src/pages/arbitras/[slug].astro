                                            <th>TEMPORADA</th>
                                            <th>PJ</th>
                                            <th>PG</th>
                                            <th>PE</th>
                                            <th>PP</th>
                                            <th>TA</th>
                                            <th>TR</th>
                                            <th>PF</th>
                                            <th>PC</th>
                                            <th>TA (F)</th>
                                            <th>TR (F)</th>
                                            <th>TA (C)</th>
                                            <th>TR (C)</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {refereeDeepStats.map((season) => (
                                            <>
                                                <tr
                                                    class="season-total-row"
                                                    onclick={`toggleSeason('${season.temporada.replace(/\//g, "-")}')`}
