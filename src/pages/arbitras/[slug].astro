                                    <td>{refereeStats.away.percPP}%</td>
                                    <td class="highlight-yellow"
                                        >{refereeStats.away.gf}</td
                                    >
                                    <td class="highlight-red"
                                        >{refereeStats.away.gc}</td
                                    >
                                    <td class="highlight-blue"
                                        >{refereeStats.away.dif > 0 ? "+" : ""}{
