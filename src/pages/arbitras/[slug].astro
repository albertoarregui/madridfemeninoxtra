                                    ))
                                }
                            </select>
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="filter-icon"
                                ><path
                                    stroke="none"
                                    d="M0 0h24v24H0z"
                                    fill="none"></path><path d="M6 9l6 6l6 -6"
                                ></path></svg
                            >
                        </div>
                    </div>
                    <div class="charts-row">
                        <div class="chart-item">
                            <h4 class="text-sm font-bold mb-2">RESULTADOS</h4>
                            <svg
                                viewBox="0 0 100 100"
                                class="pie-chart"
                                id="results-chart"
                            >
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#c8e6c9"
                                    stroke-width="20"
                                    stroke-dasharray={`${winsArc} ${circumference - winsArc}`}
                                    transform="rotate(-90 50 50)"></circle>
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#fff9c4"
                                    stroke-width="20"
                                    stroke-dasharray={`${drawsArc} ${circumference - drawsArc}`}
                                    stroke-dashoffset={-winsArc}
                                    transform="rotate(-90 50 50)"></circle>
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#ffcdd2"
                                    stroke-width="20"
                                    stroke-dasharray={`${lossesArc} ${circumference - lossesArc}`}
                                    stroke-dashoffset={-(winsArc + drawsArc)}
                                    transform="rotate(-90 50 50)"></circle>
                            </svg>
                            <div class="chart-legend" id="results-legend">
                                <div>
                                    <span class="dot green"></span> Ganados ({
                                        refereeStats.total.pg
                                    })
                                </div>
                                <div>
                                    <span class="dot orange"></span> Empatados ({
                                        refereeStats.total.pe
                                    })
                                </div>
                                <div>
                                    <span class="dot red"></span> Perdidos ({
                                        refereeStats.total.pp
                                    })
                                </div>
                            </div>
                        </div>

                        <div class="chart-item">
                            <h4 class="text-sm font-bold mb-2">TARJETAS</h4>
                            <svg
                                viewBox="0 0 100 100"
                                class="pie-chart"
                                id="cards-chart"
                            >
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#fff176"
                                    stroke-width="20"
                                    stroke-dasharray={`${yellowArc} ${circumference - yellowArc}`}
                                    transform="rotate(-90 50 50)"></circle>
                                <circle
                                    cx="50"
                                    cy="50"
                                    r="35"
                                    fill="none"
                                    stroke="#e57373"
                                    stroke-width="20"
                                    stroke-dasharray={`${redArc} ${circumference - redArc}`}
                                    stroke-dashoffset={-yellowArc}
                                    transform="rotate(-90 50 50)"></circle>
                            </svg>
                            <div class="chart-legend" id="cards-legend">
                                <div>
                                    <span class="dot yellow"></span> Amarillas ({
                                        refereeStats.total.yellowCards
                                    })
                                </div>
                                <div>
                                    <span class="dot red"></span> Rojas ({
                                        refereeStats.total.redCards
                                    })
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="matches-card">
                    <h3 class="section-subheader">PARTIDOS DIRIGIDOS</h3>
                    <div class="table-wrapper">
                        <table class="matches-table">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Competición</th>
                                    <th>Local</th>
                                    <th>Res.</th>
                                    <th>Visitante</th>
                                    <th>Estadio</th>
                                </tr>
                            </thead>
                            <tbody>
                                {
                                    matches.map((match, index) => (
                                        <tr
                                            class={`match-row ${index >= 10 ? "hidden-match" : ""}`}
                                            style={
                                                index >= 10
                                                    ? "display: none;"
                                                    : ""
                                            }
                                        >
                                            <td>
                                                {new Date(
                                                    match.fecha,
                                                ).toLocaleDateString("es-ES")}
                                            </td>
                                            <td>{match.competicion}</td>
                                            <td
                                                class={
                                                    match.club_local
                                                        .toLowerCase()
                                                        .includes("real madrid")
                                                        ? "font-bold"
                                                        : ""
                                                }
                                            >
                                                {match.club_local}
                                            </td>
                                            <td
                                                class={`font-bold ${
                                                    match.resultado === "V"
                                                        ? "text-green-600"
                                                        : match.resultado ===
                                                            "E"
                                                          ? "text-orange-500"
                                                          : "text-red-500"
                                                }`}
                                            >
                                                {match.goles_rm} -{" "}
                                                {match.goles_rival}
                                            </td>
                                            <td
                                                class={
                                                    match.club_visitante
                                                        .toLowerCase()
                                                        .includes("real madrid")
                                                        ? "font-bold"
                                                        : ""
                                                }
                                            >
                                                {match.club_visitante}
                                            </td>
                                            <td>
                                                {match.estadio && (
                                                    <a
                                                        href={`/estadios/${generateSlug(match.estadio)}`}
                                                        class="hover:text-[#ffde59] transition-colors"
                                                    >
                                                        {match.estadio.length >
                                                        20
                                                            ? match.estadio.substring(
                                                                  0,
                                                                  20,
                                                              ) + "..."
                                                            : match.estadio}
                                                    </a>
                                                )}
                                            </td>
                                        </tr>
                                    ))
                                }
                            </tbody>
                        </table>
                    </div>
                    {
                        matches.length > 10 && (
                            <div class="matches-footer">
                                <button id="show-more-matches" class="btn-more">
                                    Ver todos los partidos ({matches.length})
                                </button>
                            </div>
                        )
                    }
                </section>
            </div>

            <div class="right-column">
                <!-- Placeholder for future right column content or we can remove the grid columns if empty -->
                <section class="stadium-card">
                    <h2 class="section-header">DATOS RÁPIDOS</h2>
                    <div class="p-6 text-center space-y-4">
                        <div class="bg-gray-50 rounded-lg p-4">
                            <div class="text-3xl font-bold text-[#151e42]">
                                {refereeStats.total.pj}
                            </div>
                            <div
                                class="text-xs text-gray-500 uppercase font-bold mt-1"
                            >
                                Partidos
                            </div>
                        </div>
                        <div class="bg-gray-50 rounded-lg p-4">
                            <div class="text-3xl font-bold text-green-600">
                                {refereeStats.total.pg}
                            </div>
                            <div
                                class="text-xs text-gray-500 uppercase font-bold mt-1"
                            >
                                Victorias RM
                            </div>
                        </div>
                        <div class="bg-gray-50 rounded-lg p-4">
                            <div class="text-3xl font-bold text-yellow-600">
                                {refereeStats.total.yellowCards}
                            </div>
                            <div
                                class="text-xs text-gray-500 uppercase font-bold mt-1"
                            >
                                Amarillas
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </main>
</Layout>

<script define:vars={{ initialMatches: matches }}>
    function calculateStatsLocal(matches) {
        const stats = {
            home: {
                pj: 0,
                pg: 0,
                pe: 0,
                pp: 0,
                gf: 0,
                gc: 0,
                cleanSheets: 0,
                conceded: 0,
                yellowCards: 0,
                redCards: 0,
            },
            away: {
                pj: 0,
                pg: 0,
                pe: 0,
                pp: 0,
                gf: 0,
                gc: 0,
                cleanSheets: 0,
                conceded: 0,
                yellowCards: 0,
                redCards: 0,
            },
            total: {
                pj: 0,
                pg: 0,
                pe: 0,
                pp: 0,
                gf: 0,
                gc: 0,
                cleanSheets: 0,
                conceded: 0,
                yellowCards: 0,
                redCards: 0,
            },
        };

        matches.forEach((match) => {
            const golesRM = parseInt(match.golesRM) || 0;
            const golesRival = parseInt(match.golesRival) || 0;
            const isHome = match.club_local
                .toLowerCase()
                .includes("real madrid");
            const location = isHome ? stats.home : stats.away;

            location.pj++;
            location.gf += golesRM;
            location.gc += golesRival;

            location.yellowCards += parseInt(match.amarillas) || 0;
            location.redCards += parseInt(match.rojas) || 0;

            if (golesRM > golesRival) location.pg++;
            else if (golesRM < golesRival) location.pp++;
            else {
                if (match.penaltis === 1 || match.penaltis === "1")
                    location.pg++;
                else if (match.penaltis === 0 || match.penaltis === "0")
                    location.pp++;
                else location.pe++;
            }
        });

        const keys = [
            "pj",
            "pg",
            "pe",
            "pp",
            "gf",
            "gc",
            "yellowCards",
            "redCards",
        ];
        keys.forEach((k) => (stats.total[k] = stats.home[k] + stats.away[k]));

        const addFields = (obj) => ({
            ...obj,
            percPG: obj.pj > 0 ? ((obj.pg / obj.pj) * 100).toFixed(1) : "0.0",
            percPE: obj.pj > 0 ? ((obj.pe / obj.pj) * 100).toFixed(1) : "0.0",
            percPP: obj.pj > 0 ? ((obj.pp / obj.pj) * 100).toFixed(1) : "0.0",
            avg: obj.pj > 0 ? (obj.gf / obj.pj).toFixed(2) : "0.00",
            dif: obj.gf - obj.gc,
        });

        return {
            home: addFields(stats.home),
            away: addFields(stats.away),
            total: addFields(stats.total),
        };
    }

    function updateCharts(stats) {
        const circumference = 220;
        const totalMatches = stats.total.pj;

        const updateCircle = (id, idx, val, total, offset = 0) => {
            const chart = document.getElementById(id);
            if (!chart) return;
            const circle = chart.querySelectorAll("circle")[idx];
            if (!circle) return;

            const arc =
                total > 0 ? Math.round((val / total) * circumference) : 0;
            circle.setAttribute(
                "stroke-dasharray",
                `${arc} ${circumference - arc}`,
            );
            if (offset !== 0) circle.setAttribute("stroke-dashoffset", -offset);
            return arc;
        };

        const winsArc = updateCircle(
            "results-chart",
            0,
            stats.total.pg,
            totalMatches,
        );
        const drawsArc = updateCircle(
            "results-chart",
            1,
            stats.total.pe,
            totalMatches,
            winsArc,
        );
        updateCircle(
            "results-chart",
            2,
            stats.total.pp,
            totalMatches,
            winsArc + drawsArc,
        );

        const totalCards = stats.total.yellowCards + stats.total.redCards;
        const yArc = updateCircle(
            "cards-chart",
            0,
            stats.total.yellowCards,
            totalCards,
        );
        updateCircle("cards-chart", 1, stats.total.redCards, totalCards, yArc);

        // Legends
        const updateLegend = (id, idx, text) => {
            const el = document.getElementById(id);
            if (el && el.querySelectorAll("div")[idx])
                el.querySelectorAll("div")[idx].innerHTML = text;
        };

        updateLegend(
            "results-legend",
            0,
            `<span class="dot green"></span> Ganados (${stats.total.pg})`,
        );
        updateLegend(
            "results-legend",
            1,
            `<span class="dot orange"></span> Empatados (${stats.total.pe})`,
        );
        updateLegend(
            "results-legend",
            2,
            `<span class="dot red"></span> Perdidos (${stats.total.pp})`,
        );

        updateLegend(
            "cards-legend",
            0,
            `<span class="dot yellow"></span> Amarillas (${stats.total.yellowCards})`,
        );
        updateLegend(
            "cards-legend",
            1,
            `<span class="dot red"></span> Rojas (${stats.total.redCards})`,
        );
    }

    function updateTable(stats) {
        const table = document.querySelector(".stats-table tbody");
        if (!table) return;
        const row = (label, d) =>
            `<td>${label}</td><td>${d.pj}</td><td>${d.pg}</td><td>${d.percPG}%</td><td>${d.pe}</td><td>${d.percPE}%</td><td>${d.pp}</td><td>${d.percPP}%</td><td class="highlight-yellow">${d.gf}</td><td class="highlight-red">${d.gc}</td><td class="highlight-blue">${d.dif > 0 ? "+" : ""}${d.dif}</td><td>${d.avg}</td>`;
        table.innerHTML = `<tr>${row("LOCAL", stats.home)}</tr><tr>${row("VISITANTE", stats.away)}</tr><tr class="total-row">${row("<strong>TOTAL</strong>", stats.total)}</tr>`;
    }

    const seasonFilter = document.getElementById("season-filter");
    if (seasonFilter) {
        seasonFilter.addEventListener("change", () => {
            const selected = seasonFilter.value;
            const filtered =
                selected === "all"
                    ? initialMatches
                    : initialMatches.filter((m) => m.season === selected);
            const newStats = calculateStatsLocal(filtered);
            updateCharts(newStats);
            updateTable(newStats);
        });
    }

    const showMore = document.getElementById("show-more-matches");
    if (showMore) {
        showMore.addEventListener("click", () => {
            document.querySelectorAll(".hidden-match").forEach((r) => {
                r.classList.remove("hidden-match");
                r.style.display = "table-row";
            });
            showMore.parentElement.style.display = "none";
        });
    }
</script>

