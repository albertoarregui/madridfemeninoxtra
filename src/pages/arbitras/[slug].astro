                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Volver a Árbitras
        </a>

        <div class="rival-grid">
            <div class="left-column">
                <section class="rival-card">
                    <h2 class="section-header">FICHA DE ÁRBITRA</h2>
