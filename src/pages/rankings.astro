---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import { fetchRankingsDirectly, fetchPlayerStreaks } from "../utils/rankings";
import { fetchPlayerAwards } from "../utils/awards";
import StatsRankings from "../components/StatsRankings.astro";

const rankingsData = await fetchRankingsDirectly();
const streaksData = await fetchPlayerStreaks();
const awardsData = await fetchPlayerAwards();

const uniqueSeasons = [
    ...new Set(
        rankingsData.map((g) => g.temporada).filter((s): s is string => !!s),
    ),
]
    .sort()
    .reverse(); // Latest season first

const competitionOrder = [
    "Liga F",
    "UWCL",
    "Copa de la Reina",
    "Supercopa de España",
    "Amistosos",
];

const uniqueCompetitions = [
    ...new Set(
        rankingsData.map((g) => g.competicion).filter((c): c is string => !!c),
    ),
].sort((a, b) => {
    const indexA = competitionOrder.indexOf(a);
    const indexB = competitionOrder.indexOf(b);

    if (indexA !== -1 && indexB !== -1) return indexA - indexB;
    if (indexA !== -1) return -1;
    if (indexB !== -1) return 1;
    return a.localeCompare(b);
});
---

<Layout
    title=" Rankings y Estadísticas | Madrid Femenino Xtra"
    description="Consulta las líderes históricas del Real Madrid Femenino por temporada y competición. Rankings de máximas goleadoras, asistentes, partidos y minutos."
>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <h1 class="page-title">RANKINGS</h1>

        <h2 class="content-h2 text-left text-pretty">
            Consulta las líderes históricas, tanto por competición como por
            temporada, en las diferentes estadísticas del Real Madrid Femenino.
        </h2>

        {
            rankingsData.length > 0 ? (
                <StatsRankings
                    rankingsData={rankingsData}
                    streaksData={streaksData}
                    awardsData={awardsData}
                    seasons={uniqueSeasons}
                    competitions={uniqueCompetitions}
                />
            ) : (
                <p style="text-align: center; color: red; font-size: 1.2em; padding: 2rem;">
                    Error al cargar datos o no se encontraron registros.
                    Comprueba la conexión a Turso o tu API endpoint.
                </p>
            )
        }
    </main>
</Layout>
