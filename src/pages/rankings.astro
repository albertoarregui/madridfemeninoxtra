---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import { fetchRankingsDirectly } from "../utils/rankings";
import StatsRankings from "../components/StatsRankings.astro";

const rankingsData = await fetchRankingsDirectly();

const uniqueSeasons = [
    ...new Set(
        rankingsData.map((g) => g.temporada).filter((s): s is string => !!s),
    ),
].sort();
const uniqueCompetitions = [
    ...new Set(
        rankingsData.map((g) => g.competicion).filter((c): c is string => !!c),
    ),
].sort();
---

<Layout
    title=" Rankings y Estadísticas | Madrid Femenino Xtra"
    description="Consulta todos los rankings de estadísticas del Real Madrid Femenino: goles, asistencias, partidos, minutos y más."
>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <h1 class="page-title">RANKINGS</h1>

        <h2 class="content-h2 text-center text-pretty max-w-4xl mx-auto">
            Consulta los líderes históricos y por temporada en todas las
            categorías estadísticas del Real Madrid Femenino.
        </h2>

        {
            rankingsData.length > 0 ? (
                <StatsRankings
                    rankingsData={rankingsData}
                    seasons={uniqueSeasons}
                    competitions={uniqueCompetitions}
                />
            ) : (
                <p style="text-align: center; color: red; font-size: 1.2em; padding: 2rem;">
                    Error al cargar datos o no se encontraron registros.
                    Comprueba la conexión a Turso o tu API endpoint.
                </p>
            )
        }
    </main>
</Layout>
