---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import { fetchRivalsDirectly } from "../utils/rivales";
import Rivals from "../sections/Rivals.astro";
---

<Layout
    title="Rivales del Real Madrid Femenino | Madrid Femenino Xtra"
    description="Todos los rivales del Real Madrid Femenino: historial, resultados, porcentaje 
    de victorias, goles, porterías a cero, y máximas goleadoras y asistentes."
>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <h1 class="page-title">RIVALES</h1>

        <h2 class="content-h2">
            Todos los rivales del Real Madrid Femenino a lo largo de su
            historia: resultados, porcentaje de victorias, goles a favor, goles
            en contra, porterías a cero, y máximas goleadoras y asistentes.
            Sigue toda la actualidad del Real Madrid en Madrid Femenino Xtra.
        </h2>

        <Rivals />
    </main>
</Layout>
