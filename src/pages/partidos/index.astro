---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import { fetchGamesDirectly, fetchAllGoals } from "../../utils/partidos";
import MatchList from "../../components/MatchList.astro";
import MatchMapWrapper from "../../components/MatchMapWrapper";
import MatchStatsDashboard from "../../components/MatchStatsDashboard";
import ClubStatsDashboard from "../../components/ClubStatsDashboard";

const gamesDataDB = await fetchGamesDirectly();
const allGoalsDB = await fetchAllGoals();

const gamesData = gamesDataDB;
const allGoals = allGoalsDB;

const uniqueSeasons = [
    ...new Set(gamesData.map((g) => g.temporada_nombre).filter((s) => s)),
]
    .sort()
    .reverse();

const competitionOrder = [
    "Liga F",
    "UWCL",
    "Copa de la Reina",
    "Supercopa de España",
    "Amistosos",
];

const uniqueCompetitions = [
    ...new Set(gamesData.map((g) => g.competicion_nombre).filter((c) => c)),
].sort((a, b) => {
    const titleA = a as string;
    const titleB = b as string;
    const indexA = competitionOrder.indexOf(titleA);
    const indexB = competitionOrder.indexOf(titleB);

    if (indexA !== -1 && indexB !== -1) return indexA - indexB;
    if (indexA !== -1) return -1;
    if (indexB !== -1) return 1;
    return titleA.localeCompare(titleB);
});
---

<Layout
    title="Partidos del Real Madrid Femenino | Madrid Femenino Xtra"
    description="Todos los partidos del Real Madrid Femenino a lo largo de su historia: resultados, calendario 2025/26, alineaciones, goles, estadios y árbitras."
>
    <main class="w-full max-w-7xl mx-auto">
        <header class="page-header-container">
            <h1 class="landing-title">PARTIDOS</h1>
            <p class="landing-subtitle">Todos los partidos del Real Madrid Femenino a lo largo de su historia</p>
        </header>

        {
            gamesData.length > 0 ? (
                <>
                    <MatchStatsDashboard
                        matches={gamesData}
                        client:only="react"
                    />

                    <MatchMapWrapper matches={gamesData} client:only="react" />

                    <MatchList
                        matches={gamesData}
                        seasons={uniqueSeasons}
                        competitions={uniqueCompetitions}
                    />
                </>
            ) : (
                <p style="text-align: center; color: red; font-size: 1.2em; padding: 2rem;">
                    Error al cargar datos o no se encontraron partidos.
                </p>
            )
        }
    </main>
</Layout>

<style>
    .victoria {
        color: #16a34a;
    }
    .derrota {
        color: #dc2626;
    }
    .empate {
        color: #ca8a04;
    }
</style>


