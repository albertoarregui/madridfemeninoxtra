---
import Layout from "../../layouts/Layout.astro";
import {
    fetchGamesDirectly,
    fetchMatchLineups,
    fetchMatchSubstitutions,
    fetchStadiumStats,
    fetchRefereeStats,
    fetchMatchEvents,
    fetchMatchKit,
    slugify,
} from "../../utils/partidos";
import { getPlayerImage } from "../../utils/player-images";
import { v2 as cloudinary } from "cloudinary";
import { getAssetUrl } from "../../utils/assets";
import PlayerStatsModal from "../../components/PlayerStatsModal.astro";

cloudinary.config({
    cloud_name: import.meta.env.CLOUDINARY_CLOUD_NAME,
    api_key: import.meta.env.CLOUDINARY_API_KEY,
    api_secret: import.meta.env.CLOUDINARY_API_SECRET,
    secure: true,
});

const { slug } = Astro.params;

const allGames = await fetchGamesDirectly();
const game = allGames.find((g) => g.slug === slug);

if (!game) {
    return Astro.redirect("/404");
}

const formatDate = (dateString: string | null | undefined): string => {
    if (!dateString) return "-";
    try {
        const date = new Date(dateString);
        if (isNaN(date.getTime())) return "-";
        return date.toLocaleDateString("es-ES", {
            day: "2-digit",
            month: "2-digit",
            year: "numeric",
        });
    } catch {
        return "-";
    }
};

const formatTime = (timeString: string | null | undefined): string => {
    if (!timeString) return "-";
    return timeString.substring(0, 5);
};

const lineup = await fetchMatchLineups(game.id_partido);
const subs = await fetchMatchSubstitutions(game.id_partido);
const timelineEvents = await fetchMatchEvents(game.id_partido, game.goles_rm);
const stadiumStats = await fetchStadiumStats(game.estadio);
const matchKit = await fetchMatchKit(game.id_partido);

let mvpPlayer;

const slugifyForImages = (text: string | null | undefined): string => {
    if (!text) return "";
    return text
        .toLowerCase()
        .trim()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/[-\s]+/g, "_");
};

mvpPlayer = {
    name: game.mvp
        ? game.mvp_nombre || `MVP #${game.mvp}`
        : "MVP no disponible",
    image:
        game.mvp && game.mvp_nombre
            ? getPlayerImage(slugifyForImages(game.mvp_nombre))
            : null,
    id: game.mvp ? String(game.mvp) : "unknown",
};

const isRMEstadio =
    game.estadio &&
    (game.estadio.toLowerCase().includes("alfredo di stefano") ||
        game.estadio.toLowerCase().includes("santiago bernabeu"));

const stadiumUrl = game.estadio_foto_url;
const hasExternalStadium =
    stadiumUrl &&
    typeof stadiumUrl === "string" &&
    (stadiumUrl.startsWith("http://") || stadiumUrl.startsWith("https://"));
const stadiumImageSrc = hasExternalStadium
    ? stadiumUrl
    : getAssetUrl("estadios", game.estadio);

const getShieldSrc = (
    teamName: string | null | undefined,
    remoteUrl?: string | null | undefined,
) => {
    if (
        remoteUrl &&
        typeof remoteUrl === "string" &&
        (remoteUrl.startsWith("http://") || remoteUrl.startsWith("https://"))
    ) {
        return remoteUrl;
    }
    return getAssetUrl("escudos", teamName || "placeholder");
};

const localShield = getShieldSrc(game.club_local, game.local_foto_url);
const visitorShield = getShieldSrc(
    game.club_visitante,
    game.visitante_foto_url,
);

const refereeStats = game.id_arbitra
    ? await fetchRefereeStats(game.id_arbitra)
    : null;

const isLocalRM =
    game.club_local?.toLowerCase().includes("real madrid") ?? false;

const arbitraSlug = game.arbitra_nombre ? slugify(game.arbitra_nombre) : "";
const estadioSlug = game.estadio ? slugify(game.estadio) : "";

let galleryImages: string[] = [];
try {
    const folder = `galeries/${game.id_partido}`;
    const result = await (cloudinary as any).api.resources({
        type: "upload",
        prefix: folder,
        max_results: 100,
    });
    if (result.resources && result.resources.length > 0) {
        galleryImages = result.resources.map((resource: any) => {
            return cloudinary.url(resource.public_id, {
                transformation: [
                    {
                        overlay: "marca_agua",
                        gravity: "north_east",
                        x: 20,
                        y: 20,
                        width: 0.2,
                        flags: "relative",
                        opacity: 60,
                    },
                    { fetch_format: "auto", quality: "auto" },
                ],
            });
        });
    }
} catch (error) {}
---

<Layout
    title={`${game.club_local} vs ${game.club_visitante} | Madrid Femenino Xtra`}
    description={`Resultado y estadísticas del partido ${game.club_local} vs ${game.club_visitante}. Alineaciones, goles y crónica completa.`}>
    <main class="match-details-page">
        <a href="/partidos" class="back-link">
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Volver al resto de partidos
        </a>
        <div class="match-header-grid">
            <section class="match-card-new">
                <h2 class="section-header">FICHA DEL PARTIDO</h2>
                <div class="match-content-body">
                    <div class="match-metadata-top">
                        <span class="metadata-text">
                            {game.competicion_nombre}
                            {
                                (() => {
                                    const jornada = game.jornada;
                                    if (!jornada) return "";
                                    const lower = String(jornada).toLowerCase();
                                    if (lower.includes("amistoso")) return "";
                                    if (!isNaN(Number(jornada)))
                                        return ` (J${jornada})`;
                                    return ` (${jornada})`;
                                })()
                            }
                            <span class="bullet">•</span>
                            {formatDate(game.fecha)} - {formatTime(game.hora)}
                        </span>
                    </div>
                    <div class="match-main-content">
                        <div class="team-block-large">
                            <div class="shield-container-large">
                                {
                                    localShield && (
                                        <img
                                            src={localShield}
                                            alt={game.club_local}
                                            class="team-shield-xl"
                                        />
                                    )
                                }
                            </div>
                            <span class="team-name-xl">{game.club_local}</span>
                        </div>
                        <div class="score-block-large">
                            <span class="score-xl">
                                {
                                    game.club_local
                                        .toLowerCase()
                                        .includes("real madrid")
                                        ? game.goles_rm
                                        : game.goles_rival
                                } - {
                                    game.club_local
                                        .toLowerCase()
                                        .includes("real madrid")
                                        ? game.goles_rival
                                        : game.goles_rm
                                }
                            </span>
                        </div>
                        <div class="team-block-large">
                            <div class="shield-container-large">
                                {
                                    visitorShield && (
                                        <img
                                            src={visitorShield}
                                            alt={game.club_visitante}
                                            class="team-shield-xl"
                                        />
                                    )
                                }
                            </div>
                            <span class="team-name-xl"
                                >{game.club_visitante}</span
                            >
                        </div>
                    </div>
                    <div class="match-metadata-bottom">
                        {
                            game.arbitra_nombre ? (
                                <a
                                    href={`/arbitras/${arbitraSlug}`}
                                    class="referee-btn hover:text-[#ffde59] transition-colors decoration-none"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="icon icon-tabler icons-tabler-outline icon-tabler-user"
                                    >
                                        <path
                                            stroke="none"
                                            d="M0 0h24v24H0z"
                                            fill="none"
                                        />
                                        <path d="M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0" />
                                        <path d="M6 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2" />
                                    </svg>
                                    {game.arbitra_nombre}
                                </a>
                            ) : (
                                <span class="referee-text">
                                    Árbitra no disponible
                                </span>
                            )
                        }
                    </div>
                </div>
            </section>
            <section class="stadium-card">
                <h2 class="section-header">Estadio</h2>
                <div class="stadium-content">
                    <div class="stadium-photo">
                        {
                            stadiumImageSrc && (
                                <img
                                    src={stadiumImageSrc}
                                    alt={game.estadio}
                                    class="stadium-img-rect"
                                />
                            )
                        }
                    </div>
                    <div class="stadium-info">
                        <p class="stadium-name-large">
                            <a
                                href={`/estadios/${estadioSlug}`}
                                class="hover:text-[#ffde59] transition-colors decoration-none"
                            >
                                {game.estadio || "Estadio"}
                            </a>
                        </p>
                        <div class="stadium-meta">
                            <p>
                                <strong>Aforo:</strong>
                                {
                                    game.capacidad
                                        ? `${game.capacidad} espectadores`
                                        : "Info no disponible"
                                }
                            </p>
                            <p>
                                <strong>Ubicación:</strong>
                                {
                                    game.ciudad && game.pais
                                        ? `${game.ciudad} (${game.pais})`
                                        : "Ubicación desconocida"
                                }
                            </p>
                        </div>
                    </div>
                    {
                        stadiumStats.total > 0 && (
                            <div class="stadium-stats">
                                <div class="stat-bar">
                                    <div class="bar-label">Ganados</div>
                                    <div class="progress-track">
                                        <div
                                            class="bar-fill won"
                                            style={`width: ${(stadiumStats.wins / stadiumStats.total) * 100}%`}
                                        >
                                            <span class="bar-text">
                                                {stadiumStats.wins}
                                            </span>
                                        </div>
                                    </div>
                                </div>
                                <div class="stat-bar">
                                    <div class="bar-label">Empatados</div>
                                    <div class="progress-track">
                                        <div
                                            class="bar-fill drawn"
                                            style={`width: ${(stadiumStats.draws / stadiumStats.total) * 100}%`}
                                        >
                                            <span class="bar-text">
                                                {stadiumStats.draws}
                                            </span>
                                        </div>
                                    </div>
                                </div>
                                <div class="stat-bar">
                                    <div class="bar-label">Perdidos</div>
                                    <div class="progress-track">
                                        <div
                                            class="bar-fill lost"
                                            style={`width: ${(stadiumStats.losses / stadiumStats.total) * 100}%`}
                                        >
                                            <span class="bar-text">
                                                {stadiumStats.losses}
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        )
                    }
                </div>
            </section>
        </div>
        <div class="match-grid">
            <div class="left-column">
                <div
                    id="referee-modal"
                    class="modal-overlay"
                    style="display: none;"
                >
                    <div class="modal-content">
                        <div class="modal-header">
                            <h3 id="modal-referee-name">Nombre Árbitra</h3>
                            <button
                                class="close-btn"
                                onclick="closeRefereeModal()"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="24"
                                    height="24"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><path
                                        stroke="none"
                                        d="M0 0h24v24H0z"
                                        fill="none"></path><path
                                        d="M18 6l-12 12"></path><path
                                        d="M6 6l12 12"></path></svg
                                >
                            </button>
                        </div>
                        <div class="modal-body">
                            <div class="stat-row">
                                <div class="stat-item result win">
                                    <span class="stat-val" id="ref-wins">0</span
                                    >
                                    <span class="stat-label">Victorias</span>
                                </div>
                                <div class="stat-item result draw">
                                    <span class="stat-val" id="ref-draws"
                                        >0</span
                                    >
                                    <span class="stat-label">Empates</span>
                                </div>
                                <div class="stat-item result loss">
                                    <span class="stat-val" id="ref-losses"
                                        >0</span
                                    >
                                    <span class="stat-label">Derrotas</span>
                                </div>
                            </div>
                            <div class="card-stats-row">
                                <div class="card-stat yellow">
                                    <div class="card-icon yellow-card"></div>
                                    <span class="card-count" id="ref-yellows"
                                        >0</span
                                    >
                                </div>
                                <div class="card-stat red">
                                    <div class="card-icon red-card"></div>
                                    <span class="card-count" id="ref-reds"
                                        >0</span
                                    >
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <section class="lineup-card">
                    <h2 class="section-header">XI TITULAR</h2>
                    <div class="lineup-list">
                        {
                            lineup.map((player: any) => (
                                <div
                                    class="lineup-row clickable-player-row"
                                    data-player={encodeURIComponent(
                                        JSON.stringify(player),
                                    )}
                                    role="button"
                                    tabindex="0"
                                >
                                    <div class="player-photo-rect">
                                        {player.imageUrl &&
                                            !player.imageUrl.includes(
                                                "placeholder.png",
                                            ) && (
                                                <img
                                                    src={player.imageUrl}
                                                    alt={player.name}
                                                    class="player-img-rect"
                                                />
                                            )}
                                    </div>
                                    <span class="player-number-bold">
                                        {player.number}
                                    </span>
                                    <div class="player-info-col">
                                        <div class="player-name-row">
                                            <span class="player-name-bold">
                                                {player.name}
                                            </span>
                                        </div>
                                        <div class="player-meta-row">
                                            <span class="player-pos-label">
                                                {player.pos}
                                            </span>
                                            <span class="separator">•</span>
                                            <span
                                                class="player-minutes"
                                                title="Minutos jugados"
                                            >
                                                {player.minutes}'
                                            </span>
                                            {player.goals > 0 && (
                                                <span
                                                    class="event-icon-small"
                                                    title={`${player.goals} Goles`}
                                                >
                                                    <svg
                                                        xmlns="http://www.w3.org/2000/svg"
                                                        width="14"
                                                        height="14"
                                                        viewBox="0 0 24 24"
                                                        fill="none"
                                                        stroke="currentColor"
                                                        stroke-width="2"
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        class="icon icon-tabler icons-tabler-outline icon-tabler-ball-football"
                                                    >
                                                        <path
                                                            stroke="none"
                                                            d="M0 0h24v24H0z"
                                                            fill="none"
                                                        />
                                                        <path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0" />
                                                        <path d="M12 7l4.76 3.45l-1.76 5.55h-6l-1.76 -5.55z" />
                                                        <path d="M12 7v-4m3 13l2.5 3m-.74 -8.55l3.74 -1.45m-11.44 7.05l-2.56 2.95m.74 -8.55l-3.74 -1.45" />
                                                    </svg>
                                                    {player.goals > 1 && (
                                                        <span class="count-sub">
                                                            {player.goals}
                                                        </span>
                                                    )}
                                                </span>
                                            )}
                                            {player.assists > 0 && (
                                                <span
                                                    class="event-icon-small"
                                                    title={`${player.assists} Asistencias`}
                                                >
                                                    <svg
                                                        xmlns="http://www.w3.org/2000/svg"
                                                        width="14"
                                                        height="14"
                                                        viewBox="0 0 24 24"
                                                        fill="currentColor"
                                                        class="icon icon-tabler icons-tabler-filled icon-tabler-gift"
                                                    >
                                                        <path
                                                            stroke="none"
                                                            d="M0 0h24v24H0z"
                                                            fill="none"
                                                        />
                                                        <path d="M11 14v8h-4a3 3 0 0 1 -3 -3v-4a1 1 0 0 1 1 -1h6zm8 0a1 1 0 0 1 1 1v4a3 3 0 0 1 -3 3h-4v-8h6zm-2.5 -12a3.5 3.5 0 0 1 3.163 5h.337a2 2 0 0 1 2 2v1a2 2 0 0 1 -2 2h-7v-5h-2v5h-7a2 2 0 0 1 -2 -2v-1a2 2 0 0 1 2 -2h.337a3.486 3.486 0 0 1 -.337 -1.5c0 -1.933 1.567 -3.5 3.483 -3.5c1.755 -.03 3.312 1.092 4.381 2.934l.136 .243c1.033 -1.914 2.56 -3.114 4.291 -3.175l.209 -.002zm-9 2a1.5 1.5 0 0 0 0 3h3.143c-.741 -1.905 -1.949 -3.02 -3.143 -3zm8.983 0c-1.18 -.02 -2.385 1.096 -3.126 3h3.143a1.5 1.5 0 1 0 -.017 -3z" />
                                                    </svg>
                                                    {player.assists > 1 && (
                                                        <span class="count-sub">
                                                            {player.assists}
                                                        </span>
                                                    )}
                                                </span>
                                            )}
                                            {player.doubleYellows > 0 && (
                                                <span
                                                    style="position: relative; width: 14px; height: 12px; display: inline-flex; margin-right: 4px;"
                                                    title="Doble Amarilla"
                                                >
                                                    <span
                                                        class="card-icon-small yellow"
                                                        style="position: absolute; left: 0; transform: rotate(-10deg);"
                                                    />
                                                    <span
                                                        class="card-icon-small red"
                                                        style="position: absolute; left: 4px; transform: rotate(10deg);"
                                                    />
                                                </span>
                                            )}
                                            {player.yellowCards > 0 && (
                                                <span
                                                    class="card-icon-small yellow"
                                                    title="Tarjeta Amarilla"
                                                />
                                            )}
                                            {player.redCards > 0 && (
                                                <span
                                                    class="card-icon-small red"
                                                    title="Tarjeta Roja"
                                                />
                                            )}
                                            {player.substituted && (
                                                <span
                                                    class="sub-indicator"
                                                    title="Sustituida"
                                                    style="color: #ff6b6b;"
                                                >
                                                    <svg
                                                        xmlns="http://www.w3.org/2000/svg"
                                                        width="20"
                                                        height="20"
                                                        viewBox="0 0 24 24"
                                                        fill="currentColor"
                                                        class="icon icon-tabler icons-tabler-filled icon-tabler-arrow-big-left"
                                                    >
                                                        <path
                                                            stroke="none"
                                                            d="M0 0h24v24H0z"
                                                            fill="none"
                                                        />
                                                        <path d="M9.586 4l-6.586 6.586a2 2 0 0 0 0 2.828l6.586 6.586a2 2 0 0 0 2.18 .434l.145 -.068a2 2 0 0 0 1.089 -1.78v-2.586h7a2 2 0 0 0 2 -2v-4l-.005 -.15a2 2 0 0 0 -1.995 -1.85l-7 -.001v-2.585a2 2 0 0 0 -3.414 -1.414z" />
                                                    </svg>
                                                </span>
                                            )}
                                        </div>
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </section>
                <section class="subs-card">
                    <h2 class="section-header">Sustituciones</h2>
                    <div class="lineup-list">
                        {
                            subs.map((sub: any) => (
                                <div class="sub-row">
                                    <div class="sub-time">{sub.minute}'</div>
                                    <div class="sub-movement in">
                                        <span
                                            class="sub-arrow"
                                            style="color: #77dd77;"
                                        >
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                width="24"
                                                height="24"
                                                viewBox="0 0 24 24"
                                                fill="currentColor"
                                                class="icon icon-tabler icons-tabler-filled icon-tabler-arrow-big-right"
                                            >
                                                <path
                                                    stroke="none"
                                                    d="M0 0h24v24H0z"
                                                    fill="none"
                                                />
                                                <path d="M12.089 3.634a2 2 0 0 0 -1.089 1.78l-.001 2.586h-6.999a2 2 0 0 0 -2 2v4l.005 .15a2 2 0 0 0 1.995 1.85l6.999 -.001l.001 2.587a2 2 0 0 0 3.414 1.414l6.586 -6.586a2 2 0 0 0 0 -2.828l-6.586 -6.586a2 2 0 0 0 -2.18 -.434l-.145 .068z" />
                                            </svg>
                                        </span>
                                        <div
                                            class="sub-player-link clickable-player-row"
                                            data-player={JSON.stringify(
                                                sub.playerIn,
                                            )}
                                            role="button"
                                            tabindex="0"
                                        >
                                            {sub.playerIn.imageUrl &&
                                                !sub.playerIn.imageUrl.includes(
                                                    "placeholder.png",
                                                ) && (
                                                    <img
                                                        src={
                                                            sub.playerIn
                                                                .imageUrl
                                                        }
                                                        class="sub-img"
                                                    />
                                                )}
                                            <span class="sub-name">
                                                {sub.playerIn.name}
                                            </span>
                                            {sub.playerIn.goals > 0 && (
                                                <span
                                                    class="event-icon-small"
                                                    title={`${sub.playerIn.goals} Goles`}
                                                >
                                                    <svg
                                                        xmlns="http://www.w3.org/2000/svg"
                                                        width="14"
                                                        height="14"
                                                        viewBox="0 0 24 24"
                                                        fill="none"
                                                        stroke="currentColor"
                                                        stroke-width="2"
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        class="icon icon-tabler icons-tabler-outline icon-tabler-ball-football"
                                                    >
                                                        <path
                                                            stroke="none"
                                                            d="M0 0h24v24H0z"
                                                            fill="none"
                                                        />
                                                        <path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0" />
                                                        <path d="M12 7l4.76 3.45l-1.76 5.55h-6l-1.76 -5.55z" />
                                                        <path d="M12 7v-4m3 13l2.5 3m-.74 -8.55l3.74 -1.45m-11.44 7.05l-2.56 2.95m.74 -8.55l-3.74 -1.45" />
                                                    </svg>
                                                </span>
                                            )}
                                            {sub.playerIn.assists > 0 && (
                                                <span
                                                    class="event-icon-small"
                                                    title={`${sub.playerIn.assists} Asistencias`}
                                                >
                                                    <svg
                                                        xmlns="http://www.w3.org/2000/svg"
                                                        width="14"
                                                        height="14"
                                                        viewBox="0 0 24 24"
                                                        fill="currentColor"
                                                        class="icon icon-tabler icons-tabler-filled icon-tabler-gift"
                                                    >
                                                        <path
                                                            stroke="none"
                                                            d="M0 0h24v24H0z"
                                                            fill="none"
                                                        />
