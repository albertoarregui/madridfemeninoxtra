---
import Layout from "../../layouts/Layout.astro";
import { fetchGamesDirectly } from "../../utils/partidos";

export async function getStaticPaths() {
    const allGames = await fetchGamesDirectly();

    return allGames.map((game) => ({
        params: { slug: game.slug },
        props: { game },
    }));
}

const { game } = Astro.props;

const formatDate = (dateString: string | null | undefined): string => {
    if (!dateString) return "-";
    try {
        const date = new Date(dateString);
        if (isNaN(date.getTime())) return "-";
        return date.toLocaleDateString("es-ES", {
            day: "2-digit",
            month: "2-digit",
            year: "numeric",
        });
    } catch {
        return "-";
    }
};

const formatTime = (timeString: string | null | undefined): string => {
    if (!timeString) return "-";
    return timeString.substring(0, 5); // Extract HH:MM
};

// Empty data arrays - to be populated with real database data
const mockLineup: any[] = [];
const mockSubs: any[] = [];
const mockTimeline: any[] = [];
---

<Layout
    title={`${game.club_local} vs ${game.club_visitante} - Partido | Madrid Femenino Xtra`}
    description={`Resultado y estadísticas del partido ${game.club_local} vs ${game.club_visitante}. Alineaciones, goles y crónica completa.`}
>
    <main class="match-details-page">
        <a href="/partidos" class="back-link">
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Volver al listado
        </a>

        <div class="match-grid">
            <!-- LEFT COLUMN -->
            <div class="left-column">
                <!-- FICHA DE PARTIDO -->
                <section class="match-card">
                    <h2 class="section-header">Ficha de partido</h2>
                    <div class="match-result">
                        <div class="team-info">
                            <div class="team-badge">
                                <div class="badge-placeholder"></div>
                            </div>
                            <span class="team-name">{game.club_local}</span>
                        </div>
                        <div class="score">
                            <span class="score-number">{game.goles_rm}</span>
                            <span class="score-separator">-</span>
                            <span class="score-number">{game.goles_rival}</span>
                        </div>
                        <div class="team-info">
                            <span class="team-name">{game.club_visitante}</span>
                            <div class="team-badge">
                                <div class="badge-placeholder"></div>
                            </div>
                        </div>
                    </div>
                    <div class="match-info-grid">
                        <div class="info-item">
                            <span class="info-icon">🏆</span>
                            <span class="info-text"
                                >{game.competicion_nombre} (J{
                                    game.jornada
                                })</span
                            >
                        </div>
                        <div class="info-item">
                            <span class="info-icon">📅</span>
                            <span class="info-text"
                                >{formatDate(game.fecha)} - {
                                    formatTime(game.hora)
                                }</span
                            >
                        </div>
                        <div class="info-item">
                            <span class="info-icon">🏟️</span>
                            <span class="info-text"
                                >{game.estadio || "Stadium"}</span
                            >
                        </div>
                        <div class="info-item">
                            <span class="info-icon">👔</span>
                            <span class="info-text"
                                >{game.arbitra_nombre || "Árbitro"}</span
                            >
                        </div>
                    </div>
                </section>

                <!-- EQUIPOS TITULARES -->
                <section class="lineup-card">
                    <h2 class="section-header">Equipos titulares</h2>
                    <div class="lineup-list">
                        {
                            mockLineup.map((player) => (
                                <div class="lineup-row">
                                    <span class="player-pos">{player.pos}</span>
                                    <div class="team-badge-small">
                                        <div class="badge-placeholder-small" />
                                    </div>
                                    <span class="player-name">
                                        {player.name}
                                    </span>
                                    <div class="player-photo-small">
                                        <div class="photo-placeholder" />
                                    </div>
                                    <span class="player-number">
                                        {player.number}
                                    </span>
                                </div>
                            ))
                        }
                    </div>
                </section>

                <section class="subs-card">
                    <h2 class="section-header">Sustituciones</h2>
                    <div class="lineup-list">
                        {
                            mockSubs.map((player) => (
                                <div class="lineup-row">
                                    <span class="player-pos">{player.pos}</span>
                                    <div class="team-badge-small">
                                        <div class="badge-placeholder-small" />
                                    </div>
                                    <span class="player-name">
                                        {player.name}
                                    </span>
                                    <div class="player-photo-small">
                                        <div class="photo-placeholder" />
                                    </div>
                                    <span class="player-number">
                                        {player.number}
                                    </span>
                                </div>
                            ))
                        }
                    </div>
                </section>

                <section class="timeline-card">
                    <h2 class="section-header">Timeline del partido</h2>
                    <div class="timeline-container">
                        <div class="timeline-left-badge">
                            <div class="badge-placeholder-small"></div>
                        </div>
                        <div class="timeline-track">
                            {
                                mockTimeline.map((event, index) => (
                                    <div class="timeline-event">
                                        <div class="event-time">
                                            <span class="minute-badge">
                                                {event.minute}'
                                            </span>
                                        </div>
                                        <div class="event-content">
                                            <div
                                                class={`event-icon ${event.type}`}
                                            />
                                            <span class="event-text">
                                                {event.text}
                                            </span>
                                        </div>
                                    </div>
                                ))
                            }
                        </div>
                        <div class="timeline-right-badge">
                            <div class="badge-placeholder-small"></div>
                        </div>
                    </div>
                </section>
            </div>

            <div class="right-column">
                <section class="stadium-card">
                    <h2 class="section-header">Estadio</h2>
                    <div class="stadium-content">
                        <div class="stadium-photo">
                            <div class="photo-placeholder-large"></div>
                        </div>
                        <div class="stadium-info">
                            <p>
                                <strong>Nombre:</strong>
                                {game.estadio || "Vallecas"}
                            </p>
                            <p><strong>Aforo:</strong> 14,708 espectadores</p>
                            <p>
                                <strong>Ubicación:</strong> Madrid (Madrid) 🇪🇸
                            </p>
                            <p><strong>Inauguración:</strong> 10/05/1976</p>
                        </div>
                        <div class="stadium-stats">
                            <div class="stat-bar">
                                <div class="bar-label">Ganados</div>
                                <div
                                    class="bar-fill"
                                    style="width: 60%; background: #ffcccc;"
                                >
                                </div>
                            </div>
                            <div class="stat-bar">
                                <div class="bar-label">Empatados</div>
                                <div
                                    class="bar-fill"
                                    style="width: 30%; background: #cce5ff;"
                                >
                                </div>
                            </div>
                            <div class="stat-bar">
                                <div class="bar-label">Perdidos</div>
                                <div
                                    class="bar-fill"
                                    style="width: 10%; background: #ffffcc;"
                                >
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </main>

    <style>
        .match-details-page {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: #666;
            text-decoration: none;
            font-weight: 600;
            margin-bottom: 1.5rem;
            transition: color 0.3s;
        }

        .back-link:hover {
            color: #ffde59;
        }

        .match-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 1.5rem;
        }

        .left-column,
        .right-column {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .section-header {
            background: #ffde59;
            color: #2b2b2b;
            padding: 0.75rem 1rem;
            margin: 0;
            font-size: 1rem;
            font-weight: bold;
            text-transform: capitalize;
        }

        /* MATCH CARD */
        .match-card,
        .lineup-card,
        .subs-card,
        .timeline-card,
        .stadium-card,
        .rival-card,
        .records-card {
            background: white;
            border: 1px solid #ddd;
            border-radius: 8px;
            overflow: hidden;
        }

        .match-result {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.5rem;
            gap: 1rem;
        }

        .team-info {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
            flex: 1;
        }

        .team-badge {
            width: 60px;
            height: 60px;
        }

        .badge-placeholder,
        .badge-placeholder-small,
        .photo-placeholder,
        .photo-placeholder-large {
            width: 100%;
            height: 100%;
            background: #f0f0f0;
            border-radius: 50%;
        }

        .badge-placeholder-small {
            width: 30px;
            height: 30px;
        }

        .photo-placeholder-large {
            border-radius: 8px;
            height: 200px;
        }

        .team-name {
            font-weight: 600;
            font-size: 0.9rem;
            text-align: center;
        }

        .score {
            display: flex;
            gap: 0.5rem;
            align-items: center;
            font-size: 2.5rem;
            font-weight: bold;
        }

        .match-info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.5rem;
            padding: 1rem 1.5rem;
            background: #f9f9f9;
        }

        .info-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.85rem;
        }

        .info-icon {
            font-size: 1.2rem;
        }

        /* LINEUP */
        .lineup-list {
            display: flex;
            flex-direction: column;
        }

        .lineup-row {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            background: #fff5e6;
            border-bottom: 1px solid #ffe6cc;
        }

        .lineup-row:nth-child(even) {
            background: #ffebcc;
        }

        .player-pos {
            font-weight: bold;
            width: 30px;
            text-align: center;
        }

        .team-badge-small {
            width: 30px;
            height: 30px;
        }

        .player-name {
            flex: 1;
            font-weight: 600;
        }

        .player-photo-small {
            width: 40px;
            height: 40px;
        }

        .player-number {
            font-weight: bold;
            width: 40px;
            text-align: center;
        }

        /* TIMELINE */
        .timeline-container {
            position: relative;
            display: flex;
            padding: 1.5rem;
            gap: 1rem;
        }

        .timeline-left-badge,
        .timeline-right-badge {
            width: 50px;
            height: 50px;
            flex-shrink: 0;
        }

        .timeline-track {
            flex: 1;
            position: relative;
            padding-left: 2rem;
            border-left: 4px solid #ffde59;
        }

        .timeline-event {
            position: relative;
            margin-bottom: 1.5rem;
        }

        .event-time {
            position: absolute;
            left: -2.5rem;
            top: 0;
        }

        .minute-badge {
            background: #ffde59;
            color: #2b2b2b;
            padding: 0.25rem 0.5rem;
            border-radius: 12px;
            font-size: 0.85rem;
            font-weight: bold;
            white-space: nowrap;
        }

        .event-content {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .event-icon {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: #ddd;
        }

        .event-icon.goal {
            background: #16a34a;
        }

        .event-icon.yellow {
            background: #eab308;
        }

        .event-text {
            font-size: 0.9rem;
        }

        /* STADIUM */
        .stadium-content {
            padding: 1.5rem;
        }

        .stadium-photo {
            margin-bottom: 1rem;
        }

        .stadium-info {
            margin-bottom: 1.5rem;
        }

        .stadium-info p {
            margin: 0.5rem 0;
            font-size: 0.9rem;
        }

        .stadium-stats {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .stat-bar {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .bar-label {
            width: 100px;
            font-size: 0.85rem;
            font-weight: 600;
        }

        .bar-fill {
            height: 20px;
            border-radius: 4px;
        }

        /* RIVAL CHART */
        .rival-chart {
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
        }

        .donut-chart {
            width: 200px;
            height: 200px;
        }

        .chart-legend {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .legend-color {
            width: 20px;
            height: 20px;
            border-radius: 3px;
        }

        /* RECORDS */
        .records-list {
            padding: 1.5rem;
        }

        .record-row {
            display: flex;
            justify-content: space-between;
            padding: 0.75rem 0;
            border-bottom: 1px solid #eee;
        }

        .record-label {
            font-weight: 600;
        }

        .record-value {
            color: #ff6b00;
        }

        @media (max-width: 1024px) {
            .match-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .match-result {
                flex-direction: column;
            }

            .score {
                font-size: 2rem;
            }

            .match-info-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</Layout>
