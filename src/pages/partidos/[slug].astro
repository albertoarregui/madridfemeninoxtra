---
import Layout from "../../layouts/Layout.astro";
import {
    fetchGamesDirectly,
    fetchMatchLineups,
    fetchMatchSubstitutions,
    fetchStadiumStats,
    fetchMatchEvents,
} from "../../utils/partidos";

const { slug } = Astro.params;

const allGames = await fetchGamesDirectly();
const game = allGames.find((g) => g.slug === slug);

if (!game) {
    return Astro.redirect("/404");
}

const formatDate = (dateString: string | null | undefined): string => {
    if (!dateString) return "-";
    try {
        const date = new Date(dateString);
        if (isNaN(date.getTime())) return "-";
        return date.toLocaleDateString("es-ES", {
            day: "2-digit",
            month: "2-digit",
            year: "numeric",
        });
    } catch {
        return "-";
    }
};

const formatTime = (timeString: string | null | undefined): string => {
    if (!timeString) return "-";
    return timeString.substring(0, 5); // Extract HH:MM
};

// Data Fetching
const lineup = await fetchMatchLineups(game.id_partido);
const subs = await fetchMatchSubstitutions(game.id_partido);
const timelineEvents = await fetchMatchEvents(game.id_partido);
const stadiumStats = await fetchStadiumStats(game.estadio);

// Dynamic Stadium Images
const stadiumImages = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/estadios/*.{jpeg,jpg,png,webp}",
);
let stadiumImageSrc = null;

// Normalize stadium name to match filename (approx)
// e.g. "Alfredo Di Stéfano" -> "alfredo-di-stefano"
// naive matching: check if any file contains the stadium name slugified or part of it
if (game.estadio) {
    const slugName = game.estadio
        .toLowerCase()
        .replace(/ /g, "-")
        .replace(/[áéíóú]/g, (c: string) => "aeiou"["áéíóú".indexOf(c)]);
    // Try to find a key that includes this slug
    const matchingKey = Object.keys(stadiumImages).find((key) =>
        key.includes(slugName),
    );
    if (matchingKey) {
        const imgModule = await stadiumImages[matchingKey]();
        stadiumImageSrc = imgModule.default.src;
    }
}
---

<Layout
    title={`${game.club_local} vs ${game.club_visitante} - Partido | Madrid Femenino Xtra`}
    description={`Resultado y estadísticas del partido ${game.club_local} vs ${game.club_visitante}. Alineaciones, goles y crónica completa.`}
>
    <main class="match-details-page">
        <a href="/partidos" class="back-link">
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Volver al listado
        </a>

        <div class="match-grid">
            <!-- LEFT COLUMN -->
            <div class="left-column">
                <!-- FICHA DE PARTIDO -->
                <section class="match-card">
                    <h2 class="section-header">Ficha de partido</h2>
                    <div class="match-result">
                        <div class="team-info">
                            <div class="team-badge">
                                <div class="badge-placeholder"></div>
                            </div>
                            <span class="team-name">{game.club_local}</span>
                        </div>
                        <div class="score">
                            <span class="score-number">{game.goles_rm}</span>
                            <span class="score-separator">-</span>
                            <span class="score-number">{game.goles_rival}</span>
                        </div>
                        <div class="team-info">
                            <span class="team-name">{game.club_visitante}</span>
                            <div class="team-badge">
                                <div class="badge-placeholder"></div>
                            </div>
                        </div>
                    </div>
                    <div class="match-info-grid">
                        <div class="info-item">
                            <span class="info-icon">🏆</span>
                            <span class="info-text"
                                >{game.competicion_nombre} (J{
                                    game.jornada
                                })</span
                            >
                        </div>
                        <div class="info-item">
                            <span class="info-icon">📅</span>
                            <span class="info-text"
                                >{formatDate(game.fecha)} - {
                                    formatTime(game.hora)
                                }</span
                            >
                        </div>
                        <div class="info-item">
                            <span class="info-icon">🏟️</span>
                            <span class="info-text"
                                >{game.estadio || "Stadium"}</span
                            >
                        </div>
                        <div class="info-item">
                            <span class="info-icon">👔</span>
                            <span class="info-text"
                                >{game.arbitra_nombre || "Árbitro"}</span
                            >
                        </div>
                    </div>
                </section>

                <!-- EQUIPOS TITULARES -->
                <section class="lineup-card">
                    <h2 class="section-header">Equipos titulares</h2>
                    <div class="lineup-list">
                        {
                            lineup.map((player: any) => (
                                <a
                                    href={`/jugadoras/${player.slug}`}
                                    class="lineup-row"
                                >
                                    <div class="player-photo-rect">
                                        <img
                                            src={player.imageUrl}
                                            alt={player.name}
                                            class="player-img-rect"
                                            onerror="this.src='/assets/escudos/placeholder.png'"
                                        />
                                    </div>

                                    <span class="player-number-bold">
                                        {player.number}
                                    </span>

                                    <div class="player-info-col">
                                        <div class="player-name-row">
                                            <span class="player-name-bold">
                                                {player.name}
                                            </span>
                                        </div>
                                        <div class="player-meta-row">
                                            <span class="player-pos-label">
                                                {player.pos}
                                            </span>
                                            <span class="separator">•</span>
                                            <span
                                                class="player-minutes"
                                                title="Minutos jugados"
                                            >
                                                {player.minutes}'
                                            </span>
                                            {player.substituted && (
                                                <span
                                                    class="sub-indicator"
                                                    title="Sustituida"
                                                >
                                                    ⬇️
                                                </span>
                                            )}
                                        </div>
                                    </div>
                                </a>
                            ))
                        }
                    </div>
                </section>

                <section class="subs-card">
                    <h2 class="section-header">Sustituciones</h2>
                    <div class="lineup-list">
                        {
                            subs.map((sub: any) => (
                                <div class="sub-row">
                                    <div class="sub-time">{sub.minute}'</div>
                                    <div class="sub-movement in">
                                        <span class="sub-arrow">⬆️</span>
                                        <a
                                            href={`/jugadoras/${sub.playerIn.slug}`}
                                            class="sub-player-link"
                                        >
                                            <img
                                                src={sub.playerIn.imageUrl}
                                                class="sub-img"
                                                onerror="this.src='/assets/escudos/placeholder.png'"
                                            />
                                            <span class="sub-name">
                                                {sub.playerIn.name}
                                            </span>
                                        </a>
                                    </div>
                                    <div class="sub-movement out">
                                        <span class="sub-arrow">⬇️</span>
                                        <a
                                            href={`/jugadoras/${sub.playerOut.slug}`}
                                            class="sub-player-link"
                                        >
                                            <img
                                                src={sub.playerOut.imageUrl}
                                                class="sub-img"
                                                onerror="this.src='/assets/escudos/placeholder.png'"
                                            />
                                            <span class="sub-name">
                                                {sub.playerOut.name}
                                            </span>
                                        </a>
                                    </div>
                                </div>
                            ))
                        }
                        {
                            subs.length === 0 && (
                                <p class="no-data-msg">
                                    No hay registros de sustituciones
                                </p>
                            )
                        }
                    </div>
                </section>

                {/* Timeline Moved to Right Column */}
            </div>

            <div class="right-column">
                <section class="stadium-card">
                    <h2 class="section-header">Estadio</h2>
                    <div class="stadium-content">
                        <div class="stadium-photo">
                            {
                                stadiumImageSrc ? (
                                    <img
                                        src={stadiumImageSrc}
                                        alt={game.estadio}
                                        class="stadium-img-rect"
                                    />
                                ) : (
                                    <div class="photo-placeholder-large" />
                                )
                            }
                        </div>
                        <div class="stadium-info">
                            <p class="stadium-name-large">
                                {game.estadio || "Estadio"}
                            </p>
                            <div class="stadium-meta">
                                <p>
                                    <strong>Aforo:</strong>
                                    {
                                        game.aforo
                                            ? `${game.aforo} espectadores`
                                            : "Info no disponible"
                                    }
                                </p>
                                <p>
                                    <strong>Ubicación:</strong>
                                    {game.ubicacion || "Madrid (Madrid) 🇪🇸"}
                                </p>
                            </div>
                        </div>
                        {
                            stadiumStats.total > 0 && (
                                <div class="stadium-stats">
                                    <div class="stat-bar">
                                        <div class="bar-label">Ganados</div>
                                        <div class="progress-track">
                                            <div
                                                class="bar-fill won"
                                                style={`width: ${(stadiumStats.wins / stadiumStats.total) * 100}%`}
                                            >
                                                <span class="bar-text">
                                                    {stadiumStats.wins}
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="stat-bar">
                                        <div class="bar-label">Empatados</div>
                                        <div class="progress-track">
                                            <div
                                                class="bar-fill drawn"
                                                style={`width: ${(stadiumStats.draws / stadiumStats.total) * 100}%`}
                                            >
                                                <span class="bar-text">
                                                    {stadiumStats.draws}
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="stat-bar">
                                        <div class="bar-label">Perdidos</div>
                                        <div class="progress-track">
                                            <div
                                                class="bar-fill lost"
                                                style={`width: ${(stadiumStats.losses / stadiumStats.total) * 100}%`}
                                            >
                                                <span class="bar-text">
                                                    {stadiumStats.losses}
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            )
                        }
                    </div>
                </section>

                <section class="timeline-card">
                    <h2 class="section-header">Timeline del partido</h2>
                    <div class="timeline-container">
                        <div class="timeline-track">
                            {
                                timelineEvents.map((event, index) => (
                                    <div class="timeline-event">
                                        <div class="event-time">
                                            <span class="minute-badge">
                                                {event.minute}'
                                            </span>
                                        </div>
                                        <div class="event-content">
                                            <div
                                                class={`event-icon ${event.type}`}
                                            >
                                                {event.type === "goal"
                                                    ? "⚽"
                                                    : event.type === "sub"
                                                      ? "🔄"
                                                      : "•"}
                                            </div>
                                            <span class="event-text">
                                                {event.text}
                                            </span>
                                        </div>
                                    </div>
                                ))
                            }
                            {
                                timelineEvents.length === 0 && (
                                    <p class="no-data-msg">
                                        Sin eventos registrados
                                    </p>
                                )
                            }
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </main>

    <style>
        .match-details-page {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: #666;
            text-decoration: none;
            font-weight: 600;
            margin-bottom: 1.5rem;
            transition: color 0.3s;
        }

        .back-link:hover {
            color: #ffde59;
        }

        .match-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 1.5rem;
        }

        .left-column,
        .right-column {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .section-header {
            background: #ffde59;
            color: #2b2b2b;
            padding: 0.75rem 1rem;
            margin: 0;
            font-size: 1rem;
            font-weight: bold;
            text-transform: capitalize;
        }

        /* MATCH CARD */
        .match-card,
        .lineup-card,
        .subs-card,
        .timeline-card,
        .stadium-card,
        .rival-card,
        .records-card {
            background: white;
            border: 1px solid #ddd;
            border-radius: 8px;
            overflow: hidden;
        }

        .match-result {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.5rem;
            gap: 1rem;
        }

        .team-info {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
            flex: 1;
        }

        .team-badge {
            width: 60px;
            height: 60px;
        }

        .badge-placeholder,
        .badge-placeholder-small,
        .photo-placeholder,
        .photo-placeholder-large {
            width: 100%;
            height: 100%;
            background: #f0f0f0;
            border-radius: 50%;
        }

        .badge-placeholder-small {
            width: 30px;
            height: 30px;
        }

        .photo-placeholder-large {
            border-radius: 8px;
            height: 200px;
        }

        .team-name {
            font-weight: 600;
            font-size: 0.9rem;
            text-align: center;
        }

        .score {
            display: flex;
            gap: 0.5rem;
            align-items: center;
            font-size: 2.5rem;
            font-weight: bold;
        }

        .match-info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.5rem;
            padding: 1rem 1.5rem;
            background: #f9f9f9;
        }

        .info-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.85rem;
        }

        .info-icon {
            font-size: 1.2rem;
        }

        /* LINEUP */
        .lineup-list {
            display: flex;
            flex-direction: column;
        }

        .lineup-row {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            border-bottom: 1px solid #f0f0f0;
            background: #ffffff;
        }

        .lineup-row:nth-child(even) {
            background: #ffffff;
        }

        .player-pos {
            font-weight: bold;
            width: 30px;
            text-align: center;
        }

        .team-badge-small {
            width: 30px;
            height: 30px;
        }

        .player-name {
            flex: 1;
            font-weight: 600;
        }

        .player-photo-small {
            width: 40px;
            height: 40px;
        }

        .player-number {
            font-weight: bold;
            width: 40px;
            text-align: center;
        }

        /* TIMELINE */
        .timeline-container {
            position: relative;
            display: flex;
            padding: 1.5rem;
            gap: 1rem;
        }

        .timeline-left-badge,
        .timeline-right-badge {
            width: 50px;
            height: 50px;
            flex-shrink: 0;
        }

        .timeline-track {
            flex: 1;
            position: relative;
            padding-left: 2rem;
            border-left: 4px solid #ffde59;
        }

        .timeline-event {
            position: relative;
            margin-bottom: 1.5rem;
        }

        .event-time {
            position: absolute;
            left: -2.5rem;
            top: 0;
        }

        .minute-badge {
            background: #ffde59;
            color: #2b2b2b;
            padding: 0.25rem 0.5rem;
            border-radius: 12px;
            font-size: 0.85rem;
            font-weight: bold;
            white-space: nowrap;
        }

        .event-content {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .event-icon {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: #ddd;
        }

        .event-icon.goal {
            background: #16a34a;
        }

        .event-icon.yellow {
            background: #eab308;
        }

        .event-text {
            font-size: 0.9rem;
        }

        /* STADIUM */
        .stadium-content {
            padding: 1.5rem;
        }

        .stadium-photo {
            margin-bottom: 1rem;
        }

        .stadium-info {
            margin-bottom: 1.5rem;
        }

        .stadium-info p {
            margin: 0.5rem 0;
            font-size: 0.9rem;
        }

        .stadium-stats {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .stat-bar {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .bar-label {
            width: 100px;
            font-size: 0.85rem;
            font-weight: 600;
        }

        .bar-fill {
            height: 20px;
            border-radius: 4px;
        }

        /* RIVAL CHART */
        .rival-chart {
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
        }

        .donut-chart {
            width: 200px;
            height: 200px;
        }

        .chart-legend {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .legend-color {
            width: 20px;
            height: 20px;
            border-radius: 3px;
        }

        /* RECORDS */
        .records-list {
            padding: 1.5rem;
        }

        .record-row {
            display: flex;
            justify-content: space-between;
            padding: 0.75rem 0;
            border-bottom: 1px solid #eee;
        }

        .record-label {
            font-weight: 600;
        }

        .record-value {
            color: #ff6b00;
        }

        @media (max-width: 1024px) {
            .match-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .match-result {
                flex-direction: column;
            }

            .score {
                font-size: 2rem;
            }

            .match-info-grid {
                grid-template-columns: 1fr;
            }
        }

        /* LINEUP IMAGES & LINKS */
        /* LINEUP IMAGES & LINKS */
        a.lineup-row {
            text-decoration: none;
            color: inherit;
            transition: background-color 0.2s;
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 0.5rem;
            border-bottom: 1px solid #f0f0f0;
            background-color: #ffffff;
        }

        a.lineup-row:hover {
            background-color: #f9f9f9;
        }

        .player-photo-rect {
            width: 50px;
            height: 60px; /* Rectangular portrait aspect */
            flex-shrink: 0;
            overflow: hidden;
            background: #eee;
            border-radius: 4px;
        }

        .player-img-rect {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: top center; /* Fix for cutting off heads */
        }

        .stadium-img-rect {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-radius: 8px;
        }

        .stadium-name-large {
            font-size: 1.2rem;
            font-weight: 700;
            text-align: center;
            margin-bottom: 0.5rem;
        }

        .stadium-meta {
            font-size: 0.9rem;
            text-align: center;
            color: #666;
        }

        /* STADIUM STATS COLORS */
        .bar-fill {
            height: 24px;
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding-right: 8px;
            min-width: 10%; /* Ensure text fits */
            transition: width 0.5s ease-out;
        }

        .progress-track {
            flex: 1;
            background: #f0f0f0;
            border-radius: 4px;
            overflow: hidden;
        }

        .bar-fill.won {
            background: #bbf7d0; /* Pastel green */
        }
        .bar-fill.drawn {
            background: #fef08a; /* Pastel yellow */
        }
        .bar-fill.lost {
            background: #fecaca; /* Pastel red */
        }

        .bar-text {
            font-size: 0.75rem;
            font-weight: bold;
            color: #444;
        }

        .player-number-bold {
            font-size: 1.25rem;
            font-weight: 800; /* Bold dorsal */
            color: #333;
            min-width: 30px;
            text-align: center;
        }

        .player-info-col {
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .player-name-bold {
            font-weight: 600;
            font-size: 1rem;
            line-height: 1.2;
        }

        .player-pos-label {
            font-size: 0.8rem;
            color: #777;
            text-transform: uppercase;
        }

        /* SUBSTITUTIONS */
        .sub-row {
            display: flex;
            align-items: center;
            padding: 0.75rem 1rem;
            border-bottom: 1px solid #f0f0f0;
            gap: 1rem;
            background: #ffffff; /* Consistent white bg */
        }

        .sub-row:last-child {
            border-bottom: none;
        }

        .sub-time {
            font-weight: bold;
            background: #f5f5f5;
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            font-size: 0.85rem;
            min-width: 35px;
            text-align: center;
            color: #555;
        }

        .sub-movement {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            flex: 1;
            font-size: 0.9rem;
        }

        /* TIMELINE STYLES UPDATED */
        .timeline-container {
            padding: 1.5rem 1rem;
        }

        .timeline-track {
            border-left: 2px solid #e5e5e5;
            padding-left: 1.5rem;
            margin-left: 0.5rem;
        }

        .timeline-event {
            position: relative;
            margin-bottom: 1.5rem;
        }

        .event-time {
            position: absolute;
            left: -2.35rem; /* Adjust based on padding/border */
            top: 0;
        }

        .event-icon {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 24px;
            height: 24px;
            font-size: 1rem;
        }

        .minute-badge {
            background: #fff;
            border: 1px solid #ddd;
            border-radius: 4px;
            padding: 2px 5px;
            font-size: 0.75rem;
            font-weight: bold;
        }

        .stat-group {
            font-size: 0.9rem;
            letter-spacing: 2px;
        }

        .player-meta-row {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.85rem;
            color: #666;
            margin-top: 2px;
        }

        .separator {
            color: #ccc;
        }

        .player-minutes {
            font-weight: 500;
            color: #444;
            background: #f0f0f0;
            padding: 1px 4px;
            border-radius: 3px;
            font-size: 0.75rem;
        }

        .sub-indicator {
            font-size: 0.8rem;
        }
    </style>
</Layout>
