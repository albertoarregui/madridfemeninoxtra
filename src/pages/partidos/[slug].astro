                                            ? game.xg_en_contra || "-"
                                            : game.xg_a_favor || "-"
                                    }</span
                                >
                            </div>
                            <div
                                style="height: 8px; background: #eee; border-radius: 4px; overflow: hidden; display: flex;"
                            >
                                <div
                                    style={`width: ${
                                        isLocalRM
                                            ? (parseFloat(
                                                  game.xg_a_favor || 0,
                                              ) /
                                                  (parseFloat(
                                                      game.xg_a_favor || 1,
                                                  ) +
                                                      parseFloat(
                                                          game.xg_en_contra ||
                                                              1,
                                                      ))) *
                                              100
                                            : (parseFloat(
                                                  game.xg_en_contra || 0,
                                              ) /
                                                  (parseFloat(
                                                      game.xg_a_favor || 1,
                                                  ) +
                                                      parseFloat(
                                                          game.xg_en_contra ||
                                                              1,
                                                      ))) *
                                              100
                                    }%; background: #151e42; height: 100%;`}
                                >
                                </div>
                                <div
                                    style={`width: ${
                                        isLocalRM
                                            ? (parseFloat(
                                                  game.xg_en_contra || 0,
                                              ) /
                                                  (parseFloat(
                                                      game.xg_a_favor || 1,
                                                  ) +
                                                      parseFloat(
                                                          game.xg_en_contra ||
                                                              1,
                                                      ))) *
                                              100
                                            : (parseFloat(
                                                  game.xg_a_favor || 1,
                                              ) /
                                                  (parseFloat(
                                                      game.xg_a_favor || 1,
                                                  ) +
                                                      parseFloat(
                                                          game.xg_en_contra ||
                                                              1,
                                                      ))) *
                                              100
                                    }%; background: #ccc; height: 100%;`}
                                >
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>

        {
            galleryImages.length > 0 && (
                <section class="gallery-section" style="margin-top: 3rem;">
                    <div class="gallery-card">
                        <h2 class="section-header">Galería de imágenes</h2>
                        <div class="gallery-grid-simple">
                            {galleryImages.map((src) => (
                                <div class="gallery-item-simple">
                                    <img
                                        src={src}
                                        alt="Imagen del partido"
                                        loading="lazy"
                                    />
                                </div>
                            ))}
                        </div>
                    </div>
                </section>
            )
        }

    </main>

    <script is:inline>
        function openRefereeModal(btn) {
            try {
                const stats = JSON.parse(btn.dataset.stats);
                const name = btn.dataset.name;

                document.getElementById("modal-referee-name").textContent =
                    name;

                document.getElementById("ref-wins").textContent = stats.wins;
                document.getElementById("ref-draws").textContent = stats.draws;
                document.getElementById("ref-losses").textContent =
                    stats.losses;
                document.getElementById("ref-yellows").textContent =
                    stats.yellowCards;
                document.getElementById("ref-reds").textContent =
                    stats.redCards;

                const modal = document.getElementById("referee-modal");
                modal.style.display = "flex";

                modal.onclick = function (e) {
                    if (e.target === modal) {
                        closeRefereeModal();
                    }
                };
            } catch (e) {
                console.error("Error opening modal:", e);
            }
        }

        function closeRefereeModal() {
            document.getElementById("referee-modal").style.display = "none";
        }
    </script>

