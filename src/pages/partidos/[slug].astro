<script is:inline>
    function openRefereeModal(btn) {
        try {
            const stats = JSON.parse(btn.dataset.stats);
            const name = btn.dataset.name;
            document.getElementById("modal-referee-name").textContent = name;
            document.getElementById("ref-wins").textContent = stats.wins;
            document.getElementById("ref-draws").textContent = stats.draws;
            document.getElementById("ref-losses").textContent = stats.losses;
            document.getElementById("ref-yellows").textContent =
                stats.yellowCards;
            document.getElementById("ref-reds").textContent = stats.redCards;
            const modal = document.getElementById("referee-modal");
            modal.style.display = "flex";
            modal.onclick = function (e) {
                if (e.target === modal) {
                    closeRefereeModal();
                }
            };
        } catch (e) {
            console.error("Error opening modal:", e);
        }
    }
    function closeRefereeModal() {
        document.getElementById("referee-modal").style.display = "none";
    }
    function openVideoModal(url, titleText) {
        const modal = document.getElementById("video-modal");
        const video = document.getElementById("goal-video-player");
        const source = document.getElementById("video-source");
        const title = document.getElementById("video-modal-title");
        title.textContent = titleText;
        source.src = url;
        video.load();
        modal.style.display = "flex";
        video.play().catch((e) => console.log("Auto-play prevented", e));
        modal.onclick = function (e) {
            if (e.target === modal) {
                closeVideoModal();
            }
        };
    }
    function closeVideoModal() {
        const modal = document.getElementById("video-modal");
        const video = document.getElementById("goal-video-player");
        video.pause();
        modal.style.display = "none";
    }
</script>

