---
import { Image } from "astro:assets";
import { getAssetMetadata } from "../utils/assets";

interface Props {
    name: string;
    playerId?: string;
    manualImage?: ImageMetadata | null;
    country?: string;
    videoUrl?: string;
    imageScale?: number;
    icon?: ImageMetadata | null;
    yOffset?: number;
    poster?: boolean;
}

const {
    name,
    playerId,
    manualImage,
    country,
    imageScale = 1,
    icon,
    yOffset = 0,
    poster = false,
} = Astro.props;

let imageSrc: ImageMetadata | null | undefined = manualImage;

if (!imageSrc && playerId) {
    imageSrc = getAssetMetadata("jugadorasPerfil", playerId);
}

const flagImage = country ? getAssetMetadata("banderas", country) : null;
---

<article class={`candidate-card ${poster ? "poster-mode" : ""}`}>
    <div class="card-image-container">
        {
            imageSrc && (
                <Image
                    src={imageSrc}
                    alt={name}
                    class="candidate-image"
                    style={`transform: scale(${imageScale}) translateY(${yOffset}px);`}
                    width={400}
                />
            )
        }
        {!imageSrc && <div class="placeholder-image" />}
    </div>

    <div class="card-info">
        <div class="name-row">
            {
                icon && (
                    <Image
                        src={icon}
                        alt="Team Icon"
                        class="team-icon"
                        width={40}
                        height={40}
                    />
                )
            }
            <h3>{name}</h3>
            {
                flagImage && (
                    <Image
                        src={flagImage}
                        alt={country || ""}
                        class="flag-icon"
                        width={24}
                        height={18}
                    />
                )
            }
        </div>
    </div>
</article>

<style>
    .candidate-card {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        overflow: hidden;
        width: 280px;
        height: 380px;
        position: relative;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .candidate-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        border-color: rgba(255, 222, 89, 0.5);
    }

    .candidate-card.selected {
        border-color: #ffde59;
        box-shadow:
            0 0 0 2px #ffde59,
            0 10px 25px rgba(255, 222, 89, 0.2);
    }

    .card-image-container {
        height: 280px;
        overflow: hidden;
        position: relative;
        background: linear-gradient(to bottom, transparent, rgba(0, 0, 0, 0.5));
    }

    .candidate-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top center;
    }

    .card-info {
        padding: 15px;
        background: rgba(0, 0, 0, 0.6);
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        backdrop-filter: blur(5px);
    }

    .name-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .name-row h3 {
        margin: 0;
        font-family: "Archivo Black", sans-serif;
        font-size: 1.1rem;
        text-align: center;
        text-transform: uppercase;
        color: white;
        line-height: 1.2;
    }

    .team-icon {
        width: 30px;
        height: 30px;
        object-fit: contain;
    }

    .flag-icon {
        width: 20px;
        height: auto;
        border-radius: 2px;
    }

    .poster-mode {
        width: 320px;
    }

    .poster-mode .card-image-container {
        height: 220px;
    }
</style>


