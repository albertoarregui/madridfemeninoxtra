
import React, { useState, useMemo } from 'react';
import { StatsTable } from './StatsTable';
import { StatsCharts } from './StatsCharts';
import { COMPETITION_NAMES, TABLE_NAMES, getCompetitionId, getTableType } from '../../utils/stats-mapper';
import fbrefDataStr from '../../consts/fbref-data.json';

// Cast data to expected type
const fbrefData = fbrefDataStr as Record<string, Record<string, any[]>>;

// Helper Icons
const IconPer90 = () => (
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" className="icon icon-tabler icons-tabler-filled icon-tabler-toggle-right text-[#ffde59]"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M16 9a3 3 0 1 1 -3 3l.005 -.176a3 3 0 0 1 2.995 -2.824" /><path d="M16 5a7 7 0 0 1 0 14h-8a7 7 0 0 1 0 -14zm0 2h-8a5 5 0 1 0 0 10h8a5 5 0 0 0 0 -10" /></svg>
);
const IconAbsolute = () => (
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" className="icon icon-tabler icons-tabler-filled icon-tabler-toggle-left text-gray-400"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M8 9a3 3 0 1 1 -3 3l.005 -.176a3 3 0 0 1 2.995 -2.824" /><path d="M16 5a7 7 0 0 1 0 14h-8a7 7 0 0 1 0 -14zm0 2h-8a5 5 0 1 0 0 10h8a5 5 0 0 0 0 -10" /></svg>
);

export const StatsExplorer: React.FC<{ playerImageMap: Record<string, string> }> = ({ playerImageMap }) => {
    // 1. Get available seasons
    const seasons = useMemo(() => Object.keys(fbrefData).filter(s => s !== '2020-2021').sort().reverse(), []);

    // State - removed tableType and per90 since we only show charts now
    const [season, setSeason] = useState('todas');
    const [competition, setCompetition] = useState('todas');

    // NEW: Extract Match Logs for Charts
    const matchLogs = useMemo(() => {
        const logs: any[] = [];
        const targetSeasons = season === 'todas' ? seasons : [season];

        targetSeasons.forEach(s => {
            const seasonData = fbrefData[s] || {};
            const resultKeys = Object.keys(seasonData).filter(k => k.includes('results') && k.includes('overall'));

            resultKeys.forEach(key => {
                let isValidComp = false;
                if (competition === 'todas') {
                    isValidComp = true;
                } else {
                    if (key.includes(competition)) isValidComp = true;
                }

                if (isValidComp) {
                    const rows = seasonData[key];
                    if (Array.isArray(rows)) {
                        logs.push(...rows);
                    }
                }
            });
        });
        return logs;
    }, [season, competition, seasons]);

    // 2. Aggregation Logic
    const tableData = useMemo(() => {
        let aggregatedRows: Record<string, any> = {};
        const targetSeasons = season === 'todas' ? seasons : [season];

        targetSeasons.forEach(s => {
            const seasonData = fbrefData[s] || {};
            const availableKeys = Object.keys(seasonData).filter(k => k.startsWith('stats_'));

            const targetKeys = availableKeys.filter(k => {
                const compId = getCompetitionId(k);
                const type = getTableType(k);
                if (type !== tableType) return false;
                if (competition === 'todas') return true;
                return compId === competition;
            });

            targetKeys.forEach(key => {
                const rows = seasonData[key];
                rows.forEach(row => {
                    const playerName = row.player;
                    if (!aggregatedRows[playerName]) {
                        aggregatedRows[playerName] = {
                            player: playerName,
                            nationality: row.nationality,
                            position: row.position,
                            age: row.age,
                            games: 0,
                            games_starts: 0,
                            minutes: 0,
                        };
                        Object.keys(row).forEach(k => {
                            if (typeof row[k] === 'number') aggregatedRows[playerName][k] = 0;
                        });
                    }

                    Object.keys(row).forEach(k => {
                        if (typeof row[k] === 'number') {
                            if (k.includes('per90') || k.includes('percent') || k.includes('age')) return;
                            aggregatedRows[playerName][k] = (aggregatedRows[playerName][k] || 0) + row[k];
                        }
                    });
                });
            });
        });

        return Object.values(aggregatedRows).map(row => {
            const mins = row.minutes || 1;
            const is90 = mins / 90;
            const newRow = { ...row };

            Object.keys(newRow).forEach(k => {
                if (!k.includes('per90') && typeof newRow[k] === 'number') {
                    const per90Key = `${k}_per90`;
                    if (is90 > 0) {
                        newRow[per90Key] = Number((newRow[k] / is90).toFixed(2));
                    }
                }
            });
            return newRow;
        });

    }, [season, competition, tableType]);

    // 2b. Chart Data Aggregation (Correctly merges multiple tables without double-counting)
    const chartData = useMemo(() => {
        // Step 1: Merge data for the SAME context (Player + Season + Competition) across different tables
        // This ensures that "Goals" from Standard table and "Goals" from Shooting table are merged (overwritten), not added.
        const uniqueContexts: Record<string, any> = {};

        const targetSeasons = season === 'todas' ? seasons : [season];

        targetSeasons.forEach(s => {
            const seasonData = fbrefData[s] || {};
            const availableKeys = Object.keys(seasonData).filter(k => k.startsWith('stats_'));

            availableKeys.forEach(tableKey => {
                const compId = getCompetitionId(tableKey);
                if (competition !== 'todas' && compId !== competition) return;

                const rows = seasonData[tableKey];
                if (!Array.isArray(rows)) return;

                rows.forEach(row => {
                    const contextKey = `${row.player}_${s}_${compId}`;

                    // Exclude passing completion data from tables that duplicate it
                    // Table names: stats_passing_230, stats_passing_types_181, etc.
                    let rowToMerge = { ...row };


                    // Match tables like: stats_passing_230, stats_passing_181
                    // But NOT: stats_passing_types_230
                    const isPassingTable = /^stats_passing_\d/.test(tableKey) && !tableKey.includes('types');
                    const isPassingTypesTable = tableKey.includes('passing_types');

                    if (!isPassingTable) {
                        // This is NOT a passing table, so exclude these keys if present
                        const {
                            passes, passes_completed, passes_pct, passess_completed,
                            passes_short, passes_medium, passes_long,
                            passes_completed_short, passes_completed_medium, passes_completed_long,
                            passes_pct_short, passes_pct_medium, passes_pct_long,
                            ...rest
                        } = row;
                        rowToMerge = rest;
                    } else if (isPassingTypesTable) {
                        const { passes, passes_completed, passes_pct, passess_completed, ...rest } = row;
                        rowToMerge = rest;
                    }

                    if (!uniqueContexts[contextKey]) {
                        uniqueContexts[contextKey] = rowToMerge;
                    } else {
                        // Merge: This overwrites shared keys (like 'goals', 'minutes') with the same value (safe)
                        // and adds new keys (like 'sca' from gca table)
                        Object.assign(uniqueContexts[contextKey], rowToMerge);
                    }
                });
            });
        });

        // Step 2: Aggregate these unique contexts by Player
        const aggregatedRows: Record<string, any> = {};

        Object.values(uniqueContexts).forEach(row => {
            const playerName = row.player;
            if (!aggregatedRows[playerName]) {
                aggregatedRows[playerName] = {
                    player: playerName,
                    nationality: row.nationality,
                    position: row.position,
                    age: row.age,
                    games: 0,
                    games_starts: 0,
                    minutes: 0,
                };
            }

            Object.keys(row).forEach(k => {
                if (typeof row[k] === 'number') {
                    if (k.includes('per90') || k.includes('percent') || k.includes('pct') || k.includes('rate') || k.includes('age')) return;
                    // Now safely add because 'row' represents a unique season+comp entry
                    aggregatedRows[playerName][k] = (aggregatedRows[playerName][k] || 0) + row[k];
                }
            });
        });

        // Step 3: Result
        return Object.values(aggregatedRows).map(row => {
            const mins = row.minutes || 1;
            const is90 = mins / 90;
            const newRow = { ...row };

            Object.keys(newRow).forEach(k => {
                if (!k.includes('per90') && typeof newRow[k] === 'number') {
                    const per90Key = `${k}_per90`;
                    if (is90 > 0) {
                        newRow[per90Key] = Number((newRow[k] / is90).toFixed(2));
                    }
                }
            });
            if (newRow.passes_completed && newRow.passes) {
                const rawPct = (newRow.passes_completed / newRow.passes) * 100;
                newRow.passes_pct = Math.min(100, Number(rawPct.toFixed(1)));

                // Debug first player
                if (newRow.player === Object.values(aggregatedRows)[0]?.player) {
                    console.log('DEBUG PASSES:', {
                        player: newRow.player,
                        completed: newRow.passes_completed,
                        attempted: newRow.passes,
                        calculated: rawPct,
                        final: newRow.passes_pct
                    });
                }
            }
            if (newRow.passes_completed_short && newRow.passes_short) {
                newRow.passes_pct_short = Math.min(100, Number(((newRow.passes_completed_short / newRow.passes_short) * 100).toFixed(1)));
            }
            if (newRow.passes_completed_medium && newRow.passes_medium) {
                newRow.passes_pct_medium = Math.min(100, Number(((newRow.passes_completed_medium / newRow.passes_medium) * 100).toFixed(1)));
            }
            if (newRow.passes_completed_long && newRow.passes_long) {
                newRow.passes_pct_long = Math.min(100, Number(((newRow.passes_completed_long / newRow.passes_long) * 100).toFixed(1)));
            }
            return newRow;
        });

        // LOG FINAL DATA FOR FIRST 3 PLAYERS
        const sample = result.slice(0, 3);
        console.table(sample.map(p => ({
            Player: p.player,
            'Passes Completed': p.passes_completed,
            'Passes Attempted': p.passes,
            'Calculated %': p.passes_pct
        })));

        return result;

    }, [season, competition]); // No tableType dependency


    return (
        <div className="space-y-8">
            {/* Filters */}
            <div className="flex flex-wrap gap-4 items-center justify-between bg-white p-6 rounded-lg shadow-sm border border-gray-100">
                {/* Season Filter */}
                <div className="flex items-center gap-3">
                    <label className="text-sm font-bold text-[#151e42] uppercase tracking-wider">Temporada:</label>
                    <select
                        value={season}
                        onChange={(e) => setSeason(e.target.value)}
                        className="px-4 py-2 border-2 border-gray-200 rounded-lg text-sm font-semibold text-[#151e42] bg-white hover:border-[#ffde59] focus:border-[#ffde59] focus:outline-none transition-colors"
                    >
                        <option value="todas">Todas</option>
                        {seasons.map(s => <option key={s} value={s}>{s}</option>)}
                    </select>
                </div>

                {/* Competition Filter */}
                <div className="flex items-center gap-3">
                    <label className="text-sm font-bold text-[#151e42] uppercase tracking-wider">Competición:</label>
                    <select
                        value={competition}
                        onChange={(e) => setCompetition(e.target.value)}
                        className="px-4 py-2 border-2 border-gray-200 rounded-lg text-sm font-semibold text-[#151e42] bg-white hover:border-[#ffde59] focus:border-[#ffde59] focus:outline-none transition-colors"
                    >
                        <option value="todas">Todas</option>
                        {Object.entries(COMPETITION_NAMES).map(([id, name]) => (
                            <option key={id} value={id}>{name}</option>
                        ))}
                    </select>
                </div>
            </div>

            {/* Charts Only */}
            <StatsCharts data={aggregatedData} matchLogs={matchLogs} season={season} playerImageMap={playerImageMap} />
        </div>
    );
};
const availableCompetitions = useMemo(() => {
    const comps = new Set<string>();
    comps.add("230"); // Liga F
    comps.add("181"); // UWCL
    const targetSeasons = season === 'todas' ? seasons : [season];
    targetSeasons.forEach(s => {
        const sData = fbrefData[s] || {};
        Object.keys(sData).forEach(k => {
            if (!k.startsWith('stats_')) return;
            const cId = getCompetitionId(k);
            if (cId) comps.add(cId);
        });
    });
    return Array.from(comps);
}, [season, seasons]);

const getCompetitionLabel = (c: string) => {
    const mapped = COMPETITION_NAMES[c] || c;
    if (mapped.toLowerCase().includes("champions") || mapped.toLowerCase().includes("uwcl")) return "UWCL";
    if (mapped.toLowerCase().includes("liga f") || mapped.toLowerCase().includes("primera")) return "Liga F";
    return mapped.charAt(0).toUpperCase() + mapped.slice(1).toLowerCase();
};

// 4. Extract table types
const availableTableTypes = useMemo(() => {
    const types = new Set<string>();
    const targetSeasons = season === 'todas' ? seasons : [season];
    targetSeasons.forEach(s => {
        const sData = fbrefData[s] || {};
        Object.keys(sData).forEach(k => {
            if (!k.startsWith('stats_')) return;
            if (competition !== 'todas' && getCompetitionId(k) !== competition) return;
            types.add(getTableType(k));
        });
    });
    return Array.from(types);
}, [season, competition]);


return (
    <div className="w-full">
        {/* Filters Bar */}
        <div className="flex flex-wrap justify-center gap-4 mb-8">
            {/* Season Filter */}
            <div className="relative">
                <select
                    value={season}
                    onChange={(e) => setSeason(e.target.value)}
                    className="appearance-none bg-white text-[#151e42] border-2 border-[#ffde59] rounded-full py-3 pl-6 pr-12 text-[0.95rem] font-bold min-w-[220px] shadow-[0_2px_8px_rgba(255,222,89,0.2)] focus:outline-none focus:ring-4 focus:ring-[#ffde59]/20 hover:bg-[#fffef8] hover:border-[#ffd700] transition-all cursor-pointer tracking-wide text-center"
                >
                    <option value="todas">Todas las temporadas</option>
                    {seasons.map(s => <option key={s} value={s}>{s}</option>)}
                </select>
                <div className="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-[#151e42]">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M6 9l6 6l6 -6" /></svg>
                </div>
            </div>

            {/* Competition Filter */}
            <div className="relative">
                <select
                    value={competition}
                    onChange={(e) => setCompetition(e.target.value)}
                    className="appearance-none bg-white text-[#151e42] border-2 border-[#ffde59] rounded-full py-3 pl-6 pr-12 text-[0.95rem] font-bold min-w-[220px] shadow-[0_2px_8px_rgba(255,222,89,0.2)] focus:outline-none focus:ring-4 focus:ring-[#ffde59]/20 hover:bg-[#fffef8] hover:border-[#ffd700] transition-all cursor-pointer tracking-wide text-center"
                >
                    <option value="todas">Todas las competiciones</option>
                    {availableCompetitions.map(c => (
                        <option key={c} value={c}>
                            {getCompetitionLabel(c)}
                        </option>
                    ))}
                </select>
                <div className="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-[#151e42]">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M6 9l6 6l6 -6" /></svg>
                </div>
            </div>

            {/* Table Type Filter */}
            <div className="relative">
                <select
                    value={tableType}
                    onChange={(e) => setTableType(e.target.value)}
                    className="appearance-none bg-white text-[#151e42] border-2 border-[#ffde59] rounded-full py-3 pl-6 pr-12 text-[0.95rem] font-bold min-w-[220px] shadow-[0_2px_8px_rgba(255,222,89,0.2)] focus:outline-none focus:ring-4 focus:ring-[#ffde59]/20 hover:bg-[#fffef8] hover:border-[#ffd700] transition-all cursor-pointer tracking-wide text-center"
                >
                    {availableTableTypes.map(t => {
                        const label = TABLE_NAMES[t] || t.replace(/_/g, ' ');
                        return (
                            <option key={t} value={t}>
                                {label.charAt(0).toUpperCase() + label.slice(1).toLowerCase()}
                            </option>
                        );
                    })}
                </select>
                <div className="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-[#151e42]">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M6 9l6 6l6 -6" /></svg>
                </div>
            </div>
        </div>



        {/* CHART DASHBOARD */}
        <div className="mb-12">
            <StatsCharts data={chartData} matchLogs={matchLogs} season={season} playerImageMap={playerImageMap} />
        </div>

        {/* Controls Row (Per 90) */}
        <div className="flex justify-end mb-4 px-2">
            <button
                onClick={() => setPer90(!per90)}
                className="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-[#151e42] hover:text-[#ffde59] transition-colors"
                title={per90 ? "Ver absolutos" : "Ver por 90 minutos"}
            >
                <span>{per90 ? 'Por 90 min' : 'Totales'}</span>
                {per90 ? <IconPer90 /> : <IconAbsolute />}
            </button>
        </div>

        {/* Results Table */}
        <div className="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden min-h-[400px]">
            <StatsTable data={tableData} tableType={tableType} per90={per90} playerImageMap={playerImageMap} />
        </div>
    </div>
);
};
