---
import X from "../assets/svg/x.svg";
import Instagram from "../assets/svg/instagram.svg";
import TikTok from "../assets/svg/tiktok.svg";
import Youtube from "../assets/svg/youtube.svg";
import Facebook from "../assets/svg/facebook.svg";
import Logo from "../assets/logo.png";
---

<header class="header">
    <div class="logo">
        <a href="/">
            <img
                src={Logo.src}
                alt="Madrid Femenino Xtra"
                width="60"
                height="auto"
            />
        </a>
    </div>

    <nav id="main-nav" class="main-nav">
        <ul class="nav-list">
            <li><a href="/">Inicio</a></li>
            <li class="has-submenu">
                <div class="submenu-header">
                    <a
                        href="#"
                        aria-expanded="false"
                        aria-controls="submenu-noticias">Noticias</a
                    >
                    <button
                        class="submenu-toggle"
                        aria-expanded="false"
                        aria-controls="submenu-noticias">▼</button
                    >
                </div>

                <ul class="submenu" id="submenu-noticias">
                    <li><a href="/noticias/primer-equipo">Primer Equipo</a></li>
                    <li><a href="/noticias/cantera">Cantera</a></li>
                    <li><a href="/noticias/previas">Previas</a></li>
                    <li><a href="/noticias/cronicas">Crónicas</a></li>
                    <li><a href="/noticias/liga-f">Liga F</a></li>
                    <li><a href="/noticias/uwcl">UWCL</a></li>
                    <li>
                        <a href="/noticias/copa-de-la-reina">Copa de la Reina</a
                        >
                    </li>
                    <li>
                        <a href="/noticias/supercopa-de-espana"
                            >Supercopa de España</a
                        >
                    </li>
                </ul>
            </li>
            <li><a href="/plantilla">Plantilla</a></li>
            <li class="has-submenu">
                <div class="submenu-header">
                    <a
                        href="#"
                        aria-expanded="false"
                        aria-controls="submenu-estadisticas">Estadísticas</a
                    >
                    <button
                        class="submenu-toggle"
                        aria-expanded="false"
                        aria-controls="submenu-estadisticas">▼</button
                    >
                </div>

                <ul class="submenu" id="submenu-estadisticas">
                    <li><a href="/jugadoras">Jugadoras</a></li>
                    <li>
                        <a href="/entrenadores">Entrenadores</a>
                    </li>
                    <li><a href="/partidos">Partidos</a></li>
                    <li><a href="/rivales">Rivales</a></li>
                    <li><a href="/rankings">Rankings</a></li>
                </ul>
            </li>
            <li class="has-submenu">
                <div class="submenu-header">
                    <a
                        href="#"
                        aria-expanded="false"
                        aria-controls="submenu-zonafan">Zona Fan</a
                    >
                    <button
                        class="submenu-toggle"
                        aria-expanded="false"
                        aria-controls="submenu-zonafan">▼</button
                    >
                </div>

                <ul class="submenu" id="submenu-zonafan">
                    <li><a href="/pronosticos">Pronósticos</a></li>
                    <li><a href="/mvp">Notas y MVP</a></li>
                    <li>
                        <a href="/valoraciones">Valoraciones</a>
                    </li>
                </ul>
            </li>
            <li><a href="/sobre-nosotros">Sobre Nosotros</a></li>
            <li><a href="/contacto">Contacto</a></li>
        </ul>
    </nav>

    <div class="social-icons desktop-social-icons">
        <a href="https://x.com/madridfemxtra" target="_blank"><X /></a>
        <a
            href="https://instagram.com/madridfemxtra"
            target="_blank"
            rel="noopener noreferrer"><Instagram /></a
        >
        <a
            href="https://tiktok.com/@madridfemeninoxtra"
            target="_blank"
            rel="noopener noreferrer"><TikTok /></a
        >
        <a
            href="https://www.youtube.com/@madridfemxtra"
            target="_blank"
            rel="noopener noreferrer"><Youtube /></a
        >
        <a
            href="https://www.facebook.com/madridfemxtra"
            target="_blank"
            rel="noopener noreferrer"><Facebook /></a
        >
    </div>

    <button
        class="menu-toggle"
        id="menu-toggle"
        aria-controls="main-nav"
        aria-expanded="false"
    >
        <span class="line"></span>
        <span class="line"></span>
        <span class="line"></span>
    </button>
    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "ItemList",
            "itemListElement": [
                {
                    "@type": "SiteNavigationElement",
                    "position": 1,
                    "name": "Primer Equipo",
                    "description": "Noticias del primer equipo",
                    "url": "https://www.madridfemeninoxtra.com/noticias/primer-equipo"
                },
                {
                    "@type": "SiteNavigationElement",
                    "position": 2,
                    "name": "Cantera",
                    "description": "Noticias de la cantera",
                    "url": "https://www.madridfemeninoxtra.com/noticias/cantera"
                },
                {
                    "@type": "SiteNavigationElement",
                    "position": 3,
                    "name": "Plantilla",
                    "description": "Jugadoras del Real Madrid Femenino",
                    "url": "https://www.madridfemeninoxtra.com/plantilla"
                },
                {
                    "@type": "SiteNavigationElement",
                    "position": 4,
                    "name": "Partidos",
                    "description": "Calendario y resultados",
                    "url": "https://www.madridfemeninoxtra.com/partidos"
                },
                {
                    "@type": "SiteNavigationElement",
                    "position": 5,
                    "name": "Rankings",
                    "description": "Clasificación y estadísticas",
                    "url": "https://www.madridfemeninoxtra.com/rankings"
                }
            ]
        }
    </script>
</header>

<script src="../scripts/menu.js"></script>

<style>
    :root {
        --header-bg: #2b2b2b;
        --header-bg-gradient: linear-gradient(to right, #2b2b2b, #1f1f1f);
        --header-text: #ffffff;
        --header-accent: #ffde59;
        --header-hover-bg: rgba(255, 222, 89, 0.1);
    }

    .header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 2rem;
        background: var(--header-bg-gradient);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
        position: relative;
        z-index: 100;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .logo {
        flex-shrink: 0;
        margin-right: 2rem;
    }

    .main-nav {
        flex-grow: 1;
        display: flex;
        justify-content: center;
        margin-right: 0;
    }

    .desktop-social-icons {
        flex-shrink: 0;
        margin-left: 2rem;
        display: flex;
        gap: 1rem;
    }

    .desktop-social-icons a {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.05);
        transition: all 0.3s ease;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #ffffff !important;
    }

    .desktop-social-icons a svg {
        width: 1.2rem;
        height: 1.2rem;
        fill: #ffffff !important;
        color: #ffffff !important;
        transition: all 0.3s ease;
    }

    .desktop-social-icons a:hover {
        background: var(--header-accent);
        transform: translateY(-2px);
        border-color: var(--header-accent);
        color: #2b2b2b !important;
    }

    .desktop-social-icons a:hover svg {
        fill: #2b2b2b !important;
        color: #2b2b2b !important;
    }

    .nav-list {
        display: flex;
        list-style: none;
        padding: 0;
        margin: 0;
        gap: 2.5rem;
    }

    .nav-list a {
        color: var(--header-text);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: color 0.3s ease;
        padding: 0.5rem 0;
        position: relative;
        white-space: nowrap;
    }

    .nav-list a::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0;
        height: 2px;
        background-color: var(--header-accent);
        transition: width 0.3s ease;
    }

    .nav-list a:hover {
        color: var(--header-accent);
    }

    .nav-list a:hover::after {
        width: 100%;
    }

    .submenu-toggle {
        display: none;
    }

    .has-submenu {
        position: relative;
    }

    .submenu {
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%) translateY(10px);
        list-style: none;
        padding: 0.5rem;
        min-width: 200px;
        background: #2b2b2b;
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        border-radius: 8px;
        visibility: hidden;
        opacity: 0;
        pointer-events: none;
        transition: all 0.3s ease;
        z-index: 20;
    }

    .has-submenu:hover .submenu {
        visibility: visible;
        opacity: 1;
        pointer-events: auto;
        transform: translateX(-50%) translateY(0);
    }

    .submenu a {
        display: block;
        padding: 0.75rem 1rem;
        color: #e0e0e0;
        text-decoration: none;
        border-radius: 4px;
        text-transform: none;
        font-weight: 500;
    }

    .submenu a::after {
        display: none;
    }

    .submenu a:hover {
        background-color: rgba(255, 255, 255, 0.05);
        color: var(--header-accent);
    }

    .menu-toggle {
        display: none;
    }

    @media (max-width: 768px) {
        .header {
            justify-content: space-between;
            padding: 0.5rem 0.75rem; /* Reduced padding for mobile */
        }

        .logo {
            margin: 0;
            order: 1;
        }

        .desktop-social-icons {
            display: none;
        }

        .menu-toggle {
            display: block;
            background: none;
            border: none;
            padding: 10px;
            z-index: 100;
            cursor: pointer;
            order: 3;
        }

        .menu-toggle .line {
            display: block;
            width: 25px;
            height: 2px;
            background-color: var(--header-text);
            margin: 6px 0;
            transition:
                transform 0.3s,
                opacity 0.3s,
                background-color 0.3s;
        }

        .menu-toggle:hover .line {
            background-color: var(--header-accent);
        }

        .menu-toggle[aria-expanded="true"] .line:nth-child(1) {
            transform: translateY(8px) rotate(45deg);
        }

        .menu-toggle[aria-expanded="true"] .line:nth-child(2) {
            opacity: 0;
        }

        .menu-toggle[aria-expanded="true"] .line:nth-child(3) {
            transform: translateY(-8px) rotate(-45deg);
        }

        .main-nav {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100vh;
            background: rgba(10, 14, 39, 0.98);
            backdrop-filter: blur(10px);
            z-index: 90;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding-top: 80px;
            transform: translateX(100%);
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            order: 2;
            overflow-y: auto;
        }

        .main-nav.is-open {
            transform: translateX(0);
        }

        .nav-list {
            flex-direction: column;
            width: 100%;
            max-width: 100%;
            background: transparent;
            padding: 2rem 1rem;
            height: auto;
            gap: 1.5rem;
            text-align: center;
        }

        .nav-list > li {
            border-bottom: 1px solid rgba(255, 222, 89, 0.1);
            padding-bottom: 1rem;
            width: 100%;
        }

        .nav-list > li:last-child {
            border-bottom: none;
        }

        .nav-list a {
            font-size: 1.4rem;
            font-weight: 700;
            display: block;
        }

        .submenu-header {
            display: flex;
            justify-content: center;
            align-items: center;
            width: 100%;
            position: relative;
        }

        .submenu-header a {
            flex: 0 1 auto;
            text-align: center;
        }

        .submenu-toggle {
            position: static;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: none;
            background: rgba(255, 222, 89, 0.2);
            cursor: pointer;
            font-size: 0.85rem;
            color: var(--header-accent);
            padding: 0.4rem;
            border-radius: 50%;
            transition: all 0.3s ease;
            font-weight: 700;
            min-width: 36px;
            height: 36px;
            flex-shrink: 0;
            margin-left: 1rem;
        }

        .submenu-toggle:hover {
            background: var(--header-accent);
            color: #2b2b2b;
        }

        .submenu-toggle[aria-expanded="true"] {
            transform: rotate(180deg);
            background: var(--header-accent);
            color: #2b2b2b;
        }

        .submenu {
            position: static;
            box-shadow: none;
            border: none;
            background: transparent;
            border-radius: 0;
            max-height: 0;
            overflow: hidden;
            transform: none;
            width: 100%;
            padding: 0;
            margin: 0 auto;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .submenu.is-open {
            max-height: 2000px;
            padding: 0.75rem 0 0 0;
            margin-top: 0.75rem;
        }

        .submenu li {
            margin-bottom: 0.75rem;
            animation: slideIn 0.3s ease forwards;
            list-style: none;
        }

        .submenu li:last-child {
            margin-bottom: 0;
        }

        .submenu a {
            font-size: 1.2rem;
            padding: 0.5rem 1rem;
            color: rgba(255, 255, 255, 0.85);
            background: transparent;
            border-radius: 0;
            transition: all 0.3s ease;
            font-weight: 600;
            display: block;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }

        .submenu a::after {
            display: none;
        }

        .submenu a:hover {
            background: transparent;
            color: var(--header-accent);
            transform: none;
        }

        .has-submenu:hover .submenu {
            transform: none;
        }
    }

    @keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
