---
import X from "../assets/redes/x.svg";
import Instagram from "../assets/redes/instagram.svg";
import TikTok from "../assets/redes/tiktok.svg";
import Youtube from "../assets/redes/youtube.svg";
import Facebook from "../assets/redes/facebook.svg";
import LinkedIn from "../assets/redes/linkedin.svg";
import { Show } from "@clerk/astro/components";
const Logo = "/logo-final-trans.png";

const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname === "/" ? "/home" : pathname;

const clerkUser = await Astro.locals.currentUser();
const userName = clerkUser?.firstName || clerkUser?.fullName || 'Usuario';
const userPhoto = clerkUser?.imageUrl || '';
---

<header class="header">
    <div class="logo">
        <a href="/home">
            <img
                src={Logo}
                alt="Madrid Femenino Xtra"
                width="150"
                height="150"
                loading="eager"
                class="header-logo-img"
            />
        </a>
    </div>

    <nav id="main-nav" class="main-nav">
        <div class="mobile-menu-logo">
            <a href="/home">
                <img
                    src={Logo}
                    alt="Madrid Femenino Xtra"
                    width="120"
                    height="60"
                    loading="lazy"
                />
            </a>
        </div>
        <div class="mobile-auth-zone">
            <Show when="signed-in">
                <button class="mobile-login-btn auth-user-btn" data-action="signout">
                    {userPhoto && <img class="auth-user-avatar" src={userPhoto} alt={userName} />}
                    <span class="auth-user-name">{userName}</span>
                </button>
            </Show>
            <Show when="signed-out">
                <button class="mobile-login-btn" data-action="signin-google">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0"/><path d="M6 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2"/></svg>
                    INICIAR SESIÓN
                </button>
            </Show>
        </div>

        <ul class="nav-list">
            <li>
                <a href="/home" class={currentPath === "/home" ? "active" : ""}>
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="nav-icon"
                        ><path stroke="none" d="M0 0h24v24H0z" fill="none"
                        ></path><path d="M5 12l-2 0l9 -9l9 9l-2 0"></path><path
                            d="M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-7"
                        ></path><path
                            d="M9 21v-6a2 2 0 0 1 2 -2h2a2 2 0 0 1 2 2v6"
                        ></path></svg
                    >
                    <span>Inicio</span>
                </a>
            </li>
            <li class="has-submenu">
                <div class="submenu-header">
                    <a
                        href="#"
                        aria-expanded="false"
                        aria-controls="submenu-actualidad"
                        class={currentPath.startsWith("/noticias") || currentPath.startsWith("/plantilla") || currentPath.startsWith("/calendario") || currentPath.startsWith("/galeria") ? "active" : ""}
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="nav-icon"
                            ><path stroke="none" d="M0 0h24v24H0z" fill="none"
                            ></path><path
                                d="M16 6h3a1 1 0 0 1 1 1v11a2 2 0 0 1 -4 0v-13a1 1 0 0 0 -1 -1h-10a1 1 0 0 0 -1 1v12a3 3 0 0 0 3 3h11"
                            ></path><path d="M8 8l4 0"></path><path d="M8 12l4 0"
                            ></path><path d="M8 16l4 0"></path></svg
                        >
                        <span>Actualidad</span>
                    </a>
                    <button
                        class="submenu-toggle"
                        aria-expanded="false"
                        aria-controls="submenu-actualidad"
                        aria-label="Abrir submenú de actualidad">▼</button
                    >
                </div>

                <ul class="submenu" id="submenu-actualidad">
                    <li><a href="/noticias"><span>Noticias</span></a></li>
                    <li><a href="/plantilla"><span>Plantilla</span></a></li>
                    <li><a href="/calendario"><span>Calendario</span></a></li>
                    <li><a href="/fotogalerias"><span>Fotogalerías</span></a></li>
                    <li><a href="/premios"><span>Premios 2025/26</span></a></li>
                </ul>
            </li>
            <li class="has-submenu">
                <div class="submenu-header">
                    <a
                        href="#"
                        aria-expanded="false"
                        aria-controls="submenu-estadisticas"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="nav-icon"
                            ><path stroke="none" d="M0 0h24v24H0z" fill="none"
                            ></path><path
                                d="M3 5a1 1 0 0 1 1 -1h16a1 1 0 0 1 1 1v10a1 1 0 0 1 -1 1h-16a1 1 0 0 1 -1 -1l0 -10"
                            ></path><path d="M7 20h10"></path><path d="M9 16v4"
                            ></path><path d="M15 16v4"></path><path d="M9 12v-4"
                            ></path><path d="M12 12v-1"></path><path
                                d="M15 12v-2"></path><path d="M12 12v-1"
                            ></path></svg
                        >
                        <span>Estadísticas</span>
                    </a>
                    <button
                        class="submenu-toggle"
                        aria-expanded="false"
                        aria-controls="submenu-estadisticas"
                        aria-label="Abrir submenú de estadísticas">▼</button
                    >
                </div>

                <ul class="submenu" id="submenu-estadisticas">
                    <li><a href="/jugadoras"><span>Jugadoras</span></a></li>
                    <li>
                        <a href="/entrenadores"><span>Entrenadores</span></a>
                    </li>
                    <li><a href="/arbitras"><span>Árbitras</span></a></li>
                    <li><a href="/partidos"><span>Partidos</span></a></li>
                    <li><a href="/rivales"><span>Rivales</span></a></li>
                    <li><a href="/estadios"><span>Estadios</span></a></li>
                    <li><a href="/rankings"><span>Rankings</span></a></li>
                    <li><a href="/records"><span>Récords</span></a></li>
                </ul>
            </li>
            <li>
                <a
                    href="/sobre-nosotros"
                    class={currentPath === "/sobre-nosotros" ? "active" : ""}
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="nav-icon"
                        ><path stroke="none" d="M0 0h24v24H0z" fill="none"
                        ></path><path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0"
                        ></path><path d="M12 9h.01"></path><path
                            d="M11 12h1v4h1"></path></svg
                    >
                    <span>Sobre Nosotros</span>
                </a>
            </li>
            <li>
                <a
                    href="/contacto"
                    class={currentPath === "/contacto" ? "active" : ""}
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="nav-icon"
                        ><path stroke="none" d="M0 0h24v24H0z" fill="none"
                        ></path><path
                            d="M5.821 4.91c3.899 -2.765 9.468 -2.539 13.073 .535c3.667 3.129 4.168 8.238 1.152 11.898c-2.841 3.447 -7.965 4.583 -12.231 2.805l-.233 -.101l-4.374 .931l-.04 .006l-.035 .007h-.018l-.022 .005h-.038l-.033 .004l-.021 -.001l-.023 .001l-.033 -.003h-.035l-.022 -.004l-.022 -.002l-.035 -.007l-.034 -.005l-.016 -.004l-.024 -.005l-.049 -.016l-.024 -.005l-.011 -.005l-.022 -.007l-.045 -.02l-.03 -.012l-.011 -.006l-.014 -.006l-.031 -.018l-.045 -.024l-.016 -.011l-.037 -.026l-.04 -.027l-.002 -.004l-.013 -.009l-.043 -.04l-.025 -.02l-.006 -.007l-.056 -.062l-.013 -.014l-.011 -.014l-.039 -.056l-.014 -.019l-.005 -.01l-.042 -.073l-.007 -.012l-.004 -.008l-.007 -.012l-.014 -.038l-.02 -.042l-.004 -.016l-.004 -.01l-.017 -.061l-.007 -.018l-.002 -.015l-.005 -.019l-.005 -.033l-.008 -.042l-.002 -.031l-.003 -.01v-.016l-.004 -.054l.001 -.036l.001 -.023l.002 -.053l.004 -.025v-.019l.008 -.035l.005 -.034l.005 -.02l.004 -.02l.018 -.06l.003 -.013l1.15 -3.45l-.022 -.037c-2.21 -3.747 -1.209 -8.391 2.413 -11.119z"
                        ></path></svg
                    >
                    <span>Contacto</span>
                </a>
            </li>
        </ul>

        <div class="mobile-social-icons">
            <a href="https://x.com/madridfemxtra" target="_blank"><X /></a>
            <a
                href="https://instagram.com/madridfemxtra"
                target="_blank"
                rel="noopener noreferrer"><Instagram /></a
            >
            <a
                href="https://tiktok.com/@madridfemeninoxtra"
                target="_blank"
                rel="noopener noreferrer"><TikTok /></a
            >
            <a
                href="https://www.youtube.com/@madridfemxtra"
                target="_blank"
                rel="noopener noreferrer"><Youtube /></a
            >
            <a
                href="https://www.facebook.com/madridfemxtra"
                target="_blank"
                rel="noopener noreferrer"><Facebook /></a
            >
            <a
                href="https://www.linkedin.com/company/madrid-femenino-xtra"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="LinkedIn"><LinkedIn /></a
            >
            <a href="https://discord.gg/Q7qGW3RP" target="_blank" rel="noopener noreferrer" aria-label="Discord">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-brand-discord"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M8 12a1 1 0 1 0 2 0a1 1 0 0 0 -2 0" /><path d="M14 12a1 1 0 1 0 2 0a1 1 0 0 0 -2 0" /><path d="M15.5 17c0 1 1.5 3 2 3c1.5 0 2.833 -1.667 3.5 -3c.667 -1.667 .5 -5.833 -1.5 -11.5c-1.457 -1.015 -3 -1.34 -4.5 -1.5l-.972 1.923a11.913 11.913 0 0 0 -4.053 0l-.975 -1.923c-1.5 .16 -3.043 .485 -4.5 1.5c-2 5.667 -2.167 9.833 -1.5 11.5c.667 1.333 2 3 3.5 3c.5 0 2 -2 2 -3" /><path d="M7 16.5c3.5 1 6.5 1 10 0" /></svg>
            </a>
        </div>
    </nav>

    <div class="social-icons desktop-social-icons">
        <div class="auth-zone">
            <Show when="signed-in">
                <button class="auth-login-btn auth-user-btn" data-action="signout">
                    {userPhoto && <img class="auth-user-avatar" src={userPhoto} alt={userName} />}
                    <span class="auth-user-name">{userName}</span>
                </button>
            </Show>
            <Show when="signed-out">
                <button class="auth-login-btn" data-action="signin-google">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0"/><path d="M6 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2"/></svg>
                    INICIAR SESIÓN
                </button>
            </Show>
        </div>
        <a href="https://x.com/madridfemxtra" target="_blank"><X /></a>
        <a
            href="https://instagram.com/madridfemxtra"
            target="_blank"
            rel="noopener noreferrer"><Instagram /></a
        >
        <a
            href="https://tiktok.com/@madridfemeninoxtra"
            target="_blank"
            rel="noopener noreferrer"><TikTok /></a
        >
        <a
            href="https://www.youtube.com/@madridfemxtra"
            target="_blank"
            rel="noopener noreferrer"><Youtube /></a
        >
    </div>

    <button
        class="menu-toggle"
        id="menu-toggle"
        aria-controls="main-nav"
        aria-expanded="false"
        aria-label="Abrir menú de navegación"
    >
        <span class="line"></span>
        <span class="line"></span>
        <span class="line"></span>
    </button>
    <div id="nav-overlay" class="nav-overlay"></div>
    <script is:inline type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "ItemList",
            "itemListElement": [
                {
                    "@type": "SiteNavigationElement",
                    "position": 3,
                    "name": "Plantilla",
                    "description": "Jugadoras del Real Madrid Femenino",
                    "url": "https://www.madridfemeninoxtra.com/plantilla"
                },
                {
                    "@type": "SiteNavigationElement",
                    "position": 4,
                    "name": "Partidos",
                    "description": "Calendario y resultados",
                    "url": "https://www.madridfemeninoxtra.com/partidos"
                },
                {
                    "@type": "SiteNavigationElement",
                    "position": 5,
                    "name": "Rankings",
                    "description": "Clasificación y estadísticas",
                    "url": "https://www.madridfemeninoxtra.com/rankings"
                }
            ]
        }
    </script>
</header>

<script src="../scripts/menu.js"></script>

<script is:inline>
    document.addEventListener('click', async function(e) {
        var btn = e.target.closest('[data-action]');
        if (!btn) return;

        var action = btn.dataset.action;

        if (action === 'signin-google') {
            if (window.innerWidth <= 1024) {
                window.Clerk.redirectToSignIn({ afterSignInUrl: window.location.href });
            } else {
                window.Clerk.openSignIn({
                    afterSignInUrl: window.location.href,
                    afterSignUpUrl: window.location.href,
                });
            }
        } else if (action === 'signout') {
            try {
                await window.Clerk.signOut();
                window.location.reload();
            } catch (err) {
                console.error('Error al cerrar sesión:', err);
            }
        }
    });
</script>

<style>
    :root {
        --header-bg: #2b2b2b;
        --header-bg-gradient: linear-gradient(to right, #2b2b2b, #1f1f1f);
        --header-text: #ffffff;
        --header-accent: #ffde59;
        --header-hover-bg: rgba(255, 222, 89, 0.1);
    }

    .header {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        padding: 0.5rem 2.5rem;
        background: var(--header-bg-gradient);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
        position: relative;
        top: 0;
        left: 0;
        right: 0;
        width: 100%;
        z-index: 1000000;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    @media (max-width: 1440px) {
        .header { gap: 1.5rem; padding: 0.5rem 1.5rem; }
        .nav-list { gap: 1.5rem; }
    }

    .logo {
        display: flex;
        justify-content: flex-start;
        align-items: center;
        width: 160px;
        height: 70px;
        position: relative;
        overflow: visible;
        justify-self: start;
    }

    @media (max-width: 1024px) {
        :global(body.nav-open) .logo {
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }
        .logo {
            transition:
                opacity 0.3s ease,
                visibility 0.3s ease;
        }
    }

    .logo a {
        display: flex;
        align-items: center;
    }

    .logo a:hover {
        transform: none;
    }

    .header-logo-img {
        width: auto !important;
        height: 70px !important;
        max-width: 100% !important;
        object-fit: contain;
    }

    .custom-select-container.open {
        z-index: 9999 !important;
    }

    .custom-select-container.open .custom-select-options {
        z-index: 10000 !important;
    }

    .main-nav {
        display: flex;
        justify-content: center;
        justify-self: center;
    }

    .desktop-social-icons {
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
        justify-self: end;
        flex-wrap: wrap;
    }

    .desktop-social-icons a {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.05);
        transition: all 0.3s ease;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #ffffff !important;
    }

    .desktop-social-icons a svg {
        width: 1.2rem;
        height: 1.2rem;
        transition: all 0.3s ease;
    }

    .desktop-social-icons a:hover {
        background: var(--header-accent);
        transform: translateY(-2px);
        border-color: var(--header-accent);
        color: #2b2b2b !important;
    }

    .desktop-social-icons a:hover svg {
        color: #ffffff !important;
    }

    .icon-tabler-brand-linkedin {
        width: 1.5rem !important;
        height: 1.5rem !important;
        fill: none !important;
        stroke: currentColor !important;
        stroke-width: 2 !important;
        transition: all 0.3s ease;
    }

    .icon-tabler-brand-linkedin path {
        fill: none !important;
        stroke: currentColor !important;
        transition: all 0.3s ease;
    }

    .desktop-social-icons a:hover .icon-tabler-brand-linkedin,
    .mobile-social-icons a:hover .icon-tabler-brand-linkedin {
        stroke: #ffffff !important;
        fill: none !important;
    }

    .mobile-social-icons {
        display: none;
    }

    .nav-list {
        display: flex;
        list-style: none;
        padding: 0;
        margin: 0;
        gap: 2.5rem;
    }

    .nav-list a {
        color: var(--header-text);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: color 0.3s ease;
        padding: 0.5rem 0;
        position: relative;
        white-space: nowrap;
        display: inline-block;
    }

    .nav-icon {
        display: none;
    }

    .linkedin-stroke {
        display: none;
    }

    .nav-list a::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0;
        height: 2px;
        background-color: var(--header-accent);
        transition: width 0.3s ease;
    }

    .nav-list a:hover {
        color: var(--header-accent);
    }

    .nav-list a:hover::after,
    .nav-list a.active::after {
        width: 100%;
    }

    .nav-list a.active {
        color: var(--header-accent);
    }

    .submenu-toggle {
        display: none;
    }

    .mobile-menu-logo {
        display: none;
    }

    .has-submenu {
        position: relative;
    }

    .submenu {
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%) translateY(10px);
        list-style: none;
        padding: 0.5rem;
        min-width: 200px;
        background: #2b2b2b;
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        border-radius: 8px;
        visibility: hidden;
        opacity: 0;
        pointer-events: none;
        transition: all 0.3s ease;
        z-index: 20;
    }

    .has-submenu:hover .submenu {
        visibility: visible;
        opacity: 1;
        pointer-events: auto;
        transform: translateX(-50%) translateY(0);
    }

    .submenu a {
        display: block;
        padding: 0.75rem 1rem;
        color: #e0e0e0;
        text-decoration: none;
        border-radius: 4px;
        text-transform: none;
        font-weight: 500;
        text-align: center;
    }

    .submenu a::after {
        display: none;
    }

    .submenu a:hover {
        background-color: rgba(255, 255, 255, 0.05);
        color: var(--header-accent);
    }

    .menu-toggle {
        display: none;
    }

    @media (max-width: 1024px) {
        .header {
            display: flex;
            justify-content: space-between;
            padding: 0.5rem 1.5rem;
            top: 0;
        }

        .logo {
            margin: 0;
            order: 1;
            width: 140px;
            height: 60px;
        }

        .desktop-social-icons {
            display: none;
        }

        .menu-toggle {
            display: block;
            background: none;
            border: none;
            padding: 10px;
            z-index: 100;
            cursor: pointer;
            order: 3;
        }

        .menu-toggle .line {
            display: block;
            width: 25px;
            height: 2px;
            background-color: var(--header-text);
            margin: 6px 0;
            transition:
                transform 0.3s,
                opacity 0.3s,
                background-color 0.3s;
        }

        .menu-toggle:hover .line {
            background-color: var(--header-accent);
            width: 30px;
        }

        .menu-toggle:active {
            transform: scale(0.9);
        }

        .menu-toggle[aria-expanded="true"] .line:nth-child(1) {
            transform: translateY(8px) rotate(45deg);
        }

        .menu-toggle[aria-expanded="true"] .line:nth-child(2) {
            opacity: 0;
        }

        .menu-toggle[aria-expanded="true"] .line:nth-child(3) {
            transform: translateY(-8px) rotate(-45deg);
        }

        .main-nav {
            position: fixed;
            top: 0;
            left: 0;
            width: 85%;
            max-width: 320px;
            height: 100vh;
            background: #2b2b2b;
            box-shadow: 5px 0 25px rgba(0, 0, 0, 0.5);
            z-index: 999999;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            align-items: center;
            padding: 2rem 0;
            transform: translateX(-100%);
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            order: 2;
            overflow-y: auto;
            pointer-events: none;
        }

        .mobile-menu-logo {
            display: block;
            margin-bottom: 0;
            padding-bottom: 1.5rem;
