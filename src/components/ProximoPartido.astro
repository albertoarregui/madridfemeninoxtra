---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import vsImagen from "../assets/main/vs.png";
import { generateSlug } from "../utils/url-helper";
import { getAssetUrl, getAssetMetadata } from "../utils/assets";
import { parseMatchDate, isMatchActive } from "../utils/date-helper";
import { fetchCalendarFromDb } from "../utils/calendar";
import "@fontsource/bowlby-one-sc";

interface Props {
    rivalStats?: {
        wins: number;
        draws: number;
        losses: number;
        total: number;
    };
}

const { rivalStats } = Astro.props;

const calendarMatches = await fetchCalendarFromDb();

const nextMatch =
    calendarMatches.length > 0
        ? calendarMatches.find((match) => isMatchActive(match.date, match.time))
        : null;

const activeMatch =
    nextMatch ||
    (calendarMatches.length > 0
        ? calendarMatches[calendarMatches.length - 1]
        : null);

if (!activeMatch) {
    return null; // O podrías retornar un mensaje de "No hay partidos próximos"
}
const LOCAL_TEAM = activeMatch.team1;
const VISITOR_TEAM = activeMatch.team2;
const activeDateObj = parseMatchDate(activeMatch.date, activeMatch.time);
const MATCH_DATE = activeDateObj.toISOString();

const formatDisplayDate = (dateObj: Date) => {
    return new Intl.DateTimeFormat("es-ES", {
        day: "2-digit",
        month: "2-digit",
        year: "numeric",
        hour: "2-digit",
        minute: "2-digit",
        timeZone: "Europe/Madrid",
    }).format(dateObj);
};

const MATCH_DATE_DISPLAY = formatDisplayDate(activeDateObj);
const MATCH_TIME_DISPLAY = activeMatch.time.replace(/[^0-9:]/g, "");
const STADIUM = activeMatch.stadium || "Estadio Alfredo Di Stéfano";
const TV = activeMatch.tv || "DAZN";

function getCompetitionLogo(competitionName: string) {
    return getAssetMetadata("competiciones", competitionName);
}

const compLogo = getCompetitionLogo(activeMatch.competition);

function getTeamLogo(teamName: string) {
    return getAssetMetadata("escudos", teamName);
}

// Para el escudo: si la BD devuelve foto_url directamente, usarla; si no, buscar en assets locales
const localShieldUrl =
    activeMatch.local_foto_url || getAssetUrl("escudos", LOCAL_TEAM) || "";
const visitorShieldUrl =
    activeMatch.visitante_foto_url ||
    getAssetUrl("escudos", VISITOR_TEAM) ||
    "";

const localLogo = getTeamLogo(LOCAL_TEAM);
const visitorLogo = getTeamLogo(VISITOR_TEAM);
---

<aside class="card-proximo-partido cursor-default">
    <div class="match-header clean">
        <h2 class="section-title">PRÓXIMO PARTIDO</h2>
        <div class="competicion-badge interactive-capsule">
            {
                compLogo && (
                    <Image
                        src={compLogo}
                        alt={activeMatch.competition}
                        class="competicion-logo"
                        width={30}
                        height={30}
                        format="webp"
                    />
                )
            }
            <span class="competicion-text">
                {activeMatch.competition}
                {
                    activeMatch.jornada ? (
                        <>
                            {" | "}
                            {activeMatch.competition === "Liga F"
                                ? `Jornada ${activeMatch.jornada}`
                                : activeMatch.jornada}
                        </>
                    ) : (
                        ""
                    )
                }
            </span>
        </div>
    </div>

    <div class="match-card-content">
        <div class="teams-battle">
            <div class="team-side local">
                {
                    localShieldUrl ? (
                        <img
                            src={localShieldUrl}
                            alt={LOCAL_TEAM}
                            class="escudo-giant"
                            width="170"
                            height="170"
                        />
                    ) : localLogo ? (
                        <Image
                            src={localLogo}
                            alt={LOCAL_TEAM}
                            class="escudo-giant"
                            width={170}
                            height={170}
                            format="webp"
                        />
                    ) : (
                        <div class="escudo-placeholder" />
                    )
                }
                <span class="team-name-lg"
                    >{LOCAL_TEAM.replace("Femenino", "")}</span
                >
            </div>

            <div class="vs-center">
                <Image
                    src={vsImagen}
                    alt="VS"
                    class="vs-img-lg"
                    width={240}
                    height={240}
                    format="webp"
                />
            </div>

            <div class="team-side visitor">
                {
                    visitorShieldUrl ? (
                        <img
                            src={visitorShieldUrl}
                            alt={VISITOR_TEAM}
                            class="escudo-giant"
                            width="170"
                            height="170"
                        />
                    ) : visitorLogo ? (
                        <Image
                            src={visitorLogo}
                            alt={VISITOR_TEAM}
                            class="escudo-giant"
                            width={170}
                            height={170}
                            format="webp"
                        />
                    ) : (
                        <div class="escudo-placeholder" />
                    )
                }
                <span class="team-name-lg"
                    >{VISITOR_TEAM.replace("Femenino", "")}</span
                >
            </div>
        </div>

        <div class="meta-capsules-row">
            <div class="info-pill">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="icon icon-tabler icons-tabler-outline icon-tabler-calendar-week"
                    ><path stroke="none" d="M0 0h24v24H0z" fill="none"
                    ></path><path
                        d="M4 7a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2v-12"
                    ></path><path d="M16 3v4"></path><path d="M8 3v4"
                    ></path><path d="M4 11h16"></path><path d="M7 14h.013"
                    ></path><path d="M10.01 14h.005"></path><path
                        d="M13.01 14h.005"></path><path d="M16.015 14h.005"
                    ></path><path d="M13.015 17h.005"></path><path
                        d="M7.01 17h.005"></path><path d="M10.01 17h.005"
                    ></path></svg
                >
                <span>{MATCH_DATE_DISPLAY.split(",")[0].trim()}</span>
            </div>
            <div class="info-pill">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="icon icon-tabler icons-tabler-outline icon-tabler-clock"
                    ><path stroke="none" d="M0 0h24v24H0z" fill="none"
                    ></path><path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0"
                    ></path><path d="M12 7v5l3 3"></path></svg
                >
                <span>{MATCH_TIME_DISPLAY}</span>
            </div>
            <div class="info-pill">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="icon icon-tabler icons-tabler-outline icon-tabler-building-stadium"
                    ><path stroke="none" d="M0 0h24v24H0z" fill="none"
                    ></path><path d="M4 12a8 2 0 1 0 16 0a8 2 0 1 0 -16 0"
                    ></path><path
                        d="M4 12v7c0 .94 2.51 1.785 6 2v-3h4v3c3.435 -.225 6 -1.07 6 -2v-7"
                    ></path><path d="M15 6h4v-3h-4v7"></path><path
                        d="M7 6h4v-3h-4v7"></path></svg
                >
                <a
                    href={`/estadios/${generateSlug(STADIUM)}`}
                    class="hover:underline">{STADIUM}</a
                >
            </div>
            <div class="info-pill">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="icon icon-tabler icons-tabler-outline icon-tabler-device-tv"
                    ><path stroke="none" d="M0 0h24v24H0z" fill="none"
                    ></path><path
                        d="M3 9a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v9a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2l0 -9"
                    ></path><path d="M16 3l-4 4l-4 -4"></path></svg
                >
                <span>{TV}</span>
            </div>
        </div>

        <div class="countdown-premium">
            <h3 class="countdown-header">C O U N T D O W N</h3>
            <div id="countdown-grid-premium">
                <!-- Días -->
                <div class="cd-circle-unit" id="unit-days">
                    <div class="circle-container">
                        <svg viewBox="0 0 100 100">
                            <circle class="circle-bg" cx="50" cy="50" r="45"
                            ></circle>
                            <circle
                                class="circle-progress"
                                cx="50"
                                cy="50"
                                r="45"></circle>
                        </svg>
                        <span class="cd-val" id="val-days">00</span>
                    </div>
                    <span class="cd-label">DAYS</span>
                </div>
                <!-- Horas -->
                <div class="cd-circle-unit" id="unit-hours">
                    <div class="circle-container">
                        <svg viewBox="0 0 100 100">
                            <circle class="circle-bg" cx="50" cy="50" r="45"
                            ></circle>
                            <circle
                                class="circle-progress"
                                cx="50"
                                cy="50"
                                r="45"></circle>
                        </svg>
                        <span class="cd-val" id="val-hours">00</span>
                    </div>
                    <span class="cd-label">HOURS</span>
                </div>
                <!-- Minutos -->
                <div class="cd-circle-unit" id="unit-minutes">
                    <div class="circle-container">
                        <svg viewBox="0 0 100 100">
                            <circle class="circle-bg" cx="50" cy="50" r="45"
                            ></circle>
                            <circle
                                class="circle-progress"
                                cx="50"
                                cy="50"
                                r="45"></circle>
                        </svg>
                        <span class="cd-val" id="val-minutes">00</span>
                    </div>
                    <span class="cd-label">MINUTES</span>
                </div>
                <!-- Segundos -->
                <div class="cd-circle-unit" id="unit-seconds">
                    <div class="circle-container">
                        <svg viewBox="0 0 100 100">
                            <circle class="circle-bg" cx="50" cy="50" r="45"
                            ></circle>
                            <circle
                                class="circle-progress"
                                cx="50"
                                cy="50"
                                r="45"></circle>
                        </svg>
                        <span class="cd-val" id="val-seconds">00</span>
                    </div>
                    <span class="cd-label">SECONDS</span>
                </div>
            </div>
        </div>

        {
            rivalStats && (
                <div class="stats-footer">
                    <div class="stats-header">
                        <h4>HISTÓRICO DE ENFRENTAMIENTOS</h4>
                        <span>{rivalStats.total} PARTIDOS</span>
                    </div>
                    <div class="stats-bar-wrapper">
                        <div class="stats-bar">
                            <div
                                class="bar-segment win"
                                style={`width: ${rivalStats.total > 0 ? (rivalStats.wins / rivalStats.total) * 100 : 0}%`}
                            >
                                <div class="stat-tooltip">
                                    <span class="val">{rivalStats.wins}</span>
                                    <span class="lbl">Victorias</span>
                                </div>
                                {rivalStats.wins > 0 && (
                                    <span class="bar-label">
                                        {rivalStats.wins}
                                    </span>
                                )}
                            </div>
                            <div
                                class="bar-segment draw"
                                style={`width: ${rivalStats.total > 0 ? (rivalStats.draws / rivalStats.total) * 100 : 0}%`}
                            >
                                <div class="stat-tooltip">
                                    <span class="val">{rivalStats.draws}</span>
                                    <span class="lbl">Empates</span>
                                </div>
                                {rivalStats.draws > 0 && (
                                    <span class="bar-label">
                                        {rivalStats.draws}
                                    </span>
                                )}
                            </div>
                            <div
                                class="bar-segment loss"
                                style={`width: ${rivalStats.total > 0 ? (rivalStats.losses / rivalStats.total) * 100 : 0}%`}
                            >
                                <div class="stat-tooltip">
                                    <span class="val">{rivalStats.losses}</span>
                                    <span class="lbl">Derrotas</span>
                                </div>
                                {rivalStats.losses > 0 && (
                                    <span class="bar-label">
                                        {rivalStats.losses}
                                    </span>
                                )}
                            </div>
                        </div>
                    </div>
                </div>
            )
        }
    </div>
</aside>

<script is:inline define:vars={{ MATCH_DATE }}>
    const fechaPartido = new Date(MATCH_DATE);

    function setCircleProgress(id, percent) {
        const circle = document.querySelector(`#unit-${id} .circle-progress`);
        if (!circle) return;
        const radius = circle.r.baseVal.value;
        const circumference = 2 * Math.PI * radius;
        const offset = circumference - (percent / 100) * circumference;
        circle.style.strokeDasharray = `${circumference} ${circumference}`;
        circle.style.strokeDashoffset = offset;
    }

    function actualizar() {
        const ahora = new Date();
        const diff = fechaPartido.getTime() - ahora.getTime();

        if (diff <= 0) {
            const grid = document.getElementById("countdown-grid-premium");
            if (grid)
                grid.innerHTML =
                    "<span class='live-badge'>¡PARTIDO EN JUEGO!</span>";
            return;
        }

        const d = Math.floor(diff / (1000 * 60 * 60 * 24));
        const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const s = Math.floor((diff % (1000 * 60)) / 1000);

        const pad = (n) => n.toString().padStart(2, "0");

        document.getElementById("val-days").innerText = pad(d);
        document.getElementById("val-hours").innerText = pad(h);
        document.getElementById("val-minutes").innerText = pad(m);
        document.getElementById("val-seconds").innerText = pad(s);

        // Progress: Days (limit to 30 for visualization), Hours (24), Mins (60), Secs (60)
        setCircleProgress("days", Math.min(100, (d / 30) * 100));
        setCircleProgress("hours", (h / 24) * 100);
        setCircleProgress("minutes", (m / 60) * 100);
        setCircleProgress("seconds", (s / 60) * 100);
    }
    actualizar();
    setInterval(actualizar, 1000);
</script>

<style>
    .card-proximo-partido {
        background: #0a0a0a; /* Dark background to match the image style */
        border: 1px solid #333;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        overflow: hidden;
        margin-bottom: 0;
        font-family: "Inter", system-ui, sans-serif;
        color: #fff;
    }

    .section-title {
        font-size: 2.25rem;
        font-weight: 800;
        font-family: "Archivo Black", sans-serif;
        color: #fff;
        text-transform: uppercase;
        margin: 0;
        margin-bottom: 2rem;
        position: relative;
        display: inline-block;
    }

    .section-title::after {
        content: "";
        position: absolute;
        bottom: -10px;
        left: 50%;
        transform: translateX(-50%);
        width: 120px;
        height: 6px;
        background: #00f2ff; /* Cyan progress color */
        border-radius: 3px;
    }

    .match-header {
        padding: 2.5rem 1rem 1rem 1rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
    }

    .interactive-capsule {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 1rem;
        background-color: #1a1a1a;
        border: 1px solid #333;
        border-radius: 9999px;
    }
    .competicion-text {
        font-size: 1rem;
        font-weight: 800;
        color: #00f2ff;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .match-card-content {
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
        align-items: center;
    }

    .teams-battle {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.25rem;
        width: 100%;
    }
    .team-side {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        flex: 1;
        text-align: center;
    }
    .escudo-giant {
        width: 170px;
        height: 170px;
        object-fit: contain;
        filter: drop-shadow(0 0 15px rgba(255, 222, 89, 0.2));
    }
    .team-name-lg {
        font-size: 1.35rem;
        font-weight: 800;
        text-transform: uppercase;
        color: #fff;
    }

    .vs-img-lg {
        width: 240px;
        height: 240px;
        margin: 0 -70px;
    }

    .info-pill {
        background-color: #1a1a1a;
        border: 1px solid #333;
        color: #ccc;
    }

    /* Countdown Styling - NEW */
    .countdown-premium {
        width: 100%;
        text-align: center;
        padding: 2rem 0;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .countdown-header {
        font-size: 1.2rem;
        font-weight: 300;
        letter-spacing: 1.2rem;
        color: #888;
        margin-bottom: 2.5rem;
        margin-left: 1.2rem; /* Balance spacing */
    }
    #countdown-grid-premium {
        display: flex;
        justify-content: center;
        gap: 2.5rem;
        flex-wrap: nowrap;
    }
    .cd-circle-unit {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
    }
    .circle-container {
        position: relative;
        width: 120px;
        height: 120px;
    }
    .circle-container svg {
        transform: rotate(-90deg);
        width: 100%;
        height: 100%;
    }
    .circle-bg {
        fill: none;
        stroke: #222;
        stroke-width: 6;
        stroke-dasharray: 2 6; /* Dotted effect */
    }
    .circle-progress {
        fill: none;
        stroke: #00f2ff;
        stroke-width: 6;
        stroke-dasharray: 2 6; /* Dotted effect */
        stroke-linecap: round;
        transition: stroke-dashoffset 0.5s ease-out;
        filter: drop-shadow(0 0 8px #00f2ff);
    }
    .cd-val {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 3rem;
        font-weight: 700;
        font-family: "Bowlby One SC", sans-serif;
        color: #fff;
    }
    .cd-label {
        font-size: 0.8rem;
        font-weight: 400;
        color: #888;
        letter-spacing: 0.2rem;
    }

    .live-badge {
        font-size: 2.5rem;
        font-weight: 900;
        color: #00f2ff;
        text-shadow: 0 0 20px rgba(0, 242, 255, 0.5);
    }

    /* Stats bar footer */
    .stats-footer {
        width: 100%;
        border-top: 1px solid #333;
        padding-top: 2rem;
    }
    .stats-header h4 {
        color: #888;
    }
    .stats-bar {
        background: #222;
    }

    @media (max-width: 768px) {
        .match-card-content {
            padding: 1.5rem 0.5rem;
        }
        .teams-battle {
            flex-direction: row;
        }
        .escudo-giant {
            width: 100px;
            height: 100px;
        }
        .vs-img-lg {
            width: 120px;
            height: 120px;
            margin: 0 -35px;
        }
        .team-name-lg {
            font-size: 1rem;
        }

        #countdown-grid-premium {
            gap: 0.5rem;
        }
        .circle-container {
            width: 75px;
            height: 75px;
        }
        .cd-val {
            font-size: 1.8rem;
        }
        .cd-label {
            font-size: 0.6rem;
            letter-spacing: 0.1rem;
        }
        .countdown-header {
            font-size: 0.8rem;
            letter-spacing: 0.5rem;
            margin-bottom: 1.5rem;
        }
    }
</style>
