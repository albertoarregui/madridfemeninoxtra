---
interface Props {
    showAds?: boolean;
}

const { showAds = true } = Astro.props;
---

{
    showAds && (
        <div id="cookie-banner" class="cookie-banner hidden">
            <div class="cookie-content">
                <p>
                    Utilizamos cookies propias y de terceros para mejorar su
                    experiencia y mostrarle publicidad relacionada con sus
                    preferencias mediante el análisis de sus hábitos de
                    navegación.
                </p>
                <div class="cookie-buttons">
                    <button id="accept-cookies" class="btn-accept">
                        Aceptar
                    </button>
                    <button id="reject-cookies" class="btn-reject">
                        Rechazar
                    </button>
                    <a href="/politica-cookies" class="cookie-link">
                        Más información
                    </a>
                </div>
            </div>
        </div>
    )
}

<script is:inline>
    // Función para cargar Google AdSense
    function loadAdSense() {
        const script = document.createElement("script");
        script.src =
            "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3753331336777901";
        script.async = true;
        script.crossOrigin = "anonymous";
        document.head.appendChild(script);
    }

    // Lógica del banner
    document.addEventListener("DOMContentLoaded", () => {
        const banner = document.getElementById("cookie-banner");
        const acceptBtn = document.getElementById("accept-cookies");
        const rejectBtn = document.getElementById("reject-cookies");

        if (!banner) return;

        const cookieConsent = localStorage.getItem("cookie_consent");

        if (cookieConsent === "accepted") {
            loadAdSense();
        } else if (!cookieConsent) {
            banner.classList.remove("hidden");
        }

        acceptBtn?.addEventListener("click", () => {
            localStorage.setItem("cookie_consent", "accepted");
            banner.classList.add("hidden");
            loadAdSense();
        });

        rejectBtn?.addEventListener("click", () => {
            localStorage.setItem("cookie_consent", "rejected");
            // Eliminamos banner
            banner.classList.add("hidden");
            // No cargamos AdSense
        });
    });
</script>

<style>
    .cookie-banner {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        background-color: rgba(33, 33, 33, 0.98);
        border-top: 1px solid #ffde59;
        padding: 1.5rem;
        box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.5);
        z-index: 10000;
        backdrop-filter: blur(5px);
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .cookie-content {
        max-width: 1200px;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
    }

    .cookie-banner.hidden {
        display: none;
    }

    .cookie-content p {
        color: #e0e0e0;
        font-size: 0.95rem;
        margin: 0;
        line-height: 1.5;
        flex: 1;
    }

    .cookie-buttons {
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-shrink: 0;
    }

    .btn-accept,
    .btn-reject {
        padding: 0.6rem 1.5rem;
        border: none;
        border-radius: 6px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 0.95rem;
        text-transform: uppercase;
    }

    .btn-accept {
        background-color: #ffde59;
        color: #000;
    }

    .btn-accept:hover {
        background-color: #e6c84c;
        transform: translateY(-2px);
    }

    .btn-reject {
        background-color: transparent;
        border: 1px solid #ffde59;
        color: #ffde59;
    }

    .btn-reject:hover {
        background-color: rgba(255, 222, 89, 0.1);
        transform: translateY(-2px);
    }

    .cookie-link {
        color: #bdbdbd;
        font-size: 0.85rem;
        text-decoration: underline;
        margin-left: 0.5rem;
    }

    .cookie-link:hover {
        color: #fff;
    }

    /* Mobile adjustments */
    @media (max-width: 768px) {
        .cookie-banner {
            padding: 1rem;
        }

        .cookie-content {
            flex-direction: column;
            text-align: center;
            gap: 1rem;
        }

        .cookie-buttons {
            width: 100%;
            justify-content: center;
        }

        .btn-accept,
        .btn-reject {
            width: 100%;
        }
    }
</style>
