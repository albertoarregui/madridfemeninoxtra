---
import { Image } from "astro:assets";
import { contentfulClient } from "../lib/contentful";

let hitos: {
    slug: string;
    title: string;
    description: string;
    jugadora?: string;
    category: string;
    icon?: string;
    img: string;
}[] = [];

try {
    const lastMonth = new Date();
    lastMonth.setMonth(lastMonth.getMonth() - 1);

    const entries = await contentfulClient.getEntries({
        content_type: "noticia",
        "sys.createdAt[gte]": lastMonth.toISOString(),
        order: ["-sys.createdAt"] as any,
    });

    if (entries?.items) {
        hitos = entries.items.map((item: any) => ({
            slug: item.fields.slug || "sin-slug",
            title: item.fields.title?.toUpperCase() || "NOTICIA",
            description: item.fields.subtitle || "",
            jugadora: item.fields.player || "Jugadora",
            category: item.fields.category || "HITO",
            img: item.fields.featuredImage?.fields?.file?.url
                ? `https:${item.fields.featuredImage.fields.file.url}`
                : "https://res.cloudinary.com/dnx7vsqbi/image/upload/v1741372500/background/stadium.webp",
        }));
    }
} catch (e) {
    console.error("Error cargando hitos en el carrusel:", e);
}
---

<div class="hitos-carousel-full">
    <div class="carousel-nav-wrapper">
        <div class="hitos-grid" id="hitosGrid">
            {
                hitos.map((hito) => (
                    <a
                        href={`/noticias/${hito.slug}`}
                        class="hito-card-vertical"
                        onclick={`window.location.href='/noticias/${hito.slug}'; return false;`}
                    >
                        <div class="inner-content">
                            <div class="hito-img-wrapper">
                                <img
                                    src={hito.img}
                                    alt={hito.title}
                                    class="hito-img"
                                />
                            </div>
                            <div class="hito-info">
                                <div class="hito-badge">{hito.category}</div>
                                <h3 class="hito-name">{hito.title}</h3>
                                <p class="hito-meta">{hito.description}</p>
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</div>

<script>
    const grid = document.getElementById("hitosGrid");
    let scrollInterval: any;
    let resumeTimeout: any;
    let isPaused = false;

    if (grid) {
        const startAutoScroll = () => {
            scrollInterval = setInterval(() => {
                if (!isPaused) {
                    if (
                        grid.scrollLeft + grid.clientWidth >=
                        grid.scrollWidth
                    ) {
                        grid.scrollTo({ left: 0, behavior: "smooth" });
                    } else {
                        grid.scrollBy({ left: 2, behavior: "auto" });
                    }
                }
            }, 30);
        };

        grid.addEventListener("mouseenter", () => {
            clearTimeout(resumeTimeout);
            isPaused = true;
        });
        grid.addEventListener("mouseleave", () => {
            isPaused = false;
        });
        grid.addEventListener(
            "touchstart",
            () => {
                clearTimeout(resumeTimeout);
                isPaused = true;
            },
            { passive: true },
        );
        grid.addEventListener("touchend", () => {
            clearTimeout(resumeTimeout);
            resumeTimeout = setTimeout(() => {
                isPaused = false;
            }, 3000);
        });

        // Iniciar el scroll
        startAutoScroll();
    }
</script>

<style>
    .hitos-carousel-full {
        width: 100%;
        background: #ffffff;
        overflow: hidden;
        padding: 0;
        position: relative;
        z-index: 50;
    }

    .carousel-nav-wrapper {
        position: relative;
        width: 100%;
        display: flex;
        align-items: center;
    }

    .hitos-grid {
        display: flex;
        width: 100%;
        gap: 0;
        overflow-x: auto;
        scrollbar-width: none;
        -ms-overflow-style: none;
        scroll-behavior: smooth;
        cursor: grab;
    }

    .hitos-grid::-webkit-scrollbar {
        display: none;
    }

    .hito-card-vertical {
        flex: 1;
        display: flex;
        flex-direction: column;
        text-decoration: none;
        transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        background: #ffffff;
        min-width: 140px;
        max-width: 200px;
        border-radius: 40px 0 40px 0;
        overflow: hidden;
        margin: 0;
        position: relative;
        padding: 0;
        cursor: pointer;
        user-select: none;
        -webkit-user-drag: none;
    }

    .hito-card-vertical::before {
        content: "";
        position: absolute;
        inset: -100%;
        background: conic-gradient(
            from 0deg,
            #ffde59 0%,
            #ffde59 25%,
            transparent 50%
        );
        z-index: 0;
        opacity: 0;
        transition: opacity 0.3s;
        animation: rotate 1s linear infinite;
    }

    @keyframes rotate {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }

    .hito-card-vertical:hover {
        padding: 4px;
        border-color: transparent;
        flex: 1.6;
        z-index: 10;
    }

    .hito-card-vertical:hover::before {
        opacity: 1;
    }

    .inner-content {
        background: #ffffff;
        border-radius: inherit;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        position: relative;
        z-index: 1;
        overflow: hidden;
    }

    .hito-img-wrapper {
        width: 100%;
        aspect-ratio: 3/4.5;
        position: relative;
        overflow: hidden;
        background: #111;
    }

    .hito-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition:
            transform 0.6s ease,
            filter 0.4s ease;
        filter: brightness(0.7);
        pointer-events: none;
        user-select: none;
        -webkit-user-drag: none;
    }

    .hito-card-vertical:hover .hito-img {
        transform: scale(1.1);
        filter: brightness(1);
    }

    .hito-badge {
        display: inline-block;
        background: #ffde59;
        color: #2b2b2b;
        padding: 2px 14px;
        font-family: "Bebas Neue", sans-serif;
        font-size: 0.7rem;
        font-weight: 900;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        width: fit-content;
        margin-bottom: 0.8rem;
        border-radius: 50px;
        box-shadow: 0 2px 10px rgba(255, 222, 89, 0.3);
    }

    .hito-info {
        padding: 1.5rem 0.8rem 1rem;
        background: #ffffff;
        border-top-left-radius: 35px;
        border-top-right-radius: 35px;
        margin-top: -30px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        position: relative;
        z-index: 2;
    }

    .hito-name {
        font-family: "Archivo Black", sans-serif;
        color: #000000;
        font-size: 0.85rem;
        font-weight: 900;
        margin: 0;
        line-height: 1.1;
        text-transform: uppercase;
    }

    .hito-meta {
        font-size: 0.72rem;
        font-weight: 800;
        color: #2b2b2b;
        margin-top: 0.5rem;
        line-height: 1.2;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-transform: uppercase;
        letter-spacing: 0.2px;
    }

    @media (max-width: 768px) {
        .hitos-grid {
            scroll-snap-type: x mandatory;
            padding: 0;
            gap: 2px;
        }
        .hito-card-vertical {
            min-width: 160px;
            scroll-snap-align: start;
            border-radius: 25px 0 25px 0;
        }
        .hito-info {
            padding: 1.2rem 0.6rem 0.8rem;
            border-top-left-radius: 25px;
            border-top-right-radius: 25px;
            margin-top: -20px;
        }
        .hito-name {
            font-size: 0.8rem;
        }
    }

    @media (max-width: 480px) {
        .hito-card-vertical {
            min-width: 180px;
        }
        .hito-img-wrapper {
            aspect-ratio: 4/5;
        }
    }
</style>
