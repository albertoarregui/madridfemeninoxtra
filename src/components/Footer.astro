---
import X from "../assets/redes/x.svg";
import Instagram from "../assets/redes/instagram.svg";
import TikTok from "../assets/redes/tiktok.svg";
import Youtube from "../assets/redes/youtube.svg";
import Facebook from "../assets/redes/facebook.svg";
import LinkedIn from "../assets/redes/linkedin.svg";
import { Image } from "astro:assets";
import Logo from "../assets/main/logo.png";
---

<footer class="footer-container">
    <div class="footer-content-wrapper">
        <div class="footer-brand">
            <a href="/home" class="footer-logo-link">
                <Image
                    src={Logo}
                    alt="Madrid Femenino Xtra"
                    width={200}
                    height={80}
                    format="webp"
                    class="footer-logo-img"
                />
            </a>
            <p>
                Tu fuente 100% dedicada al Real Madrid Femenino. Consulta todas
                las noticias, resultados, clasificación, calendario y
                estadísticas en un solo lugar. ¡Entra y no te pierdas nada de la
                actualidad del equipo!
            </p>
        </div>

        <div class="footer-links">
            <h4>Menú</h4>
            <ul>
                <li><a href="/">Inicio</a></li>
                <li><a href="/plantilla">Plantilla</a></li>
                <li><a href="/rankings">Estadísticas</a></li>
                <li><a href="/sobre-nosotros">Sobre Nosotros</a></li>
                <li><a href="/contacto">Contacto</a></li>
            </ul>
        </div>

        <div class="footer-links">
            <h4>Enlaces Rápidos</h4>
            <ul>
                <li><a href="/aviso-legal">Aviso Legal</a></li>
                <li>
                    <a href="/terminos-condiciones">Términos y condiciones</a>
                </li>
                <li>
                    <a href="/politica-privacidad">Política de privacidad</a>
                </li>
                <li><a href="/politica-cookies">Política de cookies</a></li>
            </ul>
        </div>

        <div class="footer-social">
            <h4>Síguenos</h4>
            <div class="social-icons-group">
                <a
                    href="https://x.com/madridfemxtra"
                    target="_blank"
                    class="social-icon"
                    aria-label="X (Twitter)"
                >
                    <X />
                </a>
                <a
                    href="https://instagram.com/madridfemxtra"
                    target="_blank"
                    class="social-icon"
                    aria-label="Instagram"
                >
                    <Instagram />
                </a>
                <a
                    href="https://tiktok.com/@madridfemeninoxtra"
                    target="_blank"
                    class="social-icon"
                    aria-label="TikTok"
                >
                    <TikTok />
                </a>
                <a
                    href="https://www.youtube.com/@madridfemxtra"
                    target="_blank"
                    class="social-icon"
                    aria-label="YouTube"
                >
                    <Youtube />
                </a>
                <a
                    href="https://www.facebook.com/madridfemxtra"
                    target="_blank"
                    class="social-icon"
                    aria-label="Facebook"
                >
                    <Facebook />
                </a>
                <a
                    href="https://www.linkedin.com/company/madrid-femenino-xtra"
                    target="_blank"
                    class="social-icon"
                    aria-label="LinkedIn"
                >
                    <LinkedIn />
                </a>
            </div>
        </div>
    </div>

    <div class="footer-bottom">
        <p>
            &copy; {new Date().getFullYear()} Madrid Femenino Xtra. Todos los derechos
            reservados.
        </p>
    </div>
</footer>

<style>
    .footer-container {
        width: 100%;
        background: linear-gradient(to top, #2b2b2b 0%, #1f1f1f 100%);
        color: #e0e0e0;
        padding: 4rem 0 2rem;
        position: relative;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .footer-content-wrapper {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 4rem;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 4rem;
        margin-bottom: 3rem;
    }

    .footer-brand {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .footer-logo-link {
        margin-bottom: 2rem;
        display: block;
    }

    .footer-logo-img {
        width: auto !important;
        height: 80px !important;
        object-fit: contain;
        mix-blend-mode: screen;
    }

    .footer-brand p {
        font-size: 0.95rem;
        line-height: 1.6;
        color: #bdbdbd;
        max-width: 300px;
        text-align: justify;
    }

    .footer-links h4 {
        color: #fff;
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .footer-links ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .footer-links li {
        margin-bottom: 0.75rem;
    }

    .footer-links a {
        color: #bdbdbd;
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 0.95rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .footer-links a:hover {
        color: #ffde59;
        transform: translateX(4px);
    }

    .footer-social h4 {
        color: #fff;
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .social-icons-group {
        display: flex;
        gap: 1rem;
    }

    .social-icon {
        width: 40px;
        height: 40px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .social-icon svg {
        width: 20px;
        height: 20px;
        transition: all 0.3s ease;
    }

    .social-icon:hover {
        background: rgba(255, 222, 89, 0.2);
        border-color: rgba(255, 222, 89, 0.5);
        transform: translateY(-3px);
    }

    .social-icon:hover svg {
        stroke: #ffffff;
    }

    /* Direct override for LinkedIn stroke icon from Sobre Nosotros */
    .icon-tabler-brand-linkedin,
    .icon-tabler-brand-linkedin path {
        fill: none !important;
        stroke: currentColor !important;
        stroke-width: 2 !important;
    }

    .social-icon:hover .icon-tabler-brand-linkedin {
        stroke: #ffffff !important;
        fill: none !important;
    }

    .footer-bottom {
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding-top: 2rem;
        text-align: center;
        font-size: 0.9rem;
        color: #9e9e9e;
    }

    .footer-bottom p {
        margin: 0;
    }

    @media (max-width: 768px) {
        .footer-content-wrapper {
            grid-template-columns: repeat(2, 1fr);
            gap: 2rem;
            text-align: center;
        }

        .footer-brand {
            grid-column: span 2;
            align-items: center;
        }

        .footer-brand p {
            margin: 0 auto;
            text-align: center;
        }

        .footer-social {
            grid-column: span 2;
        }

        .footer-brand p {
            margin: 0 auto;
        }

        .social-icons-group {
            justify-content: center;
        }

        .footer-links a {
            justify-content: center;
        }

        .footer-links a:hover {
            transform: translateX(0);
        }
    }
</style>
