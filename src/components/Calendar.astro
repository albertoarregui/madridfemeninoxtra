            height: 8px !important;
        }
    }

    .calendar-widget {
        display: none;
        background-color: #ffffff;
        padding: 20px;
        border-radius: 12px;
        color: #333;
        font-family: "Arial", sans-serif;
        box-shadow: 0 8px 15px rgba(0, 0, 0, 0.1);
        width: 100%;
        box-sizing: border-box;
        transition:
            opacity 0.4s ease,
            transform 0.4s ease,
            padding 0.3s ease;
        opacity: 0;
        transform: translateY(10px);
    }

    .calendar-widget.active {
        display: block;
        opacity: 1;
        transform: translateY(0);
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(5px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .calendar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .month-label {
        display: flex;
        flex-direction: column;
        align-items: center;
        line-height: 1.2;
    }

    .month {
        font-size: 1.4rem;
        font-weight: 800;
        text-transform: uppercase;
        color: #333;
    }

    .year {
        font-size: 1rem;
        font-weight: 500;
        color: #666;
    }

    .nav-btn {
        background: none;
        border: none;
        cursor: pointer;
        padding: 5px;
        color: #333;
        border-radius: 50%;
