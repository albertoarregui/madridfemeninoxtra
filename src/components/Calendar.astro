            box-sizing: border-box;
        }

        .weekday {
            font-size: 0.55rem;
            margin-bottom: 1px;
            padding: 0;
            text-align: center;
        }

        .day {
            aspect-ratio: 1;
            min-height: 0;
            width: 100%;
            font-size: 0.6rem;
            border-radius: 2px;
            padding: 0;
            box-sizing: border-box;
        }

        .day-number.badge-style {
            width: 14px;
            height: 14px;
            font-size: 0.5rem;
            top: -2px;
            left: -2px;
            border-width: 1px;
        }

