        align-items: center;
        justify-content: center;
    }

    .nav-btn:hover:not(:disabled) {
        background-color: #f0f0f0;
        color: #000;
    }

    .nav-btn:disabled {
        opacity: 0.2;
        cursor: default;
    }

    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, minmax(0, 1fr));
        gap: 6px;
        text-align: center;
        width: 100%;
    }

    .weekday {
        font-size: 0.9rem;
        color: #666;
