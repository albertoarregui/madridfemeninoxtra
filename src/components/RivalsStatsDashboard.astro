---
import { TEAMS } from "../../public/consts/rivals";
import { COUNTRIES } from "../../public/consts/countries";
import { getFlagCdnCode } from "../utils/flags";
import type { ImageMetadata } from "astro";

interface Props {
    matches: any[];
}

const { matches } = Astro.props;

const rivalMap = new Map<
    string,
    { count: number; country: string; wins: number }
>();
const countryStats = new Map<
    string,
    { matches: number; wins: number; name: string }
>();

const getCountryCode = (rivalName: string) => {
    const team = TEAMS.find(
        (t) =>
            t.name === rivalName ||
            t.id === rivalName.toLowerCase().replace(/ /g, "-"),
    );
    return team ? team.country : null;
};

matches.forEach((m) => {
    const isHome =
        m.club_local === "Real Madrid" || m.club_local === "CD Tacón";
    const rivalName = isHome ? m.club_visitante : m.club_local;

    if (!rivalName || rivalName === "Real Madrid") return;

    const goalsRM = parseInt(m.goles_rm) || 0;
    const goalsRival = parseInt(m.goles_rival) || 0;

    let isWin = false;
    let isDraw = false;

    if (goalsRM > goalsRival) {
        isWin = true;
    } else if (goalsRM < goalsRival) {
        isWin = false;
    } else {
        // Draw in regular time, check penalties
        const penalties = m.penaltis;
        if (penalties === 1 || penalties === "1") {
            isWin = true;
        } else if (penalties === 0 || penalties === "0") {
            isWin = false;
        } else {
            isDraw = true;
        }
    }

    const currentRival = rivalMap.get(rivalName) || {
        count: 0,
        country: "",
        wins: 0,
    };

    if (!currentRival.country) {
        currentRival.country = getCountryCode(rivalName) || "unknown";
    }

    currentRival.count += 1;
    if (isWin) currentRival.wins += 1;

    rivalMap.set(rivalName, currentRival);

    const countryCode = currentRival.country;
    // Only count stats for visited countries if the match was played AWAY (!isHome)
    if (!isHome && countryCode && countryCode !== "unknown") {
        const currentCountry = countryStats.get(countryCode) || {
            matches: 0,
            wins: 0,
            name:
                COUNTRIES[countryCode as keyof typeof COUNTRIES]?.name ||
                countryCode,
        };
        currentCountry.matches += 1;
        if (isWin) currentCountry.wins += 1;
        countryStats.set(countryCode, currentCountry);
    }
});

const totalRivals = rivalMap.size;
const totalCountries = countryStats.size;

let maxPlayed = 0;
let mostPlayedRivalName = "-";
rivalMap.forEach((data, name) => {
    if (data.count > maxPlayed) {
        maxPlayed = data.count;
        mostPlayedRivalName = name;
    }
});

// Get shield for most played rival
const rivalLogos = import.meta.glob<{ default: ImageMetadata }>(
    "../assets/escudos/*.png",
    { eager: true },
);

function getRivalLogoSrc(rivalName: string) {
    const team = TEAMS.find((t) => t.name === rivalName);
    if (!team) return null;
    const imageId = team.id.replace(/-/g, "_");
    const imagePath = `../assets/escudos/${imageId}.png`;
    return rivalLogos[imagePath]?.default?.src;
}

const mostPlayedRivalShield = getRivalLogoSrc(mostPlayedRivalName);

const sortedByMatches = Array.from(countryStats.entries())
    .filter(([code]) => code !== "es")
    .sort((a, b) => b[1].matches - a[1].matches)
    .slice(0, 3);

const sortedByWins = Array.from(countryStats.entries())
    .filter(([code]) => code !== "es")
    .sort((a, b) => b[1].wins - a[1].wins)
    .slice(0, 3);
---

<div class="w-full max-w-7xl mx-auto mb-12 animate-fade-in-up">
    <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4"
    >
        {/* CARD 1: TOTAL RIVALS */}
        <div
            class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center group"
        >
            <div class="bg-blue-50 p-3 rounded-full text-blue-600 mb-3">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="32"
                    height="32"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
                    ></path><circle cx="9" cy="7" r="4"></circle><path
                        d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path
                        d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg
                >
            </div>
            <div>
                <p
                    class="text-sm text-gray-500 font-bold uppercase tracking-wider mb-1 group-hover:text-[#ffde59] transition-colors"
                >
                    Total Rivales
                </p>
                <p
                    class="text-3xl md:text-4xl font-black text-[#151e42] leading-none group-hover:text-[#ffde59] transition-colors counter-anim"
                >
                    {totalRivals}
                </p>
            </div>
        </div>

        {/* CARD 2: RIVAL MÁS FRECUENTE */}
        <div
            class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center group"
        >
            <div class="bg-purple-50 p-3 rounded-full text-purple-600 mb-3">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="32"
                    height="32"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path>
                    <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path>
                    <path d="M4 22h16"></path>
                    <path
                        d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"
                    ></path>
                    <path
                        d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"
                    ></path>
                    <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path>
                </svg>
            </div>
            <div class="flex flex-col items-center w-full">
                <p
                    class="text-sm text-gray-500 font-bold uppercase tracking-wider mb-3 group-hover:text-[#ffde59] transition-colors"
                >
                    Rival Histórico
                </p>
                {
                    mostPlayedRivalShield && (
                        <div class="w-16 h-16 mb-2 flex items-center justify-center">
                            <img
                                src={mostPlayedRivalShield}
                                alt={mostPlayedRivalName}
                                class="w-full h-full object-contain drop-shadow-sm"
                            />
                        </div>
                    )
                }
                <p
                    class="text-lg md:text-xl font-black text-[#151e42] leading-tight mb-1 group-hover:text-[#ffde59] transition-colors"
                    title={mostPlayedRivalName}
                >
                    {mostPlayedRivalName}
                </p>
                <p
                    class="text-xs text-gray-400 font-bold uppercase group-hover:text-[#ffde59] transition-colors"
                >
                    {maxPlayed} partidos
                </p>
            </div>
        </div>

        {/* CARD 3: PAÍSES VISITADOS */}
        <div
            class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center group"
        >
            <div class="bg-yellow-50 p-3 rounded-full text-yellow-600 mb-3">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="32"
                    height="32"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><circle cx="12" cy="12" r="10"></circle><path d="M2 12h20"
                    ></path><path
                        d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
                    ></path></svg
                >
            </div>
            <div>
                <p
                    class="text-sm text-gray-500 font-bold uppercase tracking-wider mb-1 group-hover:text-[#ffde59] transition-colors"
                >
                    Países Visitados
                </p>
                <p
                    class="text-3xl md:text-4xl font-black text-[#151e42] leading-none group-hover:text-[#ffde59] transition-colors counter-anim"
                >
                    {totalCountries}
                </p>
            </div>
        </div>

        {/* CARD 4: TOP DESTINOS */}
        <div
            class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center group"
        >
            <div class="bg-green-50 p-3 rounded-full text-green-600 mb-3">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="32"
                    height="32"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                        d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"
                    ></path><line x1="4" y1="22" x2="4" y2="15"></line></svg
                >
            </div>
            <div class="flex flex-col items-center w-full">
                <p
                    class="text-xs text-gray-500 font-bold uppercase tracking-wider mb-2 group-hover:text-[#ffde59] transition-colors"
                >
                    Top Destinos
                </p>
                <div class="flex items-start justify-center gap-3 w-full">
                    {
                        sortedByMatches.map(([code, data], idx) => (
                            <div class="flex flex-col items-center flex-1">
                                <div class="h-8 mb-1 flex items-center justify-center">
                                    <img
                                        src={`https://flagcdn.com/w40/${getFlagCdnCode(code)}.png`}
                                        alt={data.name}
                                        class="w-8 h-auto rounded-sm shadow-sm"
                                    />
                                </div>
                                <span class="text-xs font-black text-[#151e42] text-center leading-tight h-[3rem] flex items-center justify-center">
                                    {data.name}
                                </span>
                                <span class="text-xs font-bold text-gray-400 h-[1.25rem] flex items-center justify-center">
                                    {data.matches} p.
                                </span>
                            </div>
                        ))
                    }
                    {
                        sortedByMatches.length === 0 && (
                            <span class="text-xs text-gray-400 italic">
                                Sin salidas.
                            </span>
                        )
                    }
                </div>
            </div>
        </div>

        {/* CARD 5: PAÍSES CON MÁS VICTORIAS */}
        <div
            class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center group"
        >
            <div class="bg-red-50 p-3 rounded-full text-red-600 mb-3">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="32"
                    height="32"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path><path
                        d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path><path
                        d="M4 22h16"></path><path
                        d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"
                    ></path><path
                        d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"
                    ></path><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path></svg
                >
            </div>
            <div class="flex flex-col items-center w-full">
                <p
                    class="text-xs text-gray-500 font-bold uppercase tracking-wider mb-2 group-hover:text-[#ffde59] transition-colors"
                >
                    Tierra Conquistada
                </p>
                <div class="flex items-start justify-center gap-3 w-full">
                    {
                        sortedByWins.map(([code, data], idx) => (
                            <div class="flex flex-col items-center flex-1">
                                <div class="h-8 mb-1 flex items-center justify-center">
                                    <img
                                        src={`https://flagcdn.com/w40/${getFlagCdnCode(code)}.png`}
                                        alt={data.name}
                                        class="w-8 h-auto rounded-sm shadow-sm"
                                    />
                                </div>
                                <span class="text-xs font-black text-[#151e42] text-center leading-tight h-[3rem] flex items-center justify-center">
                                    {data.name}
                                </span>
                                <span class="text-xs font-bold text-gray-400 h-[1.25rem] flex items-center justify-center">
                                    {data.wins} v.
                                </span>
                            </div>
                        ))
                    }
                    {
                        sortedByWins.length === 0 && (
                            <span class="text-xs text-gray-400 italic">
                                Sin victorias.
                            </span>
                        )
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .counter-anim {
    }
</style>
