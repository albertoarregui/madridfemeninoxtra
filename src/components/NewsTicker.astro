---
import "../styles/global.css";

const WP_URL =
    "https://cms.madridfemeninoxtra.com/wp-json/wp/v2/posts?per_page=10";

interface Post {
    id: number;
    title: { rendered: string };
    slug: string;
    link: string;
}

let posts: Post[] = [];
try {
    const res = await fetch(WP_URL);
    if (res.ok) {
        posts = await res.json();
    }
} catch (e) {
    console.error("Error fetching ticker news:", e);
}
---

{
    posts.length > 0 && (
        <div class="news-ticker">
            <div class="ticker-label">ÚLTIMA HORA</div>
            <div class="ticker-overflow">
                <div class="ticker-track">
                    {posts.map((post) => (
                        <a
                            href={`/noticias/${post.slug}`}
                            class="ticker-item"
                            set:html={post.title.rendered}
                        />
                    ))}
                    {/* Duplicate for seamless loop */}
                    {posts.map((post) => (
                        <a
                            href={`/noticias/${post.slug}`}
                            class="ticker-item"
                            set:html={post.title.rendered}
                        />
                    ))}
                </div>
            </div>
        </div>
    )
}

<style>
    .news-ticker {
        background-color: #2b2b2b;
        color: white;
        display: flex;
        align-items: center;
        height: 44px;
        overflow: hidden;
        border-bottom: 1px solid rgba(255, 222, 89, 0.2);
        position: relative;
        z-index: 20;
        width: 100%;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
    }

    .ticker-label {
        background-color: var(--primary-color, #ffde59);
        color: #000;
        font-weight: 800;
        text-transform: uppercase;
        padding: 0 1.5rem;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
        position: relative;
        z-index: 2;
    }

    .ticker-label::after {
        content: "";
        position: absolute;
        top: 0;
        right: -10px;
        width: 0;
        height: 0;
        border-top: 44px solid var(--primary-color, #ffde59);
        border-right: 15px solid transparent;
        z-index: 2;
    }

    .ticker-overflow {
        flex-grow: 1;
        overflow: hidden;
        position: relative;
        height: 100%;
        mask-image: linear-gradient(
            to right,
            transparent 0%,
            black 2%,
            black 98%,
            transparent 100%
        );
    }

    .ticker-track {
        display: flex;
        align-items: center;
        height: 100%;
        animation: scroll 40s linear infinite;
        white-space: nowrap;
        padding-left: 1rem;
    }

    .ticker-track:hover {
        animation-play-state: paused;
    }

    .ticker-item {
        color: #e0e0e0;
        text-decoration: none;
        margin-right: 3rem;
        font-size: 0.95rem;
        font-weight: 500;
        position: relative;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
    }

    .ticker-item::after {
        content: "•";
        position: absolute;
        right: -1.7rem;
        color: var(--primary-color, #ffde59);
        font-size: 1.2em;
        text-decoration: none;
    }

    .ticker-item:hover {
        color: var(--primary-color, #ffde59);
    }

    @keyframes scroll {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }

    @media (max-width: 768px) {
        .news-ticker {
            height: 38px;
        }
        .ticker-label {
            padding: 0 1rem;
            font-size: 0.75rem;
        }
        .ticker-label::after {
            border-top-width: 38px;
            border-right-width: 12px;
        }
        .ticker-item {
            font-size: 0.85rem;
            margin-right: 2.5rem;
        }
    }
</style>
