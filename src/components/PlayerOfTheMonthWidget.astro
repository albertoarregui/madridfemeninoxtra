---
import { Image } from "astro:assets";
import { fetchPlayerAwards } from "../utils/awards";
import defaultLindaImg from "../assets/jugadora_del_mes/linda_caicedo_enero_2026.webp";

const allAwards = await fetchPlayerAwards();

const awardImages = import.meta.glob<{ default: ImageMetadata }>(
    "../assets/jugadora_del_mes/*.{png,jpg,jpeg,webp}",
    { eager: true },
);

function getAwardImage(
    playerName: string,
    monthName: string,
    year: number | string,
) {
    // Normalize player name: remove accents, convert to lowercase, replace spaces with underscores
    const normalizedPlayer = playerName
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/\s+/g, "_");

    const normalizedMonth = monthName.toLowerCase();
    const yearStr = year.toString();

    const paths = Object.keys(awardImages);

    // Strategy 1: Perfect match (Player + Month + Year)
    let matchingPath = paths.find((path) => {
        const p = path.toLowerCase();
        return (
            p.includes(normalizedPlayer) &&
            p.includes(normalizedMonth) &&
            p.includes(yearStr)
        );
    });

    // Strategy 2: Fallback to Player + Month (any year)
    if (!matchingPath) {
        matchingPath = paths.find((path) => {
            const p = path.toLowerCase();
            return p.includes(normalizedPlayer) && p.includes(normalizedMonth);
        });
    }

    // Strategy 3: Fallback to Player + Year (any month)
    if (!matchingPath) {
        matchingPath = paths.find((path) => {
            const p = path.toLowerCase();
            return p.includes(normalizedPlayer) && p.includes(yearStr);
        });
    }

    // Strategy 4: Fallback to just Player name (last resort)
    if (!matchingPath) {
        matchingPath = paths.find((path) => {
            const p = path.toLowerCase();
            return p.includes(normalizedPlayer);
        });
    }

    if (import.meta.env.DEV && !matchingPath) {
        console.log(
            `[AwardWidget] No image found for: ${normalizedPlayer} (${normalizedMonth} ${yearStr})`,
        );
    }

    return matchingPath ? awardImages[matchingPath].default : null;
}

const awards = allAwards.map((award) => {
    // Parse DD/MM/YYYY format
    const parts = award.fecha.split("/");
    let date: Date;
    if (parts.length === 3) {
        date = new Date(
            parseInt(parts[2]),
            parseInt(parts[1]) - 1,
            parseInt(parts[0]),
        );
    } else {
        date = new Date(award.fecha);
    }

    let monthName = "";
    let year: number | string = "----";

    if (isNaN(date.getTime())) {
        monthName = "CONSULTAR";
        year = "----";
    } else {
        monthName = date
            .toLocaleDateString("es-ES", { month: "long" })
            .toUpperCase();
        year = date.getFullYear();
    }

    const image = getAwardImage(award.nombre, monthName, year);

    if (import.meta.env.DEV) {
        console.log(
            `[AwardWidget] Mapped: ${award.nombre} (${monthName} ${year}) - Image: ${image ? "FOUND" : "NOT FOUND"}`,
        );
    }

    return {
        month: monthName,
        year: year,
        player: award.nombre.toUpperCase(),
        image: award.foto_url || image || defaultLindaImg,
        hasImage: !!award.foto_url || image !== null,
        isExternalUrl: !!award.foto_url,
        tipo: award.tipo,
        temporada: award.temporada,
    };
});

if (import.meta.env.DEV) {
    console.log(`[AwardWidget] Final awards array length: ${awards.length}`);
    if (awards.length > 0) {
        console.log(
            `[AwardWidget] First item: ${awards[0].player} - ${awards[0].month} ${awards[0].year}`,
        );
    }
}

if (awards.length === 0) {
    awards.push({
        month: "ENERO",
        year: 2026,
        player: "LINDA CAICEDO",
        image: defaultLindaImg,
        hasImage: true,
    });
}
---

<div
    class="player-month-widget group relative overflow-hidden rounded-xl bg-white shadow-md border border-gray-200 mb-8 w-full"
>
    {
        awards.map((award, index) => (
            <div
                class={`award-slide w-full transition-opacity duration-500 ${index === 0 ? "opacity-100 z-10 relative block" : "opacity-0 z-0 absolute top-0 left-0 hidden"} ${!award.hasImage ? "bg-gray-300 min-h-[400px]" : ""}`}
                data-index={index}
            >
                {award.hasImage ? (
                    award.isExternalUrl ? (
                        <img
                            src={award.image as string}
                            alt={`MVP ${award.month || award.temporada}`}
                            class="w-full h-auto object-cover"
                        />
                    ) : (
                        <Image
                            src={award.image}
                            alt={`MVP ${award.month || award.temporada}`}
                            class="w-full h-auto object-cover"
                        />
                    )
                ) : (
                    <div class="h-full w-full bg-gradient-to-br from-gray-200 to-gray-400 flex items-center justify-center">
                        <div class="text-gray-500 text-center">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-24 w-24 mx-auto mb-4 opacity-40"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                                />
                            </svg>
                            <p class="text-lg font-semibold">
                                Imagen próximamente
                            </p>
                        </div>
                    </div>
                )}

                <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/90 via-black/50 to-transparent pt-12 pb-6 px-4 text-white flex flex-col items-center justify-end">
                    <div class="text-3xl font-black uppercase leading-none shadow-black drop-shadow-lg text-center mb-2">
                        {award.player}
                    </div>
                </div>

                <div
                    class={`photo-season-badge ${award.tipo === "TEMPORADA" ? "temporada-badge" : ""}`}
                >
                    {award.tipo === "TEMPORADA"
                        ? `MVP ${award.temporada}`
                        : `MVP ${award.month} ${award.year}`}
                </div>
            </div>
        ))
    }

    {
        awards.length > 1 && (
            <>
                <button
                    class="nav-btn prev absolute left-2 top-1/2 -translate-y-1/2 bg-black/30 hover:bg-black/50 text-white p-1.5 rounded-full backdrop-blur-sm transition-all z-20 hover:scale-110"
                    aria-label="Mes anterior"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <polyline points="15 18 9 12 15 6" />
                    </svg>
                </button>
                <button
                    class="nav-btn next absolute right-2 top-1/2 -translate-y-1/2 bg-black/30 hover:bg-black/50 text-white p-1.5 rounded-full backdrop-blur-sm transition-all z-20 hover:scale-110"
                    aria-label="Siguiente mes"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <polyline points="9 18 15 12 9 6" />
                    </svg>
                </button>
            </>
        )
    }
</div>

<style>
    .photo-season-badge {
        position: absolute;
        top: 1rem;
        left: 1rem;
        transform: none;
        background: #151e42;
        color: #ffde59;
        padding: 0.35rem 1rem;
        border-radius: 4px;
        font-size: 0.85rem;
        font-weight: 900;
        font-family: "Archivo Black", sans-serif;
        letter-spacing: 0.5px;
        border: none;
        white-space: nowrap;
        z-index: 20;
    }

    .photo-season-badge.temporada-badge {
        background: #d4af37; /* Golden background for season */
        color: #fff;
    }
</style>

<script>
    document.addEventListener("astro:page-load", () => {
        initSliders();
    });

    initSliders();

    function initSliders() {
        const widgets = document.querySelectorAll(".player-month-widget");
        widgets.forEach((widget) => {
            const slides = widget.querySelectorAll(".award-slide");
            if (slides.length <= 1) return;

            const prevBtn = widget.querySelector(".prev");
            const nextBtn = widget.querySelector(".next");
            let currentIndex = 0;

            function updateButtons() {
                if (prevBtn instanceof HTMLElement) {
                    const isOldest = currentIndex === slides.length - 1;
                    prevBtn.style.opacity = isOldest ? "0.3" : "1";
                    prevBtn.style.cursor = isOldest ? "default" : "pointer";
                    prevBtn.style.pointerEvents = isOldest ? "none" : "auto";
                }
                if (nextBtn instanceof HTMLElement) {
                    const isNewest = currentIndex === 0;
                    nextBtn.style.opacity = isNewest ? "0.3" : "1";
                    nextBtn.style.cursor = isNewest ? "default" : "pointer";
                    nextBtn.style.pointerEvents = isNewest ? "none" : "auto";
                }
            }

            function showSlide(index: number) {
                slides.forEach((slide, i) => {
                    if (i === index) {
                        slide.classList.remove(
                            "opacity-0",
                            "z-0",
                            "absolute",
                            "top-0",
                            "left-0",
                            "hidden",
                        );
                        slide.classList.add(
                            "opacity-100",
                            "z-10",
                            "relative",
                            "block",
                        );
                    } else {
                        slide.classList.remove(
                            "opacity-100",
                            "z-10",
                            "relative",
                            "block",
                        );
                        slide.classList.add(
                            "opacity-0",
                            "z-0",
                            "absolute",
                            "top-0",
                            "left-0",
                            "hidden",
                        );
                    }
                });
                updateButtons();
            }

            updateButtons();

            prevBtn?.addEventListener("click", () => {
                if (currentIndex < slides.length - 1) {
                    currentIndex++;
                    showSlide(currentIndex);
                }
            });

            nextBtn?.addEventListener("click", () => {
                if (currentIndex > 0) {
                    currentIndex--;
                    showSlide(currentIndex);
                }
            });
        });
    }
</script>
