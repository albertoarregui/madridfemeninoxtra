---
import { Image } from "astro:assets";
import { fetchPlayerAwards } from "../utils/awards";
// Fallback image
import defaultFellerImg from "../assets/widgets/player_month/feller_mahoudiciembre.jpg";

// Fetch real data
const allAwards = await fetchPlayerAwards();

// Load dynamic images from assets/jugadora_del_mes folder
const awardImages = import.meta.glob<{ default: ImageMetadata }>(
    "../assets/jugadora_del_mes/*.{png,jpg,jpeg,webp}",
    { eager: true },
);

function getAwardImage(awardId: number) {
    const matchingPath = Object.keys(awardImages).find(
        (path) =>
            path.includes(`/${awardId}.`) ||
            path.includes(`/award_${awardId}.`) ||
            path.includes(`/${awardId}_`),
    );
    return matchingPath ? awardImages[matchingPath].default : null;
}

// Map to widget format
const awards = allAwards.map((award) => {
    const date = new Date(award.fecha);
    const monthName = date
        .toLocaleDateString("es-ES", { month: "long" })
        .toUpperCase();
    const year = date.getFullYear();
    const image = getAwardImage(award.id_premio);

    return {
        month: monthName,
        year: year,
        player: award.nombre.toUpperCase(),
        image: image || defaultFellerImg,
    };
});

// If no awards found, use the fallback mock
if (awards.length === 0) {
    awards.push({
        month: "DICIEMBRE",
        year: 2025,
        player: "LINDA CAICEDO",
        image: defaultFellerImg,
    });
}
---

<div
    class="player-month-widget group relative overflow-hidden rounded-xl bg-white shadow-md border border-gray-200 mb-8"
>
    <div class="relative aspect-[4/3] w-full overflow-hidden bg-gray-100">
        {
            awards.map((award, index) => (
                <div
                    class={`award-slide absolute inset-0 transition-opacity duration-500 ${index === 0 ? "opacity-100 z-10" : "opacity-0 z-0"}`}
                    data-index={index}
                >
                    <Image
                        src={award.image}
                        alt={`Jugadora del mes ${award.month}`}
                        class="h-full w-full object-cover"
                    />

                    {/* Overlay Gradient */}
                    <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/90 via-black/50 to-transparent pt-12 pb-6 px-4 text-white flex flex-col items-center justify-end">
                        <div class="text-3xl font-black uppercase leading-none shadow-black drop-shadow-lg text-center mb-2">
                            {award.player}
                        </div>
                        <div class="text-base font-bold text-[#ffde59] opacity-100 uppercase tracking-widest shadow-black drop-shadow-md text-center">
                            {award.month} {award.year}
                        </div>
                    </div>
                </div>
            ))
        }

        {/* Navigation Controls (Hidden if only 1 item) */}
        {
            awards.length > 1 && (
                <>
                    <button
                        class="nav-btn prev absolute left-2 top-1/2 -translate-y-1/2 bg-black/30 hover:bg-black/50 text-white p-1.5 rounded-full backdrop-blur-sm transition-all z-20 hover:scale-110"
                        aria-label="Mes anterior"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <polyline points="15 18 9 12 15 6" />
                        </svg>
                    </button>
                    <button
                        class="nav-btn next absolute right-2 top-1/2 -translate-y-1/2 bg-black/30 hover:bg-black/50 text-white p-1.5 rounded-full backdrop-blur-sm transition-all z-20 hover:scale-110"
                        aria-label="Siguiente mes"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <polyline points="9 18 15 12 9 6" />
                        </svg>
                    </button>
                </>
            )
        }
    </div>
</div>

<script>
    // Simple slider logic
    document.addEventListener("astro:page-load", () => {
        initSliders();
    });

    // Also run on initial load
    initSliders();

    function initSliders() {
        const widgets = document.querySelectorAll(".player-month-widget");
        widgets.forEach((widget) => {
            const slides = widget.querySelectorAll(".award-slide");
            if (slides.length <= 1) return; // No functionality needed for single slide

            const prevBtn = widget.querySelector(".prev");
            const nextBtn = widget.querySelector(".next");
            let currentIndex = 0;

            function updateButtons() {
                if (prevBtn) {
                    // Si estamos en el principio (índice 0), ocultar/desactivar Prev
                    const isFirst = currentIndex === 0;
                    prevBtn.style.opacity = isFirst ? "0.3" : "1";
                    prevBtn.style.cursor = isFirst ? "default" : "pointer";
                    prevBtn.style.pointerEvents = isFirst ? "none" : "auto";
                }
                if (nextBtn) {
                    // Si estamos en el final, ocultar/desactivar Next
                    const isLast = currentIndex === slides.length - 1;
                    nextBtn.style.opacity = isLast ? "0.3" : "1";
                    nextBtn.style.cursor = isLast ? "default" : "pointer";
                    nextBtn.style.pointerEvents = isLast ? "none" : "auto";
                }
            }

            function showSlide(index) {
                slides.forEach((slide, i) => {
                    if (i === index) {
                        slide.classList.remove("opacity-0", "z-0");
                        slide.classList.add("opacity-100", "z-10");
                    } else {
                        slide.classList.remove("opacity-100", "z-10");
                        slide.classList.add("opacity-0", "z-0");
                    }
                });
                updateButtons();
            }

            // Inicializar estado botones
            updateButtons();

            prevBtn?.addEventListener("click", () => {
                if (currentIndex > 0) {
                    currentIndex--;
                    showSlide(currentIndex);
                }
            });

            nextBtn?.addEventListener("click", () => {
                if (currentIndex < slides.length - 1) {
                    currentIndex++;
                    showSlide(currentIndex);
                }
            });
        });
    }
</script>
