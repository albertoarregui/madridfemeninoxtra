---
import type { ImageMetadata } from "astro";

interface Match {
    id_partido?: number;
    slug: string;
    fecha: string;
    competicion_nombre: string;
    club_local: string;
    club_visitante: string;
    goles_rm: number;
    goles_rival: number;
    resultado: string;
    temporada_nombre: string;
}

interface Props {
    matches: Match[];
    seasons?: string[];
    competitions?: string[];
}

const { matches, seasons = [], competitions = [] } = Astro.props;

// Importar todos los escudos de equipos
const teamLogos = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/escudos/*.png",
    { eager: true },
);

// Importar todos los logos de competiciones
const competitionLogos = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/competiciones/*.png",
    { eager: true },
);

// Función para obtener el logo de una competición
function getCompetitionLogo(competitionName: string) {
    const normalizedName = competitionName
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/\s+/g, "_")
        .replace(/:/g, "")
        .replace(/-/g, "_")
        .trim();

    const competitionMap: Record<string, string> = {
        spain_liga_f_women: "liga_f",
        liga_f: "liga_f",
        europe_champions_league_women_league_phase: "uwcl",
        champions_league_women: "uwcl",
        uwcl: "uwcl",
        copa_de_la_reina: "copa_de_la_reina",
        supercopa_de_espana: "supercopa_de_espana",
    };

    const mappedName = competitionMap[normalizedName] || normalizedName;
    const logoPath = `/src/assets/competiciones/${mappedName}.png`;

    return competitionLogos[logoPath]?.default;
}

// Función para obtener el escudo de un equipo
function getTeamLogo(teamName: string) {
    const normalizedName = teamName
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/\s+/g, "_")
        .replace(/\./g, "")
        .replace(/w$/i, "")
        .trim();

    const teamNameMap: Record<string, string> = {
        real_madrid_: "real_madrid",
        fc_barcelona: "fc_barcelona",
        athletic_bilbao: "athletic_club",
        atletico_madrid: "atletico_de_madrid",
        deportivo_la_coruna: "deportivo_abanca",
        levante: "levante_ud",
        costa_adeje: "costa_adeje_tenerife",
        eibar: "sd_eibar",
        alaves: "alaves",
        alhama: "alhama",
        arsenal: "arsenal",
        as_roma: "as_roma",
        cacereno: "cacereno",
        espanyol: "espanyol",
        granada: "granada_cf",
        madrid_cff: "madrid_cff",
        paris_fc: "paris_fc",
        psg: "psg",
        rayo_vallecano: "rayo_vallecano",
        sevilla: "sevilla_fc",
        valencia: "valencia_cf",
        villarreal: "villarreal_cf",
        betis: "real_betis",
        real_sociedad: "real_sociedad",
        sporting_huelva: "sporting_de_huelva",
        fundacion_albacete: "fundacion_albacete",
    };

    const mappedName = teamNameMap[normalizedName] || normalizedName;
    const logoPath = `/src/assets/escudos/${mappedName}.png`;

    return teamLogos[logoPath]?.default;
}
---

<div class="match-list-ui">
    <!-- Controles de Filtro -->
    <div class="filters-container">
        {
            seasons.length > 0 && (
                <select id="filtro-temporada">
                    <option value="todos">Todas las Temporadas</option>
                    {seasons.map((season) => (
                        <option value={season}>{season}</option>
                    ))}
                </select>
            )
        }

        {
            competitions.length > 0 && (
                <select id="filtro-competicion">
                    <option value="todos">Todas las Competiciones</option>
                    {competitions.map((comp) => (
                        <option value={comp}>{comp}</option>
                    ))}
                </select>
            )
        }
    </div>

    <!-- Contenedor de Partidos -->
    <div id="matches-container" class="matches-container">
        {
            matches.map((match) => {
                const formatDate = (dateString: string) => {
                    if (!dateString) return "-";
                    try {
                        const date = new Date(dateString);
                        const day = date.getDate().toString().padStart(2, "0");
                        const month = (date.getMonth() + 1)
                            .toString()
                            .padStart(2, "0");
                        const hours = date
                            .getUTCHours()
                            .toString()
                            .padStart(2, "0");
                        const minutes = date
                            .getUTCMinutes()
                            .toString()
                            .padStart(2, "0");
                        return `${day}.${month}. ${hours}:${minutes}`;
                    } catch {
                        return "-";
                    }
                };

                const resultClass =
                    match.resultado === "V"
                        ? "win"
                        : match.resultado === "D"
                          ? "loss"
                          : "draw";

                const localLogo = getTeamLogo(match.club_local);
                const visitanteLogo = getTeamLogo(match.club_visitante);
                const competitionLogo = getCompetitionLogo(
                    match.competicion_nombre,
                );

                return (
                    <div
                        class="match-item"
                        data-season={match.temporada_nombre}
                        data-competition={match.competicion_nombre}
                    >
                        <div class="match-competition">
                            <div class="competition-info">
                                {competitionLogo && (
                                    <img
                                        src={competitionLogo.src}
                                        alt={match.competicion_nombre}
                                        class="competition-logo"
                                    />
                                )}
                                <span class="competition-name">
                                    {match.competicion_nombre}
                                </span>
                            </div>
                            <a href="#" class="standings-link">
                                Standings
                            </a>
                        </div>

                        <a
                            href={`/partidos/${match.slug}`}
                            class="match-detail"
                        >
                            <div class="match-date-time">
                                {formatDate(match.fecha)}
                            </div>

                            <div class="match-teams-score">
                                <div class="team">
                                    {localLogo ? (
                                        <img
                                            src={localLogo.src}
                                            alt={match.club_local}
                                            class="team-shield"
                                        />
                                    ) : (
                                        <div class="team-shield-placeholder" />
                                    )}
                                    <span class="team-name">
                                        {match.club_local}
                                    </span>
                                </div>

                                <div class="score-wrapper">
                                    <span class="score">{match.goles_rm}</span>
                                    <span class="vs">vs</span>
                                    <span class="score">
                                        {match.goles_rival}
                                    </span>
                                </div>

                                <div class="team">
                                    {visitanteLogo ? (
                                        <img
                                            src={visitanteLogo.src}
                                            alt={match.club_visitante}
                                            class="team-shield"
                                        />
                                    ) : (
                                        <div class="team-shield-placeholder" />
                                    )}
                                    <span class="team-name">
                                        {match.club_visitante}
                                    </span>
                                </div>
                            </div>

                            <div class={`result-indicator ${resultClass}`}>
                                {match.resultado}
                            </div>
                        </a>
                    </div>
                );
            })
        }
    </div>
</div>

<script>
    const seasonSelect = document.getElementById(
        "filtro-temporada",
    ) as HTMLSelectElement;
    const competitionSelect = document.getElementById(
        "filtro-competicion",
    ) as HTMLSelectElement;
    const matchesContainer = document.getElementById("matches-container");

    function filterMatches() {
        const selectedSeason = seasonSelect?.value || "todos";
        const selectedCompetition = competitionSelect?.value || "todos";
        const matchItems = matchesContainer?.querySelectorAll(".match-item");

        let visibleCount = 0;

        matchItems?.forEach((item) => {
            const itemElement = item as HTMLElement;
            const season = itemElement.dataset.season || "";
            const competition = itemElement.dataset.competition || "";

            const matchesSeason =
                selectedSeason === "todos" || season === selectedSeason;
            const matchesCompetition =
                selectedCompetition === "todos" ||
                competition === selectedCompetition;

            if (matchesSeason && matchesCompetition) {
                itemElement.style.display = "";
                visibleCount++;
            } else {
                itemElement.style.display = "none";
            }
        });

        const existingMessage = matchesContainer?.querySelector(
            ".no-results-message",
        );
        if (visibleCount === 0 && !existingMessage) {
            const noResultsMsg = document.createElement("p");
            noResultsMsg.className = "no-results-message";
            noResultsMsg.textContent =
                "No se encontraron partidos con los filtros seleccionados.";
            matchesContainer?.appendChild(noResultsMsg);
        } else if (visibleCount > 0 && existingMessage) {
            existingMessage.remove();
        }
    }

    seasonSelect?.addEventListener("change", filterMatches);
    competitionSelect?.addEventListener("change", filterMatches);
</script>

<style>
    .match-list-ui {
        width: 100%;
        max-width: 680px;
        margin: 0 auto;
    }

    .filters-container {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        justify-content: center;
    }

    .filters-container select {
        padding: 0.75rem 1.5rem;
        background: #ffffff;
        color: #2b2b2b;
        border: 2px solid #ffde59;
        border-radius: 25px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        min-width: 220px;
        transition: all 0.3s ease;
        box-shadow: 0 2px 8px rgba(255, 222, 89, 0.2);
        outline: none;
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
    }

    .filters-container select:hover {
        background: #fffef8;
        border-color: #ffd700;
        box-shadow: 0 4px 12px rgba(255, 222, 89, 0.3);
        transform: translateY(-2px);
    }

    .filters-container select:focus {
        outline: none;
        border-color: #ffd700;
        box-shadow: 0 0 0 4px rgba(255, 222, 89, 0.2);
    }

    .matches-container {
        display: flex;
        flex-direction: column;
        gap: 0;
        background: #ffffff;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .match-item {
        background: #ffffff;
        border-bottom: 1px solid #f0f0f0;
    }

    .match-item:last-child {
        border-bottom: none;
    }

    .match-competition {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 1rem;
        background: #f8f9fa;
        border-bottom: 1px solid #e9ecef;
    }

    .competition-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .competition-logo {
        width: 24px;
        height: 24px;
        object-fit: contain;
    }

    .competition-name {
        color: #6c757d;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .standings-link {
        color: #5a9bc7;
        font-size: 0.85rem;
        text-decoration: underline;
        transition: color 0.2s;
    }

    .standings-link:hover {
        color: #4a8bb7;
    }

    .match-detail {
        display: grid;
        grid-template-columns: 100px 1fr 50px;
        align-items: center;
        padding: 1rem;
        gap: 1.5rem;
        text-decoration: none;
        transition: background 0.3s ease;
    }

    .match-detail:hover {
        background: rgba(255, 222, 89, 0.15);
    }

    .match-date-time {
        color: #6c757d;
        font-size: 0.9rem;
        font-weight: 500;
    }

    .match-teams-score {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1.5rem;
    }

    .team {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .team-shield {
        width: 28px;
        height: 28px;
        object-fit: contain;
        flex-shrink: 0;
    }

    .team-shield-placeholder {
        width: 28px;
        height: 28px;
        background: #e9ecef;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .team-name {
        color: #2b2b2b;
        font-size: 0.95rem;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .score-wrapper {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        justify-content: center;
    }

    .score {
        color: #2b2b2b;
        font-size: 1.2rem;
        font-weight: 700;
    }

    .vs {
        color: #9ca3af;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
    }

    .result-indicator {
        width: 32px;
        height: 32px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.85rem;
        flex-shrink: 0;
    }

    .result-indicator.win {
        background: #2ecc71;
        color: #ffffff;
    }

    .result-indicator.loss {
        background: #e74c3c;
        color: #ffffff;
    }

    .result-indicator.draw {
        background: #f39c12;
        color: #ffffff;
    }

    .no-results-message {
        color: #6c757d;
        text-align: center;
        padding: 3rem 1rem;
        font-size: 1rem;
    }

    @media (max-width: 768px) {
        .match-detail {
            grid-template-columns: 80px 1fr 40px;
            gap: 1rem;
            padding: 0.75rem;
        }

        .match-date-time {
            font-size: 0.8rem;
        }

        .team-name {
            font-size: 0.85rem;
        }

        .team-shield,
        .team-shield-placeholder {
            width: 24px;
            height: 24px;
        }

        .competition-logo {
            width: 20px;
            height: 20px;
        }

        .score {
            font-size: 1rem;
        }

        .vs {
            font-size: 0.65rem;
        }

        .filters-container select {
            min-width: 150px;
            font-size: 0.85rem;
        }

        .result-indicator {
            width: 28px;
            height: 28px;
            font-size: 0.75rem;
        }

        .match-teams-score {
            gap: 1rem;
        }
    }
</style>
