---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Match {
    id_partido?: number;
    slug: string;
    fecha: string;
    hora?: string;
    competicion_nombre: string;
    club_local: string;
    club_visitante: string;
    goles_rm: number;
    goles_rival: number;
    resultado: string;
    temporada_nombre: string;
    local_shield_url?: string;
    visitante_shield_url?: string;
}

interface Props {
    matches: Match[];
    seasons?: string[];
    competitions?: string[];
}

const { matches, seasons = [], competitions = [] } = Astro.props;

import { getAssetMetadata } from "../utils/assets";

function getCompetitionLogo(competitionName: string) {
    return getAssetMetadata("competiciones", competitionName);
}

function getTeamLogo(teamName: string) {
    return getAssetMetadata("escudos", teamName);
}
---

<div class="match-list-ui">
    <div class="filters-container">
        {
            seasons.length > 0 && (
                <div class="filter-wrapper">
                    <select
                        id="filtro-temporada"
                        aria-label="Filtrar por temporada"
                    >
                        <option value="todos">Todas las Temporadas</option>
                        {seasons.map((season) => (
                            <option value={season}>{season}</option>
                        ))}
                    </select>
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="filter-icon"
                    >
                        <>
                            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                            <path d="M6 9l6 6l6 -6" />
                        </>
                    </svg>
                </div>
            )
        }

        {
            competitions.length > 0 && (
                <div class="filter-wrapper">
                    <select
                        id="filtro-competicion"
                        aria-label="Filtrar por competición"
                    >
                        <option value="todos">Todas las Competiciones</option>
                        {competitions.map((comp) => (
                            <option value={comp}>{comp}</option>
                        ))}
                    </select>
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="filter-icon"
                    >
                        <>
                            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                            <path d="M6 9l6 6l6 -6" />
                        </>
                    </svg>
                </div>
            )
        }
    </div>

    <div id="matches-container" class="matches-container">
        {
            matches.map((match) => {
                const formatDate = (
                    dateString: string,
                    timeString?: string,
                ) => {
                    if (!dateString) return "-";
                    try {
                        const date = new Date(dateString);
                        const day = date.getDate().toString().padStart(2, "0");
                        const month = (date.getMonth() + 1)
                            .toString()
                            .padStart(2, "0");
                        const year = date.getFullYear().toString().slice(-2);

                        let timeDisplay = "00:00";
                        if (timeString && timeString !== "00:00") {
                            timeDisplay = timeString.substring(0, 5);
                        } else {
                            const hours = date
                                .getUTCHours()
                                .toString()
                                .padStart(2, "0");
                            const minutes = date
                                .getUTCMinutes()
                                .toString()
                                .padStart(2, "0");
                            timeDisplay = `${hours}:${minutes}`;
                        }

                        return `${day}.${month}.${year} ${timeDisplay}`;
                    } catch {
                        return "-";
                    }
                };

                const resultClass =
                    match.resultado === "V"
                        ? "win"
                        : match.resultado === "D"
                          ? "loss"
                          : "draw";

                const localLogoSrc =
                    match.local_shield_url || getTeamLogo(match.club_local);
                const visitanteLogoSrc =
                    match.visitante_shield_url ||
                    getTeamLogo(match.club_visitante);
                const competitionLogo = getCompetitionLogo(
                    match.competicion_nombre,
                );

                return (
                    <div
                        class="match-item"
                        data-season={match.temporada_nombre}
                        data-competition={match.competicion_nombre}
                    >
                        <div class="match-competition">
                            <div class="competition-info">
                                {competitionLogo && (
                                    <Image
                                        src={competitionLogo}
                                        alt={match.competicion_nombre}
                                        class="competition-logo"
                                        width={24}
                                        height={24}
                                        format="webp"
                                    />
                                )}
                                <span class="competition-name">
                                    {match.competicion_nombre}
                                </span>
                            </div>
                        </div>

                        <a
                            href={`/partidos/${match.slug}`}
                            class="match-detail"
                        >
                            <div class="match-date-time">
                                {formatDate(match.fecha, match.hora)}
                            </div>

                            <div class="match-teams-score">
                                <div class="team team-local">
                                    <span class="team-name">
                                        {match.club_local}
                                    </span>
                                    {localLogoSrc ? (
                                        <img
                                            src={
                                                typeof localLogoSrc === "string"
                                                    ? localLogoSrc
                                                    : localLogoSrc.src
                                            }
                                            alt={match.club_local}
                                            class="team-shield"
                                            width={28}
                                            height={28}
                                        />
                                    ) : (
                                        <div class="team-shield-placeholder" />
                                    )}
                                </div>

                                <div class="score-wrapper">
                                    <span class="score">
                                        {match.club_local
                                            .toLowerCase()
                                            .includes("real madrid")
                                            ? match.goles_rm
                                            : match.goles_rival}
                                    </span>
                                    <span class="vs">-</span>
                                    <span class="score">
                                        {match.club_local
                                            .toLowerCase()
                                            .includes("real madrid")
                                            ? match.goles_rival
                                            : match.goles_rm}
                                    </span>
                                </div>

                                <div class="team team-visitor">
                                    {visitanteLogoSrc ? (
                                        <img
                                            src={
                                                typeof visitanteLogoSrc ===
                                                "string"
                                                    ? visitanteLogoSrc
                                                    : visitanteLogoSrc.src
                                            }
                                            alt={match.club_visitante}
                                            class="team-shield"
                                            width={28}
                                            height={28}
                                        />
                                    ) : (
                                        <div class="team-shield-placeholder" />
                                    )}
                                    <span class="team-name">
                                        {match.club_visitante}
                                    </span>
                                </div>
                            </div>

                            <div class={`result-indicator ${resultClass}`}>
                                {match.resultado}
                            </div>
                        </a>
                    </div>
                );
            })
        }
    </div>
</div>

<script>
    const seasonSelect = document.getElementById(
        "filtro-temporada",
    ) as HTMLSelectElement;
    const competitionSelect = document.getElementById(
        "filtro-competicion",
    ) as HTMLSelectElement;
    const matchesContainer = document.getElementById("matches-container");

    function filterMatches() {
        const selectedSeason = seasonSelect?.value || "todos";
        const selectedCompetition = competitionSelect?.value || "todos";
        const matchItems = matchesContainer?.querySelectorAll(".match-item");

        let visibleCount = 0;

        matchItems?.forEach((item) => {
            const itemElement = item as HTMLElement;
            const season = itemElement.dataset.season || "";
            const competition = itemElement.dataset.competition || "";

            const matchesSeason =
                selectedSeason === "todos" || season === selectedSeason;
            const matchesCompetition =
                selectedCompetition === "todos" ||
                competition === selectedCompetition;

            if (matchesSeason && matchesCompetition) {
                itemElement.style.display = "";
                visibleCount++;
            } else {
                itemElement.style.display = "none";
            }
        });

        const existingMessage = matchesContainer?.querySelector(
            ".no-results-message",
        );
        if (visibleCount === 0 && !existingMessage) {
            const noResultsMsg = document.createElement("p");
            noResultsMsg.className = "no-results-message";
            noResultsMsg.textContent =
                "No se encontraron partidos con los filtros seleccionados.";
            matchesContainer?.appendChild(noResultsMsg);
        } else if (visibleCount > 0 && existingMessage) {
            existingMessage.remove();
        }
    }

    seasonSelect?.addEventListener("change", filterMatches);
    competitionSelect?.addEventListener("change", filterMatches);
</script>

<style>
    .match-list-ui {
        width: 100%;
        max-width: 800px;
        margin: 0 auto;
    }

    .filters-container {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        justify-content: center;
    }

    .filter-wrapper {
        position: relative;
        display: inline-block;
    }

    .filter-icon {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
        color: #2b2b2b;
        width: 20px;
        height: 20px;
    }

    .filters-container select {
        padding: 0.75rem 3rem 0.75rem 1.5rem;
        background: #ffffff;
        color: #2b2b2b;
        border: 2px solid #ffde59;
        border-radius: 25px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        min-width: 220px;
        transition: all 0.3s ease;
        box-shadow: 0 2px 8px rgba(255, 222, 89, 0.2);
        outline: none;
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        text-align: center;
    }

    .filters-container select:hover {
        background: #fffef8;
        border-color: #ffd700;
    }

    .filters-container select:focus {
        outline: none;
        border-color: #ffd700;
        box-shadow: 0 0 0 4px rgba(255, 222, 89, 0.2);
    }

    .matches-container {
        display: flex;
        flex-direction: column;
        gap: 0;
        background: #ffffff;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .match-item {
        background: #ffffff;
        border-bottom: 1px solid #f0f0f0;
    }

    .match-item:last-child {
        border-bottom: none;
    }

    .match-competition {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 1rem;
        background: #f8f9fa;
        border-bottom: 1px solid #e9ecef;
    }

    .competition-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .competition-logo {
        width: 24px;
        height: 24px;
        object-fit: contain;
    }

    .competition-name {
        color: #6c757d;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .match-detail {
        display: grid;
        grid-template-columns: 80px 1fr 40px;
        align-items: center;
        padding: 1rem;
        gap: 1rem;
        text-decoration: none;
        transition: background 0.3s ease;
    }

    .match-detail:hover {
        background: rgba(255, 222, 89, 0.15);
    }

    .match-date-time {
        color: #6c757d;
        font-size: 0.9rem;
        font-weight: 500;
        text-align: center;
    }

    .match-teams-score {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
    }

    .team {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex: 1;
        min-width: 0;
    }

    .team-local {
        justify-content: flex-end;
        text-align: right;
    }

    .team-visitor {
        justify-content: flex-start;
        text-align: left;
    }

    .team-shield {
        width: 28px;
        height: 28px;
        object-fit: contain;
        flex-shrink: 0;
    }

    .team-shield-placeholder {
        width: 28px;
        height: 28px;
        background: #e9ecef;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .team-name {
        color: #2b2b2b;
        font-size: 0.95rem;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .score-wrapper {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        justify-content: center;
        min-width: 60px;
    }

    .score {
        color: #2b2b2b;
        font-size: 1.2rem;
        font-weight: 700;
    }

    .vs {
        color: #2b2b2b;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    .result-indicator {
        width: 32px;
        height: 32px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.85rem;
        flex-shrink: 0;
    }

    .result-indicator.win {
        background: #2ecc71;
        color: #ffffff;
    }

    .result-indicator.loss {
        background: #e74c3c;
        color: #ffffff;
    }

    .result-indicator.draw {
        background: #f39c12;
        color: #ffffff;
    }

    .no-results-message {
        color: #6c757d;
        text-align: center;
        padding: 3rem 1rem;
        font-size: 1rem;
    }

    @media (max-width: 640px) {
        .match-detail {
            grid-template-columns: 1fr;
            grid-template-rows: auto auto auto;
            gap: 0.5rem;
            padding: 0.75rem;
            text-align: center;
        }

        .match-date-time {
            font-size: 0.8rem;
            margin-bottom: 0.25rem;
        }

        .match-teams-score {
            width: 100%;
            justify-content: center;
        }

        .team-name {
            font-size: 0.9rem;
            white-space: normal;
            overflow: visible;
            text-overflow: clip;
            text-align: center;
        }

        .team-local,
        .team-visitor {
            justify-content: center;
            text-align: center;
        }

        .team-shield,
        .team-shield-placeholder {
            width: 24px;
            height: 24px;
        }

        .score {
            font-size: 1.1rem;
        }

        .result-indicator {
            margin: 0 auto;
            width: 28px;
            height: 28px;
            font-size: 0.75rem;
        }

        .result-indicator {
            position: absolute;
            top: 0.75rem;
            right: 0.75rem;
        }

        .match-item {
            position: relative;
        }
    }
</style>
