<div class="top-bar">
    <div class="top-bar-content">
        <div class="date-display" id="top-bar-date"></div>
    </div>
</div>

<script>
    const dateEl = document.getElementById("top-bar-date");
    if (dateEl) {
        const now = new Date();
        const options: Intl.DateTimeFormatOptions = {
            weekday: "long",
            day: "numeric",
            month: "long",
        };
        const dateStr = now.toLocaleDateString("es-ES", options);
        // Capitalize first letter
        dateEl.textContent = dateStr.charAt(0).toUpperCase() + dateStr.slice(1);
    }
</script>

<style>
    .top-bar {
        background: linear-gradient(to right, #2b2b2b, #1f1f1f);
        color: #e0e0e0;
        padding: 0.5rem 2rem;
        font-size: 0.85rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .top-bar-content {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        justify-content: flex-end; /* Align to right */
        align-items: center;
    }

    .date-display {
        font-weight: 500;
        color: var(--primary-color, #ffde59);
        text-transform: capitalize;
    }

    @media (max-width: 768px) {
        .top-bar {
            padding: 0.5rem 1rem;
        }
        .top-bar-content {
            justify-content: center; /* Center on mobile if desired, or keep right */
        }
    }
</style>
