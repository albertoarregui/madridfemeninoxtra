<div class="top-bar">
    <div class="top-bar-content">
        <div class="date-display" id="top-bar-date"></div>
    </div>
</div>

<script is:inline>
    (function () {
        const dateEl = document.getElementById("top-bar-date");
        if (dateEl) {
            const now = new Date();
            const options = {
                weekday: "long",
                day: "numeric",
                month: "long",
            };
            const dateStr = now.toLocaleDateString("es-ES", options);
            dateEl.textContent =
                dateStr.charAt(0).toUpperCase() + dateStr.slice(1);
        }
    })();
</script>

<style>
    .top-bar {
        background: linear-gradient(to right, #2b2b2b, #1f1f1f);
        color: #e0e0e0;
        padding: 0.5rem 2rem;
        font-size: 0.85rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        position: relative;
        top: 0;
        left: 0;
        right: 0;
        width: 100%;
        z-index: 210;
        height: 32px;
        display: flex;
        align-items: center;
    }

    .top-bar-content {
        width: 100%;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        padding-right: 0;
    }

    .date-display {
        font-weight: 500;
        color: #ffffff;
        text-transform: capitalize;
        font-size: 0.8rem;
    }

    @media (max-width: 1024px) {
        .top-bar {
            display: flex;
            justify-content: center;
            padding: 0 1rem;
        }
    }
</style>
