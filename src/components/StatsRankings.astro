---
interface GoalData {
    id_gol: number;
    goleadora: string | null;
    asistente: string | null;
    id_partido: number;
    goles_a_favor: number;
    goles_en_contra: number;
    minuto: number | null;
    parte_cuerpo: string | null;
    tipo: string | null;
    competicion?: string;
    temporada?: string;
}

interface Props {
    goalsData: GoalData[];
    seasons: string[];
    competitions: string[];
}

const { goalsData, seasons, competitions } = Astro.props;
---

<div class="stats-rankings-ui">
    <!-- Filtros -->
    <div class="filters-container">
        <div class="filter-wrapper">
            <select id="filtro-temporada">
                <option value="todos">Todas las Temporadas</option>
                {
                    seasons.map((season) => (
                        <option value={season}>{season}</option>
                    ))
                }
            </select>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="filter-icon"
            >
                <>
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                    <path d="M6 9l6 6l6 -6"></path>
                </>
            </svg>
        </div>

        <div class="filter-wrapper">
            <select id="filtro-competicion">
                <option value="todos">Todas las Competiciones</option>
                {
                    competitions.map((comp) => (
                        <option value={comp}>{comp}</option>
                    ))
                }
            </select>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="filter-icon"
            >
                <>
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                    <path d="M6 9l6 6l6 -6"></path>
                </>
            </svg>
        </div>
    </div>

    <!-- Grid de Rankings -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Máximas Goleadoras -->
        <div class="ranking-card" id="scorers-table">
            <h3 class="ranking-title">Máximas Goleadoras</h3>
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr>
                            <th scope="col" class="w-16 text-center">Pos</th>
                            <th scope="col">Jugadora</th>
                            <th scope="col" class="text-center">Goles</th>
                        </tr>
                    </thead>
                    <tbody id="scorers-body">
                        <!-- Will be populated by JavaScript -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Máximas Asistentes -->
        <div class="ranking-card" id="assisters-table">
            <h3 class="ranking-title">Máximas Asistentes</h3>
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr>
                            <th scope="col" class="w-16 text-center">Pos</th>
                            <th scope="col">Jugadora</th>
                            <th scope="col" class="text-center">Asistencias</th>
                        </tr>
                    </thead>
                    <tbody id="assisters-body">
                        <!-- Will be populated by JavaScript -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Goles Generados -->
        <div class="ranking-card" id="contributors-table">
            <h3 class="ranking-title">Goles Generados</h3>
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr>
                            <th scope="col" class="w-16 text-center">Pos</th>
                            <th scope="col">Jugadora</th>
                            <th scope="col" class="text-center">Total</th>
                        </tr>
                    </thead>
                    <tbody id="contributors-body">
                        <!-- Will be populated by JavaScript -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script define:vars={{ goalsData }}>
    const seasonSelect = document.getElementById("filtro-temporada");
    const competitionSelect = document.getElementById("filtro-competicion");
    const scorersBody = document.getElementById("scorers-body");
    const assistersBody = document.getElementById("assisters-body");
    const contributorsBody = document.getElementById("contributors-body");

    // Helper function to get player image URL
    function getPlayerImage(playerName) {
        if (!playerName) return "";
        const slug = playerName
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .replace(/\s+/g, "_");
        return `/assets/jugadoras/${slug}.png`;
    }

    function calculateRankings() {
        const selectedSeason = seasonSelect.value;
        const selectedCompetition = competitionSelect.value;

        // Filter data
        const filteredData = goalsData.filter((item) => {
            const matchesSeason =
                selectedSeason === "todos" || item.temporada === selectedSeason;
            const matchesCompetition =
                selectedCompetition === "todos" ||
                item.competicion === selectedCompetition;
            return matchesSeason && matchesCompetition;
        });

        console.log("Datos filtrados:", filteredData.length, "registros");
        console.log("Primeros 3 registros:", filteredData.slice(0, 3));

        // Calculate scorers
        const scorersMap = {};
        filteredData.forEach((item) => {
            if (item.goleadora) {
                scorersMap[item.goleadora] =
                    (scorersMap[item.goleadora] || 0) + 1;
            }
        });

        const sortedScorers = Object.entries(scorersMap)
            .map(([jugadora, goles]) => ({ jugadora, goles }))
            .sort((a, b) => b.goles - a.goles);

        console.log("Goleadoras calculadas:", sortedScorers.length);
        console.log("Top 3 goleadoras:", sortedScorers.slice(0, 3));

        // Calculate assisters
        const assistersMap = {};
        filteredData.forEach((item) => {
            if (item.asistente) {
                assistersMap[item.asistente] =
                    (assistersMap[item.asistente] || 0) + 1;
            }
        });

        const sortedAssisters = Object.entries(assistersMap)
            .map(([jugadora, asistencias]) => ({ jugadora, asistencias }))
            .sort((a, b) => b.asistencias - a.asistencias);

        // Calculate contributors (goals + assists)
        const contributorsMap = {};
        filteredData.forEach((item) => {
            if (item.goleadora) {
                contributorsMap[item.goleadora] = contributorsMap[
                    item.goleadora
                ] || { goles: 0, asistencias: 0 };
                contributorsMap[item.goleadora].goles += 1;
            }
            if (item.asistente) {
                contributorsMap[item.asistente] = contributorsMap[
                    item.asistente
                ] || { goles: 0, asistencias: 0 };
                contributorsMap[item.asistente].asistencias += 1;
            }
        });

        const sortedContributors = Object.entries(contributorsMap)
            .map(([jugadora, stats]) => ({
                jugadora,
                total: stats.goles + stats.asistencias,
                goles: stats.goles,
                asistencias: stats.asistencias,
            }))
            .sort((a, b) => b.total - a.total);

        // Update scorers table
        if (sortedScorers.length === 0) {
            scorersBody.innerHTML =
                '<tr><td colspan="3" class="no-data">No hay datos registrados.</td></tr>';
        } else {
            scorersBody.innerHTML = sortedScorers
                .map(
                    (item, index) => `
                <tr>
                    <td class="pos-cell text-center">${index + 1}</td>
                    <td class="player-cell">
                        <div class="flex items-center gap-3">
                            <div class="player-img-container">
                                <img 
                                    src="${getPlayerImage(item.jugadora)}" 
                                    alt="${item.jugadora}" 
                                />
                            </div>
                            <div class="player-name">${item.jugadora}</div>
                        </div>
                    </td>
                    <td class="stat-cell text-center">${item.goles}</td>
                </tr>
            `,
                )
                .join("");
        }

        // Update assisters table
        if (sortedAssisters.length === 0) {
            assistersBody.innerHTML =
                '<tr><td colspan="3" class="no-data">No hay datos registrados.</td></tr>';
        } else {
            assistersBody.innerHTML = sortedAssisters
                .map(
                    (item, index) => `
                <tr>
                    <td class="pos-cell text-center">${index + 1}</td>
                    <td class="player-cell">
                        <div class="flex items-center gap-3">
                            <div class="player-img-container">
                                <img 
                                    src="${getPlayerImage(item.jugadora)}" 
                                    alt="${item.jugadora}" 
                                />
                            </div>
                            <div class="player-name">${item.jugadora}</div>
                        </div>
                    </td>
                    <td class="stat-cell text-center">${item.asistencias}</td>
                </tr>
            `,
                )
                .join("");
        }

        // Update contributors table
        if (sortedContributors.length === 0) {
            contributorsBody.innerHTML =
                '<tr><td colspan="3" class="no-data">No hay datos registrados.</td></tr>';
        } else {
            contributorsBody.innerHTML = sortedContributors
                .map(
                    (item, index) => `
                <tr>
                    <td class="pos-cell text-center">${index + 1}</td>
                    <td class="player-cell">
                        <div class="flex items-center gap-3">
                            <div class="player-img-container">
                                <img 
                                    src="${getPlayerImage(item.jugadora)}" 
                                    alt="${item.jugadora}" 
                                />
                            </div>
                            <div class="player-name">${item.jugadora}</div>
                        </div>
                    </td>
                    <td class="stat-cell text-center">${item.total}</td>
                </tr>
            `,
                )
                .join("");
        }
    }

    // Initial calculation
    calculateRankings();

    // Event listeners
    seasonSelect?.addEventListener("change", calculateRankings);
    competitionSelect?.addEventListener("change", calculateRankings);
</script>

<style>
    .stats-rankings-ui {
        width: 100%;
        margin: 0 auto;
    }

    /* Filters Styles - Matched with MatchList */
    .filters-container {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        justify-content: center; /* Centered like MatchList */
    }

    .filter-wrapper {
        position: relative;
        display: inline-block;
        flex: 1;
        min-width: 200px;
        max-width: 300px;
    }

    .filter-icon {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
        color: #2b2b2b;
        width: 20px;
        height: 20px;
    }

    .filters-container select {
        width: 100%;
        padding: 0.75rem 3rem 0.75rem 1.5rem;
        background: #ffffff;
        color: #2b2b2b;
        border: 2px solid #ffde59;
        border-radius: 25px; /* Keeping rounded selects as per MatchList style */
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 2px 8px rgba(255, 222, 89, 0.2);
        outline: none;
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
    }

    .filters-container select:hover {
        background: #fffef8;
        border-color: #ffd700;
    }

    .filters-container select:focus {
        outline: none;
        border-color: #ffd700;
        box-shadow: 0 0 0 4px rgba(255, 222, 89, 0.2);
    }

    /* Ranking Cards */
    .ranking-card {
        background: #ffffff;
        /* Restored shadow but kept square (no rounded-xl) */
        box-shadow:
            0 4px 6px -1px rgba(0, 0, 0, 0.1),
            0 2px 4px -1px rgba(0, 0, 0, 0.06); /* Tailwind shadow-md */
        border: 1px solid #f0f0f0;
        border-radius: 0; /* Explicitly square */
        overflow: hidden;
    }

    .ranking-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: #2b2b2b;
        padding: 1rem;
        border-bottom: 1px solid #e9ecef;
        background: #f8f9fa; /* MatchList header bg */
        margin: 0;
        text-align: center; /* Centered title */
        text-transform: uppercase; /* Uppercase title */
    }

    /* Table Styles */
    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead {
        background: #f8f9fa;
    }

    th {
        padding: 0.75rem 1.5rem;
        text-align: left;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        color: #6c757d;
        letter-spacing: 0.05em;
    }

    th.text-center {
        text-align: center;
    }

    th.text-right {
        text-align: right;
    }

    tbody tr {
        border-bottom: 1px solid #f0f0f0;
        transition: background 0.3s ease;
    }

    tbody tr:last-child {
        border-bottom: none;
    }

    tbody tr:hover {
        background: rgba(255, 222, 89, 0.15); /* MatchList hover effect */
    }

    td {
        padding: 1rem 1.5rem;
        white-space: nowrap;
    }

    .pos-cell {
        font-size: 0.875rem;
        color: #6c757d;
        font-weight: 500;
    }

    .player-cell {
    }

    .player-img-container {
        width: 1.5rem !important; /* Matches player name line height */
        height: 1.5rem !important; /* Matches player name line height */
        flex-shrink: 0; /* Prevent shrinking on large screens */
        border: 2px solid #e5e7eb; /* Square frame matching player name */
        overflow: hidden; /* Ensure content stays inside */
    }

    .player-img-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .player-name {
        font-size: 0.875rem;
        font-weight: 600;
        color: #2b2b2b;
    }

    .stat-cell {
        /* text-align: right; - Removed to allow class override */
        font-size: 0.875rem;
        font-weight: 700;
        color: #2b2b2b; /* Changed from blue-600 to match MatchList text color */
    }

    .text-center {
        text-align: center;
    }

    .no-data {
        padding: 2rem;
        text-align: center;
        color: #6c757d;
        font-size: 0.9rem;
    }
</style>
