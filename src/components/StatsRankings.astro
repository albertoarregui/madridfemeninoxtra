---
import type { RankingStat, StreakData } from "../utils/rankings";
import type { AwardData } from "../utils/awards";

interface Props {
    rankingsData: RankingStat[];
    streaksData: StreakData[];
    awardsData: AwardData[];
    seasons: string[];
    competitions: string[];
    players?: any[];
}

import { getAssetUrl } from "../utils/assets";
const {
    rankingsData,
    streaksData,
    awardsData,
    seasons,
    competitions,
    players = [],
} = Astro.props;

const playerImageMap = Object.fromEntries(
    players.map((p: any) => [p.slug, p.imageUrl]),
);
---

<div class="stats-rankings-ui">
    <div class="filters-container">
        <div class="custom-select-container" id="container-tipo">
            <div class="custom-select-trigger" id="trigger-tipo">
                <span class="selected-text">Convocatorias</span>
                <div class="custom-select-arrow">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="m6 9 6 6 6-6"></path></svg
                    >
                </div>
            </div>
            <div class="custom-select-options">
                <div
                    class="custom-select-option selected"
                    data-value="convocatorias"
                >
                    Convocatorias
                </div>
                <div class="custom-select-option" data-value="partidos">
                    Partidos jugados
                </div>
                <div class="custom-select-option" data-value="titularidades">
                    Titularidades
                </div>
                <div class="custom-select-option" data-value="minutos">
                    Minutos jugados
                </div>
                <div class="custom-select-option" data-value="cambios_entrada">
                    Cambios (Entrada)
                </div>
                <div class="custom-select-option" data-value="cambios_salida">
                    Cambios (Salida)
                </div>
                <div class="custom-select-option" data-value="victorias">
                    Victorias
                </div>
                <div class="custom-select-option" data-value="porterias_cero">
                    Porterías a cero
                </div>
                <div
                    class="custom-select-option"
                    data-value="tarjetas_amarillas"
                >
                    Tarjetas amarillas
                </div>
                <div class="custom-select-option" data-value="tarjetas_rojas">
                    Tarjetas rojas
                </div>
                <div class="custom-select-option" data-value="capitanias">
                    Capitanías
                </div>
                <div class="custom-select-option" data-value="goles">
                    Goleadoras
                </div>
                <div class="custom-select-option" data-value="asistencias">
                    Asistentes
                </div>
                <div class="custom-select-option" data-value="goles_generados">
                    Goles generados
                </div>
                <div class="custom-select-option" data-value="goles_victoria">
                    Match winners
                </div>
                <div class="custom-select-option" data-value="goles_empate">
                    Goles para empatar
                </div>
                <div class="custom-select-option" data-value="goles_abrelatas">
                    Goles para abrir el marcador
                </div>
                <div class="custom-select-option" data-value="penaltis">
                    Penaltis marcados
                </div>
                <div class="custom-select-option" data-value="streak_scoring">
                    Partidos consecutivos marcando
                </div>
                <div class="custom-select-option" data-value="streak_assisting">
                    Partidos consecutivos asistiendo
                </div>
                <div class="custom-select-option" data-value="streak_ga">
                    Partidos consecutivos con gol o asistencia
                </div>
                <div
                    class="custom-select-option"
                    data-value="streak_clean_sheet"
                >
                    Porterías a cero consecutivas
                </div>
                <div class="custom-select-option" data-value="award_monthly">
                    Mejor Jugadora del Mes
                </div>
                <div class="custom-select-option" data-value="award_season">
                    Mejor Jugadora de la Temporada
                </div>
            </div>
            <select
                id="filtro-tipo"
                aria-label="Tipo de ranking"
                style="display: none;"
            >
                <option value="convocatorias" selected>Convocatorias</option>
                <option value="partidos">Partidos jugados</option>
                <option value="titularidades">Titularidades</option>
                <option value="minutos">Minutos jugados</option>
                <option value="cambios_entrada">Cambios (Entrada)</option>
                <option value="cambios_salida">Cambios (Salida)</option>
                <option value="victorias">Victorias</option>
                <option value="porterias_cero">Porterías a cero</option>
                <option value="tarjetas_amarillas">Tarjetas amarillas</option>
                <option value="tarjetas_rojas">Tarjetas rojas</option>
                <option value="capitanias">Capitanías</option>
                <option value="goles">Goleadoras</option>
                <option value="asistencias">Asistentes</option>
                <option value="goles_generados">Goles generados</option>
                <option value="goles_victoria">Match winners</option>
                <option value="goles_empate">Goles para empatar</option>
                <option value="goles_abrelatas"
                    >Goles para abrir el marcador</option
                >
                <option value="penaltis">Penaltis marcados</option>
                <option value="streak_scoring"
                    >Partidos consecutivos marcando</option
                >
                <option value="streak_assisting"
                    >Partidos consecutivos asistiendo</option
                >
                <option value="streak_ga"
                    >Partidos consecutivos con gol o asistencia</option
                >
                <option value="streak_clean_sheet"
                    >Porterías a cero consecutivas</option
                >
                <option value="award_monthly">Mejor Jugadora del Mes</option>
                <option value="award_season"
                    >Mejor Jugadora de la Temporada</option
                >
            </select>
        </div>

        <div class="custom-select-container" id="container-temporada">
            <div class="custom-select-trigger" id="trigger-temporada">
                <span class="selected-text">Todas las Temporadas</span>
                <div class="custom-select-arrow">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="m6 9 6 6 6-6"></path></svg
                    >
                </div>
            </div>
            <div class="custom-select-options">
                <div class="custom-select-option selected" data-value="todos">
                    Todas las Temporadas
                </div>
                {
                    seasons.map((season) => (
                        <div class="custom-select-option" data-value={season}>
                            {season}
                        </div>
                    ))
                }
            </div>
            <select
                id="filtro-temporada"
                aria-label="Filtrar por temporada"
                style="display: none;"
            >
                <option value="todos" selected>Todas las Temporadas</option>
                {
                    seasons.map((season) => (
                        <option value={season}>{season}</option>
                    ))
                }
            </select>
        </div>

        <div class="custom-select-container" id="container-competicion">
            <div class="custom-select-trigger" id="trigger-competicion">
                <span class="selected-text">Todas las Competiciones</span>
                <div class="custom-select-arrow">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="m6 9 6 6 6-6"></path></svg
                    >
                </div>
            </div>
            <div class="custom-select-options">
                <div class="custom-select-option selected" data-value="todos">
                    Todas las Competiciones
                </div>
                <div class="custom-select-option" data-value="oficiales">
                    Partidos Oficiales
                </div>
                <div class="custom-select-option" data-value="Liga F">
                    Liga F
                </div>
                <div class="custom-select-option" data-value="UWCL">UWCL</div>
                <div class="custom-select-option" data-value="Copa de la Reina">
                    Copa de la Reina
                </div>
                <div
                    class="custom-select-option"
                    data-value="Supercopa de España"
                >
                    Supercopa de España
                </div>
                <div class="custom-select-option" data-value="Amistoso">
                    Amistosos
                </div>
            </div>
            <select
                id="filtro-competicion"
                aria-label="Filtrar por competición"
                style="display: none;"
            >
                <option value="todos" selected>Todas las Competiciones</option>
                <option value="oficiales">Partidos Oficiales</option>
                <option value="Liga F">Liga F</option>
                <option value="UWCL">UWCL</option>
                <option value="Copa de la Reina">Copa de la Reina</option>
                <option value="Supercopa de España">Supercopa de España</option>
                <option value="Amistoso">Amistosos</option>
            </select>
        </div>
    </div>

    <div class="ranking-cards-container">
        <div class="ranking-card" id="dynamic-table-card">
            <h3 class="ranking-title" id="dynamic-table-title">Ranking</h3>
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead id="dynamic-table-head"> </thead>
                    <tbody id="dynamic-table-body"> </tbody>
                </table>
            </div>
            <div class="pagination-controls" id="pagination-controls">
                <div id="page-numbers" class="page-numbers"></div>
            </div>
        </div>
    </div>
</div>

<script
    define:vars={{
        rankingsData,
        streaksData,
        awardsData,
        playerImageMap,
    }}
>
    function setupStatsRankings() {
        const typeSelect = document.getElementById("filtro-tipo");
        const seasonSelect = document.getElementById("filtro-temporada");
        const competitionSelect = document.getElementById("filtro-competicion");
        const tableTitle = document.getElementById("dynamic-table-title");
        const tableHead = document.getElementById("dynamic-table-head");
        const tableBody = document.getElementById("dynamic-table-body");
        const pageNumbers = document.getElementById("page-numbers");
        const paginationControls = document.getElementById(
            "pagination-controls",
        );

        if (!typeSelect || !seasonSelect || !competitionSelect) return;

        let currentPage = 1;
        const playersPerPage = 25;
        let cachedPlayers = [];
        let cachedConfig = null;

        const tableConfigs = {
            goles: {
                title: "Máximas goleadoras",
                headers: ["Pos", "Jugadora", "Goles"],
                dataKeys: ["goles"],
                primaryKey: "goles",
            },
            asistencias: {
                title: "Máximas asistentes",
                headers: ["Pos", "Jugadora", "Asistencias"],
                dataKeys: ["asistencias"],
                primaryKey: "asistencias",
            },
            goles_generados: {
                title: "Más goles generados",
                headers: ["Pos", "Jugadora", "Goles", "Asistencias", "G+A"],
                dataKeys: ["goles", "asistencias", "goles_generados"],
                primaryKey: "goles_generados",
            },
            goles_victoria: {
                title: "Goles que dan la victoria",
                headers: ["Pos", "Jugadora", "Goles Victoria"],
                dataKeys: ["goles_victoria"],
                primaryKey: "goles_victoria",
            },
            goles_empate: {
                title: "Goles del empate",
                headers: ["Pos", "Jugadora", "Goles Empate"],
                dataKeys: ["goles_empate"],
                primaryKey: "goles_empate",
            },
            goles_abrelatas: {
                title: "Goles abrelatas (1º del partido)",
                headers: ["Pos", "Jugadora", "Goles Abrelatas"],
                dataKeys: ["goles_abrelatas"],
                primaryKey: "goles_abrelatas",
            },
            penaltis: {
                title: "Penaltis marcados",
                headers: ["Pos", "Jugadora", "Penaltis"],
                dataKeys: ["penaltis"],
                primaryKey: "penaltis",
            },
            partidos: {
                title: "Más partidos jugados",
                headers: ["Pos", "Jugadora", "Partidos"],
                dataKeys: ["partidos"],
                primaryKey: "partidos",
            },
            minutos: {
                title: "Más minutos jugados",
                headers: ["Pos", "Jugadora", "Minutos"],
                dataKeys: ["minutos"],
                primaryKey: "minutos",
            },
            titularidades: {
                title: "Más titularidades",
                headers: ["Pos", "Jugadora", "Titularidades"],
                dataKeys: ["titularidades"],
                primaryKey: "titularidades",
            },
            convocatorias: {
                title: "Más convocatorias",
                headers: ["Pos", "Jugadora", "Convocatorias"],
                dataKeys: ["convocatorias"],
                primaryKey: "convocatorias",
            },
            cambios_entrada: {
                title: "Más cambios (Entrada)",
                headers: ["Pos", "Jugadora", "Entradas"],
                dataKeys: ["cambio_entrada"],
                primaryKey: "cambio_entrada",
            },
            cambios_salida: {
                title: "Más cambios (Salida)",
                headers: ["Pos", "Jugadora", "Salidas"],
                dataKeys: ["cambio_salida"],
                primaryKey: "cambio_salida",
            },
            victorias: {
                title: "Más victorias",
                headers: ["Pos", "Jugadora", "Victorias"],
                dataKeys: ["victorias"],
                primaryKey: "victorias",
            },
            porterias_cero: {
                title: "Más porterías a cero",
                headers: ["Pos", "Portera", "P. Imbat."],
                dataKeys: ["porterias_cero"],
                primaryKey: "porterias_cero",
            },
            tarjetas_amarillas: {
                title: "Más tarjetas amarillas",
                headers: ["Pos", "Jugadora", "Amarillas"],
                dataKeys: ["tarjetas_amarillas"],
                primaryKey: "tarjetas_amarillas",
            },
            tarjetas_rojas: {
                title: "Más tarjetas rojas",
                headers: ["Pos", "Jugadora", "Rojas"],
                dataKeys: ["tarjetas_rojas"],
                primaryKey: "tarjetas_rojas",
            },
            capitanias: {
                title: "Más capitanías",
                headers: ["Pos", "Jugadora", "Capitanías"],
                dataKeys: ["capitanias"],
                primaryKey: "capitanias",
            },
            streak_scoring: {
                title: "Más partidos consecutivos marcando",
                headers: ["Pos", "Jugadora", "Partidos"],
                dataKeys: ["streak_scoring"],
                primaryKey: "streak_scoring",
                isStreak: true,
            },
            streak_assisting: {
                title: "Más partidos consecutivos asistiendo",
                headers: ["Pos", "Jugadora", "Partidos"],
                dataKeys: ["streak_assisting"],
                primaryKey: "streak_assisting",
                isStreak: true,
            },
            streak_ga: {
                title: "Más partidos consecutivos con goles generados",
                headers: ["Pos", "Jugadora", "Partidos"],
                dataKeys: ["streak_ga"],
                primaryKey: "streak_ga",
                isStreak: true,
            },
            streak_clean_sheet: {
                title: "Más partidos consecutivos con portería a cero",
                headers: ["Pos", "Portera/Defensa", "Partidos"],
                dataKeys: ["streak_clean_sheet"],
                primaryKey: "streak_clean_sheet",
                isStreak: true,
            },
            award_monthly: {
                title: "Mejor Jugadora del Mes",
                headers: ["Pos", "Jugadora", "Premios"],
                dataKeys: ["award_count"],
                primaryKey: "award_count",
                isAward: true,
                awardType: "mes",
            },
            award_season: {
                title: "Mejor Jugadora de la Temporada",
                headers: ["Pos", "Jugadora", "Premios"],
                dataKeys: ["award_count"],
                primaryKey: "award_count",
                isAward: true,
                awardType: "temporada",
            },
        };

        function getPlayerImage(slug) {
            if (!slug) return "";
            return playerImageMap[slug] || "";
        }

        function isDefenderOrGK(pos) {
            if (!pos) return false;
            const p = pos.toLowerCase();
            return (
                p.includes("portera") ||
                p.includes("defensa") ||
                p.includes("central") ||
                p.includes("lateral")
            );
        }

        function calculateRankings() {
            const selectedType = typeSelect.value;
            const selectedSeason = seasonSelect.value;
            const selectedCompetition = competitionSelect.value;

            const config = tableConfigs[selectedType];
            if (!config) return;

            if (config.isAward) {
                const compContainer = document.getElementById(
                    "container-competicion",
                );
                if (compContainer) compContainer.style.display = "none";

                if (selectedType === "award_monthly") {
                    const seasonContainer = document.getElementById(
                        "container-temporada",
                    );
                    if (seasonContainer) seasonContainer.style.display = "none";
                } else {
                    const seasonContainer = document.getElementById(
                        "container-temporada",
                    );
                    if (seasonContainer)
                        seasonContainer.style.display = "block";
                }
            } else {
                const compContainer = document.getElementById(
                    "container-competicion",
                );
                const seasonContainer = document.getElementById(
                    "container-temporada",
                );
                if (compContainer) compContainer.style.display = "block";
                if (seasonContainer) seasonContainer.style.display = "block";
            }

            tableTitle.textContent = config.title;

            tableHead.innerHTML = `
            <tr>
                ${config.headers
                    .map(
                        (h, i) => `
                    <th scope="col" class="${i === 1 ? "" : "text-center"} ${i === 0 ? "w-16" : ""}">
                        ${h}
                    </th>
                `,
                    )
                    .join("")}
            </tr>
        `;

            let sortedPlayers = [];

            if (config.isStreak) {
                sortedPlayers = streaksData.filter((item) => {
                    const matchSeason =
                        selectedSeason === "todos"
                            ? item.temporada === "all"
                            : item.temporada === selectedSeason;

                    let matchComp = false;
                    if (selectedCompetition === "todos") {
                        matchComp =
                            item.competicion === "all" ||
                            item.competicion === "todos";
                    } else if (selectedCompetition === "oficiales") {
                        matchComp =
                            item.competicion === "all" ||
                            item.competicion === "todos";
                    } else {
                        matchComp = item.competicion === selectedCompetition;
                    }

                    return matchSeason && matchComp;
                });

                sortedPlayers = sortedPlayers
                    .filter((p) => Number(p[config.primaryKey]) > 0)
                    .sort(
                        (a, b) =>
                            Number(b[config.primaryKey]) -
                            Number(a[config.primaryKey]),
                    );
            } else if (config.isAward) {
                const playerMap = {};

                const filteredAwards = awardsData.filter((award) => {
                    const tipo = (award.tipo || "").toUpperCase();

                    if (selectedType === "award_monthly") {
                        if (
                            !tipo.includes("MES") &&
                            !tipo.includes("MENSUAL") &&
                            tipo !== ""
                        )
                            return false;
                        return true;
                    } else {
                        if (
                            !tipo.includes("TEMPORADA") &&
                            !tipo.includes("SEASON") &&
                            !tipo.includes("MVP")
                        )
                            return false;

                        const matchSeason =
                            selectedSeason === "todos" ||
                            award.temporada === selectedSeason;

                        return matchSeason;
                    }
                });

                filteredAwards.forEach((award) => {
                    if (!playerMap[award.id_jugadora]) {
                        playerMap[award.id_jugadora] = {
                            id_jugadora: award.id_jugadora,
                            nombre: award.nombre,
                            slug: award.slug,
                            award_count: 0,
                            periods: [],
                        };
                    }
                    playerMap[award.id_jugadora].award_count++;

                    const period =
                        config.awardType === "mes"
                            ? award.mes
                            : award.temporada;
                    if (
                        period &&
                        !playerMap[award.id_jugadora].periods.includes(period)
                    ) {
                        playerMap[award.id_jugadora].periods.push(period);
                    }
                });

                sortedPlayers = Object.values(playerMap)
                    .filter((p) => p.award_count > 0)
                    .map((p) => ({
                        ...p,
                        periods_text:
                            p.periods.slice(0, 3).join(", ") +
                            (p.periods.length > 3 ? "..." : ""),
                    }))
                    .sort((a, b) => b.award_count - a.award_count);
            } else {
                const playerMap = {};

                rankingsData.forEach((item) => {
                    if (
                        selectedSeason !== "todos" &&
                        item.temporada !== selectedSeason
                    )
                        return;

                    if (selectedCompetition === "oficiales") {
                        const officialComps = [
                            "Liga F",
                            "UWCL",
                            "Copa de la Reina",
                            "Supercopa de España",
                        ];
                        if (!officialComps.includes(item.competicion)) return;
                    } else if (
                        selectedCompetition !== "todos" &&
                        item.competicion !== selectedCompetition
                    ) {
                        return;
                    }

                    if (selectedType === "porterias_cero") {
                        if (!isDefenderOrGK(item.posicion)) return;
                    }

                    if (!playerMap[item.id_jugadora]) {
                        playerMap[item.id_jugadora] = {
                            id_jugadora: item.id_jugadora,
                            nombre: item.nombre,
                            slug: item.slug,
                            posicion: item.posicion,
                            ...Object.fromEntries(
                                config.dataKeys.map((k) => [k, 0]),
                            ),
                        };
                    }

                    config.dataKeys.forEach((key) => {
                        playerMap[item.id_jugadora][key] += item[key] || 0;
                    });
                });

                const sortKey = config.primaryKey;

                sortedPlayers = Object.values(playerMap)
                    .filter((p) => p[sortKey] > 0)
                    .sort((a, b) => b[sortKey] - a[sortKey]);
            }

            cachedPlayers = sortedPlayers;
            cachedConfig = config;
            const totalPages = Math.ceil(cachedPlayers.length / playersPerPage);
            if (totalPages > 1) {
                paginationControls.style.display = "flex";
            } else {
                paginationControls.style.display = "none";
            }

            currentPage = 1;

            renderPage(cachedPlayers, cachedConfig);
        }

        function renderPage(allPlayers, config) {
            const totalPages = Math.ceil(allPlayers.length / playersPerPage);
            const startIndex = (currentPage - 1) * playersPerPage;
            const endIndex = startIndex + playersPerPage;
            const playersToShow = allPlayers.slice(startIndex, endIndex);

            if (playersToShow.length === 0 && allPlayers.length === 0) {
                tableBody.innerHTML =
                    '<tr><td colspan="10" class="no-data">No hay datos registrados.</td></tr>';
            } else {
                tableBody.innerHTML = playersToShow
                    .map((player, index) => {
                        const globalIndex = startIndex + index;
                        const extraStyle = "";

                        const isFirstPage = currentPage === 1;
                        const isTopThree = globalIndex < 3;
                        const shouldHighlight = isFirstPage && isTopThree;
                        const rowClass = shouldHighlight
                            ? `class="top-three-row top-${globalIndex + 1}"`
                            : "";

                        const valueCells = config.dataKeys
                            .map(
                                (key) => `
                    <td class="stat-cell text-center" style="${extraStyle}">${player[key]}</td>
                `,
                            )
                            .join("");

                        return `
                    <tr ${rowClass}>
                        <td class="pos-cell text-center" style="${extraStyle}">${globalIndex + 1}</td>
                        <td class="player-cell" style="${extraStyle}">
                            <a href="/jugadoras/${player.slug}" class="player-link">
                                <div class="flex items-center gap-2">
                                    <div class="player-thumb-wrapper">
                                        <img 
                                            src="${getPlayerImage(player.slug)}" 
                                            alt="${player.nombre}"
                                            class="player-thumb-img"
                                        />
                                    </div>
                                    <div class="player-name">${player.nombre}</div>
                                </div>
                            </a>
                        </td>
                        ${valueCells}
                    </tr>
                `;
                    })
                    .join("");
            }

            pageNumbers.innerHTML = "";

            for (let i = 1; i <= totalPages; i++) {
                const pageBtn = document.createElement("button");
                pageBtn.className = "page-number-btn";
                pageBtn.textContent = i;
                pageBtn.setAttribute("data-page", i);

                if (i === currentPage) {
                    pageBtn.classList.add("active");
                }

                pageBtn.addEventListener("click", () => {
                    currentPage = i;
                    renderPage(cachedPlayers, cachedConfig);
                });

                pageNumbers.appendChild(pageBtn);
            }
        }

        function updateRankings() {
            calculateRankings();
        }

        function initCustomSelects() {
            const statsRoot = document.querySelector(".stats-rankings-ui");
            if (!statsRoot) return;
            const containers = statsRoot.querySelectorAll(
                ".custom-select-container",
            );

            containers.forEach((container) => {
                const trigger = container.querySelector(
                    ".custom-select-trigger",
                );
                const select = container.querySelector("select");
                const options = container.querySelectorAll(
                    ".custom-select-option",
                );
                const selectedText = trigger?.querySelector(".selected-text");

                if (!trigger || !select) return;

                trigger.addEventListener("click", (e) => {
                    e.stopPropagation();
                    containers.forEach((c) => {
                        if (c !== container) c.classList.remove("open");
                    });
                    container.classList.toggle("open");
                });

                options.forEach((option) => {
                    option.addEventListener("click", () => {
                        const value = option.dataset.value;
                        const text = option.textContent?.trim();

                        if (selectedText) selectedText.textContent = text;
                        options.forEach((opt) =>
                            opt.classList.remove("selected"),
                        );
                        option.classList.add("selected");
                        if (value !== undefined) {
                            select.value = value;
                            select.dispatchEvent(new Event("change"));
                        }

                        container.classList.remove("open");
                    });
                });
            });

            // Close when clicking outside
            document.addEventListener("click", (e) => {
                if (!statsRoot.contains(e.target)) {
                    containers.forEach((c) => c.classList.remove("open"));
                }
            });
        }

        function updateRankings() {
            calculateRankings();
        }

        initCustomSelects();
        calculateRankings();

        // attach change listeners directly without worrying about window since old elements are destroyed
        typeSelect.addEventListener("change", updateRankings);
        seasonSelect.addEventListener("change", updateRankings);
        competitionSelect.addEventListener("change", updateRankings);
    }

    document.addEventListener("astro:page-load", setupStatsRankings);
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", setupStatsRankings);
    } else {
        setupStatsRankings();
    }
</script>

