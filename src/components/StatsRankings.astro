---
import type { RankingStat } from "../utils/rankings";

interface Props {
    rankingsData: RankingStat[];
    seasons: string[];
    competitions: string[];
}

const { rankingsData, seasons, competitions } = Astro.props;
---

<div class="stats-rankings-ui">
    <div class="filters-container">
        <!-- Explorer Filter (Custom Order) -->
        <div class="filter-wrapper">
            <select id="filtro-tipo">
                <option value="convocatorias">Convocatorias</option>
                <option value="partidos">Partidos Jugados</option>
                <option value="titularidades">Titularidades</option>
                <option value="minutos">Minutos Jugados</option>
                <option value="cambios_entrada">Cambios (Entrada)</option>
                <option value="cambios_salida">Cambios (Salida)</option>
                <option value="victorias">Victorias</option>
                <option value="porterias_cero">Porterías a cero</option>
                <option value="tarjetas_amarillas">Tarjetas Amarillas</option>
                <option value="tarjetas_rojas">Tarjetas Rojas</option>
                <option value="capitanias">Capitanías</option>
                <option value="goles">Máximas Goleadoras</option>
                <option value="asistencias">Máximas Asistentes</option>
                <option value="goles_generados">Goles Generados</option>
            </select>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="filter-icon"
                ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                    d="M6 9l6 6l6 -6"></path></svg
            >
        </div>

        <!-- Season Selector -->
        <div class="filter-wrapper">
            <select id="filtro-temporada">
                <option value="todos">Todas las Temporadas</option>
                {
                    seasons.map((season) => (
                        <option value={season}>{season}</option>
                    ))
                }
            </select>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="filter-icon"
                ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                    d="M6 9l6 6l6 -6"></path></svg
            >
        </div>

        <!-- Competition Selector (Custom Order) -->
        <div class="filter-wrapper">
            <select id="filtro-competicion">
                <option value="todos">Todas las Competiciones</option>
                <option value="oficiales">Partidos Oficiales</option>
                <option value="Liga F">Liga F</option>
                <option value="UWCL">UWCL</option>
                <option value="Copa de la Reina">Copa de la Reina</option>
                <option value="Supercopa de España">Supercopa de España</option>
                <option value="Amistosos">Amistosos</option>
            </select>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="filter-icon"
                ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                    d="M6 9l6 6l6 -6"></path></svg
            >
        </div>
    </div>

    <!-- Filter Info Tag Removed as requested -->
    <!-- <div id="active-filter-tag" class="text-center mb-6 text-sm text-gray-500 font-medium"></div> -->

    <div class="ranking-cards-container">
        <!-- Dynamic Table Container -->
        <div class="ranking-card" id="dynamic-table-card">
            <h3 class="ranking-title" id="dynamic-table-title">Ranking</h3>
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead id="dynamic-table-head">
                        <!-- Headers injected by JS -->
                    </thead>
                    <tbody id="dynamic-table-body">
                        <!-- Rows injected by JS -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script define:vars={{ rankingsData }}>
    const typeSelect = document.getElementById("filtro-tipo");
    const seasonSelect = document.getElementById("filtro-temporada");
    const competitionSelect = document.getElementById("filtro-competicion");
    const tableTitle = document.getElementById("dynamic-table-title");
    const tableHead = document.getElementById("dynamic-table-head");
    const tableBody = document.getElementById("dynamic-table-body");
    // const activeFilterTag = document.getElementById("active-filter-tag"); // Removed

    // Definitions for table configurations
    const tableConfigs = {
        goles: {
            title: "Máximas Goleadoras",
            headers: ["Pos", "Jugadora", "Goles"],
            dataKeys: ["goles"],
            primaryKey: "goles",
        },
        asistencias: {
            title: "Máximas Asistentes",
            headers: ["Pos", "Jugadora", "Asistencias"],
            dataKeys: ["asistencias"],
            primaryKey: "asistencias",
        },
        goles_generados: {
            title: "Goles Generados (G+A)",
            headers: ["Pos", "Jugadora", "Goles", "Asistencias", "G+A"],
            dataKeys: ["goles", "asistencias", "goles_generados"],
            primaryKey: "goles_generados",
        },
        // Legacy key removed but kept in mind if needed
        partidos: {
            title: "Más Partidos Jugados",
            headers: ["Pos", "Jugadora", "Partidos"],
            dataKeys: ["partidos"],
            primaryKey: "partidos",
        },
        minutos: {
            title: "Más Minutos Jugados",
            headers: ["Pos", "Jugadora", "Minutos"],
            dataKeys: ["minutos"],
            primaryKey: "minutos",
        },
        titularidades: {
            title: "Más Titularidades",
            headers: ["Pos", "Jugadora", "Titularidades"],
            dataKeys: ["titularidades"],
            primaryKey: "titularidades",
        },
        convocatorias: {
            title: "Más Convocatorias",
            headers: ["Pos", "Jugadora", "Convocatorias"],
            dataKeys: ["convocatorias"],
            primaryKey: "convocatorias",
        },
        cambios_entrada: {
            title: "Más Cambios (Entrada)",
            headers: ["Pos", "Jugadora", "Entradas"],
            dataKeys: ["cambio_entrada"],
            primaryKey: "cambio_entrada",
        },
        cambios_salida: {
            title: "Más Cambios (Salida)",
            headers: ["Pos", "Jugadora", "Salidas"],
            dataKeys: ["cambio_salida"],
            primaryKey: "cambio_salida",
        },
        victorias: {
            title: "Más Victorias",
            headers: ["Pos", "Jugadora", "Victorias"],
            dataKeys: ["victorias"],
            primaryKey: "victorias",
        },
        porterias_cero: {
            title: "Porterías a Cero",
            headers: ["Pos", "Portera", "P. Imbat."],
            dataKeys: ["porterias_cero"],
            primaryKey: "porterias_cero",
        },
        tarjetas_amarillas: {
            title: "Tarjetas Amarillas",
            headers: ["Pos", "Jugadora", "Amarillas"],
            dataKeys: ["tarjetas_amarillas"],
            primaryKey: "tarjetas_amarillas",
        },
        tarjetas_rojas: {
            title: "Tarjetas Rojas",
            headers: ["Pos", "Jugadora", "Rojas"],
            dataKeys: ["tarjetas_rojas"],
            primaryKey: "tarjetas_rojas",
        },
        capitanias: {
            title: "Capitanías",
            headers: ["Pos", "Jugadora", "Capitanías"],
            dataKeys: ["capitanias"],
            primaryKey: "capitanias",
        },
    };

    function getPlayerImage(playerName) {
        if (!playerName) return "";
        const slug = playerName
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .replace(/\s+/g, "_");
        return `/assets/jugadoras/${slug}.png`;
    }

    function calculateRankings() {
        const selectedType = typeSelect.value;
        const selectedSeason = seasonSelect.value;
        const selectedCompetition = competitionSelect.value;

        const config = tableConfigs[selectedType];

        // Update Title
        tableTitle.textContent = config.title;

        // Render Headers
        tableHead.innerHTML = `
            <tr>
                ${config.headers
                    .map(
                        (h, i) => `
                    <th scope="col" class="${i === 1 ? "" : "text-center"} ${i === 0 ? "w-16" : ""}">
                        ${h}
                    </th>
                `,
                    )
                    .join("")}
            </tr>
        `;

        // Process Data
        // Aggregate by player
        const playerMap = {};

        rankingsData.forEach((item) => {
            // Filter Season
            if (selectedSeason !== "todos" && item.temporada !== selectedSeason)
                return;

            // Filter Competition
            if (selectedCompetition === "oficiales") {
                const officialComps = [
                    "Liga F",
                    "UWCL",
                    "Copa de la Reina",
                    "Supercopa de España",
                ];
                if (!officialComps.includes(item.competicion)) return;
            } else if (
                selectedCompetition !== "todos" &&
                item.competicion !== selectedCompetition
            ) {
                // Fuzzy match for Amistosos if needed, but exact match should work if data is clean
                return;
            }

            // Aggregate
            if (!playerMap[item.id_jugadora]) {
                playerMap[item.id_jugadora] = {
                    nombre: item.nombre,
                    ...Object.fromEntries(config.dataKeys.map((k) => [k, 0])),
                };
            }

            config.dataKeys.forEach((key) => {
                playerMap[item.id_jugadora][key] += item[key] || 0;
            });
        });

        let sortKey = config.primaryKey;
        // Legacy check removed as distinct keys handle it now

        // Convert to array and sort
        const sortedPlayers = Object.values(playerMap)
            .filter((p) => p[sortKey] > 0) // Only show players with > 0 stats
            .sort((a, b) => b[sortKey] - a[sortKey])
            .slice(0, 50); // Limit to top 50

        // Render Body
        if (sortedPlayers.length === 0) {
            tableBody.innerHTML =
                '<tr><td colspan="10" class="no-data">No hay datos registrados.</td></tr>';
        } else {
            tableBody.innerHTML = sortedPlayers
                .map((player, index) => {
                    const isFirst = index === 0;
                    // const isLast = index === sortedPlayers.length - 1; // Unused
                    const extraStyle = ""; // Simplified style

                    // Value cells
                    const valueCells = config.dataKeys
                        .map(
                            (key) => `
                    <td class="stat-cell text-center" style="${extraStyle}">${player[key]}</td>
                `,
                        )
                        .join("");

                    return `
                    <tr>
                        <td class="pos-cell text-center" style="${extraStyle}">${index + 1}</td>
                        <td class="player-cell" style="${extraStyle}">
                            <div class="flex items-center gap-2">
                                <div class="player-thumb-wrapper">
                                    <img 
                                        src="${getPlayerImage(player.nombre)}" 
                                        alt="${player.nombre}"
                                        class="player-thumb-img"
                                    />
                                </div>
                                <div class="player-name">${player.nombre}</div>
                            </div>
                        </td>
                        ${valueCells}
                    </tr>
                `;
                })
                .join("");
        }
    }

    // Init
    calculateRankings();

    // Listeners
    typeSelect.addEventListener("change", calculateRankings);
    seasonSelect.addEventListener("change", calculateRankings);
    competitionSelect.addEventListener("change", calculateRankings);
</script>

<style is:global>
    .stats-rankings-ui {
        width: 100%;
        margin: 0 auto;
        font-family:
            "Inter",
            system-ui,
            -apple-system,
            sans-serif;
    }

    .filters-container {
        display: flex;
        gap: 1.5rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        justify-content: center;
    }

    .filter-wrapper {
        position: relative;
        display: flex;
        flex-direction: column;
        flex: 1;
        min-width: 220px;
        max-width: 320px;
    }

    /* Labels removed */
    .filter-label {
        display: none;
    }

    .filter-icon {
        position: absolute;
        right: 1.25rem;
        top: 50%; /* Center vertically */
        transform: translateY(-50%);
        pointer-events: none;
        color: #6b7280;
        width: 18px;
        height: 18px;
        z-index: 2;
    }

    .filters-container select {
        width: 100%;
        padding: 0.875rem 3rem 0.875rem 1.5rem; /* More padding left for pill shape */
        background: #ffffff;
        color: #1f2937;
        border: 1px solid #d1d5db;
        border-radius: 9999px; /* Fully rounded */
        font-size: 0.95rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
        outline: none;
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
    }

    /* Centering the options text visually might need text-align-last: center or just padding */
    .filters-container select {
        text-align: left;
        padding-left: 2rem;
    }

    .filters-container select:hover {
        border-color: #fbbf24;
        background: #fffdf5;
    }

    .filters-container select:focus {
        border-color: #fbbf24;
        box-shadow: 0 0 0 4px rgba(251, 191, 36, 0.15);
        background: #ffffff;
    }

    .ranking-cards-container {
        margin-top: 1rem;
    }

    .ranking-card {
        background: #ffffff;
        box-shadow:
            0 10px 15px -3px rgba(0, 0, 0, 0.1),
            0 4px 6px -2px rgba(0, 0, 0, 0.05);
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        overflow: hidden;
    }

    .ranking-title {
        font-size: 1.25rem;
        font-weight: 800;
        color: #111827;
        padding: 1.25rem 2rem;
        border-bottom: 2px solid #fbbf24;
        background: #ffffff;
        margin: 0;
        text-align: left;
        text-transform: uppercase;
        letter-spacing: 0.025em;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .ranking-title::before {
        content: "";
        display: inline-block;
        width: 6px;
        height: 24px;
        background: #fbbf24;
        border-radius: 4px;
    }

    .overflow-x-auto {
        scrollbar-width: thin;
        scrollbar-color: #d1d5db transparent;
        overflow-x: auto;
    }

    .overflow-x-auto::-webkit-scrollbar {
        height: 6px;
    }
    .overflow-x-auto::-webkit-scrollbar-track {
        background: transparent;
    }
    .overflow-x-auto::-webkit-scrollbar-thumb {
        background-color: #d1d5db;
        border-radius: 20px;
    }

    table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

    thead {
        background: #f9fafb;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    th {
        padding: 1rem 1.5rem;
        text-align: left;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #6b7280;
        letter-spacing: 0.05em;
        background: #f9fafb;
        border-bottom: 1px solid #e5e7eb;
        white-space: nowrap;
    }

    th.text-center {
        text-align: center;
    }

    tbody tr {
        background: #ffffff;
        transition: all 0.2s ease;
    }

    tbody tr:nth-child(even) {
        background: #fcfcfc;
    }

    tbody tr:hover {
        background: #fffbeb;
        transform: scale(1.001);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        position: relative;
        z-index: 5;
    }

    td {
        padding: 1.15rem 1.5rem;
        white-space: nowrap;
        color: #374151;
        font-size: 0.95rem;
        border-bottom: 1px solid #f3f4f6;
    }

    tbody tr:last-child td {
        border-bottom: none;
    }

    .pos-cell {
        font-size: 0.9rem;
        color: #9ca3af;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
        width: 4rem;
    }

    /* Top 3 Highlighting */
    tbody tr:nth-child(1) .pos-cell {
        color: #d97706;
        font-size: 1.1rem;
        font-weight: 800;
    }
    tbody tr:nth-child(2) .pos-cell {
        color: #5f666f;
        font-weight: 800;
    }
    tbody tr:nth-child(3) .pos-cell {
        color: #b45309;
        font-weight: 800;
    }

    .player-cell {
        vertical-align: middle;
    }

    .player-thumb-wrapper {
        width: 3rem;
        height: 3rem;
        min-width: 3rem;
        min-height: 3rem;
        flex-shrink: 0;
        border: 2px solid #ffffff;
        box-shadow: 0 0 0 1px #e5e7eb;
        border-radius: 8px; /* Square with rounded corners */
        overflow: hidden;
        background: #f3f4f6;
        display: flex;
        align-items: flex-end; /* Align image to bottom */
        justify-content: center;
    }

    /* Top 3 sizing logic */
    tbody tr:nth-child(1) .player-thumb-wrapper {
        width: 18rem; /* Ultra Hero size */
        height: 18rem;
        min-width: 18rem;
        min-height: 18rem;
        border-color: #ffd700; /* Gold */
        box-shadow:
            0 0 0 2px #ffd700,
            0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    tbody tr:nth-child(2) .player-thumb-wrapper,
    tbody tr:nth-child(3) .player-thumb-wrapper {
        width: 10rem; /* Very Large */
        height: 10rem;
        min-width: 10rem;
        min-height: 10rem;
    }

    tbody tr:nth-child(2) .player-thumb-wrapper {
        border-color: #c0c0c0; /* Silver */
        box-shadow:
            0 0 0 2px #c0c0c0,
            0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    tbody tr:nth-child(3) .player-thumb-wrapper {
        border-color: #cd7f32; /* Bronze */
        box-shadow:
            0 0 0 2px #cd7f32,
            0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    tbody tr:hover .player-thumb-wrapper {
        transform: scale(1.05); /* Slightly less zoom */
        border-color: #fbbf24;
    }

    .player-thumb-img {
        width: 100%;
        height: 100%;
        object-fit: contain; /* Prevent cropping */
        object-position: bottom center; /* Anchor to bottom */
    }

    .player-name {
        font-size: 0.95rem;
        font-weight: 600;
        color: #111827;
        letter-spacing: -0.01em;
    }

    .stat-cell {
        font-size: 1.05rem;
        font-weight: 700;
        color: #111827;
        font-variant-numeric: tabular-nums;
        font-feature-settings: "tnum";
    }

    .no-data {
        padding: 4rem 2rem;
        text-align: center;
        color: #9ca3af;
        font-style: italic;
        background: #f9fafb;
    }

    .w-16 {
        width: 5rem;
    }
    .text-center {
        text-align: center;
    }
    .flex {
        display: flex;
    }
    .items-center {
        align-items: center;
    }
    .gap-2 {
        gap: 0.75rem;
    }

    @media (max-width: 768px) {
        .ranking-title {
            padding: 1rem;
            font-size: 1.1rem;
        }

        td,
        th {
            padding: 0.75rem 1rem;
        }

        .filters-container {
            flex-direction: column;
            align-items: center;
        }

        .filter-wrapper {
            width: 100%;
            max-width: 100%;
        }
    }
</style>
