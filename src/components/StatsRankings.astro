---
import type { RankingStat, StreakData } from "../utils/rankings";
import type { AwardData } from "../utils/awards";

interface Props {
    rankingsData: RankingStat[];
    streaksData: StreakData[];
    awardsData: AwardData[];
    seasons: string[];
    competitions: string[];
    players?: any[];
}

import { getAssetUrl } from "../utils/assets";
const {
    rankingsData,
    streaksData,
    awardsData,
    seasons,
    competitions,
    players = [],
} = Astro.props;

const playerImageMap = Object.fromEntries(
    players.map((p: any) => [p.slug, getAssetUrl("jugadoras", p.slug)]),
);
---

<div class="stats-rankings-ui">
    <div class="filters-container">
        <div class="filter-wrapper">
            <select id="filtro-tipo" aria-label="Tipo de ranking">
                <option value="convocatorias">Convocatorias</option>
                <option value="partidos">Partidos jugados</option>
                <option value="titularidades">Titularidades</option>
                <option value="minutos">Minutos jugados</option>
                <option value="cambios_entrada">Cambios (Entrada)</option>
                <option value="cambios_salida">Cambios (Salida)</option>
                <option value="victorias">Victorias</option>
                <option value="porterias_cero">Porterías a cero</option>
                <option value="tarjetas_amarillas">Tarjetas amarillas</option>
                <option value="tarjetas_rojas">Tarjetas rojas</option>
                <option value="capitanias">Capitanías</option>
                <option value="goles">Goleadoras</option>
                <option value="asistencias">Asistentes</option>
                <option value="goles_generados">Goles generados</option>
                <option value="goles_victoria">Match winners</option>
                <option value="goles_empate">Goles para empatar</option>
                <option value="goles_abrelatas"
                    >Goles para abrir el marcador</option
                >
                <option value="penaltis">Penaltis marcados</option>
                <option value="streak_scoring"
                    >Partidos consecutivos marcando</option
                >
                <option value="streak_assisting"
                    >Partidos consecutivos asistiendo</option
                >
                <option value="streak_ga"
                    >Partidos consecutivos con gol o asistencia</option
                >
                <option value="streak_clean_sheet"
                    >Porterías a cero consecutivas</option
                >
                <option value="award_monthly">Mejor Jugadora del Mes</option>
                <option value="award_season"
                    >Mejor Jugadora de la Temporada</option
                >
            </select>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="filter-icon"
            >
                <>
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                    <path d="M6 9l6 6l6 -6"></path>
                </>
            </svg>
        </div>

        <div class="filter-wrapper">
            <select id="filtro-temporada" aria-label="Filtrar por temporada">
                <option value="todos">Todas las Temporadas</option>
                {
                    seasons.map((season) => (
                        <option value={season}>{season}</option>
                    ))
                }
            </select>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="filter-icon"
            >
                <>
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                    <path d="M6 9l6 6l6 -6"></path>
                </>
            </svg>
        </div>

        <div class="filter-wrapper">
            <select
                id="filtro-competicion"
                aria-label="Filtrar por competición"
            >
                <option value="todos">Todas las Competiciones</option>
                <option value="oficiales">Partidos Oficiales</option>
                <option value="Liga F">Liga F</option>
                <option value="UWCL">UWCL</option>
                <option value="Copa de la Reina">Copa de la Reina</option>
                <option value="Supercopa de España">Supercopa de España</option>
                <option value="Amistoso">Amistosos</option>
            </select>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="filter-icon"
            >
                <>
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                    <path d="M6 9l6 6l6 -6"></path>
                </>
            </svg>
        </div>
    </div>

    <div class="ranking-cards-container">
        <div class="ranking-card" id="dynamic-table-card">
            <h3 class="ranking-title" id="dynamic-table-title">Ranking</h3>
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead id="dynamic-table-head"> </thead>
                    <tbody id="dynamic-table-body"> </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script define:vars={{ rankingsData, streaksData, awardsData, playerImageMap }}>
    const typeSelect = document.getElementById("filtro-tipo");
    const seasonSelect = document.getElementById("filtro-temporada");
    const competitionSelect = document.getElementById("filtro-competicion");
    const tableTitle = document.getElementById("dynamic-table-title");
    const tableHead = document.getElementById("dynamic-table-head");
    const tableBody = document.getElementById("dynamic-table-body");

    const tableConfigs = {
        goles: {
            title: "Máximas goleadoras",
            headers: ["Pos", "Jugadora", "Goles"],
            dataKeys: ["goles"],
            primaryKey: "goles",
        },
        asistencias: {
            title: "Máximas asistentes",
            headers: ["Pos", "Jugadora", "Asistencias"],
            dataKeys: ["asistencias"],
            primaryKey: "asistencias",
        },
        goles_generados: {
            title: "Más goles generados",
            headers: ["Pos", "Jugadora", "Goles", "Asistencias", "G+A"],
            dataKeys: ["goles", "asistencias", "goles_generados"],
            primaryKey: "goles_generados",
        },
        goles_victoria: {
            title: "Goles que dan la victoria",
            headers: ["Pos", "Jugadora", "Goles Victoria"],
            dataKeys: ["goles_victoria"],
            primaryKey: "goles_victoria",
        },
        goles_empate: {
            title: "Goles del empate",
            headers: ["Pos", "Jugadora", "Goles Empate"],
            dataKeys: ["goles_empate"],
            primaryKey: "goles_empate",
        },
        goles_abrelatas: {
            title: "Goles abrelatas (1º del partido)",
            headers: ["Pos", "Jugadora", "Goles Abrelatas"],
            dataKeys: ["goles_abrelatas"],
            primaryKey: "goles_abrelatas",
        },
        penaltis: {
            title: "Penaltis marcados",
            headers: ["Pos", "Jugadora", "Penaltis"],
            dataKeys: ["penaltis"],
            primaryKey: "penaltis",
        },
        partidos: {
            title: "Más partidos jugados",
            headers: ["Pos", "Jugadora", "Partidos"],
            dataKeys: ["partidos"],
            primaryKey: "partidos",
        },
        minutos: {
            title: "Más minutos jugados",
            headers: ["Pos", "Jugadora", "Minutos"],
            dataKeys: ["minutos"],
            primaryKey: "minutos",
        },
        titularidades: {
            title: "Más titularidades",
            headers: ["Pos", "Jugadora", "Titularidades"],
            dataKeys: ["titularidades"],
            primaryKey: "titularidades",
        },
        convocatorias: {
            title: "Más convocatorias",
            headers: ["Pos", "Jugadora", "Convocatorias"],
            dataKeys: ["convocatorias"],
            primaryKey: "convocatorias",
        },
        cambios_entrada: {
            title: "Más cambios (Entrada)",
            headers: ["Pos", "Jugadora", "Entradas"],
            dataKeys: ["cambio_entrada"],
            primaryKey: "cambio_entrada",
        },
        cambios_salida: {
            title: "Más cambios (Salida)",
            headers: ["Pos", "Jugadora", "Salidas"],
            dataKeys: ["cambio_salida"],
            primaryKey: "cambio_salida",
        },
        victorias: {
            title: "Más victorias",
            headers: ["Pos", "Jugadora", "Victorias"],
            dataKeys: ["victorias"],
            primaryKey: "victorias",
        },
        porterias_cero: {
            title: "Más porterías a cero",
            headers: ["Pos", "Portera", "P. Imbat."],
            dataKeys: ["porterias_cero"],
            primaryKey: "porterias_cero",
        },
        tarjetas_amarillas: {
            title: "Más tarjetas amarillas",
            headers: ["Pos", "Jugadora", "Amarillas"],
            dataKeys: ["tarjetas_amarillas"],
            primaryKey: "tarjetas_amarillas",
        },
        tarjetas_rojas: {
            title: "Más tarjetas rojas",
            headers: ["Pos", "Jugadora", "Rojas"],
            dataKeys: ["tarjetas_rojas"],
            primaryKey: "tarjetas_rojas",
        },
        capitanias: {
            title: "Más capitanías",
            headers: ["Pos", "Jugadora", "Capitanías"],
            dataKeys: ["capitanias"],
            primaryKey: "capitanias",
        },
        streak_scoring: {
            title: "Más partidos consecutivos marcando",
            headers: ["Pos", "Jugadora", "Partidos"],
            dataKeys: ["streak_scoring"],
            primaryKey: "streak_scoring",
            isStreak: true,
        },
        streak_assisting: {
            title: "Más partidos consecutivos asistiendo",
            headers: ["Pos", "Jugadora", "Partidos"],
            dataKeys: ["streak_assisting"],
            primaryKey: "streak_assisting",
            isStreak: true,
        },
        streak_ga: {
            title: "Más partidos consecutivos con goles generados",
            headers: ["Pos", "Jugadora", "Partidos"],
            dataKeys: ["streak_ga"],
            primaryKey: "streak_ga",
            isStreak: true,
        },
        streak_clean_sheet: {
            title: "Más partidos consecutivos con portería a cero",
            headers: ["Pos", "Portera/Defensa", "Partidos"],
            dataKeys: ["streak_clean_sheet"],
            primaryKey: "streak_clean_sheet",
            isStreak: true,
        },
        award_monthly: {
            title: "Mejor Jugadora del Mes",
            headers: ["Pos", "Jugadora", "Premios", "Meses"],
            dataKeys: ["award_count"],
            primaryKey: "award_count",
            isAward: true,
            awardType: "mes",
        },
        award_season: {
            title: "Mejor Jugadora de la Temporada",
            headers: ["Pos", "Jugadora", "Premios", "Temporadas"],
            dataKeys: ["award_count"],
            primaryKey: "award_count",
            isAward: true,
            awardType: "temporada",
        },
    };

    function getPlayerImage(slug) {
        if (!slug) return "";
        return playerImageMap[slug] || "";
    }

    function isDefenderOrGK(pos) {
        if (!pos) return false;
        const p = pos.toLowerCase();
        return (
            p.includes("portera") ||
            p.includes("defensa") ||
            p.includes("central") ||
            p.includes("lateral")
        );
    }

    function calculateRankings() {
        const selectedType = typeSelect.value;
        const selectedSeason = seasonSelect.value;
        const selectedCompetition = competitionSelect.value;

        const config = tableConfigs[selectedType];
        if (!config) return;

        tableTitle.textContent = config.title;

        tableHead.innerHTML = `
            <tr>
                ${config.headers
                    .map(
                        (h, i) => `
                    <th scope="col" class="${i === 1 ? "" : "text-center"} ${i === 0 ? "w-16" : ""}">
                        ${h}
                    </th>
                `,
                    )
                    .join("")}
            </tr>
        `;

        let sortedPlayers = [];

        if (config.isStreak) {
            sortedPlayers = streaksData.filter((item) => {
                const matchSeason =
                    selectedSeason === "todos"
                        ? item.temporada === "all"
                        : item.temporada === selectedSeason;

                let matchComp = false;
                if (selectedCompetition === "todos") {
                    matchComp =
                        item.competicion === "all" ||
                        item.competicion === "todos";
                } else if (selectedCompetition === "oficiales") {
                    matchComp =
                        item.competicion === "all" ||
                        item.competicion === "todos";
                } else {
                    matchComp = item.competicion === selectedCompetition;
                }

                return matchSeason && matchComp;
            });

            sortedPlayers = sortedPlayers
                .filter((p) => Number(p[config.primaryKey]) > 0)
                .sort(
                    (a, b) =>
                        Number(b[config.primaryKey]) -
                        Number(a[config.primaryKey]),
                );

            if (
                selectedSeason !== "todos" &&
                award.temporada !== selectedSeason
            ) {
                return false;
            }

            return true;

            const playerMap = {};
            filteredAwards.forEach((award) => {
                if (!playerMap[award.id_jugadora]) {
                    playerMap[award.id_jugadora] = {
                        nombre: award.nombre,
                        slug: award.slug,
                        award_count: 0,
                        periods: [],
                    };
                }
                playerMap[award.id_jugadora].award_count++;

                const period =
                    config.awardType === "mes" ? award.mes : award.temporada;
                if (
                    period &&
                    !playerMap[award.id_jugadora].periods.includes(period)
                ) {
                    playerMap[award.id_jugadora].periods.push(period);
                }
            });

            sortedPlayers = Object.values(playerMap)
                .filter((p) => p.award_count > 0)
                .map((p) => ({
                    ...p,
                    periods_text:
                        p.periods.slice(0, 3).join(", ") +
                        (p.periods.length > 3 ? "..." : ""),
                }))
                .sort((a, b) => b.award_count - a.award_count);
        } else {
            const playerMap = {};

            rankingsData.forEach((item) => {
                if (
                    selectedSeason !== "todos" &&
                    item.temporada !== selectedSeason
                )
                    return;

                if (selectedCompetition === "oficiales") {
                    const officialComps = [
                        "Liga F",
                        "UWCL",
                        "Copa de la Reina",
                        "Supercopa de España",
                    ];
                    if (!officialComps.includes(item.competicion)) return;
                } else if (
                    selectedCompetition !== "todos" &&
                    item.competicion !== selectedCompetition
                ) {
                    return;
                }

                if (selectedType === "porterias_cero") {
                    if (!isDefenderOrGK(item.posicion)) return;
                }

                if (!playerMap[item.id_jugadora]) {
                    playerMap[item.id_jugadora] = {
                        nombre: item.nombre,
                        slug: item.slug,
                        posicion: item.posicion,
                        ...Object.fromEntries(
                            config.dataKeys.map((k) => [k, 0]),
                        ),
                    };
                }

                config.dataKeys.forEach((key) => {
                    playerMap[item.id_jugadora][key] += item[key] || 0;
                });
            });

            const sortKey = config.primaryKey;

            sortedPlayers = Object.values(playerMap)
                .filter((p) => p[sortKey] > 0)
                .sort((a, b) => b[sortKey] - a[sortKey]);
        }

        sortedPlayers = sortedPlayers.slice(0, 50);
        if (sortedPlayers.length === 0) {
            tableBody.innerHTML =
                '<tr><td colspan="10" class="no-data">No hay datos registrados.</td></tr>';
        } else {
            tableBody.innerHTML = sortedPlayers
                .map((player, index) => {
                    const extraStyle = "";
                    const valueCells = config.dataKeys
                        .map(
                            (key) => `
                    <td class="stat-cell text-center" style="${extraStyle}">${player[key]}</td>
                `,
                        )
                        .join("");

                    const periodsCell = config.isAward
                        ? `
                    <td class="stat-cell text-center" style="${extraStyle}">${player.periods_text || ""}</td>
                    `
                        : "";

                    return `
                    <tr>
                        <td class="pos-cell text-center" style="${extraStyle}">${index + 1}</td>
                        <td class="player-cell" style="${extraStyle}">
                            <a href="/jugadoras/${player.slug}" class="player-link">
                                <div class="flex items-center gap-2">
                                    <div class="player-thumb-wrapper">
                                        <img 
                                            src="${getPlayerImage(player.slug)}" 
                                            alt="${player.nombre}"
                                            class="player-thumb-img"
                                        />
                                    </div>
                                    <div class="player-name">${player.nombre}</div>
                                </div>
                            </a>
                        </td>
                        ${valueCells}
                        ${periodsCell}
                    </tr>
                `;
                })
                .join("");
        }
    }

    calculateRankings();

    typeSelect.addEventListener("change", calculateRankings);
    seasonSelect.addEventListener("change", calculateRankings);
    competitionSelect.addEventListener("change", calculateRankings);
</script>

<style is:global>
    .stats-rankings-ui {
        width: 100%;
        margin: 0 auto;
        font-family:
            "Inter",
            system-ui,
            -apple-system,
            sans-serif;
    }

    .filters-container {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        justify-content: center;
    }

    .filter-wrapper {
        position: relative;
        display: inline-block;
    }

    .filter-icon {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
        color: #2b2b2b;
        width: 20px;
        height: 20px;
        z-index: 2;
    }

    .filters-container select {
        padding: 0.75rem 3rem 0.75rem 1.5rem;
        background: #ffffff;
        color: #2b2b2b;
        border: 2px solid #ffde59;
        border-radius: 25px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        width: 280px;
        min-width: 280px;
        max-width: 280px;
        transition: all 0.3s ease;
        box-shadow: 0 2px 8px rgba(255, 222, 89, 0.2);
        outline: none;
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        text-align: center;
    }

    .filters-container select:hover {
        background: #fffef8;
        border-color: #ffd700;
    }

    .filters-container select:focus {
        outline: none;
        border-color: #ffd700;
        box-shadow: 0 0 0 4px rgba(255, 222, 89, 0.2);
    }

    .ranking-cards-container {
        margin-top: 1rem;
    }

    .ranking-card {
        background: #ffffff;
        box-shadow:
            0 10px 15px -3px rgba(0, 0, 0, 0.1),
            0 4px 6px -2px rgba(0, 0, 0, 0.05);
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        overflow: hidden;
    }

    .ranking-title {
        font-size: 1.25rem;
        font-weight: 800;
        color: #111827;
        padding: 1.25rem 2rem;
        border-bottom: 2px solid #fbbf24;
        background: #ffffff;
        margin: 0;
        text-align: left;
        text-transform: uppercase;
        letter-spacing: 0.025em;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .ranking-title::before {
        content: "";
        display: inline-block;
        width: 6px;
        height: 24px;
        background: #fbbf24;
        border-radius: 4px;
    }

    .overflow-x-auto {
        scrollbar-width: thin;
        scrollbar-color: #d1d5db transparent;
        overflow-x: auto;
    }

    .overflow-x-auto::-webkit-scrollbar {
        height: 6px;
    }
    .overflow-x-auto::-webkit-scrollbar-track {
        background: transparent;
    }
    .overflow-x-auto::-webkit-scrollbar-thumb {
        background-color: #d1d5db;
        border-radius: 20px;
    }

    table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

    thead {
        background: #f9fafb;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    th {
        padding: 1rem 1.5rem;
        text-align: left;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #6b7280;
        letter-spacing: 0.05em;
        background: #f9fafb;
        border-bottom: 1px solid #e5e7eb;
        white-space: nowrap;
    }

    th.text-center {
        text-align: center;
    }

    tbody tr {
        background: #ffffff;
        transition: all 0.2s ease;
    }

    tbody tr:nth-child(even) {
        background: #fcfcfc;
    }

    tbody tr:hover {
        background: #fffbeb;
        transform: scale(1.001);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        position: relative;
        z-index: 5;
    }

    td {
        padding: 1.15rem 1.5rem;
        white-space: nowrap;
        color: #374151;
        font-size: 0.95rem;
        border-bottom: 1px solid #f3f4f6;
    }

    tbody tr:last-child td {
        border-bottom: none;
    }

    .pos-cell {
        font-size: 0.9rem;
        color: #9ca3af;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
        width: 4rem;
    }

    tbody tr:nth-child(1) .pos-cell {
        color: #d97706;
        font-size: 1.1rem;
        font-weight: 800;
    }
    tbody tr:nth-child(2) .pos-cell {
        color: #5f666f;
        font-weight: 800;
    }
    tbody tr:nth-child(3) .pos-cell {
        color: #b45309;
        font-weight: 800;
    }

    .player-cell {
        vertical-align: middle;
    }

    .player-thumb-wrapper {
        width: 3rem;
        height: 3rem;
        min-width: 3rem;
        min-height: 3rem;
        flex-shrink: 0;
        border: 2px solid #ffffff;
        box-shadow: 0 0 0 1px #e5e7eb;
        border-radius: 8px;
        overflow: hidden;
        background: #f3f4f6;
        display: flex;
        align-items: flex-end;
        justify-content: center;
    }

    tbody tr:nth-child(1) .player-thumb-wrapper {
        width: 18rem;
        height: 18rem;
        min-width: 18rem;
        min-height: 18rem;
        border-color: #ffd700;
        box-shadow:
            0 0 0 2px #ffd700,
            0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    tbody tr:nth-child(2) .player-thumb-wrapper,
    tbody tr:nth-child(3) .player-thumb-wrapper {
        width: 10rem;
        height: 10rem;
        min-width: 10rem;
        min-height: 10rem;
    }

    tbody tr:nth-child(2) .player-thumb-wrapper {
        border-color: #c0c0c0;
        box-shadow:
            0 0 0 2px #c0c0c0,
            0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    tbody tr:nth-child(3) .player-thumb-wrapper {
        border-color: #cd7f32;
        box-shadow:
            0 0 0 2px #cd7f32,
            0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    tbody tr:hover .player-thumb-wrapper {
        transform: scale(1.05);
        border-color: #fbbf24;
    }

    .player-thumb-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        object-position: bottom center;
    }

    .player-name {
        font-size: 0.95rem;
