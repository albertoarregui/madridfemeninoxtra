---
import { COACHES } from "../../public/consts/coaches";
import { COUNTRIES } from "../../public/consts/countries";
import type { ImageMetadata } from "astro";
import "../styles/global.css";

const listofCoaches = COACHES.map((coach) => {
    const { country } = coach;
    // @ts-ignore
    const countryName = COUNTRIES[country]?.name || "";
    return { ...coach, countryName };
});

const coachImages = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/entrenadores/*.png",
    { eager: true },
);

function getCoachImageSrc(coachId: string) {
    const imageId = coachId.replace(/-/g, "_");
    const imagePath = `/src/assets/entrenadores/${imageId}.png`;
    return coachImages[imagePath]?.default;
}
---

<section class="max-w-[1600px] mx-auto px-4 py-8">
    <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 gap-y-10 pt-4"
    >
        {
            listofCoaches.map((coach) => {
                const coachImgSrc = getCoachImageSrc(coach.id)?.src;
                return (
                    <a
                        href={`/entrenadores/${coach.id}`}
                        class="group relative flex flex-col items-center transition-all duration-300 hover:-translate-y-1"
                    >
                        {/* Card Background */}
                        <div class="absolute inset-x-0 bottom-0 top-6 bg-gradient-to-br from-[#1d274e] to-[#151e42] rounded-2xl shadow-lg border border-white/5 group-hover:border-[#ffde59]/50 transition-all duration-300 group-hover:shadow-[0_0_20px_rgba(255,222,89,0.15)] z-0 overflow-hidden" />

                        {/* Image Container */}
                        <div class="w-full h-72 relative z-10 px-4 -mb-12">
                            <div class="w-full h-full relative flex items-end justify-center">
                                <img
                                    src={coachImgSrc}
                                    alt={coach.name}
                                    class="w-full h-full object-cover object-top transform origin-bottom transition-transform duration-300 group-hover:scale-110 group-hover:-translate-y-2 rounded-t-2xl"
                                />
                            </div>
                        </div>

                        {/* Info Container */}
                        <div class="w-full p-5 relative z-20 mt-12">
                            {/* Position Badge */}
                            <div class="absolute -top-6 left-6 z-20">
                                <span class="px-3 py-1 bg-black/50 backdrop-blur-md border border-white/20 rounded-full text-xs font-bold uppercase tracking-wider text-white group-hover:bg-[#ffde59] group-hover:text-black transition-colors">
                                    Entrenador
                                </span>
                            </div>

                            <div class="flex items-start justify-between mb-2 mt-2">
                                <h3 class="text-xl font-black font-bebas text-white uppercase tracking-wide group-hover:text-[#ffde59] transition-colors leading-none truncate w-full">
                                    {coach.name}
                                </h3>
                            </div>

                            <div class="flex items-center gap-2 text-gray-400 text-sm font-medium">
                                <img
                                    src={`https://flagcdn.com/w40/${coach.country}.png`}
                                    alt={coach.countryName}
                                    class="w-5 h-5 rounded-full object-cover shadow-sm"
                                />
                                <span class="uppercase">
                                    {coach.countryName}
                                </span>
                            </div>

                            {/* View Profile Button */}
                            <div class="mt-4 pt-4 border-t border-white/10 flex justify-end">
                                <span class="text-xs font-bold uppercase tracking-wider text-[#ffde59] flex items-center gap-1 transition-colors group-hover:text-white">
                                    Ver Perfil <span class="text-lg">→</span>
                                </span>
                            </div>
                        </div>
                    </a>
                );
            })
        }
    </div>
</section>
