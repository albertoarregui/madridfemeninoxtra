---
import { COUNTRIES } from "../consts/countries";
import { getFlagSrc } from "../utils/flags";
import {
    fetchAndCleanPlayers,
    fetchPlayersDirectly,
    getPlayerImageUrl,
} from "../utils/players";

// Fetch all players from DB
const allPlayersDb = await fetchPlayersDirectly();

// Determine the latest season globally
const allSeasons = allPlayersDb.flatMap((p) => p.temporadas || []);
const latestSeason = [...new Set(allSeasons)].sort().reverse()[0];

// Filter players who played in the latest season with dorsal 1-24
const squadPlayers = allPlayersDb.filter((player) => {
    const dorsal = player.dorsales && player.dorsales[latestSeason];
    return dorsal !== undefined && Number(dorsal) >= 1 && Number(dorsal) <= 24;
});

// Maintain the same order and grouping as defined in SQUAD if possible,
// or just use the DB players grouped by position.
const listofPlayers = squadPlayers.map((player) => {
    const { pais_origin } = player;
    const dorsal = player.dorsales[latestSeason];
    const profilePhoto =
        player.profile_photos && player.profile_photos[latestSeason];
    const seasonPhoto =
        player.season_photos && player.season_photos[latestSeason];
    const countryName =
        (COUNTRIES as any)[pais_origin]?.name || pais_origin || "";

    return {
        ...player,
        id: player.id_jugadora.toString(), // For compatibility with older code
        name: player.nombre,
        number: dorsal.toString(),
        position: player.posicion,
        country: pais_origin,
        countryName,
        flagUrl: getFlagSrc(pais_origin),
        date_birth: player.fecha_nacimiento,
        height: player.altura,
        weight: player.peso,
        imageUrl: getPlayerImageUrl({
            ...player,
            foto_perfil_url: profilePhoto,
            foto_url: seasonPhoto,
        }),
        thumbnailUrl: getPlayerImageUrl({
            ...player,
            foto_perfil_url: null,
            foto_url: seasonPhoto,
        }),
    };
});

// Sort by number
listofPlayers.sort((a, b) => Number(a.number) - Number(b.number));

// Group players by position for the rows
const getNormalizedPosition = (pos: string) => {
    const p = pos?.toLowerCase() || "";
    if (p.includes("portera")) return "Portera";
    if (p.includes("defensa") || p.includes("lateral") || p.includes("central"))
        return "Defensa";
    if (
        p.includes("medio") ||
        p.includes("centro") ||
        p.includes("pivote") ||
        p.includes("interior")
    )
        return "Centrocampista";
    if (
        p.includes("delantera") ||
        p.includes("extremo") ||
        p.includes("punta") ||
        p.includes("ariete")
    )
        return "Delantera";
    return "Otros";
};

const porteras = listofPlayers.filter(
    (p) => getNormalizedPosition(p.position) === "Portera",
);
const defensas = listofPlayers.filter(
    (p) => getNormalizedPosition(p.position) === "Defensa",
);
const medios = listofPlayers.filter(
    (p) => getNormalizedPosition(p.position) === "Centrocampista",
);
const delanteras = listofPlayers.filter(
    (p) => getNormalizedPosition(p.position) === "Delantera",
);
const otros = listofPlayers.filter(
    (p) => getNormalizedPosition(p.position) === "Otros",
);

const rows = [
    { title: "PORTERAS", players: porteras },
    { title: "DEFENSAS", players: defensas },
    { title: "CENTROCAMPISTAS", players: medios },
    { title: "DELANTERAS", players: delanteras },
].filter((row) => row.players.length > 0);

if (otros.length > 0) {
    rows.push({ title: "OTRAS", players: otros });
}

function calculateAge(birthDateString: string): number {
    const birthDate = new Date(birthDateString);
    const today = new Date();
    let age = today.getFullYear() - birthDate.getFullYear();
    const monthDiff = today.getMonth() - birthDate.getMonth();
    if (
        monthDiff < 0 ||
        (monthDiff === 0 && today.getDate() < birthDate.getDate())
    ) {
        age--;
    }
    return age;
}
---

<section class="player-selector">
    <div class="player-container">
        <div class="main-player-display">
            <div class="player-info-top">
                <span class="player-position" id="player-position"
                    >{
                        listofPlayers.length > 0
                            ? listofPlayers[0].position
                            : "-"
                    }</span
                >
                <div class="player-country-flat">
                    <img
                        id="player-flag"
                        src={listofPlayers.length > 0
                            ? getFlagSrc(listofPlayers[0].country)
                            : ""}
                        alt={listofPlayers.length > 0
                            ? listofPlayers[0].countryName
                            : ""}
                        class="country-flag"
                    />
                    <span id="player-country-name"
                        >{
                            listofPlayers.length > 0
                                ? listofPlayers[0].countryName
                                : "-"
                        }</span
                    >
                </div>
            </div>
            <div class="player-main-image-container">
                {
                    listofPlayers.length > 0 && (
                        <img
                            id="player-main-image"
                            src={listofPlayers[0].imageUrl}
                            alt={listofPlayers[0].name}
                            class="player-main-image"
                        />
                    )
                }
            </div>
            <h2 class="player-name" id="player-name">
                {
                    listofPlayers.length > 0
                        ? listofPlayers[0].name
                        : "Seleccione jugadora"
                }
            </h2>
            <div class="player-stats">
                <div class="stat-item">
                    <span class="stat-label">Edad</span>
                    <span class="stat-value" id="player-age"
                        >{
                            listofPlayers.length > 0
                                ? calculateAge(listofPlayers[0].date_birth)
                                : "-"
                        }</span
                    >
                </div>
                <div class="stat-item">
                    <span class="stat-label">Altura</span>
                    <span class="stat-value" id="player-height"
                        >{
                            listofPlayers.length > 0
                                ? `${listofPlayers[0].height}m`
                                : "-"
                        }</span
                    >
                </div>
                <div class="stat-item">
                    <span class="stat-label">Peso</span>
                    <span class="stat-value" id="player-weight"
                        >{
                            listofPlayers.length > 0
                                ? `${listofPlayers[0].weight}kg`
                                : "-"
                        }</span
                    >
                </div>
            </div>

            <div class="player-actions">
                {
                    listofPlayers.length > 0 && (
                        <a
                            href={`/jugadoras/${listofPlayers[0].slug}`}
                            id="player-profile-link"
                            class="btn-profile"
                        >
                            Ver perfil
                        </a>
                    )
                }
            </div>
        </div>

        <div class="player-rows-container">
            {
                rows.map((row) => (
                    <div class="player-row-section">
                        <h4 class="section-title">{row.title}</h4>
                        <div class="player-row">
                            {row.players.map((player) => {
                                const globalIndex = listofPlayers.findIndex(
                                    (p) => p.id === player.id,
                                );
                                return (
                                    <button
                                        class={`player-thumbnail desktop-thumb ${globalIndex === 0 ? "active" : ""}`}
                                        data-player-id={player.id}
                                        data-player-index={globalIndex}
                                        data-profile-image={player.imageUrl}
                                        aria-label={`Select ${player.name}`}
                                    >
                                        <span class="thumbnail-number">
                                            {player.number}
                                        </span>
                                        <div class="thumbnail-image-wrapper">
                                            <img
                                                src={player.thumbnailUrl}
                                                alt={player.name}
                                                class="thumbnail-image"
                                            />
                                        </div>
                                    </button>
                                );
                            })}
                        </div>
                    </div>
                ))
            }
        </div>
    </div>

    <div class="mobile-player-carousel">
        <button
            class="carousel-arrow left"
            id="carousel-prev"
            aria-label="Previous player"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg
            >
        </button>

        <div class="mobile-thumbnails-wrapper">
            <div class="mobile-thumbnails-track">
                {
                    listofPlayers.map((player, index) => {
                        return (
                            <button
                                class={`player-thumbnail mobile-thumb ${index === 0 ? "active" : ""}`}
                                data-player-id={player.id}
                                data-player-index={index}
                                data-profile-image={player.imageUrl}
                                aria-label={`Select ${player.name}`}
                            >
                                <span class="thumbnail-number">
                                    {player.number}
                                </span>
                                <div class="thumbnail-image-wrapper">
                                    <img
                                        src={player.thumbnailUrl}
                                        alt={player.name}
                                        class="thumbnail-image"
                                    />
                                </div>
                            </button>
                        );
                    })
                }
            </div>
        </div>

        <button
            class="carousel-arrow right"
            id="carousel-next"
            aria-label="Next player"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
            >
        </button>
    </div>
</section>

<script define:vars={{ players: listofPlayers }}>
    function calculateAge(birthDateString) {
        const birthDate = new Date(birthDateString);
        const today = new Date();
        let age = today.getFullYear() - birthDate.getFullYear();
        const monthDiff = today.getMonth() - birthDate.getMonth();
        if (
            monthDiff < 0 ||
            (monthDiff === 0 && today.getDate() < birthDate.getDate())
        ) {
            age--;
        }
        return age;
    }

    let selectedIndex = 0;

    function updatePlayerDisplay(index, isSelection = false) {
        const player = players[index];
        if (!player) return;

        if (isSelection) {
            selectedIndex = index;
        }

        const setContent = (id, text) => {
            const el = document.getElementById(id);
            if (el) el.textContent = text;
        };

        setContent("player-position", player.position);
        setContent("player-country-name", player.countryName);
        setContent("player-name", player.name);
        setContent("player-height", `${player.height}m`);
        setContent("player-number", player.number);
        setContent("player-weight", `${player.weight}kg`);
        setContent("player-age", calculateAge(player.date_birth));

        const flag = document.getElementById("player-flag");
        if (flag) {
            flag.src = player.flagUrl;
            flag.alt = player.countryName;
        }

        const imgElement = document.getElementById("player-main-image");
        if (imgElement) {
            let thumbButton = document.querySelector(
                `.desktop-thumb[data-player-id="${player.id}"]`,
            );
            if (!thumbButton) {
                thumbButton = document.querySelector(
                    `.mobile-thumb[data-player-id="${player.id}"]`,
                );
            }

            if (thumbButton && thumbButton.dataset.profileImage) {
                imgElement.src = thumbButton.dataset.profileImage;
            }
            imgElement.alt = player.name;
        }

        const link = document.getElementById("player-profile-link");
        if (link) {
            link.href = `/jugadoras/${player.id.replace(/_/g, "-")}`;
        }

        document.querySelectorAll(".player-thumbnail").forEach((thumb) => {
            const thumbIndex = parseInt(thumb.dataset.playerIndex || "-1");
            thumb.classList.toggle("active", thumbIndex === selectedIndex);
        });
    }

    const rowsContainer = document.querySelector(".player-rows-container");

    const wrapper = document.querySelector(".mobile-thumbnails-wrapper");
    const prevBtn = document.getElementById("carousel-prev");
    const nextBtn = document.getElementById("carousel-next");

    function scrollCarousel(direction) {
        if (!wrapper) return;
        const itemSize = 96;
        const scrollAmount = direction * itemSize;
        wrapper.scrollBy({ left: scrollAmount, behavior: "smooth" });
    }

    if (prevBtn) {
        prevBtn.addEventListener("click", () => scrollCarousel(-1));
    }

    if (nextBtn) {
        nextBtn.addEventListener("click", () => scrollCarousel(1));
    }

    if (wrapper) {
        wrapper.addEventListener("wheel", (e) => {
            e.preventDefault();
            const scrollAmount = e.deltaY;
            wrapper.scrollBy({ left: scrollAmount, behavior: "smooth" });
        });
    }

    document.querySelectorAll(".player-thumbnail").forEach((thumb) => {
        thumb.addEventListener("mouseenter", (e) => {
            if (window.innerWidth > 768) {
                const target = e.currentTarget;
                if (target && target.dataset.playerIndex) {
                    const index = parseInt(target.dataset.playerIndex);
                    updatePlayerDisplay(index, false);
                }
            }
        });

        thumb.addEventListener("click", (e) => {
            const target = e.currentTarget;
            if (target && target.dataset.playerIndex) {
                const index = parseInt(target.dataset.playerIndex);
                updatePlayerDisplay(index, true);
            }
        });
    });

    if (rowsContainer) {
        rowsContainer.addEventListener("mouseleave", () => {
            if (window.innerWidth > 768) {
                updatePlayerDisplay(selectedIndex, false);
            }
        });
    }
</script>

<style>
    .player-selector {
        width: 100%;
        margin: 0 auto;
        padding: 0;
    }

    .mobile-player-carousel {
        display: none;
    }

    .player-container {
        display: flex;
        flex-direction: column;
        gap: 3rem;
        width: 100%;
        max-width: 1700px;
        margin: 0 auto;
    }

    /* Desktop Styles */
    @media (min-width: 1024px) {
        .player-container {
            flex-direction: row !important;
            align-items: center !important;
            gap: 4rem;
            justify-content: center;
        }

        .main-player-display {
            flex: 1;
            position: sticky;
            top: 6rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-width: 0;
            padding: 0;
        }

        .player-rows-container {
            flex: 1;
            display: grid !important;
            grid-template-columns: repeat(2, 1fr) !important;
            gap: 3rem 2rem;
            align-items: start !important;
            min-width: 0;
            padding: 0;
        }

        .player-row-section {
            display: flex !important;
            flex-direction: column !important;
            gap: 1.5rem !important;
            width: 100% !important;
        }

        .section-title {
            font-size: 2.8rem !important;
            font-weight: 800 !important;
            font-family: "Bebas Neue", sans-serif !important;
            color: #1a1a1a;
            margin: 0 0 1.2rem 0 !important;
            padding-left: 1rem;
            border-left: 4px solid #ffde59;
            text-transform: uppercase;
            line-height: 1;
        }

        .player-row {
            display: grid !important;
            grid-template-columns: repeat(4, 1fr) !important;
            gap: 10px;
            width: 100%;
            justify-items: center;
        }
    }

    /* Common Components */
    .player-info-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        margin-bottom: 2.5rem;
        padding: 0 1rem;
    }

    .player-position {
        font-size: 1.8rem;
        font-family: "Archivo Black", sans-serif;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #1a1a1a;
        font-weight: 800;
    }

    .player-country-flat {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .country-flag {
        width: 48px;
        height: auto;
        border-radius: 4px;
        /* Removed box-shadow as requested */
    }

    #player-country-name {
        font-size: 1.6rem;
        font-weight: 800;
        font-family: "Archivo Black", sans-serif;
        text-transform: uppercase;
        color: #1a1a1a;
    }

    .player-main-image-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 450px;
        margin-bottom: 2rem;
        position: relative;
    }

    .player-main-image {
        height: 450px;
        width: auto;
        max-width: 100%;
        object-fit: contain;
        display: block;
        margin: 0 auto;
        -webkit-mask-image: linear-gradient(
            to bottom,
            rgba(0, 0, 0, 1) 60%,
            rgba(0, 0, 0, 0) 100%
        );
        mask-image: linear-gradient(
            to bottom,
            rgba(0, 0, 0, 1) 60%,
            rgba(0, 0, 0, 0) 100%
        );
    }

    .player-name {
        text-align: center;
        font-size: clamp(2.5rem, 5vw, 5rem);
        font-weight: 900;
        font-family: "Permanent Marker", cursive;
        color: #ffde59;
        margin-bottom: 2rem;
        text-transform: uppercase;
        line-height: 1;
        min-height: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .player-stats {
        display: flex;
        justify-content: center;
        gap: 3rem;
        margin-bottom: 2.5rem;
    }

    .stat-item {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .stat-label {
        font-size: 0.9rem;
        font-family: "Archivo Black", sans-serif;
        color: #1a1a1a;
        text-transform: uppercase;
        font-style: italic;
        opacity: 0.7;
    }

    .stat-value {
        font-size: 3.5rem;
        font-weight: 900;
        font-family: "Archivo Black", sans-serif;
        color: #ffde59;
        line-height: 1;
    }

    .btn-profile {
        background: #ffde59;
        color: #1a1a1a;
        padding: 1.2rem 3.5rem;
        border-radius: 50px;
        text-transform: uppercase;
        font-weight: 900;
        font-size: 1.2rem;
        text-decoration: none;
        box-shadow: 0 4px 20px rgba(255, 222, 89, 0.4);
        transition: all 0.3s ease;
    }

    .btn-profile:hover {
        background: #ffcc00;
        transform: translateY(-3px);
    }

    /* Thumbnails */
    .player-thumbnail {
        width: 85px;
        height: 85px;
        background: rgba(0, 0, 0, 0.02);
        border: none;
        cursor: pointer;
        position: relative;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        transition: all 0.3s ease;
    }

    .player-thumbnail::before,
    .player-thumbnail::after {
        content: "";
        position: absolute;
        width: 20px;
        height: 20px;
        border: 4px solid #ffde59;
        opacity: 0;
        transition: all 0.3s ease;
    }

    .player-thumbnail::before {
        top: -6px;
        left: -6px;
        border-bottom: none;
        border-right: none;
    }
    .player-thumbnail::after {
        bottom: -6px;
        right: -6px;
        border-top: none;
        border-left: none;
    }

    .player-thumbnail.active::before,
    .player-thumbnail.active::after {
        opacity: 1;
    }

    .player-thumbnail.active {
        background: rgba(255, 222, 89, 0.1);
        box-shadow: 0 0 20px rgba(255, 222, 89, 0.3);
    }

    .thumbnail-number {
        position: absolute;
        bottom: 10px;
        left: 50%;
        transform: translateX(-50%);
        color: #ffde59;
        font-size: 3.5rem;
        font-weight: 900;
        font-family: "Permanent Marker", cursive;
        z-index: 10;
        line-height: 1;
        text-shadow: 2px 2px 10px rgba(0, 0, 0, 0.8);
    }

    .thumbnail-image-wrapper {
        width: 100%;
        height: 100%;
        position: relative;
    }

    .thumbnail-image {
        width: 110%;
        height: auto;
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        filter: grayscale(80%);
        transition: all 0.3s ease;
    }

    .player-thumbnail.active .thumbnail-image,
    .player-thumbnail:hover .thumbnail-image {
        filter: grayscale(0%);
        transform: translateX(-50%);
    }

    /* Mobile */
    @media (max-width: 1023px) {
        .player-selector {
            padding: 3rem 1rem;
        }
        .main-player-display {
            margin-bottom: 4rem;
        }
        .player-rows-container {
            gap: 3rem;
        }
        .player-row {
            grid-template-columns: repeat(
                auto-fill,
                minmax(80px, 1fr)
            ) !important;
        }
        .player-thumbnail {
            width: 85px;
            height: 85px;
        }
        .thumbnail-number {
            font-size: 2.5rem;
            bottom: 5px;
        }
        .stat-value {
            font-size: 2.5rem;
        }
    }
</style>
