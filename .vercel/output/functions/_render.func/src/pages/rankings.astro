---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import { fetchGoalsAssistsDirectly } from "../utils/goles_y_asistencias";
import StatsRankings from "../components/StatsRankings.astro";

const goalsData = await fetchGoalsAssistsDirectly();

const uniqueSeasons = [
    ...new Set(
        goalsData.map((g) => g.temporada).filter((s): s is string => !!s),
    ),
].sort();
const uniqueCompetitions = [
    ...new Set(
        goalsData.map((g) => g.competicion).filter((c): c is string => !!c),
    ),
].sort();
---

<Layout
    title=" Máximas goleadoras y asistentes del Real Madrid Femenino | Madrid Femenino Xtra"
    description="Consulta el detalle de todos los goles y asistencias por jugadora, por temporada y competición."
>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <h1 class="page-title">GOLES Y ASISTENCIAS</h1>

        <h2 class="content-h2">
            Consulta el detalle de todos los goles y asistencias por jugadora,
            por temporada y competición. Sigue toda la actualidad del Real
            Madrid en Madrid Femenino Xtra.
        </h2>

        {
            goalsData.length > 0 ? (
                <StatsRankings
                    goalsData={goalsData}
                    seasons={uniqueSeasons}
                    competitions={uniqueCompetitions}
                />
            ) : (
                <p style="text-align: center; color: red; font-size: 1.2em; padding: 2rem;">
                    Error al cargar datos o no se encontraron registros.
                    Comprueba la conexión a Turso o tu API endpoint.
                </p>
            )
        }
    </main>
</Layout>
