---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";

const query = Astro.url.searchParams.get("q") || "";
const searchUrl = `/api/search?q=${encodeURIComponent(query)}`;

interface SearchResult {
    type: "player" | "rival" | "match";
    title: string;
    subtitle: string;
    url: string;
    relevance: number;
}

let results: SearchResult[] = [];
let error = "";

if (query) {
    try {
        const response = await fetch(
            `${Astro.url.origin}/api/search?q=${encodeURIComponent(query)}`,
        );
        if (response.ok) {
            const data = await response.json();
            results = data.results || [];
        } else {
            error = "Error al realizar la búsqueda";
        }
    } catch (e) {
        console.error("Search error:", e);
        error = "Error al realizar la búsqueda";
    }
}

// Group results by type
const playerResults = results.filter((r) => r.type === "player");
const rivalResults = results.filter((r) => r.type === "rival");
const matchResults = results.filter((r) => r.type === "match");
---

<Layout title={`Búsqueda: ${query} - Madrid Femenino Xtra`}>
    <div class="search-page">
        <div class="search-container">
            <h1 class="page-title">Resultados de búsqueda</h1>

            <div class="search-box">
                <form action="/search" method="get" class="search-form">
                    <input
                        type="search"
                        name="q"
                        value={query}
                        placeholder="Buscar jugadoras, entrenadores, rivales..."
                        class="search-input"
                        autofocus
                    />
                    <button type="submit" class="search-button">Buscar</button>
                </form>
            </div>

            {
                query && (
                    <div class="search-results">
                        {error && <p class="error-message">{error}</p>}

                        {!error && results.length === 0 && (
                            <div class="no-results">
                                <p>
                                    No se encontraron resultados para "
                                    <strong>{query}</strong>"
                                </p>
                                <p class="suggestion">
                                    Intenta con otros términos de búsqueda
                                </p>
                            </div>
                        )}

                        {!error && results.length > 0 && (
                            <div class="results-summary">
                                <p>
                                    Se encontraron{" "}
                                    <strong>{results.length}</strong>{" "}
                                    resultado(s) para "<strong>{query}</strong>"
                                </p>
                            </div>
                        )}

                        {playerResults.length > 0 && (
                            <section class="results-section">
                                <h2 class="section-title">
                                    Jugadoras ({playerResults.length})
                                </h2>
                                <div class="results-grid">
                                    {playerResults.map((result) => (
                                        <a
                                            href={result.url}
                                            class="result-card"
                                        >
                                            <h3 class="result-title">
                                                {result.title}
                                            </h3>
                                            <p class="result-subtitle">
                                                {result.subtitle}
                                            </p>
                                        </a>
                                    ))}
                                </div>
                            </section>
                        )}

                        {rivalResults.length > 0 && (
                            <section class="results-section">
                                <h2 class="section-title">
                                    Rivales ({rivalResults.length})
                                </h2>
                                <div class="results-grid">
                                    {rivalResults.map((result) => (
                                        <a
                                            href={result.url}
                                            class="result-card"
                                        >
                                            <h3 class="result-title">
                                                {result.title}
                                            </h3>
                                            <p class="result-subtitle">
                                                {result.subtitle}
                                            </p>
                                        </a>
                                    ))}
                                </div>
                            </section>
                        )}

                        {matchResults.length > 0 && (
                            <section class="results-section">
                                <h2 class="section-title">
                                    Partidos ({matchResults.length})
                                </h2>
                                <div class="results-grid">
                                    {matchResults.map((result) => (
                                        <a
                                            href={result.url}
                                            class="result-card"
                                        >
                                            <h3 class="result-title">
                                                {result.title}
                                            </h3>
                                            <p class="result-subtitle">
                                                {result.subtitle}
                                            </p>
                                        </a>
                                    ))}
                                </div>
                            </section>
                        )}
                    </div>
                )
            }
        </div>
    </div>
</Layout>

<style>
    .search-page {
        min-height: 100vh;
        background: #f5f5f5;
        padding: 2rem 1rem;
    }

    .search-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .page-title {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--negro, #333);
        margin-bottom: 2rem;
        text-align: center;
    }

    .search-box {
        background: white;
        padding: 2rem;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        margin-bottom: 2rem;
    }

    .search-form {
        display: flex;
        gap: 1rem;
        max-width: 800px;
        margin: 0 auto;
    }

    .search-input {
        flex: 1;
        padding: 1rem 1.5rem;
        border: 2px solid #ddd;
        border-radius: 8px;
        font-size: 1rem;
        transition: border-color 0.3s ease;
    }

    .search-input:focus {
        outline: none;
        border-color: #ffde59;
    }

    .search-button {
        padding: 1rem 2rem;
        background: #ffde59;
        color: #2b2b2b;
        border: none;
        border-radius: 8px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        text-transform: uppercase;
        font-size: 0.9rem;
    }

    .search-button:hover {
        background: #2b2b2b;
        color: #ffffff;
    }

    .search-results {
        background: white;
        padding: 2rem;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .results-summary {
        margin-bottom: 2rem;
        padding: 1rem;
        background: #f9f9f9;
        border-left: 4px solid #ffde59;
        border-radius: 4px;
    }

    .no-results {
        text-align: center;
        padding: 3rem;
        color: #666;
    }

    .no-results strong {
        color: #333;
    }

    .suggestion {
        margin-top: 1rem;
        font-size: 0.9rem;
        color: #999;
    }

    .error-message {
        padding: 1rem;
        background: #fee;
        color: #c33;
        border-radius: 8px;
        text-align: center;
    }

    .results-section {
        margin-bottom: 3rem;
    }

    .results-section:last-child {
        margin-bottom: 0;
    }

    .section-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 1.5rem;
        padding-left: 1rem;
        border-left: 4px solid #ffde59;
    }

    .results-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }

    .result-card {
        background: white;
        padding: 1.5rem;
        border-radius: 8px;
        border: 2px solid #eee;
        text-decoration: none;
        transition: all 0.3s ease;
        display: block;
    }

    .result-card:hover {
        border-color: #ffde59;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(255, 222, 89, 0.3);
    }

    .result-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #2b2b2b;
        margin-bottom: 0.5rem;
    }

    .result-subtitle {
        font-size: 0.9rem;
        color: #666;
        margin: 0;
    }

    @media (max-width: 768px) {
        .search-form {
            flex-direction: column;
        }

        .results-grid {
            grid-template-columns: 1fr;
        }

        .page-title {
            font-size: 2rem;
        }
    }
</style>
